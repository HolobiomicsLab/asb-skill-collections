      }
    },
    {
      "@id": "asbval:assertion/skill/rna-seq-quantification-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Salmon consists of three components: a lightweight-mapping model, an online phase that estimates initial expression levels and model parameters, and an offline phase that refines expression estimates... Salmon also provides the ability to estimate abundance uncertainty due to random sampling and the ambiguity introduced by multimapping reads",
      "asbval:note": "Paper describes Salmon's quantification methodology and equivalence classes (passage 8: 'Salmon constructs \"rich\" equivalence classes over all the sequenced fragments'), but does NOT describe a validation workflow comparing different implementations or versions. The paper benchmarks Salmon against kallisto and eXpress, not different versions of Salmon itself. The specific validation task (cross-version comparison, differential mapping analysis for bug detection) is not present in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "rna-seq-quantification-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate transcript abundance quantification results across different implementations or versions by comparing mapping rates, per-read mapping agreement, and quantification metrics (NumReads, EffectiveLength) using equivalence-class correlation and differential mapping analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
