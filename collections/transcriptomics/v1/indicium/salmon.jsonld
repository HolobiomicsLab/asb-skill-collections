    {
      "@id": "asbval:assertion/skill/sam-record-parsing-and-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Salmon can quantify an experiment... using pre-computed alignments provided in SAM or BAM format. Salmon can quantify abundance either via a built-in, ultra-fast read-mapping procedure (quasi-mapping) [17], or using pre-computed alignments provided in SAM or BAM format.",
      "asbval:note": "Paper confirms Salmon accepts SAM/BAM input and performs quantification, but does not discuss SAM output generation, buffer flushing, or validation of SAM record completeness. The card's focus on detecting data loss from buffer flushing failures and comparing SAM record counts against NumReads is not addressed in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
