    {
      "@id": "asbval:assertion/skill/transcript-abundance-correlation-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We benchmark Salmon against kallisto [10] and eXpress [15] + Bowtie2 [16]; both of these methods also implement their own bias models. We show that Salmon typically outperforms both kallisto and eXpress in terms of accuracy (Fig. 1a\u2013d, Supplementary Fig. 2, Supplementary Fig. 3).",
      "asbval:note": "Paper compares Salmon against kallisto and eXpress using accuracy metrics (MARD, Spearman correlation) on simulated and real data, but does not explicitly use Pearson correlation or 'per-read mapping agreement metrics' as stated in the claim. The paper uses Spearman correlation and MARD (mean absolute relative difference) instead. The comparison is between different tools (Salmon vs. kallisto/eXpress), not between two implementations of the same tool (salmon 2.0 vs. salmon 1.12.0 C++) as the card implies.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "transcript-abundance-correlation-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compare per-transcript quantification outputs (NumReads, TPM) between two RNA-seq quantification tools or implementations using Pearson correlation and per-read mapping agreement metrics to assess quantitative concordance and identify systematic differences in abundance estimatio",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:46:06.205011+00:00",
      "sepio:credibility_status": {
