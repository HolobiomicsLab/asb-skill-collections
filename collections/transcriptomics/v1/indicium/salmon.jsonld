    {
      "@id": "asbval:assertion/skill/sam-record-parsing-and-validation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our novel quantification procedure, called Salmon, achieves greater accuracy than tools such as kallisto and eXpress, employs sample-specific bias models that account for sequence-specific, fragment-GC and positional biases, and simultaneously achieves the same order-of-magnitude speed benefits as kallisto and Sailfish.",
      "asbval:note": "Paper confirms Salmon quantifies transcript abundance and reports metrics (TPM, nucleotide fractions, transcript fractions), but does not mention a NumReads metric or any mechanism to compare quantification summaries against SAM record counts.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "sam-record-parsing-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "salmon quant quantifies transcript abundance from reads and reports NumReads metric for comparison against SAM record count",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:45:20.392954+00:00",
      "sepio:credibility_status": {
