    {
      "@id": "asbval:assertion/skill/read-mapping-rate-calculation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Salmon achieves greater accuracy than tools such as kallisto and eXpress, employs sample-specific bias models that account for sequence-specific, fragment-GC and positional biases, and simultaneously achieves the same order-of-magnitude speed benefits as kallisto and Sailfish.",
      "asbval:note": "Paper focuses on transcript abundance quantification accuracy and bias correction, not explicitly on 'read mapping rate' as a standalone metric. The paper benchmarks quantification accuracy (TPM correlation, sensitivity/FDR in DE testing) rather than mapping rate percentage. Mapping is mentioned as a component (quasi-mapping vs. alignment-based), but mapping rate itself is not a primary validation metric discussed.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "read-mapping-rate-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Calculate the percentage of sequencing reads successfully mapped to a reference transcriptome after quantification, a core metric for validating mapper agreement and sensitivity across implementations and parameter configurations.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:43:43.516365+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
