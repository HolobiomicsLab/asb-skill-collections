    {
      "@id": "asbval:assertion/skill/mapping-agreement-cross-tool-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We benchmark Salmon against kallisto [10] and eXpress [15] + Bowtie2 [16]; both of these methods also implement their own bias models. We also test Salmon using traditional alignments (from Bowtie2) as input (denoted as \"Salmon(a)\"). We show that Salmon typically outperforms both kallisto and eXpress in terms of accuracy (Fig. 1a\u2013d, Supplementary Fig. 2, Supplementary Fig. 3).",
      "asbval:note": "Paper compares Salmon against OTHER tools (kallisto, eXpress) rather than comparing versions/implementations of Salmon itself. The card's specific focus on cross-version Salmon validation (e.g., Rust vs C++ implementations) is not addressed in the paper. Paper does validate quantification accuracy but not per-read agreement between tool implementations.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mapping-agreement-cross-tool-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Quantify per-read and per-transcript agreement between two transcript-quantification tools (e.g., salmon versions or implementations) to assess consistency and expose algorithmic differences.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:42:25.979473+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
