    {
      "@id": "asbval:assertion/skill/rna-seq-quantification-selective-alignment/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Salmon consists of three components: a lightweight-mapping model, an online phase that estimates initial expression levels and model parameters, and an offline phase that refines expression estimates... The offline phase applies either a standard EM algorithm or a variational Bayesian EM algorithm [20] over a reduced representation of the data represented by the equivalence classes",
      "asbval:note": "Paper describes Salmon's quantification using 'lightweight-mapping' and EM/VBEM inference, but does NOT mention 'selective alignment', 'MEM extraction', or 'k-mer-based mapping' by those names. The paper describes 'quasi-mapping' (k-mer allocation) and 'pseudoalignment' concepts, but the specific term 'selective alignment' and the detailed MEM/chain-pruning methodology are not present in these passages. This appears to be a more recent development (salmon 2.0) not covered in the 2017 paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "rna-seq-quantification-selective-alignment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Quantify transcript abundances from RNA-seq reads using selective alignment, which combines fast k-mer-based mapping with MEM extraction and alignment scoring to assign reads to transcripts while estimating abundance via an EM/VBEM statistical model.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:43:59.225085+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/rna-seq-quantification-selective-alignment/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The TPM for transcript ti ti, is given by TPMi = \u03c4i \u00b7 10^6... Salmon typically outperforms both kallisto and eXpress in terms of accuracy... achieving a sensitivity 53% to 250% higher, at the same FDRs",
      "asbval:note": "Paper explicitly describes TPM computation and transcript-level quantification with isoform resolution.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "yes",
