    {
      "@id": "asbval:assertion/skill/pearson-correlation-analysis-genomics/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We show that Salmon typically outperforms both kallisto and eXpress in terms of accuracy (Fig. 1a\u2013d, Supplementary Fig. 2, Supplementary Fig. 3)... Salmon's dual-phase inference algorithm and sample-specific bias models yield improved inter-replicate concordance (Supplementary Fig. 4) compared to both kallisto and eXpress.",
      "asbval:note": "Paper reports inter-replicate concordance and accuracy comparisons (Spearman correlations mentioned in statistics section), but does not explicitly perform Pearson correlation between two Salmon implementations (C++ vs. Rust). The paper compares Salmon against other tools (kallisto, eXpress), not different versions of Salmon itself.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "pearson-correlation-analysis-genomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute Pearson correlation coefficients (r) between quantification results (e.g., per-transcript NumReads) from two implementations or seed strategies to assess quantitative agreement and reproducibility of transcript abundance estimates.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
