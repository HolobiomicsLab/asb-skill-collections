      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Classify reads at the boundary of mapping disagreement between two mappers (e.g., C++ vs. Rust salmon) by re-aligning them using full Smith-Waterman alignment to determine whether they should be strong-aligned, weak-aligned, or unmapped.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
