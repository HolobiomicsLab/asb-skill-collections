    {
      "@id": "asbval:assertion/skill/mapping-agreement-cross-tool-validation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "All tests were performed with eXpress v1.5.1, kallisto v0.43.0, Salmon v0.8.0 and Bowtie2 v2.2.4.",
      "asbval:note": "Paper uses Salmon v0.8.0 (C++), not v1.12.0. The C++ implementation is confirmed, but the specific version number in the card does not match the paper's version.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
