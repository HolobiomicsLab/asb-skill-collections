    {
      "@id": "asbval:assertion/skill/rna-seq-quantification-selective-alignment/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Salmon achieves greater accuracy than tools such as kallisto and eXpress, employs sample-specific bias models that account for sequence-specific, fragment-GC and positional biases, and simultaneously achieves the same order-of-magnitude speed benefits as kallisto and Sailfish",
      "asbval:note": "Paper confirms fast, bias-aware quantification, but does NOT mention '99%+ per-read mapping agreement' or selective alignment specifically. The 99.83% figure mentioned in the card is not in these passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "rna-seq-quantification-selective-alignment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "selective alignment is appropriate when you want fast, bias-aware quantification with high read assignment accuracy (99%+ per-read mapping agreement)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:43:59.225085+00:00",
      "sepio:credibility_status": {
