      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "No mention of piscem-rs or any Rust port in the paper. The paper describes Salmon's lightweight-mapping model and quasi-mapping procedure but does not name piscem-rs as a component.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
