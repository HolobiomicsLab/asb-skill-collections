    },
    {
      "@id": "asbval:assertion/skill/transcript-abundance-correlation-analysis/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "All methods were run with bias correction enabled, using a transcriptome built with the RefSeq gene annotation file and the genome FASTA contained within the hg19 Illumina iGenome, to allow for comparison with the results in [5].",
      "asbval:note": "Paper does use identical transcriptome/index for fair comparison (RefSeq + hg19 iGenome for all methods), which aligns with the principle stated in the 'When NOT to use' section. However, the card's scope is about comparing two implementations of Salmon, not comparing different tools, so this principle is not directly applicable to the card's stated use case.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "transcript-abundance-correlation-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: When comparing tools run on different reference indices or different cleaned FASTA sources\u2014differences in index content will dominate tool differences.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:46:06.205011+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/transcript-abundance-correlation-analysis/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "On the RSEM-sim data we evaluated all methods without bias correction. On all other data, we enabled bias correction for all methods.",
      "asbval:note": "Paper does control for bias correction by applying it consistently across methods (or disabling it consistently). However, the card references '--seqBias' and '--gcBias' flags which are not mentioned in the paper. The paper discusses 'bias correction' generically and mentions specific bias models (sequence-specific, GC-content, positional) but does not use those exact flag names.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4197",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "transcript-abundance-correlation-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: When one or both quantification runs used bias correction (--seqBias, --gcBias) or non-standard chain-pruning thresholds without explicit matching\u2014these parameters will confound the comparison.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:46:06.205011+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
