    {
      "@id": "asbval:assertion/skill/multiple-testing-correction-visualization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Gene set enrichment analysis (GSEA) is an ubiquitously used tool for evaluating pathway enrichment in transcriptional data. Typical experimental design consists in comparing two conditions with several replicates using a differential gene expression test followed by preranked GSEA performed against a collection of hundreds and thousands of pathways.",
      "asbval:note": "Paper discusses GSEA and multiple-testing correction (mentions 'multiple hypotheses correction procedure'), but does not explicitly describe visualization of corrected P-values and effect sizes as a 'ranked table plot'. The paper focuses on P-value estimation accuracy rather than visualization methodology.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "multiple-testing-correction-visualization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Visualize corrected P-values and effect sizes from gene set enrichment analysis results as a ranked table plot, enabling rapid assessment of pathway significance across multiple simultaneous hypothesis tests.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:31:06.137692+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/multiple-testing-correction-visualization/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we present FGSEA (Fast Gene Set Enrichment Analysis) method that is able to estimate arbitrarily low GSEA P-values with a high accuracy in a matter of minutes or even seconds. FGSEA is open source and available as an R package in Bioconductor ( http://bioconductor.org/packages/fgsea/ ) and on GitHub ( https://github.com/ctlab/fgsea/ ).",
      "asbval:note": "fgsea confirmed as R package for preranked GSEA. Paper confirms P-value computation and multiple-testing correction context, though specific mention of Benjamini-Hochberg, ES, NES, and size columns not verbatim in provided passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "multiple-testing-correction-visualization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "fgsea (Preranked gene set enrichment analysis; computes raw pval, padj (via Benjamini-Hochberg), ES, NES, and size for each pathway to feed downstream visualization)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:31:06.137692+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
