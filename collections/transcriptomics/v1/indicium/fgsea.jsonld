    {
      "@id": "asbval:assertion/skill/gene-set-enrichment-analysis/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Typical experimental design consists in comparing two conditions with several replicates using a differential gene expression test followed by preranked GSEA performed against a collection of hundreds and thousands of pathways.",
      "asbval:note": "Scope description aligns with paper's description of preranked GSEA workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gene-set-enrichment-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When you have a ranked list of gene-level statistics and a collection of gene sets, and need to test whether genes in each set are randomly distributed in the ranking or clustered toward high or low values.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
