    {
      "@id": "asbval:assertion/card/task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "FGSEA (Fast Gene Set Enrichment Analysis) method that is able to estimate arbitrarily low GSEA P-values with a high accuracy in a matter of minutes or even seconds... FGSEA is able to routinely estimate P-values up to 10 \u2212100 with a small and predictable estimation error.",
      "asbval:note": "Core capability of fgsea directly stated in abstract.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "yes",
