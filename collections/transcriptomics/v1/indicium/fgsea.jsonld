    {
      "@id": "asbval:assertion/skill/gene-set-enrichment-scoring-coregulation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Gene set enrichment analysis (GSEA) is an ubiquitously used tool for evaluating pathway enrichment in transcriptional data. Typical experimental design consists in comparing two conditions with several replicates using a differential gene expression test followed by preranked GSEA",
      "asbval:note": "Core research question aligns with paper's focus on preranked GSEA for pathway enrichment evaluation.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gene-set-enrichment-scoring-coregulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Score pathway enrichment and co-regulation patterns using fast preranked GSEA (fgsea) to quantify whether gene sets show coordinated expression changes across samples or conditions.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:29:56.172498+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/gene-set-enrichment-scoring-coregulation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "FGSEA (Fast Gene Set Enrichment Analysis) method that is able to estimate arbitrarily low GSEA P-values with a high accuracy in a matter of minutes or even seconds",
      "asbval:note": "Paper explicitly addresses fast p-value calculation for pathway enrichment.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gene-set-enrichment-scoring-coregulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "rapid calculation of pathway-level statistics and p-values to assess biological pathway activation",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
