    {
      "@id": "asbval:assertion/skill/pathway-activity-correlation-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Gene set enrichment analysis (GSEA) is an ubiquitously used tool for evaluating pathway enrichment in transcriptional data. Typical experimental design consists in comparing two conditions with several replicates using a differential gene expression test followed by preranked GSEA performed against a collection of hundreds and thousands of pathways.",
      "asbval:note": "Paper describes GSEA methodology and comparing conditions, but does not explicitly address comparing results across different dimensionalities or dimensionality reduction robustness. The paper focuses on improving P-value estimation accuracy in GSEA, not on validating signal preservation across dimensionality reductions.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "pathway-activity-correlation-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compare pathway enrichment results (scores and p-values) across different input dimensionalities or analytical approaches to assess the robustness and reproducibility of pathway activity inference.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:31:20.889077+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/pathway-activity-correlation-analysis/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we present FGSEA (Fast Gene Set Enrichment Analysis) method that is able to estimate arbitrarily low GSEA P-values with a high accuracy in a matter of minutes or even seconds.",
      "asbval:note": "fgsea is confirmed as the primary tool. Paper describes it as computing P-values accurately; the 'adaptive multi-level split Monte-Carlo scheme' is the underlying method referenced in the abstract.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pathway-activity-correlation-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "fgsea: Fast preranked GSEA for pathway enrichment; computes p-values via adaptive multi-level split Monte-Carlo scheme to enable accurate comparison across dimensionalities",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
