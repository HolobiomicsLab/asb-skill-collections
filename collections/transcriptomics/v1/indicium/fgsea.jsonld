    {
      "@id": "asbval:assertion/skill/pathway-activity-correlation-analysis/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "geseca is not mentioned anywhere in the provided passages. The paper focuses exclusively on FGSEA and does not discuss GESECA or alternative enrichment methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
