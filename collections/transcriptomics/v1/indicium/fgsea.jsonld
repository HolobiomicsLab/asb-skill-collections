    {
      "@id": "asbval:assertion/skill/gene-expression-matrix-normalization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Gene set enrichment analysis (GSEA) is an ubiquitously used tool for evaluating pathway enrichment in transcriptional data. Typical experimental design consists in comparing two conditions with several replicates using a differential gene expression test followed by preranked GSEA",
      "asbval:note": "Paper focuses on FGSEA method for fast P-value estimation in GSEA, not on microarray normalization procedures. The paper assumes preprocessed/ranked data as input ('preranked GSEA') but does not describe log transformation or quantile normalization workflows. The card's research question addresses data preprocessing; the paper addresses downstream enrichment analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "gene-expression-matrix-normalization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
