    {
      "@id": "asbval:assertion/skill/gene-expression-ranking-preparation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Typical experimental design consists in comparing two conditions with several replicates using a differential gene expression test followed by preranked GSEA performed against a collection of hundreds and thousands of pathways.",
      "asbval:note": "The paper explicitly describes preranked GSEA workflow with differential gene expression testing as the upstream step, which aligns with the research question of preparing ranked gene statistics.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gene-expression-ranking-preparation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Prepare ranked gene statistics from expression data for preranked gene set enrichment analysis (GSEA). This skill transforms raw or normalized expression matrices into per-gene summary statistics (typically log fold-change or t-statistics) suitable for input to fast GSEA algorith",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:29:08.512378+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/gene-expression-ranking-preparation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we present FGSEA (Fast Gene Set Enrichment Analysis) method that is able to estimate arbitrarily low GSEA P-values with a high accuracy in a matter of minutes or even seconds. FGSEA is open source and available as an R package in Bioconductor ( http://bioconductor.org/packages/fgsea/ ) and on GitHub ( https://github.com/ctlab/fgsea/ ).",
      "asbval:note": "fgsea is the primary subject of the paper and is confirmed as an R package for fast GSEA. The paper describes it as accepting preranked gene statistics.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gene-expression-ranking-preparation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "fgsea (Accepts ranked gene statistics as input (stats parameter) for fast preranked GSEA)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
