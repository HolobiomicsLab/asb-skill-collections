    {
      "@id": "asbval:assertion/skill/statistical-precision-comparison-ranked-outputs/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "FGSEA is able to estimate arbitrarily low GSEA P-values with a high accuracy in a matter of minutes or even seconds... FGSEA is able to routinely estimate P-values up to 10 \u2212100 with a small and predictable estimation error.",
      "asbval:note": "Paper demonstrates FGSEA's ability to estimate low P-values accurately and compares it to reference implementation, but does not explicitly describe comparing two estimation modes (default lower-bound vs. adaptive refinement) within FGSEA itself. The paper compares FGSEA to other implementations, not internal precision modes.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "statistical-precision-comparison-ranked-outputs",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compare P-value precision and ranking consistency between two statistical estimation modes (e.g., default lower-bound vs. adaptive refinement) to validate whether relaxing precision constraints produces numerically valid and meaningful differences in gene set enrichment rankings.",
