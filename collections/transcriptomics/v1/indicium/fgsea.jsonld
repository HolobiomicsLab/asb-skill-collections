    {
      "@id": "asbval:assertion/skill/statistical-comparison-p-value-conservation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the reference implementation of this method cannot accurately estimate small P-values, which significantly limits its sensitivity due to multiple hypotheses correction procedure. Here we present FGSEA (Fast Gene Set Enrichment Analysis) method that is able to estimate arbitrarily low GSEA P-values with a high accuracy",
      "asbval:note": "Paper addresses P-value accuracy and comparison between methods (reference vs FGSEA), but does not explicitly address dimensionality reduction or log10-transformation correlation as a validation strategy. The paper compares two GSEA implementations' P-value estimates, not dimensionality-reduced vs full-dimensional matrices.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "statistical-comparison-p-value-conservation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate that dimensionality reduction or alternative analytical pipelines preserve the statistical significance (p-values) of pathway enrichment results by computing correlation of log10-transformed p-values between two analytical approaches.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
