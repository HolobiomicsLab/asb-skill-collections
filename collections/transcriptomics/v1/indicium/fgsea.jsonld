      }
    },
    {
      "@id": "asbval:assertion/skill/gene-set-enrichment-scoring-coregulation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not discuss dimensionality reduction or validation of enrichment signal preservation across reduced vs. full-dimensional representations. This appears to be an application context added by the card author, not a focus of the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1101-060012",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "gene-set-enrichment-scoring-coregulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
