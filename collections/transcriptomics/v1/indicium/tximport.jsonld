    {
      "@id": "asbval:assertion/skill/matrix-equivalence-validation/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In this report, we make and give evidence for three claims: 1) gene-level estimation is considerably more stable than transcript-level; 2) regardless of the level at which abundance estimation is done, inferences at the gene level are appealing in terms of robustness, statistical performance and interpretation; 3) the magnitude of the difference between results obtained by simple counting and transcript-level abundance estimation is generally small in real data sets.",
      "asbval:note": "The paper does address the choice between transcript-level and gene-level analysis, but the task card frames this as a 'matrix-equivalence-validation' skill, which is not what the paper discusses. The paper argues for gene-level analysis over transcript-level, not for validating equivalence between two pathways.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "matrix-equivalence-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When to use: deciding whether to retain transcript-level detail for isoform analysis or compress directly to gene level",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:13:59.987401+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
