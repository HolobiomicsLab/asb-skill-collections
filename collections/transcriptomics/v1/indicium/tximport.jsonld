    {
      "@id": "asbval:assertion/claim/claim_046",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "For 3 prime tagged RNA-seq data, correcting the counts for gene length will induce a bias in the analysis because the counts do not have length bias.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:source_excerpt": "If you have 3' tagged RNA-seq data, then correcting the\ncounts for gene length will induce a bias in your analysis, because\nthe counts do not have length bias.",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_046",
