      "asbval:target_claim_text": "tximport: Imports transcript-level abundance, counts, and length matrices from quantification software (salmon, kallisto, Sailfish); aggregates to gene level using tx2gene mapping; produces the length matrix that encodes isoform-usage-driven gene-length variation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
