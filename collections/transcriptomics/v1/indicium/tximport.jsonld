    {
      "@id": "asbval:assertion/skill/gene-length-offset-matrix-computation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we provide an R package ( tximport) to help users integrate transcript-level abundance estimates from common quantification pipelines into count-based statistical inference engines... To facilitate a broad range of analysis choices, depending on the biological question of interest, we provide an R package, tximport, to import transcript lengths and abundance estimates from several popular quantification packages and export (estimated) count matrices and, optionally, average transcript length correction terms (i.e., offsets) that can be used as inputs to common statistical engines, such as DESeq2, edgeR and limma.",
      "asbval:note": "Verbatim match: tximport produces offset matrices from transcript lengths for correcting gene-level counts.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gene-length-offset-matrix-computation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute a transcript-length-derived offset matrix from tximport output to correct gene-level RNA-seq counts for differential isoform usage before differential expression analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:12:50.801566+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/gene-length-offset-matrix-computation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Accounting for the potentially varying average transcript length across samples when performing DGE, either in the definition of the count matrix (scaledTPM) or by defining offsets, led to considerably improved false discovery rate (FDR) control compared to using the observed feature Counts or aggregated Salmon counts (simplesum) directly... It is important to note that this improvement is entirely attributable to an improved handling of genes with changes in isoform composition between the conditions.",
      "asbval:note": "Semantic equivalence: paper demonstrates that sample-specific transcript length offsets correct for differential isoform usage (DTU) to improve FDR control.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gene-length-offset-matrix-computation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill embeds length normalization into the statistical model to avoid biased inference when isoform composition varies across samples.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:12:50.801566+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
