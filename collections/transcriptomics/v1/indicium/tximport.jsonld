      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "rna-seq-count-matrix-generation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "tximport - primary tool for importing transcript-level quantification and summarizing to gene-level matrices; handles salmon, sailfish, and kallisto formats",
