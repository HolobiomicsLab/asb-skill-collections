    {
      "@id": "asbval:assertion/skill/transcript-level-count-aggregation/013",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Several software packages have been developed for performing such 'simple' counting (e.g., feature Counts and HTSeq-count). More recently, the field has seen a surge in methods aimed at quantifying the abundances of individual transcripts (e.g., Cufflinks, RSEM, Bit Seq, kallisto and Salmon).",
      "asbval:note": "Paper clearly distinguishes between simple counting (featureCounts, HTSeq) and transcript-level quantification methods (Salmon, kallisto, etc.), supporting the scope statement.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcript-level-count-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: You are using alignment-based quantification (e.g., featureCounts, HTSeq) rather than pseudo-alignment tools.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:16:16.934188+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/transcript-to-gene-mapping/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we provide an R package ( tximport) to help users integrate transcript-level abundance estimates from common quantification pipelines into count-based statistical inference engines... taking advantage of transcript-level abundance estimates when defining or analyzing gene-level abundances leads to improved differential gene expression results... average transcript length correction terms (i.e., offsets) that can be used as inputs to common statistical engines, such as DESeq2, edgeR and limma",
      "asbval:note": "Fully supported. The paper explicitly describes tximport's role in aggregating transcript-level estimates to gene level and using transcript length offsets to correct for differential isoform usage.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcript-to-gene-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Construction and application of a transcript-to-gene mapping table (tx2gene) to aggregate transcript-level quantification estimates into gene-level matrices for downstream differential expression analysis. This skill enables correction for gene-length variation across samples cau",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:16:34.440622+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
