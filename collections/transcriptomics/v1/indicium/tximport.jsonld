    {
      "@id": "asbval:assertion/skill/rna-seq-count-normalization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we provide an R package ( tximport) to help users integrate transcript-level abundance estimates from common quantification pipelines into count-based statistical inference engines... taking advantage of transcript-level abundance estimates when defining or analyzing gene-level abundances leads to improved differential gene expression results... We propose two alternative ways of integrating transcript abundance estimates into the DGE pipeline: to define an \"artificial\" count matrix, or to calculate offsets that can be used in the statistical modeling of the observed gene counts",
      "asbval:note": "Core research question is directly supported by abstract and methods sections.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "rna-seq-count-normalization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Normalize transcript- or gene-level count matrices derived from quantification tools (salmon, kallisto, Sailfish) by incorporating sample-specific length offsets and library size factors to account for differential isoform usage and sequencing depth before differential expression",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:15:23.533465+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/rna-seq-count-normalization/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "to help users integrate transcript-level abundance estimates from common quantification pipelines into count-based statistical inference engines... we provide an R package, tximport, to import transcript lengths and abundance estimates from several popular quantification packages and export (estimated) count matrices and, optionally, average transcript length correction terms (i.e., offsets) that can be used as inputs to common statistical engines, such as DESeq2, edgeR and limma",
      "asbval:note": "Explicitly mentions bridging quantification tools with count-based statistical engines.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "rna-seq-count-normalization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill bridges probabilistic quantification estimates with count-based statistical models in edgeR, DESeq2, or limma-voom.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:15:23.533465+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
