      "asbval:target_artifact_id": "inferential-replicate-handling",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Import and propagate inferential replicates (Gibbs samples or bootstrap samples) from quantification tools (Salmon, Sailfish, kallisto) through tximport to enable edgeR to estimate count overdispersion and generate divided counts that account for quantification uncertainty in dif",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
