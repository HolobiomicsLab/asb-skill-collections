      "asbval:target_artifact_id": "deseq2-object-initialization-from-transcript-data",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill bridges transcript-level abundance estimates to gene-level differential expression analysis while preserving length-derived offsets.",
