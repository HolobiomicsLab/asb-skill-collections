    {
      "id": "claim_001",
      "context": "explicit",
      "subject": "explicit",
      "qualifier": "consistent_with",
      "relation": "describes",
      "object": "tximport imports transcript-level abundance, estimated counts, and transcript lengths, and summarizes them into matrices for use with downstream statistical analysis packages such as edgeR, DESeq2, and limma-voom.",
      "asserted_by": "doi:10.12688/f1000research.7563.1",
      "@type": "asb:Claim",
      "source_task_kind_status": "ambiguous_multi_kind",
      "about_entity": [
        {
          "id": "asb:spine_sys_tximport"
        },
        {
          "id": "asb:spine_tool_deseq2"
        },
        {
          "id": "asb:spine_tool_edger"
        },
        {
          "id": "asb:spine_tool_limma_voom"
        }
      ]
    },
