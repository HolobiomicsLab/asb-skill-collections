    {
      "@id": "asbval:assertion/claim/claim_001",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "tximport imports transcript-level abundance, estimated counts, and transcript lengths, and summarizes them into matrices for use with downstream statistical analysis packages such as edgeR, DESeq2, and limma-voom.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:source_excerpt": "Imports transcript-level abundance, estimated counts and \ntranscript lengths, and summarizes into matrices for use with downstream\nstatistical analysis packages such as edgeR, DESeq2, limma-voom.",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_001",
      "asbval:target_artifact_kind": "ledger_claim",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:08:56.874038+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/claim/claim_002",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "The tximport approach corrects for potential changes in gene length across samples from differential isoform usage.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:source_excerpt": "this approach corrects for potential changes in gene length across samples \n(e.g. from differential isoform usage)",
