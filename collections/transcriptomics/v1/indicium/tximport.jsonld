    {
      "@id": "asbval:assertion/skill/salmon-output-parsing/012",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Several software packages have been developed for performing such 'simple' counting (e.g., feature Counts and HTSeq-count). More recently, the field has seen a surge in methods aimed at quantifying the abundances of individual transcripts (e.g., Cufflinks, RSEM, Bit Seq, kallisto and Salmon).",
      "asbval:note": "Paper distinguishes between simple counting tools (featureCounts, HTSeq) and transcript quantification tools (Salmon, kallisto), supporting the distinction in the card.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "salmon-output-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Quantification was performed with alignment-based tools (e.g., featureCounts, HTSeq) rather than pseudoalignment (use those tools' output directly)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:15:43.842261+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
