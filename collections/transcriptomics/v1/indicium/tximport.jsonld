    {
      "@id": "asbval:assertion/skill/rna-seq-count-matrix-generation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we provide an R package ( tximport) to help users integrate transcript-level abundance estimates from common quantification pipelines into count-based statistical inference engines... To facilitate a broad range of analysis choices, depending on the biological question of interest, we provide an R package, tximport, to import transcript lengths and abundance estimates from several popular quantification packages and export (estimated) count matrices and, optionally, average transcript length correction terms (i.e., offsets) that can be used as inputs to common statistical engines, such as DESeq2, edgeR and limma.",
      "asbval:note": "Claim is fully supported. Paper explicitly describes tximport's function to import transcript-level estimates from salmon/kallisto and generate gene-level count matrices with length offsets for downstream analysis with DESeq2, edgeR, and limma.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "rna-seq-count-matrix-generation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Generate gene-level count, abundance (TPM), and length matrices from transcript-level quantification files (salmon, sailfish, or kallisto) using transcript-to-gene mapping. This approach corrects for differential isoform usage effects on gene length and enables downstream statist",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:15:05.987238+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
