    {
      "@id": "asbval:assertion/skill/transcript-to-gene-mapping/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Several different quantification approaches have been proposed, ranging from simple counting of reads that overlap given genomic regions to more complex estimation of underlying transcript abundances... the sequencing reads must be used as the basis for abundance quantification of transcriptomic features of interest, such as genes or transcripts... we show that gene-level abundance estimates and statistical inference offer advantages over transcript-level analyses",
      "asbval:note": "Supported. The paper demonstrates the need for gene-level aggregation from transcript-level quantification.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcript-to-gene-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "A tx2gene mapping is required when your quantification tool reports transcript-level abundances, counts, and lengths, but your experimental design and statistical framework call for gene-level summaries.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:16:34.440622+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/transcript-to-gene-mapping/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Several software packages have been developed for performing such 'simple' counting (e.g., feature Counts and HTSeq-count). More recently, the field has seen a surge in methods aimed at quantifying the abundances of individual transcripts",
      "asbval:note": "Supported by implication. The paper distinguishes between gene-level counting tools (featureCounts, HTSeq-count) and transcript-level quantification tools, implying that gene-level counts do not require tx2gene mapping.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcript-to-gene-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input quantification is already at gene level (e.g., featureCounts output): tx2gene mapping is unnecessary and tximport summarization will be redundant.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
