    {
      "@id": "asbval:assertion/skill/transcript-level-count-aggregation/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we provide an R package ( tximport) to help users integrate transcript-level abundance estimates from common quantification pipelines into count-based statistical inference engines... such as DESeq2, edgeR and limma",
      "asbval:note": "Scope is largely supported for salmon, kallisto, DESeq2, edgeR, and limma. However, sailfish is not explicitly listed in the paper as a supported tool (only mentioned in peer review), and oarfish is not mentioned at all (post-2015 tool).",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
