      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/claim/claim_041",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "One should not manually pass the original gene-level counts to downstream methods without an offset.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:source_excerpt": "Do not manually pass the original gene-level counts\nto downstream methods *without an offset*.",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_041",
      "asbval:target_artifact_kind": "ledger_claim",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:08:56.874038+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/claim/claim_042",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "The only case where passing original gene-level counts without an offset would make sense is if there is no length bias to the counts, as may happen in 3 prime tagged RNA-seq data.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:source_excerpt": "The only case where this\nwould make sense is if there is no length bias to the counts, as \nmay happen in 3' tagged RNA-seq data",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_042",
      "asbval:target_artifact_kind": "ledger_claim",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:08:56.874038+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/claim/claim_043",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "The original gene-level counts are in txi$counts when tximport is run with countsFromAbundance=no.",
