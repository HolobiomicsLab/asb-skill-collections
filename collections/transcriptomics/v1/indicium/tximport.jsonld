    {
      "@id": "asbval:assertion/skill/salmon-output-parsing/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the sequencing reads must be used as the basis for abundance quantification of transcriptomic features of interest, such as genes or transcripts",
      "asbval:note": "Paper discusses the distinction between gene-level and transcript-level quantification, implying that tximport is for transcript-to-gene conversion, not for already-aggregated data.",
