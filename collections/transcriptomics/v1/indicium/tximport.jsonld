      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When to use: When you have salmon quant.sf.gz output files from pseudoalignment-based transcript quantification and need to convert transcript-level abundance estimates and counts into gene-level matrices for differential expression analysis with edgeR, DESeq2, or limma-voom.",
