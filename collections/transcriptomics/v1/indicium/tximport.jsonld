    {
      "@id": "asbval:assertion/claim/claim_044",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "Using only txi$counts is simply passing the summed estimated transcript counts, and does not correct for potential differential isoform usage.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:source_excerpt": "Using only `txi$counts` is simply passing the summed\nestimated transcript counts, and does not correct for potential differential\nisoform usage (the offset)",
