      }
    },
    {
      "@id": "asbval:assertion/claim/claim_047",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "For 3 prime tagged RNA-seq, the original counts from txi$counts should be used as a counts matrix without calculating an offset and without using countsFromAbundance.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:source_excerpt": "Instead of using the default\nfull-transcript-length pipeline, we recommend to use the\noriginal counts, e.g. `txi$counts` as a counts matrix, e.g. providing\nto *DESeqDataSetFromMatrix* or to the *edgeR* or *limma* functions\nwithout calculating an offset and without using *countsFr",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_047",
      "asbval:target_artifact_kind": "ledger_claim",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
