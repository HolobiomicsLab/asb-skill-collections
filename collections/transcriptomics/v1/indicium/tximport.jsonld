    {
      "@id": "asbval:assertion/skill/rna-seq-count-matrix-generation/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Accounting for the potentially varying average transcript length across samples when performing DGE, either in the definition of the count matrix (scaledTPM) or by defining offsets, led to considerably improved false discovery rate (FDR) control... this improvement is entirely attributable to an improved handling of genes with changes in isoform composition between the conditions",
      "asbval:note": "Paper explicitly demonstrates that accounting for average transcript length (which varies with isoform usage) improves FDR control in DGE analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "rna-seq-count-matrix-generation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "This approach corrects for differential isoform usage effects on gene length",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:15:05.987238+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
