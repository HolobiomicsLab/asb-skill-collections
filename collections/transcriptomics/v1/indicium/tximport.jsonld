      "@id": "asbval:assertion/skill/isoform-usage-bias-correction/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we provide an R package ( tximport) to help users integrate transcript-level abundance estimates from common quantification pipelines into count-based statistical inference engines",
      "asbval:note": "Paper confirms tximport accepts transcript-level quantification outputs.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "isoform-usage-bias-correction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have transcript-level quantification (e.g., from salmon, kallisto, or Sailfish) with estimated transcript abundances and lengths.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:13:39.301275+00:00",
