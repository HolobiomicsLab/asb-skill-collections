      "asbval:source_excerpt": "some of the upstream quantification methods (*salmon*, *sailfish*, *kallisto*) \nare substantially faster and require less memory\nand disk usage compared to alignment-based methods that require\ncreation and storage of BAM files",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_003",
      "asbval:target_artifact_kind": "ledger_claim",
