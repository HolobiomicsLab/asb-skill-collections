    {
      "@id": "asbval:assertion/claim/claim_028",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "The ignoreAfterBar=TRUE argument is used to split incoming quantification matrix rownames at the first bar and only use the part before the bar as an identifier.",
      "asbval:note": "Text names the argument 'ignoreAfterBar=TRUE' but source excerpt does not explicitly mention this argument name; describes the concept correctly but lacks direct argument reference.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:source_excerpt": "This is\nbecause the Gencode transcripts have names like\n\"ENST00000456328.2|ENSG00000223972.5|...\", though our `tx2gene` table\nonly includes the first \"ENST\" identifier. We therefore want to split\nthe incoming quantification matrix rownames at the first bar \"|\", and\nonly use this ",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "claim_028",
      "asbval:target_artifact_kind": "ledger_claim",
