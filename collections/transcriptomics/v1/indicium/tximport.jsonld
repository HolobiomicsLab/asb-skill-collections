    {
      "@id": "asbval:assertion/claim/claim_037",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "One suggested way of importing estimates for use with differential gene expression methods is to use gene-level estimated counts from the quantification tools and additionally use the transcript-level abundance estimates to calculate a gene-level offset.",
