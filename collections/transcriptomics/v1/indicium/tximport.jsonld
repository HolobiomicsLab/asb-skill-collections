        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:08:56.874038+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/claim/claim_038",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "The gene-level offset corrects for changes to the average transcript length across samples.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:source_excerpt": "a gene-level offset\nthat corrects for changes to the average transcript length across\nsamples",
