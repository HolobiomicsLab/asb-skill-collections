        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/claim/claim_040",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "A second method for importing estimates for differential gene expression is to use tximport argument countsFromAbundance=lengthScaledTPM or scaledTPM and then use the gene-level count matrix directly.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
      "asbval:source_excerpt": "The second method is to use the `tximport` argument\n`countsFromAbundance=\"lengthScaledTPM\"` or `\"scaledTPM\"`, and then to\nuse the gene-level count matrix `txi$counts` directly as you would a regular\ncount matrix with these software.",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_040",
      "asbval:target_artifact_kind": "ledger_claim",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
