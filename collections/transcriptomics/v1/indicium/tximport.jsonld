      "@id": "asbval:assertion/skill/deseq2-object-initialization-from-transcript-data/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Accounting for the potentially varying average transcript length across samples when performing DGE, either in the definition of the count matrix (scaledTPM) or by defining offsets, led to considerably improved false discovery rate (FDR) control",
      "asbval:note": "Paper demonstrates that length-derived offsets from transcript-level estimates improve gene-level DGE analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
