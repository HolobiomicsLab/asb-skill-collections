    {
      "@id": "asbval:assertion/skill/rna-seq-count-normalization/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We used Salmon (v0.5.1) to estimate TPM values for each transcript... From the bootstrap estimates generated by Salmon, we also estimated the coefficient of variation... Salmon transcript lengths and estimated TPMs to define average transcript lengths",
      "asbval:note": "Paper confirms Salmon produces transcript-level estimates, TPMs, and bootstrap replicates used by tximport. However, the paper uses Salmon v0.5.1 (2015), not v1.3.9. The specific version claim about Gibbs samples/bootstrap in v1.3.9 cannot be verified from these passages.",
      "asbval:perspicacite_kb": "asb-paper-10-12688-f1000research-7563-1",
