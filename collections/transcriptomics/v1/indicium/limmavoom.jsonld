    {
      "@id": "asbval:assertion/skill/differential-expression-result-interpretation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This article develops differential expression methods for RNA-seq experiments of arbitrary complexity... We use linear models to describe how the treatment factors are assigned to the different RNA samples.",
      "asbval:note": "Paper focuses on RNA-seq and microarray data; qPCR and proteomics are not mentioned. The scope claim is broader than the paper's actual scope.",
