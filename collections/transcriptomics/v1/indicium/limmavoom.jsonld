      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TMM-scale normalization [54] was used for all the analysis methods... The normalized log-counts and associated precision weights can then be entered into the limma analysis pipeline, or indeed into any statistical pipeline for microarray data that is precision weight aware.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
