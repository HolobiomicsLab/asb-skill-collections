    {
      "@id": "asbval:assertion/card/10_1093_nar_gkv007__task_002/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "One popular differential expression pipeline is that provided by the limma software package [9]. The limma pipeline includes linear modeling to analyze complex experiments with multiple treatment factors, quantitative weights to account for variations in precision between different observations, and empirical Bayes statistical methods to borrow strength between genes.",
      "asbval:note": "limma is extensively discussed throughout the paper as the primary tool for linear modeling and differential expression analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_002",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "limma",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:06:40.295167+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/card/10_1093_nar_gkv007__task_002/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The results presented in this article were obtained using R version 3.0.0 and the software packages limma 3.16.2, edgeR 3.2.3, baySeq 1.14.1, DESeq 1.12.0, DSS 1.4.0, PoissonSeq 1.1.2 and tweeDEseqCountData 1.0.8.",
      "asbval:note": "R is explicitly mentioned as the programming environment used for all analyses.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
