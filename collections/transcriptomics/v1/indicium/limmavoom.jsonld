    {
      "@id": "asbval:assertion/skill/linear-model-fitting-for-gene-expression/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We assume that: E(ygi)=\u03bcgi=xiT\u03b2g where xi is a vector of covariates and \u03b2g is a vector of unknown coefficients representing log2-fold-changes between experimental conditions. In matrix terms: E(yg)=X\u03b2g where yg is the vector of log-cpm values for gene g and X is the design matrix with the xi as rows.",
      "asbval:note": "Design matrix X explicitly encodes experimental conditions and covariates.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "linear-model-fitting-for-gene-expression",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Design matrix encoding experimental groups or conditions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:10:06.791731+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/linear-model-fitting-for-gene-expression/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This yields regression coefficient estimates \u03b2^g, fitted values \u03bc^gi=xiT\u03b2^g and residual standard deviations sg.",
      "asbval:note": "Both coefficient estimates and residual standard deviations (errors) are explicitly produced by the linear model fitting procedure.",
