      }
    },
    {
      "@id": "asbval:assertion/card/10_1093_nar_gkv007__task_002/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The above linear model is fitted, by ordinary least squares, to the log-cpm values ygi for each gene. This yields regression coefficient estimates \u03b2^g, fitted values \u03bc^gi=xiT\u03b2^g and residual standard deviations sg.",
      "asbval:note": "Paper describes lmFit applied to RNA-seq log-cpm data (not microarray), producing coefficient estimates, fitted values, and residual standard deviations. The function and outputs exist but the claim specifies 'microarray dataset' while the paper applies lmFit to RNA-seq data via voom. The functional output (coefficient estimates, fitted values) is correct but the data type context differs.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
