      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "The skill is essential when sample sizes are small or when mean-variance trends are pronounced and could bias downstream statistical inference.",
      "eco:evidence_type": {
