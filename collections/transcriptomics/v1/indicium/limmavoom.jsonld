    {
      "@id": "asbval:assertion/skill/design-matrix-construction-experiments/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This article compares the performance of the limma-based pipelines to edgeR [20,34], DESeq [13], baySeq [21], TSPM [25], PoissonSeq [26] and DSS [22], all of which are based on NB or over-dispersed Poisson distributions.",
      "asbval:note": "edgeR is mentioned as a comparison method but the paper does not explicitly describe edgeR's use of design matrices for specifying contrasts. The paper focuses on limma and voom, not edgeR's design matrix workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "design-matrix-construction-experiments",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "edgeR \u2014 Companion package that uses design matrices to specify contrasts and normalization factors in DGEList workflows",
      "eco:evidence_type": {
