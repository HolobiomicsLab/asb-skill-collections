    {
      "@id": "asbval:assertion/skill/precision-weight-calculation-rna-seq/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper being validated is 10.1186/gb-2014-15-2-r29 (Law et al. 2014 on voom). The DOI 10.1093/nar/gkv007 appears to be a different paper (likely the limma review paper cited in the card's source_paper_title field). The voom method was first published in the current paper (10.1186/gb-2014-15-2-r29), not in 10.1093/nar/gkv007.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "precision-weight-calculation-rna-seq",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[voom].source_paper_doi",
      "asbval:target_claim_text": "10.1093/nar/gkv007",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:07.614137+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/precision-weight-calculation-rna-seq/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The current paper's title is 'voom: precision weights unlock linear model analysis tools for RNA-seq read counts' (Law et al. 2014). The cited source_paper_title appears to refer to a different limma review paper, not the voom paper itself.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "precision-weight-calculation-rna-seq",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[voom].source_paper_title",
      "asbval:target_claim_text": "limma powers differential expression analyses for RNA-sequencing and microarray studies",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:07.614137+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/prior-distribution-fitting-for-genomics/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The limma pipeline includes linear modeling to analyze complex experiments with multiple treatment factors, quantitative weights to account for variations in precision between different observations, and empirical Bayes statistical methods to borrow strength between genes. Borrowing information between genes is a crucial feature of the genome-wide statistical methods, as it allows for gene-specific variation while still providing reliable inference with small sample sizes. The normal-based empirical Bayes statistical procedures can adapt to different types of datasets and can provide exact type I error rate control even for experiments with a small number of replicate samples.",
      "asbval:note": "Passage directly confirms empirical Bayes methods for variance stabilization with small sample sizes and borrowing strength between genes.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prior-distribution-fitting-for-genomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Empirical Bayesian estimation of hyperparameters in the prior distribution over gene-wise variances, enabling computation of moderated t-statistics and B-statistics that remain stable even with small sample sizes in microarray and RNA-seq studies.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:20.535428+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/prior-distribution-fitting-for-genomics/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The voom method estimates the mean-variance relationship of the log-counts, generates a precision weight for each observation and enters these into the limma empirical Bayes analysis pipeline.",
      "asbval:note": "Confirms empirical Bayes pipeline pools information across genes; passage 3 explicitly states 'Borrowing information between genes is a crucial feature'.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prior-distribution-fitting-for-genomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill stabilizes variance estimates across genes by pooling information through a shared prior.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:20.535428+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/prior-distribution-fitting-for-genomics/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "One popular differential expression pipeline is that provided by the limma software package [9]. The limma pipeline includes linear modeling to analyze complex experiments with multiple treatment factors, quantitative weights to account for variations in precision between different observations, and empirical Bayes statistical methods to borrow strength between genes.",
      "asbval:note": "limma package explicitly named and described as providing empirical Bayes methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prior-distribution-fitting-for-genomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "limma",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:20.535428+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/prior-distribution-fitting-for-genomics/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The voom methodology proposed in the article is implemented in the voom function of the limma package. The limma-trend method was implemented by inputting the log-cpm values from voom into limma's standard pipeline, with trend=TRUE for the eBayes function.",
      "asbval:note": "eBayes function explicitly named in passage 14. lmFit is referenced implicitly in Materials and Methods section discussing linear model fitting.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prior-distribution-fitting-for-genomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "limma provides lmFit and eBayes functions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:20.535428+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/prior-distribution-fitting-for-genomics/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The results presented in this article were obtained using R version 3.0.0 and the software packages limma 3.16.2, edgeR 3.2.3, baySeq 1.14.1, DESeq 1.12.0, DSS 1.4.0, PoissonSeq 1.1.2 and tweeDEseqCountData 1.0.8.",
      "asbval:note": "R explicitly named as runtime environment for limma and other packages.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prior-distribution-fitting-for-genomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "R runtime environment",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:20.535428+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/prior-distribution-fitting-for-genomics/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The above linear model is fitted, by ordinary least squares, to the log-cpm values ygi for each gene. This yields regression coefficient estimates \u03b2^g, fitted values \u03bc^gi=xiT\u03b2^g and residual standard deviations sg.",
      "asbval:note": "Passage describes fitting linear models to microarray and RNA-seq data as prerequisite for empirical Bayes procedure.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prior-distribution-fitting-for-genomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply when you have a fitted linear model (lmFit object) from microarray or RNA-seq count data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:20.535428+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/prior-distribution-fitting-for-genomics/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The normal-based empirical Bayes statistical procedures can adapt to different types of datasets and can provide exact type I error rate control even for experiments with a small number of replicate samples.",
      "asbval:note": "Passage confirms empirical Bayes provides reliable inference with small sample sizes; paper demonstrates this with simulations using 3 and 6 samples.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prior-distribution-fitting-for-genomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Small sample sizes (fewer than ~5\u201310 arrays/samples per group) benefit from variance stabilization",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:20.535428+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/prior-distribution-fitting-for-genomics/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "An obstacle to applying normal-based statistical methods to read counts is that the counts have markedly unequal variabilities, even after log-transformation. Large counts have much larger standard deviations than small counts.",
      "asbval:note": "Paper addresses heteroscedasticity and variance modeling to handle genes with different expression levels and technical noise.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prior-distribution-fitting-for-genomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Avoids inflated variance estimates for genes with low expression or high technical noise",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:20.535428+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/prior-distribution-fitting-for-genomics/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The above linear model is fitted, by ordinary least squares, to the log-cpm values ygi for each gene. This yields regression coefficient estimates \u03b2^g, fitted values \u03bc^gi=xiT\u03b2^g and residual standard deviations sg. Also computed is the average log-cpm y\u00afg for each gene.",
      "asbval:note": "Passage confirms linear model fitting is prerequisite; empirical Bayes operates on fitted model outputs, not raw counts.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prior-distribution-fitting-for-genomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input is already a feature table or count matrix without a fitted linear model; eBayes requires an lmFit object as input.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:20.535428+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/rna-seq-count-normalization-tmm/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The different count-based packages implement different methods of compositional normalization [54]. For our simulations, there are no compositional differences between the libraries so there should be no need to estimate compositional normalization factors. For this reason we did not use the calcNormFactors function with edgeR or estimateSizeFactors with DESeq or estNormFactors with DSS.",
      "asbval:note": "Paper mentions TMM-scale normalization and calcNormFactors but does not provide detailed explanation of how TMM works or its role in composition bias correction. The paper uses TMM normalization in some analyses (e.g., Nigerian lymphoblastoid cell lines, Drosophila, mouse strains) but explicitly states it was NOT used in simulations due to no compositional differences. The claim about TMM's function is semantically reasonable but not explicitly detailed in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "rna-seq-count-normalization-tmm",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "TMM normalization computes scale factors that account for RNA composition bias in RNA-seq count data, enabling fair comparison of gene expression across samples with different sequencing depths and transcript abundance distributions. This normalization is typically applied via ed",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:37.435328+00:00",
      "sepio:credibility_status": {
