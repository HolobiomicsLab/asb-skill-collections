    {
      "@id": "asbval:assertion/skill/precision-weight-calculation-rna-seq/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A key advantage of the limma pipelines is that they provide accurate type I error rate control even when the number of RNA-seq samples is small. The NB and Poisson based methods either fail to control the error correctly or are excessively conservative.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
