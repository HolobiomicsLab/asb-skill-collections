    {
      "@id": "asbval:assertion/skill/design-matrix-construction-experiments/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A multidimensional scaling plot of log-cpm values shows the gradual change in gene expression during embryonic development, with each stage intermediate in expression profile between the stages before and after (Figure 9).",
      "asbval:note": "The paper mentions exploratory analysis (MDS plots) but emphasizes that the main focus is on hypothesis-driven differential expression testing with design matrices.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "design-matrix-construction-experiments",
