    {
      "@id": "asbval:assertion/skill/design-matrix-construction-experiments/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The results presented in this article were obtained using R version 3.0.0 and the software packages limma 3.16.2, edgeR 3.2.3, baySeq 1.14.1, DESeq 1.12.0, DSS 1.4.0, PoissonSeq 1.1.2 and tweeDEseqCountData 1.0.8.",
      "asbval:note": "Paper confirms R is used as the programming environment, but does not explicitly mention model.matrix() or design matrix construction functions. The claim about 'model.matrix()' or 'manual specification' is not verbatim in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2014-15-2-r29",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "design-matrix-construction-experiments",
