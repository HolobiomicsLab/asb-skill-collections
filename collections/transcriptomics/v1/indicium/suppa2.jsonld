      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Parse a genome annotation GTF file to extract and define alternative splicing events (exon skipping, intron retention, alternative splice sites, etc.) and generate indexed event definition files (ioe, ioi, gtf) for downstream PSI quantification and differential splicing analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
