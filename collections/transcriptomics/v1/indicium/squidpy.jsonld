    {
      "@id": "asbval:assertion/skill/sparse-matrix-verification-and-validation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The function builds a spatial graph and saves its adjacency and weighted adjacency matrices to adata.obsp['spatial_connectivities'] in either Numpy or Scipy sparse arrays. The weights of the weighted adjacency matrix are distances in the case of coord_type = 'generic' and ordinal numbers of hexagonal rings in the case of coord_type = 'grid'. Together with the connectivities, we also provide a sparse adjacency matrix of distances, saved in adata.obsp['spatial_distances']",
      "asbval:note": "Paper describes adjacency and distance matrices stored as sparse arrays with specific properties.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sparse-matrix-verification-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "CSR sparse matrices with expected dimensions (n_obs \u00d7 n_obs), sparsity patterns, and diagonal constraints",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:11:14.792225+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/sparse-matrix-verification-and-validation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Spatial proximity is encoded in spatial graphs, which require flexibility to support the variety of neighborhood metrics that spatial data types and users may require... Squidpy can compute all the aforementioned modalities thus making it technology-agnostic",
      "asbval:note": "Paper documents multiple neighborhood graph construction approaches supported by Squidpy.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
