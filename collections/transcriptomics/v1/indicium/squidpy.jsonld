    {
      "@id": "asbval:assertion/skill/neighborhood-enrichment-computation/012",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy supports inputs from diverse spatial molecular technologies with spot-based, single-cell or subcellular spatial resolution... For instance, in Spatial Transcriptomics (ST, Visium and DBit-seq), a node is a spot... whereas in imaging-based molecular data (seqFISH, MERFISH, Imaging Mass Cytometry, CyCif, 4i and Spatial Metabolomics)",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
