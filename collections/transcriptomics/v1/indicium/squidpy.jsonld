      }
    },
    {
      "@id": "asbval:assertion/skill/spatial-statistics-interpretation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy is built on top of Scanpy and Anndata... Its modularity makes it suitable to be interfaced with a variety of additional tools in the Python data science and machine-learning ecosystem... as well as several single-cell data analysis packages.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-statistics-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "scanpy: Provides data preprocessing and annotation workflows that feed into spatial statistics",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:12:56.375283+00:00",
