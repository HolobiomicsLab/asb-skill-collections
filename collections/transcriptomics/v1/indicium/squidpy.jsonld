    {
      "@id": "asbval:assertion/card/10_1038_s41592_021_01358_2__task_005/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This image feature matrix can then be used in any single-cell analysis workflow, just like the gene matrix. The scale and size of the image used to calculate features can be adjusted using the scale and spot_scale parameters. Feature extraction can be parallelized by providing n_jobs (see Supplementary Fig. 1). The calculated feature matrix is stored in adata[key].",
      "asbval:note": "Paper confirms that computed image features are stored in AnnData (adata[key]), but does not specify whether they are stored in obsm or var slots specifically. The exact slot location is not detailed in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_005",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "AnnData object with computed image features stored in obsm or var slots",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:06:15.850455+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/card/10_1038_s41592_021_01358_2__task_005/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "No mention in the paper of verification logs or reports showing dask array status before and after materialization. The paper discusses lazy loading and dask usage but does not describe any logging or reporting mechanism for tracking materialization status.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "task_005",
