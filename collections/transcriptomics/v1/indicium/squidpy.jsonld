      }
    },
    {
      "@id": "asbval:assertion/skill/spatial-statistics-interpretation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not mention pynndescent. For k-nearest neighbors, paper states: 'For a fixed number of the closest spots for each spot, it leverages the k-nearest neighbors search from Scikit-learn' (passage 8). The underlying k-NN implementation uses Scikit-learn, not pynndescent.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "spatial-statistics-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "pynndescent: Underlying library for efficient k-NN graph construction in spatial_neighbors()",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:12:56.375283+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/spatial-statistics-interpretation/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Different approaches of defining a neighborhood relation among spots are used for different types of spatial datasets... it is also possible to compute a neighbor graph based on Delaunay triangulation... For a fixed number of the closest spots for each spot, it leverages the k-nearest neighbors search from Scikit-learn... To get all spots within a specified radius (in units of the spatial coordinates) from each spot as neighbors, the parameter radius should be used.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-statistics-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Building spatial neighbor graph using Delaunay triangulation, grid-based (hexagonal/square), k-nearest neighbors, or radius-based approaches",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:12:56.375283+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spatial-statistics-interpretation/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To estimate the deviation of this number versus a random configuration of cluster labels in the same connectivity graph, we scramble the cluster labels while maintaining the connectivities and then recount the number of nodes recovered in each iteration (1,000 times by default). Using these estimates, we calculate expected means (\u00b5ij) and standard deviations (\u03c3ij) for each pair and a z score as... The z score indicates if a cluster pair is over-represented or over-depleted for node\u2013node interactions in the connectivity graph.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-statistics-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Permutation-based statistical test with z-score calculation to assess over-representation or depletion of cluster pairs",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:12:56.375283+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spatial-statistics-interpretation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Clusters of enriched cell types (such as 'Lateral plate mesoderm' with 'Allantois' and 'Intermediate mesoderm' clusters, 'Endothelium' with 'Hematoendothelial progenitors'; Fig. 2b) are consistent with the original publication... The z score indicates if a cluster pair is over-represented or over-depleted for node\u2013node interactions in the connectivity graph.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-statistics-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "Neighborhood enrichment scores (z-scores) indicating spatial co-enrichment or depletion between categorical pairs",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:12:56.375283+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spatial-statistics-interpretation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy supports inputs from diverse spatial molecular technologies with spot-based, single-cell or subcellular spatial resolution... Squidpy can compute all the aforementioned modalities thus making it technology-agnostic",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-statistics-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Applicable to diverse spatial omics technologies (Visium, MERFISH, seqFISH, etc.) with spot-based, single-cell, or subcellular resolution",
      "eco:evidence_type": {
