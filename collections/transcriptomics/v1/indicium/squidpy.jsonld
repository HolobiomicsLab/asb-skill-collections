    {
      "@id": "asbval:assertion/skill/adjacency-matrix-sparsity-analysis/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "saves its adjacency and weighted adjacency matrices to adata.obsp['spatial_connectivities']... we also provide a sparse adjacency matrix of distances, saved in adata.obsp['spatial_distances']",
      "asbval:note": "Paper uses key 'spatial_connectivities' for adjacency matrix, not 'spatial_neighbors' as claimed in the card. The distance matrix key 'spatial_distances' is correct.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
