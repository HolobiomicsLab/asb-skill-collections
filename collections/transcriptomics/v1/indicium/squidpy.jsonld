    {
      "@id": "asbval:assertion/skill/spatial-statistics-interpretation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy provides several tools that leverage the spatial graph to address such questions... The spatial graph is a graph of spatial neighbors with cells (or spots in case of Visium) as nodes and neighborhood relations between spots as edges... sq.gr.nhood_enrichment(adata, cluster_key=\"<cluster_key>\")",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-statistics-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Squidpy: Provides spatial neighbor graph construction and neighborhood enrichment statistical testing functions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:12:56.375283+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spatial-statistics-interpretation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy is built on top of Scanpy and Anndata and it relies on several scientific computing libraries in Python... The function builds a spatial graph and saves its adjacency and weighted adjacency matrices to adata.obsp['spatial_connectivities']",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-statistics-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "anndata: Data structure for storing spatial coordinates, annotations, and enrichment results as AnnData.obs and .uns",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
