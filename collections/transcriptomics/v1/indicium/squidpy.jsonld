    {
      "@id": "asbval:assertion/skill/categorical-annotation-handling-in-omics-data/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Neighborhood enrichment test: The association between label pairs in the connectivity graph is estimated by counting the sum of nodes that belong to classes i and j (for example cluster annotation) and are proximal to each other... To estimate the deviation of this number versus a random configuration of cluster labels in the same connectivity graph, we scramble the cluster labels while maintaining the connectivities and then recount the number of nodes recovered in each iteration (1,000 times by default).",
      "asbval:note": "Directly supported by Methods section describing neighborhood enrichment test on categorical cluster annotations.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "categorical-annotation-handling-in-omics-data",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Use categorical cell-type, tissue-region, or other discrete biological annotations stored in AnnData metadata to compute neighborhood enrichment statistics and assess whether spatial neighborhoods are significantly enriched or depleted for specific categories.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:08:33.167281+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
