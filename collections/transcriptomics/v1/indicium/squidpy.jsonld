    {
      "@id": "asbval:assertion/skill/adjacency-matrix-sparsity-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The function builds a spatial graph and saves its adjacency and weighted adjacency matrices to adata.obsp['spatial_connectivities'] in either Numpy or Scipy sparse arrays. The weights of the weighted adjacency matrix are distances in the case of coord_type = 'generic' and ordinal numbers of hexagonal rings in the case of coord_type = 'grid'. Together with the connectivities, we also provide a sparse adjacency matrix of distances, saved in adata.obsp['spatial_distances']",
      "asbval:note": "Paper explicitly describes storage of adjacency and distance matrices in adata.obsp as sparse arrays (Scipy sparse format, which includes CSR).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "adjacency-matrix-sparsity-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Verify the structural integrity and sparsity properties of adjacency and distance matrices stored as CSR sparse matrices in AnnData objects after spatial graph construction.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:08:06.244431+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/adjacency-matrix-sparsity-analysis/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The function builds a spatial graph and saves its adjacency and weighted adjacency matrices to adata.obsp['spatial_connectivities'] in either Numpy or Scipy sparse arrays.",
      "asbval:note": "Paper confirms storage of adjacency and distance matrices as sparse arrays but does not explicitly discuss domain constraints like diagonal zeros or consistency checks between paired matrices. The claim about domain constraints is inferred but not directly stated in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "adjacency-matrix-sparsity-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "spatial graphs are correctly formatted, maintain expected sparsity patterns, and satisfy domain constraints (diagonal zeros for distance, consistent structure across paired matrices)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:08:06.244431+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/adjacency-matrix-sparsity-analysis/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "sq.gr.spatial_neighbors(adata, coord_type=\"grid\", n_neigh=6, n_rings=<int>)",
      "asbval:note": "Paper explicitly documents the sq.gr.spatial_neighbors() function and its role in spatial graph construction.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
