      }
    },
    {
      "@id": "asbval:assertion/skill/image-feature-extraction-from-tissue-sections/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy is built on top of Scanpy and Anndata and it relies on several scientific computing libraries in Python. Its modularity makes it suitable to be interfaced with a variety of additional tools in the Python data science and machine-learning ecosystem.",
      "asbval:note": "Fully supported: paper states Squidpy is built on Scanpy and emphasizes modularity for downstream workflows.",
