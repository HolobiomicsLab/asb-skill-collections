    {
      "@id": "asbval:assertion/skill/categorical-annotation-handling-in-omics-data/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "sq.gr.spatial_neighbors(adata, coord_type=\"grid\", n_neigh=6, n_rings=<int>)... The function builds a spatial graph and saves its adjacency and weighted adjacency matrices to adata.obsp['spatial_connectivities']",
      "asbval:note": "Paper documents spatial_neighbors() function and its integration with AnnData.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "categorical-annotation-handling-in-omics-data",
