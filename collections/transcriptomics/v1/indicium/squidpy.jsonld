    {
      "@id": "asbval:assertion/card/10_1038_s41592_021_01358_2__task_001/scope_drift",
      "@type": "asbval:ScopeDriftAssertion",
      "asbval:drift_notes": [
        "The card claims the adjacency matrix key is 'spatial_neighbors', but the paper documents it as 'spatial_connectivities'. This is a minor naming discrepancy that could cause implementation issues.",
        "The card includes a 'verification report' as an expected output, which is a testing/validation artifact not described in the paper's methods or results. This appears to be an addition beyond what the paper documents.",
        "The card frames this as reproducing a task on 'a bundled example dataset', but the paper does not explicitly describe bundled example datasets in the passages provided\u2014only references to external datasets (seqFISH, MERFISH, Visium, etc.)."
      ],
      "asbval:n_drift_notes": 3,
      "asbval:target_artifact_id": "task_001",
