    {
      "@id": "asbval:assertion/skill/python-data-structure-verification/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy, a Python-based framework for the analysis of spatially resolved omics data. Squidpy aims to bring the diversity of spatial data in a common data representation and provide a common set of analysis and interactive visualization tools. The time t the gene takes to reach consensus is then used a 'Sepal score' and indicates the degree of spatial variability of the gene. It can be computed with: sq.gr.sepal(adata)",
      "asbval:note": "Squidpy and its sepal function are explicitly documented in the paper; outputs are stored in AnnData objects.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "python-data-structure-verification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Squidpy \u2014 Spatial analysis tool whose outputs (e.g., from squidpy.gr.sepal) are validated against expected field names and dimensions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:10:43.158352+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/python-data-structure-verification/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy, a Python framework that brings together tools from omics and image analysis to enable scalable description of spatial molecular data. Squidpy is built on top of Scanpy and Anndata and it relies on several scientific computing libraries in Python",
      "asbval:note": "Python is confirmed as the implementation language for Squidpy and its analysis functions.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "python-data-structure-verification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Python \u2014 Programming language used to write inspection and assertion code for verifying field names, dtypes, and array shapes",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
