      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy is built on top of Scanpy and Anndata and it relies on several scientific computing libraries in Python, such as Scikit-image, Napari and Dask. The function builds a spatial graph and saves its adjacency and weighted adjacency matrices to adata.obsp['spatial_connectivities']",
      "asbval:note": "AnnData is confirmed as the core data structure; passage shows explicit use of adata attributes (.obsp) for storing results.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "python-data-structure-verification",
