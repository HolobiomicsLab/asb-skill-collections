    {
      "@id": "asbval:assertion/skill/spatial-neighbor-graph-construction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The spatial graph is a graph of spatial neighbors with cells (or spots in case of Visium) as nodes and neighborhood relations between spots as edges. We use spatial coordinates of spots to identify neighbors among them... To get all spots within a specified radius (in units of the spatial coordinates) from each spot as neighbors, the parameter radius should be used... For a fixed number of the closest spots for each spot, it leverages the k-nearest neighbors search from Scikit-learn and n_neigh must be used to set the number of neighbors... The function builds a spatial graph and saves its adjacency and weighted adjacency matrices to adata.obsp['spatial_connectivities'] in either Numpy or Scipy sparse arrays.",
      "asbval:note": "Fully supported. Paper explicitly describes radius-based and k-nearest-neighbor approaches, storage in AnnData.obsp as sparse arrays.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-neighbor-graph-construction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Construct a spatial neighbor graph from coordinate data in an AnnData object using radius-based or k-nearest-neighbor detection, storing adjacency and distance matrices as sparse CSR structures.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:12:16.934083+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spatial-neighbor-graph-construction/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "sq.gr.spatial_neighbors(adata, coord_type=\"grid\", n_neigh=6, n_rings=<int>)... sq.gr.spatial_neighbors(adata, coord_type=\"generic\", n_neigh=<int>)... sq.gr.spatial_neighbors(adata, coord_type=\"generic\", radius=<float>)... sq.gr.spatial_neighbors(adata, coord_type=\"generic\", delaunay=True)",
      "asbval:note": "Fully supported. Paper documents the spatial_neighbors() function with multiple parameter options.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-neighbor-graph-construction",
