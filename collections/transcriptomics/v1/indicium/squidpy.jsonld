    {
      "@id": "asbval:assertion/card/10_1038_s41592_021_01358_2__task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The function builds a spatial graph and saves its adjacency and weighted adjacency matrices to adata.obsp['spatial_connectivities'] in either Numpy or Scipy sparse arrays. The weights of the weighted adjacency matrix are distances in the case of coord_type = 'generic' and ordinal numbers of hexagonal rings in the case of coord_type = 'grid'. Together with the connectivities, we also provide a sparse adjacency matrix of distances, saved in adata.obsp['spatial_distances']",
      "asbval:note": "Paper confirms spatial_neighbors function stores adjacency and distance matrices in adata.obsp with keys 'spatial_connectivities' and 'spatial_distances' (not 'spatial_neighbors' as card states, but functionally equivalent).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Does squidpy.gr.spatial_neighbors correctly construct and store a CSR graph in an AnnData object with expected keys and structure when applied to a bundled example dataset?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:05:18.631294+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/card/10_1038_s41592_021_01358_2__task_001/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The function builds a spatial graph and saves its adjacency and weighted adjacency matrices to adata.obsp['spatial_connectivities'] in either Numpy or Scipy sparse arrays... Together with the connectivities, we also provide a sparse adjacency matrix of distances, saved in adata.obsp['spatial_distances']",
      "asbval:note": "Paper uses key 'spatial_connectivities' for adjacency matrix, not 'spatial_neighbors' as claimed. The distance matrix key 'spatial_distances' matches. Both are stored as sparse arrays (Scipy sparse, which includes CSR format).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "AnnData object with spatial graph stored in obsp as CSR matrices with keys 'spatial_neighbors' (adjacency) and 'spatial_distances' (distance matrix)",
      "eco:evidence_type": {
