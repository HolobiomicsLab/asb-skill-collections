    {
      "@id": "asbval:assertion/skill/python-data-structure-verification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy introduces two main data representations to manage and store spatial omics data in a technology-agnostic way: a neighborhood graph from spatial coordinates and large-source tissue images acquired in spatial omics data (Fig. 1b). Both data representations leverage sparse or memory-efficient approaches in Python for scalability and ease of use. Squidpy is built on top of Scanpy and Anndata and it relies on several scientific computing libraries in Python, such as Scikit-image, Napari and Dask.",
      "asbval:note": "Paper describes Squidpy's use of AnnData and Scanpy for storing spatial analysis results; validation of output structure is implicit in the framework's design.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "python-data-structure-verification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate that computed spatial analysis results conform to expected field names, data types, and dimensions when stored in standard Python data structures (AnnData objects, dictionaries, arrays).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:10:43.158352+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/python-data-structure-verification/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy is built on top of Scanpy and Anndata and it relies on several scientific computing libraries in Python",
      "asbval:note": "Scanpy is confirmed as foundational to Squidpy's data structure conventions.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
