    {
      "@id": "asbval:assertion/skill/graph-builder-subclassing-squidpy/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy is built on top of Scanpy and Anndata and it relies on several scientific computing libraries in Python, such as Scikit-image, Napari and Dask. Its modularity makes it suitable to be interfaced with a variety of additional tools in the Python data science and machine-learning ecosystem.",
      "asbval:note": "Paper confirms Squidpy integrates with AnnData and provides spatial graph construction. However, no class named 'GraphBuilderCSR' is mentioned in the paper. The paper describes spatial_neighbors() function and spatial graph infrastructure but does not expose a GraphBuilderCSR base class for subclassing.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "graph-builder-subclassing-squidpy",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Squidpy: Provides the GraphBuilderCSR base class and integration framework for spatial graph construction within AnnData workflows",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:09:25.345306+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/graph-builder-subclassing-squidpy/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "pytest is not mentioned in the paper. Paper mentions 'extensive testing suite, implemented in a robust continuous integration pipeline' but does not name pytest.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "graph-builder-subclassing-squidpy",
