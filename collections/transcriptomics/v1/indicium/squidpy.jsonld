    {
      "@id": "asbval:assertion/skill/image-feature-extraction-from-tissue-sections/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Squidpy is built on top of Scanpy and Anndata and it relies on several scientific computing libraries in Python. ImageContainer is able to interface with Anndata objects to relate any pixel-level information to the observations stored in Anndata (such as cells and spots). This image feature matrix can then be used in any single-cell analysis workflow, just like the gene matrix.",
      "asbval:note": "Fully supported: paper describes AnnData as core data structure for storing spatial and feature data.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "image-feature-extraction-from-tissue-sections",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "AnnData: Data structure for storing spatial coordinates, gene expression, and image-derived features across observations and feature spaces",
      "eco:evidence_type": {
