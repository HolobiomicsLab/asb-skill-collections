    {
      "@id": "asbval:assertion/skill/neighborhood-enrichment-computation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A key question in the analysis of spatial molecular data is the description and quantification of spatial patterns and cellular neighborhoods across the tissue. Squidpy provides several tools that leverage the spatial graph to address such questions... we built a spatial nearest-neighbor graph based on Delaunay triangulation and computed a permutation-based neighborhood enrichment across cell-type annotations",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-021-01358-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "neighborhood-enrichment-computation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute neighborhood enrichment scores for categorical cell annotations in spatial omics data using pre-built neighbor graphs. This identifies statistically enriched or depleted cell types in spatial neighborhoods, revealing local tissue organization and cell-type co-localization",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:10:26.965419+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
