      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "pytest: Framework for unit and integration testing of the builder class, matrix properties, and shape/sparsity invariants",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:09:25.345306+00:00",
