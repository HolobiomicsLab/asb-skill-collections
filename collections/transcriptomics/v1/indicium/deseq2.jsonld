      }
    },
    {
      "@id": "asbval:assertion/skill/independent-filtering-multiple-testing-correction/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In Figures 2A,B and 3, genes found in this way to be significant at an estimated FDR of 10% are depicted in red.",
      "asbval:note": "The paper explicitly uses FDR threshold of 0.1 (10%) in examples and benchmarks.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
