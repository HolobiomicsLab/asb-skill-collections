      }
    },
    {
      "@id": "asbval:assertion/skill/ma-plot-visualization-and-interpretation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We demonstrate the advantages of DESeq2's new features by describing a number of applications possible with shrunken fold changes and their estimates of standard error, including improved gene ranking and visualization",
      "asbval:note": "Paper emphasizes visualization of shrunken vs. unshrunken fold changes for comparison and bias detection.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ma-plot-visualization-and-interpretation",
