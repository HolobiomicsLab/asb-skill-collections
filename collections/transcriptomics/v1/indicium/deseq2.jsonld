    {
      "@id": "asbval:assertion/skill/statistical-hypothesis-testing-rna-seq/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We present DESeq2, a method for differential analysis of count data, using shrinkage estimation for dispersions and fold changes to improve stability and interpretability of estimates... The read count K ij for gene i in sample j is described with a GLM of the negative binomial family with a logarithmic link",
      "asbval:note": "Core claim fully supported by abstract and methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "statistical-hypothesis-testing-rna-seq",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Perform statistical significance testing on RNA-seq count data using negative binomial generalized linear models to identify differentially expressed genes between experimental conditions.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:23:29.692590+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/statistical-hypothesis-testing-rna-seq/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DESeq2, a method for differential analysis of count data, using shrinkage estimation for dispersions and fold changes to improve stability and interpretability of estimates... The Wald test P values from the subset of genes that pass an independent filtering step... are adjusted for multiple testing using the procedure of Benjamini and Hochberg",
      "asbval:note": "Shrinkage estimation and FDR control via Benjamini-Hochberg adjustment confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "statistical-hypothesis-testing-rna-seq",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "moderated estimation of dispersion and fold change to control false discovery rates",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:23:29.692590+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/statistical-hypothesis-testing-rna-seq/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We present DESeq2, a method for differential analysis of count data... The DESeq2 package is available at http://www.bioconductor.org/packages/release/bioc/html/DESeq2.html... For significance testing, DESeq2 uses a Wald test: the shrunken estimate of LFC is divided by its standard error, resulting in a z-statistic, which is compared to a standard normal distribution.",
      "asbval:note": "DESeq2 confirmed as primary tool for all claimed functions.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "statistical-hypothesis-testing-rna-seq",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "DESeq2 - Core tool for constructing DESeqDataSet, estimating dispersions, fitting negative binomial GLMs, and computing p-values and adjusted p-values",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:23:29.692590+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/statistical-hypothesis-testing-rna-seq/003",
