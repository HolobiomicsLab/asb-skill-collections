    {
      "@id": "asbval:assertion/skill/statistical-hypothesis-testing-rna-seq/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The starting point of a DESeq2 analysis is a count matrix K with one row for each gene i and one column for each sample j.",
      "asbval:note": "Paper confirms DESeq2 requires raw count input, not pre-filtered gene lists.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "statistical-hypothesis-testing-rna-seq",
      "asbval:target_artifact_kind": "skill_bundle",
