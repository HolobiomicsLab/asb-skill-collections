    {
      "@id": "asbval:assertion/skill/adaptive-prior-distribution-selection/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To incorporate empirical Bayes shrinkage of LFCs, we postulate a zero-centered normal prior for the coefficients \u03b2_ir of model (2) that represent LFCs (i.e., typically, all coefficients except for the intercept \u03b2_i0): \u03b2_ir ~ N(0, \u03c3\u00b2_r).",
      "asbval:note": "Paper explicitly describes zero-centered normal prior for LFC shrinkage.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "adaptive-prior-distribution-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "DESeq2 uses a normal prior for LFC shrinkage",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:18:34.207955+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/bayesian-effect-size-moderation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DESeq2 overcomes this issue by shrinking LFC estimates toward zero in a manner such that shrinkage is stronger when the available information for a gene is low... We again employ an empirical Bayes procedure",
      "asbval:note": "Paper describes empirical Bayes shrinkage of LFCs and the general approach, but does NOT mention lfcShrink() function or the specific estimator types (apeglm, normal, ashr). The paper was published in 2014 and describes the core shrinkage methodology; lfcShrink() with multiple estimators is a later addition to DESeq2 not covered in this paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "bayesian-effect-size-moderation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply empirical Bayes shrinkage to log fold change estimates from RNA-seq differential expression analysis, reducing noise in effect size estimates while preserving genuine signal through adaptive priors. This skill uses DESeq2's lfcShrink() function with multiple estimator types",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
