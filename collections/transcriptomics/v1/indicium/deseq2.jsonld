    {
      "@id": "asbval:assertion/claim/claim_022",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "By default, results are for the last variable in the design formula and the last level compared to the reference level.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:source_excerpt": "With no additional arguments to *results*, the log2 fold change and\nWald test *p* value will be for the **last variable** in the design\nformula, and if this is a factor, the comparison will be the **last\nlevel** of this variable over the **reference level**",
      "asbval:substring_in_paper": false,
