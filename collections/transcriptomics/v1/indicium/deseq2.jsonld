    {
      "@id": "asbval:assertion/skill/fold-change-interpretation-and-ranking/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We present DESeq2, a method for differential analysis of count data, using shrinkage estimation for dispersions and fold changes to improve stability and interpretability of estimates. This enables a more quantitative analysis focused on the strength rather than the mere presence of differential expression.",
      "asbval:note": "Paper explicitly describes DESeq2's purpose as enabling quantitative analysis of fold changes and differential expression with improved interpretability. Ranking by fold change and p-value adjustment are core features discussed throughout.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "fold-change-interpretation-and-ranking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Interpret and rank genes by log\u2082 fold change and adjusted p-value after DESeq2 differential expression analysis to prioritize biologically significant changes while controlling false discovery rate.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:20:30.166675+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/fold-change-interpretation-and-ranking/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The Wald test P values from the subset of genes that pass an independent filtering step, described in the next section, are adjusted for multiple testing using the procedure of Benjamini and Hochberg [21].",
      "asbval:note": "Paper explicitly describes FDR control via Benjamini-Hochberg adjustment of p-values.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "fold-change-interpretation-and-ranking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "controlling false discovery rate",
