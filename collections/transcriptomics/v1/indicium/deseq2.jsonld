    {
      "@id": "asbval:assertion/skill/bayesian-effect-size-moderation/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A common difficulty in the analysis of HTS data is the strong variance of LFC estimates for genes with low read count... DESeq2 overcomes this issue by shrinking LFC estimates toward zero in a manner such that shrinkage is stronger when the available information for a gene is low",
      "asbval:note": "Paper supports the motivation (high variance in LFC estimates for low-count genes) and the shrinkage approach. However, the paper does not discuss credible intervals as an output of the shrinkage procedure in the main text (though standard errors are reported for MAP estimates).",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "bayesian-effect-size-moderation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After running DESeq2 differential expression analysis and extracting results with raw log fold changes, apply this skill when you observe high variance in effect size estimates across genes\u2014particularly when many genes have small counts, unreliable variance estimates, or when you",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:18:48.715144+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
