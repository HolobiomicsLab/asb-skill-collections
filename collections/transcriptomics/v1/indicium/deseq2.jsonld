    {
      "@id": "asbval:assertion/skill/rna-seq-experimental-design-specification/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The starting point of a DESeq2 analysis is a count matrix K... For each gene, we fit a generalized linear model (GLM)... the design matrix elements indicate whether a sample j is treated or not... The use of linear models, however, provides the flexibility to also analyze more complex designs, as is often useful in genomic studies.",
      "asbval:note": "Paper confirms that design specification occurs before GLM fitting and supports treatment/condition specification, but does not explicitly mention tximport or batch effect handling in the provided passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "rna-seq-experimental-design-specification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Before constructing a DESeqDataSet from count data or tximport output, when you have raw RNA-seq samples that need to be annotated with experimental conditions, treatment groups, batch effects, or other covariates.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:22:46.019416+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/rnaseq-count-matrix-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We present DESeq2, a method for differential analysis of count data, using shrinkage estimation for dispersions and fold changes to improve stability and interpretability of estimates... DESeq2 uses the average expression strength of each gene, across all samples, as its filter criterion, and it omits all genes with mean normalized counts below a filtering threshold from multiple testing adjustment.",
      "asbval:note": "Core research question fully supported by abstract and methods sections.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "rnaseq-count-matrix-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Construct a DESeq2 data object from RNA-seq count matrices, estimate dispersions via negative binomial GLM, and extract differential expression results with automated independent filtering.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:23:00.719109+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/rnaseq-count-matrix-analysis/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The DESeq2 package is available at http://www.bioconductor.org/packages/release/bioc/html/DESeq2.html... The read count K ij for gene i in sample j is described with a GLM of the negative binomial family with a logarithmic link: K ij \u223c NB ( mean = \u03bc ij , dispersion = \u03b1 i )",
      "asbval:note": "DESeq2 confirmed as primary tool for negative binomial GLM and independent filtering.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "rnaseq-count-matrix-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "DESeq2 \u2014 Core package for constructing DESeqDataSet, estimating dispersions, fitting negative binomial GLMs, and extracting differential expression results with independent filtering",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:23:00.719109+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
