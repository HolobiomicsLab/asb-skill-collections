    {
      "@id": "asbval:assertion/claim/claim_025",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "The ashr shrinkage estimator fits a mixture of Normal distributions to form the prior.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:source_excerpt": "`ashr` is the adaptive shrinkage estimator from the\n  [ashr](https://github.com/stephens999/ashr) package [@Stephens2016].\n  Here DESeq2 uses the ashr option to fit a mixture of Normal distributions to\n  form the prior, with `method=\"shrinkage\"`.",
      "asbval:substring_in_paper": false,
