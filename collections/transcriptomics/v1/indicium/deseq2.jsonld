    {
      "@id": "asbval:assertion/skill/differential-gene-expression-analysis/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Other methods to obtain count matrices include the htseq-count script [62] and the Bioconductor packages easyRNASeq [63] and featureCount [64].",
      "asbval:note": "Paper explicitly mentions HTSeq and featureCounts. Salmon, kallisto, and RSEM are not mentioned in the provided passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
