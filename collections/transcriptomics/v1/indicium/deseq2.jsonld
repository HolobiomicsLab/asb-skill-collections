    {
      "@id": "asbval:assertion/skill/independent-filtering-optimization/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DESeq2 uses the average expression strength of each gene, across all samples, as its filter criterion, and it omits all genes with mean normalized counts below a filtering threshold from multiple testing adjustment... We model read counts K ij as following a negative binomial distribution (sometimes also called a gamma-Poisson distribution) with mean \u03bc ij and dispersion \u03b1 i.",
      "asbval:note": "DESeq2 confirmed for independent filtering and negative binomial GLM. However, the 'results()' function is not explicitly named or discussed in the passages; the filtering mechanism is described as part of the general DESeq2 workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "independent-filtering-optimization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "DESeq2 - Core package providing the results() function, automatic independent filtering based on mean normalized counts, and negative binomial GLM framework for differential expression testing",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
