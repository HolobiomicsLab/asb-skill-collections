    {
      "@id": "asbval:assertion/skill/count-data-normalization-rna-seq/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Note that although we refer in this paper to counts of reads in genes, the methods presented here can be applied as well to other kinds of HTS count data... the methods presented here can be applied as well to other kinds of HTS count data",
      "asbval:note": "Paper emphasizes that DESeq2 works with raw count data and uses negative binomial distribution, implying pre-normalized data would be inappropriate. However, the paper does not explicitly warn against applying normalization to already-normalized data. The scope statement is reasonable but not directly supported by explicit cautionary text in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "count-data-normalization-rna-seq",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Count data has already been normalized (e.g., TMM, quantile normalization, or log-transformed counts provided); applying DESeq2 normalization on pre-normalized data will distort fold-change estimates",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:19:02.951552+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/count-data-normalization-rna-seq/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The read count K ij for gene i in sample j is described with a GLM of the negative binomial family... K ij \u223c NB ( mean = \u03bc ij , dispersion = \u03b1 i )",
      "asbval:note": "Paper explicitly states DESeq2 models read counts with negative binomial distribution, implying raw counts are required, not normalized abundance.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "count-data-normalization-rna-seq",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input is transcript-level abundance (TPM, FPKM) rather than raw counts; DESeq2 assumes count data with a negative binomial distribution, not normalized abundance",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:19:02.951552+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/count-matrix-format-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The starting point of a DESeq2 analysis is a count matrix K with one row for each gene i and one column for each sample j. The matrix entries K ij indicate the number of sequencing reads that have been unambiguously mapped to a gene in a sample... The read count K ij for gene i in sample j is described with a GLM of the negative binomial family",
      "asbval:note": "Paper explicitly describes count matrix structure and negative binomial model requirements; un-normalized integer counts are fundamental to the method.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "count-matrix-format-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Verify that a count matrix destined for DESeq2 differential expression analysis contains un-normalized integer counts aggregated to the gene level, with proper sample metadata and design specification.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:19:15.335036+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
