    {
      "@id": "asbval:assertion/claim/claim_005",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "DESeq2 internally corrects for library size, so transformed or normalized values should not be used as input.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:source_excerpt": "The DESeq2 model\ninternally corrects for library size, so transformed or normalized\nvalues such as counts scaled by library size should not be used as\ninput.",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_005",
      "asbval:target_artifact_kind": "ledger_claim",
      "eco:evidence_type": {
