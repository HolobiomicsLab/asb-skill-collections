    {
      "@id": "asbval:assertion/claim/claim_009",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "Tximport is the recommended pipeline for DESeq2 to create gene-level count matrices from transcript abundance estimates.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:source_excerpt": "Our recommended pipeline for *DESeq2* is to use fast transcript \nabundance quantifiers upstream of DESeq2, and then to create\ngene-level count matrices for use with DESeq2 \nby importing the quantification data using\n[tximport](http://bioconductor.org/packages/tximport)",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_009",
      "asbval:target_artifact_kind": "ledger_claim",
