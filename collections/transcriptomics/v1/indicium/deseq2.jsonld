      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper describes only one shrinkage approach: empirical Bayes with a zero-centered normal prior. It does not discuss apeglm, ashr, or comparison across multiple estimator types. These are later additions to DESeq2.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
