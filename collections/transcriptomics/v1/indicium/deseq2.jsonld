    {
      "@id": "asbval:assertion/skill/deseqdataset-construction-from-quantification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper (Love et al. 2014) does not discuss tximport, transcript-level quantification, or DESeqDataSetFromTximport(). The paper focuses on gene-level count analysis using DESeq2 and mentions that 'the methods presented here can be applied as well to other kinds of HTS count data' but does not describe workflows for converting transcript quantifications to gene-level counts. The paper's own workflow uses HTSeq and featureCounts for gene-level counting, not transcript aggregation.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "deseqdataset-construction-from-quantification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Convert transcript-level quantification files (from Salmon, kallisto, or RSEM) into a DESeqDataSet object suitable for differential expression testing. This skill bridges quantification tools and DESeq2 by aggregating transcript abundance to gene level and wrapping the result in ",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:19:30.619799+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/deseqdataset-construction-from-quantification/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "tximport is not mentioned anywhere in the paper. The paper does not discuss transcript-level quantification import or aggregation workflows.",
