      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/bayesian-effect-size-moderation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DESeq2 overcomes this issue by shrinking LFC estimates toward zero in a manner such that shrinkage is stronger when the available information for a gene is low... We again employ an empirical Bayes procedure: we first perform ordinary GLM fits to obtain maximum-likelihood estimates (MLEs) for the LFCs and then fit a zero-centered normal distribution to the observed distribution of MLEs over all genes.",
      "asbval:note": "Paper describes DESeq2's shrinkage methodology for LFCs using empirical Bayes with a zero-centered normal prior. However, the lfcShrink() function is not mentioned by name in the paper. The paper describes the core shrinkage algorithm but not the later-added lfcShrink() wrapper function or its multiple estimator types.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "bayesian-effect-size-moderation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "DESeq2 with lfcShrink() function for Bayesian moderation of log fold changes",
