    {
      "@id": "asbval:assertion/claim/claim_012",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "Salmon, Sailfish, and kallisto are substantially faster and require less memory and disk usage compared to alignment-based methods.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:source_excerpt": "some of these methods (*Salmon*, *Sailfish*, *kallisto*) \nare substantially faster and require less memory\nand disk usage compared to alignment-based methods that require\ncreation and storage of BAM files",
