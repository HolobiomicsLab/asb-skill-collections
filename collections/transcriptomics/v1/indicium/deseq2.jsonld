      }
    },
    {
      "@id": "asbval:assertion/skill/rna-seq-differential-expression-analysis/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The starting point of a DESeq2 analysis is a count matrix K... For each gene, we fit a generalized linear model (GLM)... Empirical Bayes shrinkage for dispersion estimation... Empirical Bayes shrinkage for fold-change estimation... Hypothesis tests for differential expression",
      "asbval:note": "All four components (normalization, dispersion, hypothesis testing, LFC shrinkage) are explicitly described in the paper.",
