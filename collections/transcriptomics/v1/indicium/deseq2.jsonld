      "asbval:evidence_quote": null,
      "asbval:note": "tximport not mentioned in provided passages. Paper discusses HTSeq-count and TopHat2 alignment but does not reference tximport, Salmon, kallisto, or RSEM.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
