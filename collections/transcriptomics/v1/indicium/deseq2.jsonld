      }
    },
    {
      "@id": "asbval:assertion/skill/ma-plot-visualization-and-interpretation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The shrunken MAP LFCs offer a more reproducible quantification of transcriptional differences than standard MLE LFCs.",
      "asbval:note": "Paper discusses shrinkage estimators (MAP vs. MLE) but does not name specific shrinkage types like 'apeglm', 'normal', or 'ashr'. The paper focuses on the empirical Bayes shrinkage approach implemented in DESeq2 itself, not external shrinkage methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
