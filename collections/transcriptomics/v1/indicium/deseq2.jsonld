      "asbval:target_artifact_kind": "ledger_claim",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:15:17.830770+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/claim/claim_011",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "Using fast transcript abundance quantifiers corrects for potential changes in gene length across samples from differential isoform usage.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:source_excerpt": "this approach corrects for potential changes in gene length across samples \n(e.g. from differential isoform usage)",
