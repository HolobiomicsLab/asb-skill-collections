      "@id": "asbval:assertion/skill/statistical-hypothesis-testing-rna-seq/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The starting point of a DESeq2 analysis is a count matrix K with one row for each gene i and one column for each sample j. The matrix entries K ij indicate the number of sequencing reads that have been unambiguously mapped to a gene in a sample... Other methods to obtain count matrices include the htseq-count script [62]",
      "asbval:note": "Scope statement aligns with paper's description of DESeq2 input and use case.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "statistical-hypothesis-testing-rna-seq",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have RNA-seq count matrices (from alignment, transcript quantification, or HTSeq-count files) and need to test for differential expression between two or more conditions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:23:29.692590+00:00",
