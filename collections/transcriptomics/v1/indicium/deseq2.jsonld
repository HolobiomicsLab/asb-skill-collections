    {
      "@id": "asbval:assertion/skill/adaptive-prior-distribution-selection/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DESeq2 integrates methodological advances with several novel features to facilitate a more quantitative analysis of comparative RNA-seq data using shrinkage estimators for dispersion and fold change.",
      "asbval:note": "Paper describes shrinkage of log fold changes using a zero-centered normal prior (passage 17: '\u03b2_ir ~ N(0, \u03c3\u00b2_r)'), but does NOT mention apeglm or ashr as alternative adaptive priors. The paper's LFC shrinkage uses only a normal prior fitted empirically to the data. The card claims selection among three named priors (apeglm, normal, ashr), but the paper only implements normal prior shrinkage. apeglm and ashr are not discussed in the provided passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "adaptive-prior-distribution-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Select and apply an adaptive prior distribution (apeglm, normal, or ashr) to shrink log fold change estimates in DESeq2 differential expression analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:18:34.207955+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/adaptive-prior-distribution-selection/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DESeq2 overcomes this issue by shrinking LFC estimates toward zero in a manner such that shrinkage is stronger when the available information for a gene is low, which may be because counts are low, dispersion is high or there are few degrees of freedom.",
      "asbval:note": "Paper explicitly describes shrinking LFC estimates to improve precision when information is limited. Scope aligns with paper's core contribution.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "adaptive-prior-distribution-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After running DESeq() and extracting raw results with results(), when you have log fold change estimates with high variance and wish to improve their precision.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:18:34.207955+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/adaptive-prior-distribution-selection/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DESeq2 integrates methodological advances with several novel features to facilitate a more quantitative analysis of comparative RNA-seq data using shrinkage estimators for dispersion and fold change.",
      "asbval:note": "Paper confirms DESeq2 provides normalization, dispersion estimation, and LFC shrinkage. However, the paper does NOT mention an 'lfcShrink()' function by name. The shrinkage is described as part of the core DESeq2 workflow, not as a separate function. The function name 'lfcShrink()' is not present in any passage.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
