      }
    },
    {
      "@id": "asbval:assertion/skill/results-table-extraction-and-comparison/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We present DESeq2, a method for differential analysis of count data, using shrinkage estimation for dispersions and fold changes... The DESeq2 package is available at http://www.bioconductor.org/packages/release/bioc/html/DESeq2.html",
      "asbval:note": "Paper confirms DESeq2 provides shrinkage estimation for fold changes and results extraction. However, the paper does not mention lfcShrink() function or the ability to apply multiple shrinkage estimators (apeglm, normal, ashr). The paper describes only the empirical Bayes shrinkage approach built into DESeq2's core workflow, not post-hoc lfcShrink() with alternative estimators.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "results-table-extraction-and-comparison",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "DESeq2 - Core package for differential expression analysis; provides results() to extract results tables and lfcShrink() to apply shrinkage estimators (apeglm, normal, ashr) and compare shrunken log fold changes",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:22:10.912211+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/results-table-extraction-and-comparison/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not mention ashr, lfcShrink(), or any integration of ashr with DESeq2. The ashr package is not cited or discussed in any passage. This appears to be a post-publication extension.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
