    },
    {
      "@id": "asbval:assertion/skill/differential-gene-expression-analysis/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The starting point of a DESeq2 analysis is a count matrix K with one row for each gene i and one column for each sample j. The matrix entries K ij indicate the number of sequencing reads that have been unambiguously mapped to a gene in a sample.",
      "asbval:note": "Paper clearly specifies raw count input requirement.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "differential-gene-expression-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "DESeq2 requires unnormalized count data, not normalized expression matrices (TPM, RPKM, log2-transformed)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:19:49.189073+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/differential-gene-expression-analysis/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The use of linear models, however, provides the flexibility to also analyze more complex designs, as is often useful in genomic studies [15].",
      "asbval:note": "Paper discusses flexible design matrices for complex experimental designs, though batch and cell type are not explicitly named as examples.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
