    },
    {
      "@id": "asbval:assertion/skill/statistical-hypothesis-testing-rna-seq/012",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Note that although we refer in this paper to counts of reads in genes, the methods presented here can be applied as well to other kinds of HTS count data... The use of linear models, however, provides the flexibility to also analyze more complex designs",
      "asbval:note": "Paper emphasizes count-based input and negative binomial modeling, implying raw counts are required.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "statistical-hypothesis-testing-rna-seq",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have continuous normalized expression data (e.g., log2-transformed or TPM) rather than raw counts; DESeq2 requires raw count input",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
