    {
      "@id": "asbval:assertion/skill/results-table-extraction-and-comparison/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We present DESeq2, a method for differential analysis of count data, using shrinkage estimation for dispersions and fold changes to improve stability and interpretability of estimates.",
      "asbval:note": "Paper describes shrinkage estimation for fold changes and dispersions in DESeq2, but does NOT mention apeglm, normal, or ashr as shrinkage estimator options. The paper focuses on DESeq2's empirical Bayes shrinkage approach (MAP estimation with zero-centered normal prior). The specific shrinkage methods (apeglm, normal, ashr) appear to be post-publication extensions not covered in this 2014 paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "results-table-extraction-and-comparison",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Extract differential expression results tables from DESeq2 analysis objects and compare shrinkage estimator outputs (apeglm, normal, ashr) using log fold change values, p-values, and adjusted p-values across conditions.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
