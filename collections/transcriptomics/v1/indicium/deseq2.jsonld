      }
    },
    {
      "@id": "asbval:assertion/skill/transcript-abundance-quantification-import/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper (Love et al. 2014) does not mention tximport, Salmon, kallisto, RSEM, or transcript-level quantification import workflows. The paper focuses on DESeq2 methodology for differential expression analysis of count data, assuming count matrices are already prepared. The paper mentions HTSeq-count and other methods for obtaining count matrices but does not discuss transcript-to-gene aggregation via tximport.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "transcript-abundance-quantification-import",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Import transcript-level abundance quantifications from tools like Salmon, kallisto, or RSEM and aggregate them to gene-level counts using tximport, producing a list object suitable for downstream differential expression analysis with DESeq2.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:23:50.353323+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
