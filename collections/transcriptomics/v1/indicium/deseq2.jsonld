    {
      "@id": "asbval:assertion/skill/p-value-adjustment-methodology/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The Wald test P values from the subset of genes that pass an independent filtering step, described in the next section, are adjusted for multiple testing using the procedure of Benjamini and Hochberg [21].",
      "asbval:note": "Paper explicitly describes independent filtering and Benjamini-Hochberg adjustment. IHW is mentioned in passage context but not as a primary method in DESeq2 itself.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "p-value-adjustment-methodology",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Systematic adjustment of p-values from differential expression tests to control false discovery rate and account for multiple hypothesis testing, using either independent filtering based on mean normalized counts or weighting-based approaches like Independent Hypothesis Weighting",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:21:55.798883+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/p-value-adjustment-methodology/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DESeq2 uses the average expression strength of each gene, across all samples, as its filter criterion, and it omits all genes with mean normalized counts below a filtering threshold from multiple testing adjustment. DESeq2 by default will choose a threshold that maximizes the number of genes found at a user-specified target FDR.",
      "asbval:note": "Directly supported in paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "p-value-adjustment-methodology",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Independent filtering based on mean normalized counts",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:21:55.798883+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/p-value-adjustment-methodology/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "IHW is not described as a core DESeq2 method in the paper passages. The paper focuses on independent filtering and Benjamini-Hochberg adjustment. IHW may be mentioned in supplementary materials or external references, but is not a primary DESeq2 feature in the main text.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
