    {
      "@id": "asbval:assertion/claim/claim_031",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "For a log2 fold change of -1, the treatment induces a multiplicative change of 0.5 in gene expression level.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:source_excerpt": "For a particular gene, a log2 fold change of -1 for\n`condition treated vs untreated` means that the treatment\ninduces a multiplicative change in observed gene expression level of\n$2^{-1} = 0.5$ compared to the untreated condition.",
