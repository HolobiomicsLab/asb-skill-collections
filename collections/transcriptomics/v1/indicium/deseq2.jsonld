    {
      "@id": "asbval:assertion/skill/independent-filtering-multiple-testing-correction/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The read count K ij for gene i in sample j is described with a GLM of the negative binomial family with a logarithmic link: K ij \u223c NB ( mean = \u03bc ij , dispersion = \u03b1 i )",
      "asbval:note": "DESeq2 explicitly uses negative binomial GLMs as described in Methods section.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-014-0550-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "independent-filtering-multiple-testing-correction",
