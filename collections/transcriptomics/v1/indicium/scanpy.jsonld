      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "It includes methods for preprocessing, visualization, clustering, pseudotime and trajectory inference, differential expression testing, and simulation of gene regulatory networks.",
      "asbval:note": "Paper demonstrates preprocessing, clustering, and visualization (embedding) capabilities on standard datasets (PBMCs)",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
