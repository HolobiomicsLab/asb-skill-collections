    {
      "@id": "asbval:assertion/skill/single-cell-graph-construction-neighborhood/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SCANPY provides preprocessing comparable to SEURAT [10] and CELL RANGER [6], visualization through TSNE [11, 12], graph-drawing [13\u201315] and diffusion maps [11, 16, 17], clustering similar to PHENOGRAPH [18\u201320], identification of marker genes for clusters via differential expression tests and pseudotemporal ordering via diffusion pseudotime [21]",
      "asbval:note": "The paper describes the full workflow including preprocessing, graph-based methods, clustering, and trajectory inference, consistent with the scope description.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "single-cell-graph-construction-neighborhood",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have preprocessed single-cell RNA-seq data (normalized and dimensionality-reduced via PCA) and need to establish cell-to-cell connectivity for trajectory inference, clustering validation, or graph-based visualization.",
      "eco:evidence_type": {
