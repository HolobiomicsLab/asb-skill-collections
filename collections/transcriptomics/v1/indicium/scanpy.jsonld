    {
      "@id": "asbval:assertion/skill/anndata-object-manipulation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Its Python-based implementation efficiently deals with data sets of more than one million cells. ... SCANPY's Python-based implementation is easy to interface with advanced machine-learning packages, such as TENSORFLOW [9].",
