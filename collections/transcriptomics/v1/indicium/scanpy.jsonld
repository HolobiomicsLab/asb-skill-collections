    {
      "@id": "asbval:assertion/skill/anndata-object-manipulation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Along with Scanpy, we present AnnData, a generic class for handling annotated data matrices ( https://github.com/theislab/anndata ). ... a corresponding package ANNDATA\u2014which stores a data matrix with the most general annotations possible: annotations of observations (samples, cells) and variables (features, genes), and unstructured annotations.",
      "asbval:note": "Core claim directly supported by abstract and methods sections describing AnnData's purpose.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "anndata-object-manipulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Construct and manipulate annotated data matrices (AnnData objects) to store single-cell gene expression data alongside cluster assignments, metadata, and analysis results.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T17:59:47.817653+00:00",
      "sepio:credibility_status": {
