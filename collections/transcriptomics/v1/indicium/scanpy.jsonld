      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SCANPY introduces a class for representing a graph of neighborhood relations among data points... Typically, SCANPY's tools reuse a once-computed, single graph representation of data and hence, avoid the use of different, potentially inconsistent, and computationally expensive representations of data.",
      "asbval:note": "Paper describes graph abstraction and neighborhood representation suitable for downstream methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "trajectory-inference-preprocessing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This preprocessing step abstracts the high-dimensional cell-to-cell neighborhood structure into a coarse-grained partition graph suitable for downstream trajectory algorithms like PAGA",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
