      }
    },
    {
      "@id": "asbval:assertion/skill/anndata-object-manipulation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "It includes methods for preprocessing, visualization, clustering, pseudotime and trajectory inference, differential expression testing, and simulation of gene regulatory networks. ... All statistics and machine-learning tools extract information from a data matrix, which can be added to an ANNDATA object while leaving the structure of ANNDATA unaffected.",
      "asbval:note": "Paper demonstrates AnnData's role in storing results from multiple workflow stages.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "anndata-object-manipulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill enables flexible storage and retrieval of intermediate and final results across preprocessing, clustering, and differential expression workflows.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T17:59:47.817653+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
