      }
    },
    {
      "@id": "asbval:assertion/skill/single-cell-rna-seq-normalization/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Along with Scanpy, we present AnnData, a generic class for handling annotated data matrices ( https://github.com/theislab/anndata ). ... a corresponding package ANNDATA\u2014which stores a data matrix with the most general annotations possible: annotations of observations (samples, cells) and variables (features, genes), and unstructured annotations.",
      "asbval:note": "AnnData is confirmed as the data structure used with Scanpy for storing annotated data matrices.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "single-cell-rna-seq-normalization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "anndata (Data structure (AnnData object) that stores the expression matrix and metadata for normalized counts)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:04:16.145962+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/single-cell-rna-seq-normalization/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Its Python-based implementation efficiently deals with data sets of more than one million cells",
      "asbval:note": "Paper explicitly states Scanpy is Python-based.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "yes",
