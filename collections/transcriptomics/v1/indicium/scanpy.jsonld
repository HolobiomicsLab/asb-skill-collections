    {
      "@id": "asbval:assertion/skill/ci-pipeline-reproducibility-verification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SCANPY's and ANNDATA's open-source code are maintained on GITHUB (https://github.com/theislab/scanpy, https://github.com/theislab/anndata) and published under the BSD3 license. SCANPY and ANNDATA are released via the Python packaging index",
      "asbval:note": "Paper confirms Scanpy is a Python project with open-source code on GitHub and uses Python ecosystem tools (numpy, scipy, matplotlib, pandas, h5py, scikit-learn, etc.). However, the paper does NOT mention Hatch, pytest, CI workflows, or test suites. The card's research question assumes Scanpy uses Hatch and pytest, but the paper provides no evidence of these specific tools being used for testing or CI.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "ci-pipeline-reproducibility-verification",
