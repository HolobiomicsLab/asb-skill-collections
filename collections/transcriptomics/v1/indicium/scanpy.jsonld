    {
      "@id": "asbval:assertion/card/10_1186_s13059_017_1382_0__task_003/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "identification of marker genes for clusters via differential expression tests",
      "asbval:note": "Paper confirms Scanpy performs differential expression testing and marker gene identification. However, the paper does not specifically name the 'rank_genes_groups' function, the 'Wilcoxon test' parameter, or 'leiden' clustering. The paper mentions 'Louvain algorithm' for clustering (passage 3: 'Cells are clustered using the Louvain algorithm') and references diffusion pseudotime, but does not explicitly detail the rank_genes_groups function or Wilcoxon test specification.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_003",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Does Scanpy's rank_genes_groups function with Wilcoxon test produce marker gene rankings that match expected documentation examples when applied to leiden-clustered pbmc3k data?",
      "eco:evidence_type": {
