    {
      "@id": "asbval:assertion/skill/highly-variable-gene-selection/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SCANPY provides preprocessing comparable to SEURAT [10] and CELL RANGER [6], visualization through TSNE [11, 12], graph-drawing [13\u201315] and diffusion maps [11, 16, 17], clustering similar to PHENOGRAPH [18\u201320], identification of marker genes for clusters via differential expression tests and pseudotemporal ordering via diffusion pseudotime",
      "asbval:note": "Paper describes preprocessing capabilities including normalization and feature selection as part of SCANPY's workflow. The specific mention of 'highly variable genes' filtering is not explicitly named in passages, but variance-based gene selection is a standard preprocessing step in single-cell analysis frameworks that SCANPY implements.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "highly-variable-gene-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Identify and retain genes with high variance across single cells to reduce dimensionality while preserving biological signal",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
