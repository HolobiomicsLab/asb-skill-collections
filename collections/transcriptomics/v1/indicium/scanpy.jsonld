    {
      "@id": "asbval:assertion/skill/anndata-object-manipulation/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SCANPY provides preprocessing comparable to SEURAT [10] and CELL RANGER [6], visualization through TSNE [11, 12], graph-drawing [13\u201315] and diffusion maps [11, 16, 17], clustering similar to PHENOGRAPH [18\u201320], identification of marker genes for clusters via differential expression tests and pseudotemporal ordering via diffusion pseudotime [21]",
      "asbval:note": "Paper describes sequential workflow steps (preprocessing \u2192 clustering \u2192 differential expression \u2192 trajectory inference) but does not explicitly name 'leiden' or 'paga' in the provided passages; uses 'Louvain algorithm' and 'diffusion pseudotime' instead.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "anndata-object-manipulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
