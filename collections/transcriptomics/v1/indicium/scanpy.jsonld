    {
      "@id": "asbval:assertion/skill/memory-efficient-single-cell-computation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SCANPY's functions operate in-place by default but allow the optional non-destructive transformation of objects. Pipelines written this way can then also be run in backed mode to exploit online-learning formulations of algorithms.",
      "asbval:note": "Paper mentions 'backed mode' for memory-efficient operation via HDF5-backed AnnData objects, not Dask arrays. The paper does not mention Dask or dask.array.Array. The paper's 'backed mode' is a different mechanism (HDF5-based disk backing) than Dask lazy evaluation.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "memory-efficient-single-cell-computation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply lazy-evaluation preprocessing and analysis operations to Dask-backed AnnData objects to process large single-cell gene expression matrices without forcing the entire expression matrix into memory.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
