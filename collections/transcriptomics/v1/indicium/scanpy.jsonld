    {
      "@id": "asbval:assertion/card/10_1186_s13059_017_1382_0__task_002/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To simplify memory-efficient pipelines, SCANPY's functions operate in-place by default but allow the optional non-destructive transformation of objects. Pipelines written this way can then also be run in backed mode to exploit online-learning formulations of algorithms.",
      "asbval:note": "Paper confirms SCANPY supports 'backed mode' for memory-efficient operation and mentions HDF5-backed ANNDATA objects, but does not specifically mention Dask-backed arrays. The paper discusses HDF5-based backing, not Dask array support.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_002",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Can preprocessing functions in the scanpy pp module operate on Dask-backed AnnData objects without eagerly loading the entire expression matrix into memory?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T17:57:00.808059+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/card/10_1186_s13059_017_1382_0__task_002/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ANNDATA is similar to R's EXPRESSIONSET [26], but supports sparse data and allows HDF5-based backing of ANNDATA objects on disk, a format independent of platform, framework, and language. This allows operating on an ANNDATA object without fully loading it into memory\u2014the functionality is offered via ANNDATA's backed mode as opposed to its memory mode.",
      "asbval:note": "Paper confirms sparse data support and HDF5-backed mode for memory-efficient operation without full materialization, but does not mention Dask-backed structures specifically.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_002",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "AnnData object with processed expression data, retaining Dask-backed or sparse structure without full materialization",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T17:57:00.808059+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
