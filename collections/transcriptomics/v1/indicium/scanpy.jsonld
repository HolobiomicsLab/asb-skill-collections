    {
      "@id": "asbval:assertion/skill/anndata-object-structure-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Along with Scanpy, we present AnnData, a generic class for handling annotated data matrices... SCANPY's functions operate in-place by default but allow the optional non-destructive transformation of objects. Pipelines written this way can then also be run in backed mode to exploit online-learning formulations of algorithms.",
      "asbval:note": "Paper confirms AnnData structure, in-place operations, and backed mode (HDF5-based backing), but does NOT mention Dask-backed arrays specifically. Paper discusses HDF5 backing and online-learning, not Dask lazy evaluation. Dask is not mentioned anywhere in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "anndata-object-structure-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate that an AnnData object retains correct structure and dimensional integrity after preprocessing operations, particularly when using lazy evaluation with Dask-backed arrays.",
