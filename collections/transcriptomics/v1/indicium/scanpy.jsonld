      "@id": "asbval:assertion/skill/memory-efficient-single-cell-computation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Along with SCANPY, we present ANNDATA, a generic class for handling annotated data matrices. ANNDATA is similar to R's EXPRESSIONSET, but supports sparse data and allows HDF5-based backing of ANNDATA objects on disk, a format independent of platform, framework, and language. This allows operating on an ANNDATA object without fully loading it into memory\u2014the functionality is offered via ANNDATA's backed mode as opposed to its memory mode.",
      "asbval:note": "Paper confirms AnnData supports memory-efficient operations via HDF5-backed mode, not Dask arrays. No mention of Dask array support in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "memory-efficient-single-cell-computation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "anndata \u2014 Data structure for storing single-cell expression matrices and metadata; natively supports Dask arrays as the X attribute for lazy evaluation",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
