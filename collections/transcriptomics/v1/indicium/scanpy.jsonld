    {
      "@id": "asbval:assertion/skill/leiden-clustering-of-cells/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SCANPY provides preprocessing comparable to SEURAT [10] and CELL RANGER [6], visualization through TSNE [11, 12], graph-drawing [13\u201315] and diffusion maps [11, 16, 17], clustering similar to PHENOGRAPH [18\u201320], identification of marker genes for clusters via differential expression tests and pseudotemporal ordering via diffusion pseudotime [21]",
      "asbval:note": "Paper mentions clustering via PHENOGRAPH and graph-based methods as core of SCANPY, but does not explicitly name the Leiden algorithm. The paper references the Louvain clustering package [41] as a dependency. Leiden is a successor to Louvain but is not mentioned by name in the provided passages. The functional capability (clustering on kNN graphs without specifying cluster count) is present, but the specific algorithm name (Leiden) is not confirmed in these passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "leiden-clustering-of-cells",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply the Leiden community detection algorithm to a k-nearest neighbor (kNN) graph of single-cell transcriptomes to partition cells into discrete clusters without requiring a priori specification of cluster number.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
