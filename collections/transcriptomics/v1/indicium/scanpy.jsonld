      }
    },
    {
      "@id": "asbval:assertion/skill/dask-array-lazy-evaluation-verification/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Along with SCANPY, we present ANNDATA, a generic class for handling annotated data matrices... ANNDATA is similar to R's EXPRESSIONSET [26], but supports sparse data and allows HDF5-based backing of ANNDATA objects on disk... This allows operating on an ANNDATA object without fully loading it into memory\u2014the functionality is offered via ANNDATA's backed mode as opposed to its memory mode.",
      "asbval:note": "The paper confirms AnnData supports memory-efficient backing via HDF5, not Dask. The card claims Dask-backed support, but the paper only documents HDF5-backed mode for lazy evaluation.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "dask-array-lazy-evaluation-verification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "anndata - Data structure (AnnData) that can wrap Dask-backed expression matrices",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:00:34.351780+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
