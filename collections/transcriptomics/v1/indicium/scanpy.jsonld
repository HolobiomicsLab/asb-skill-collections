    {
      "@id": "asbval:assertion/skill/single-cell-graph-construction-neighborhood/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Typically, SCANPY's tools reuse a once-computed, single graph representation of data and hence, avoid the use of different, potentially inconsistent, and computationally expensive representations of data.",
      "asbval:note": "The paper confirms that graph construction is a prerequisite for downstream tools, but PAGA is not mentioned in the passages. The general principle of graph-based prerequisites is supported.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-017-1382-0",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "single-cell-graph-construction-neighborhood",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Specifically required as a prerequisite step before running partition-based graph abstraction (PAGA) or other neighborhood-dependent algorithms.",
      "eco:evidence_type": {
