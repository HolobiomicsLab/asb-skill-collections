    {
      "@id": "asbval:assertion/skill/bioinformatics-tool-version-compatibility-assessment/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "HiC-Pro proposes a fast sparse-based implementation of the iterative correction method [17], allowing normalization of genome-wide high-resolution contact matrices in a short time and with reasonable memory requirements. The code for the normalization is available as a standalone package (https://github.com/hiclib/iced) as well as being included in HiC-Pro.",
      "asbval:note": "Paper confirms iced is available as a standalone package and is included in HiC-Pro, but does not specify the version constraints (python \u22652.7, numpy \u22651.16, scipy \u22650.19, sklearn, pandas). The paper does not explicitly state that iced 'must be independently installed' \u2014 it is included in HiC-Pro.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-015-0831-x",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "bioinformatics-tool-version-compatibility-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "iced, role: ICE normalization of Hi-C contact maps; requires python \u22652.7, numpy \u22651.16, scipy \u22650.19, sklearn, pandas; must be independently installed",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:42.120264+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
