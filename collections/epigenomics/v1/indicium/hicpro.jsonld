    {
      "@id": "asbval:assertion/skill/system-dependency-version-checking/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The following additional software and libraries are required: the bowtie2 mapper [26], R and the BioConductor packages RColorBrewer, ggplot2, grid, Samtools (>0.1.19), Python (>2.7) with the pysam, bx.python, numpy and scipy libraries, and the g++ compiler. Note that a bowtie2 version > 2.2.2 is strongly recommended for allele-specific analysis, because, since this version, read alignment on an N-masked genome has been highly improved. Most of the installation steps are fully automatic using a simple command line. The bowtie2 and Samtools software are automatically downloaded and installed if not detected on the system.",
      "asbval:note": "Paper confirms automatic installation of bowtie2 and samtools if not detected, and version requirements for bowtie2 (>2.2.2 for allele-specific analysis) and samtools (>0.1.19). However, the paper does NOT mention automatic version checking or installation for R or Python themselves\u2014only that they are required. The card claims automatic installation of 'missing or outdated tools' but the paper only states automatic download/install 'if not detected', not version validation and upgrade. This is a partial match: the function exists but is narrower than claimed.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-015-0831-x",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "system-dependency-version-checking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Detect and validate installed dependency binaries (bowtie2, samtools, R, Python) against minimum version requirements, and automatically install missing or outdated tools to ensure pipeline environment compatibility.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:15:38.656007+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/system-dependency-version-checking/001",
