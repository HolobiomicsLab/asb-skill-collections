      }
    },
    {
      "@id": "asbval:assertion/card/10_1186_s13059_015_0831_x__task_001/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "No mention of a 'config-system.txt' file in the passages. The paper mentions 'a single configuration file' where 'Analysis parameters are all defined' but does not name it or describe it as containing resolved paths to binaries.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-015-0831-x",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "task_001",
