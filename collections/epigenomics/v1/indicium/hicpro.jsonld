    {
      "@id": "asbval:assertion/skill/python-environment-management/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "HiC-Pro is an optimized and flexible pipeline for processing Hi-C data from raw reads to normalized contact maps... The user can easily run the complete analysis workflow with a single command line either on a single laptop or on a computer cluster. Analysis parameters are all defined in a single configuration file.",
      "asbval:note": "Paper confirms HiC-Pro requires Python environment setup and can be run on various computational platforms.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-015-0831-x",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "python-environment-management",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use this skill at the start of any HiC-Pro pipeline execution or when setting up a new computational environment for Hi-C analysis",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:14:29.339678+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/python-environment-management/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "HiC-Pro proposes a fast sparse-based implementation of the iterative correction method [17], allowing normalization of genome-wide high-resolution contact matrices... The code for the normalization is available as a standalone package (https://github.com/hiclib/iced) as well as being included in HiC-Pro.",
      "asbval:note": "Paper confirms iced is available as standalone package and used for iterative correction normalization.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-015-0831-x",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "python-environment-management",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "iced - ICE normalization of Hi-C contact matrices; must be independently installed and imported into Python environment",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
