    },
    {
      "@id": "asbval:assertion/skill/module-import-and-api-verification/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The code for the normalization is available as a standalone package (https://github.com/hiclib/iced) as well as being included in HiC-Pro.",
      "asbval:note": "Paper states iced is available as standalone package AND included in HiC-Pro, contradicting the claim that it is 'no longer bundled'. The paper does not indicate whether bundling was removed in later versions.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-015-0831-x",
