    {
      "@id": "asbval:assertion/skill/module-import-and-api-verification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The code for the normalization is available as a standalone package (https://github.com/hiclib/iced) as well as being included in HiC-Pro.",
      "asbval:note": "Paper confirms iced is a standalone package and normalization component, but does not explicitly discuss module import verification or API validation as a pre-pipeline step. The paper describes iced as part of the normalization workflow but not the validation/verification task itself.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-015-0831-x",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "module-import-and-api-verification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate that required Python modules (e.g., iced for Hi-C ICE normalization) are correctly installed, importable, and expose the expected API before downstream pipeline steps depend on them.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
