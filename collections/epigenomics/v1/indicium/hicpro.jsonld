    {
      "@id": "asbval:assertion/skill/dependency-installation-and-verification/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "HiC-Pro is organized into four distinct modules following the main steps of Hi-C data analysis: (i) read alignment, (ii) detection and filtering of valid interaction products, (iii) binning and (iv) contact map normalization (Fig. 3). Most of the installation steps are fully automatic using a simple command line.",
      "asbval:note": "Paper describes the multi-stage pipeline and automatic installation at initialization, consistent with the scope claim.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13059-015-0831-x",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "dependency-installation-and-verification",
      "asbval:target_artifact_kind": "skill_bundle",
