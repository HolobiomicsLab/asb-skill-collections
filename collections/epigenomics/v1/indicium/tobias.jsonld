    {
      "@id": "asbval:assertion/skill/chromatin-accessibility-binding-status-classification/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS (Transcription factor Occupancy prediction By Investigation of ATAC-seq Signal), a comprehensive computational framework that we created for footprinting analysis... TOBIAS is a collection of command-line tools utilizing a minimal input of ATAC-seq reads, TF motifs and genome information to perform all levels of footprinting analysis.",
      "asbval:note": "TOBIAS is confirmed as a comprehensive framework with command-line tools for ATAC-seq footprinting analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chromatin-accessibility-binding-status-classification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TOBIAS: collection of command-line bioinformatics tools for performing footprinting analysis on ATAC-seq data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:20:34.940646+00:00",
      "sepio:credibility_status": {
