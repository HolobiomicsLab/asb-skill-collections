    {
      "@id": "asbval:assertion/skill/motif-site-occupancy-comparison/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "bound TFs hinder cleavage of DNA, resulting in defined regions of decreased signal strength within larger regions of high signal \u2014 known as footprints. Surprisingly, although this concept shows considerable potential to survey genome-wide binding of multiple TFs in parallel from a single experiment",
      "asbval:note": "The mechanism of footprint detection via Tn5 depletion is clearly described.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
