    {
      "@id": "asbval:assertion/skill/nucleotide-footprint-pattern-recognition/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "While footprinting analysis of ATAC-seq data can theoretically enable investigation of transcription factor (TF) binding... DGF is a computational analysis of chromatin accessibility assays such as ATAC-seq, which employs DNA effector enzymes that only cut accessible DNA regions. Similarly to nucleosomes, bound TFs hinder cleavage of DNA, resulting in defined regions of decreased signal strength within larger regions of high signal \u2014 known as footprints",
      "asbval:note": "Core research question is directly supported by paper's conceptual framing of footprinting.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "nucleotide-footprint-pattern-recognition",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Identify and quantify transcription factor occupancy by detecting the characteristic depletion of Tn5 insertion signals around protein-bound DNA motifs in ATAC-seq data.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:22:39.273536+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/nucleotide-footprint-pattern-recognition/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The TOBIAS bias correction module (named ATACorrect) utilizes a dinucleotide weight matrix (DWM) to estimate the background bias of the Tn5 transposase... Subtracting these expected cuts from the uncorrected signals yields a corrected track, highlighting the effect of protein binding",
      "asbval:note": "ATACorrect is explicitly named and its function matches the card claim.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "nucleotide-footprint-pattern-recognition",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TOBIAS ATACorrect \u2014 Correct Tn5 insertion bias in ATAC-seq BAM files to produce bias-corrected cut-site signal suitable for footprint detection",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:22:39.273536+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/nucleotide-footprint-pattern-recognition/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The corrected cutsites enable calculation of footprint scores with a scoring function taking into account both the accessibility and depth of the local footprint",
      "asbval:note": "Paper describes footprint score calculation but does not explicitly name a tool called 'ScoreBigwig'. The function is performed within TOBIAS but the specific module name is not confirmed in passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "nucleotide-footprint-pattern-recognition",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TOBIAS ScoreBigwig \u2014 Calculate footprint scores from bias-corrected cut-site signals at transcription factor binding sites",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:22:39.273536+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/nucleotide-footprint-pattern-recognition/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This continuous footprint score is correlated with the presence of transcription factor binding sites in the genome, and a threshold is set to distinguish between bound and unbound sites... the differential binding module summarizes individual site scores for each TF, and compares them between conditions",
      "asbval:note": "Paper describes the function of bound/unbound classification and differential binding but does not explicitly name a module called 'BINDetect' in the provided passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "nucleotide-footprint-pattern-recognition",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TOBIAS BINDetect \u2014 Estimate bound versus unbound transcription factor binding sites and detect differential binding based on footprint scores and motif sequences",
      "eco:evidence_type": {
