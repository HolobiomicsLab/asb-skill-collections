      }
    },
    {
      "@id": "asbval:assertion/skill/genomic-region-annotation-integration/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The corrected cutsites enable calculation of footprint scores with a scoring function taking into account both the accessibility and depth of the local footprint... This continuous footprint score is correlated with the presence of transcription factor binding sites in the genome, and a threshold is set to distinguish between bound and unbound sites.",
      "asbval:note": "Claim accurately describes the footprint scoring process: converting bias-corrected signal into scores that measure depletion and accessibility at base-pair resolution.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "genomic-region-annotation-integration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill converts bias-corrected ATAC-seq insertion signal into footprint scores by measuring Tn5 insertion depletion patterns within accessible chromatin regions. It quantifies the magnitude of transcription factor binding footprints at base-pair resolution for downstream diff",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:22:05.395624+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/genomic-region-annotation-integration/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The TOBIAS bias correction module (named ATACorrect) utilizes a dinucleotide weight matrix (DWM) to estimate the background bias of the Tn5 transposase... Subtracting these expected cuts from the uncorrected signals yields a corrected track, highlighting the effect of protein binding",
      "asbval:note": "ATACorrect is explicitly named and described as the bias correction module within TOBIAS.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
