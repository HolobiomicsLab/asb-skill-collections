    {
      "@id": "asbval:assertion/skill/tn5-insertion-position-extraction-and-counting/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we present TOBIAS, a comprehensive, accurate, and fast footprinting framework enabling genome-wide investigation of TF binding dynamics for hundreds of TFs simultaneously... TOBIAS is a collection of command-line tools utilizing a minimal input of ATAC-seq reads, TF motifs and genome information (Fig. 1b) to perform all levels of footprinting analysis including bias correction (Fig. 1c), footprinting (Fig. 1d), and comparison between conditions (Fig. 1e).",
      "asbval:note": "TOBIAS is explicitly described as a comprehensive framework and collection of command-line tools for ATAC-seq footprinting analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tn5-insertion-position-extraction-and-counting",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TOBIAS (general) - collection of command-line bioinformatics tools for performing footprinting analysis on ATAC-seq data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:23:55.038774+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/tn5-insertion-position-extraction-and-counting/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS is a collection of command-line tools utilizing a minimal input of ATAC-seq reads, TF motifs and genome information (Fig. 1b) to perform all levels of footprinting analysis... The corrected cutsites enable calculation of footprint scores with a scoring function taking into account both the accessibility and depth of the local footprint.",
      "asbval:note": "The scope accurately describes the input requirements (ATAC-seq BAM files, genomic coordinates/TF motifs) and the goal (quantifying Tn5 cleavage spatial distribution).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tn5-insertion-position-extraction-and-counting",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have ATAC-seq BAM files and a set of genomic coordinates (e.g., transcription factor motif sites, peak regions) and need to quantify the spatial distribution of Tn5 cleavage events relative to those coordinates.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:23:55.038774+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/tn5-insertion-position-extraction-and-counting/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recent advances have enabled the application of ATAC-seq in single cells, but this generates sparse matrices, rendering footprinting approaches on single cells elusive. However, we speculate that by creating aggregated pseudo-bulk signals from large clustered single-cell ATAC datasets, DGF analysis might also become possible in single cells.",
      "asbval:note": "The paper explicitly acknowledges that single-cell ATAC-seq without aggregation is problematic for footprinting due to sparsity, supporting the 'when NOT to use' guidance.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tn5-insertion-position-extraction-and-counting",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Input is single-cell ATAC-seq without pseudobulk aggregation; raw single-cell resolution lacks sufficient signal depth for reliable footprint detection without cell clustering and aggregation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:23:55.038774+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
