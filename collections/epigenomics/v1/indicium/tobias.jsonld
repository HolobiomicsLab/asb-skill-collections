      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill detects which transcription factors show altered chromatin occupancy between conditions by leveraging the visible depletion of Tn5 insertions around protein-bound sites.",
      "eco:evidence_type": {
