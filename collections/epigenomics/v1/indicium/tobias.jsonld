      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TOBIAS PlotAggregate - Aggregate and visualize insertion count distributions across multiple sites to display footprint profiles and validate extraction results",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
