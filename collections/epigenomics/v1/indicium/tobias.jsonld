    {
      "@id": "asbval:assertion/skill/transcription-factor-footprint-scoring/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS is a comprehensive computational framework that we created for footprinting analysis... to perform all levels of footprinting analysis including bias correction, footprinting, and comparison between conditions. The corrected cutsites enable calculation of footprint scores with a scoring function taking into account both the accessibility and depth of the local footprint.",
      "asbval:note": "Research question accurately describes the core functionality of TOBIAS footprinting pipeline.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcription-factor-footprint-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute genome-wide footprint enrichment scores from bias-corrected ATAC-seq signal to quantify transcription factor occupancy at regulatory sites. This skill detects the characteristic depletion of Tn5 insertions around protein-bound DNA regions and enables comparative analysis ",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:24:33.878221+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/transcription-factor-footprint-scoring/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The TOBIAS bias correction module (named ATACorrect) utilizes a dinucleotide weight matrix (DWM) to estimate the background bias of the Tn5 transposase... Subtracting these expected cuts from the uncorrected signals yields a corrected track, highlighting the effect of protein binding.",
      "asbval:note": "ATACorrect is explicitly named and described as the bias correction module within TOBIAS.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcription-factor-footprint-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TOBIAS ATACorrect \u2014 upstream step: corrects Tn5 insertion bias in ATAC-seq BAM files to produce clean signal tracks required for footprint scoring",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:24:33.878221+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
