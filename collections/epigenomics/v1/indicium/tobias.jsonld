    {
      "@id": "asbval:assertion/card/10_1038_s41467_020_18035_1__task_002/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The corrected cutsites enable calculation of footprint scores with a scoring function taking into account both the accessibility and depth of the local footprint",
      "asbval:note": "The paper confirms that TOBIAS produces footprint scores at genomic positions (evidenced by footprint score tracks shown in figures and described in methods). However, the paper does not explicitly name the output file format as 'bigWig'. The paper mentions 'TOBIAS output tracks' loaded into IGV and UCSC track hubs, which are compatible with bigWig format, but the specific file format is not explicitly stated in the passages provided.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_002",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "Scored bigWig file with footprint scores at each genomic position",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:16:17.396369+00:00",
      "sepio:credibility_status": {
