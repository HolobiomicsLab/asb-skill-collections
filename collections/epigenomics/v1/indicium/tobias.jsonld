    {
      "@id": "asbval:assertion/card/10_1038_s41467_020_18035_1__task_003/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS is a comprehensive computational framework that we created for footprinting analysis... to perform all levels of footprinting analysis including bias correction, footprinting, and comparison between conditions. The corrected cutsites enable calculation of footprint scores with a scoring function taking into account both the accessibility and depth of the local footprint... This continuous footprint score is correlated with the presence of transcription factor binding sites in the genome, and a threshold is set to distinguish between bound and unbound sites.",
      "asbval:note": "Research question is directly supported by the paper's description of TOBIAS methodology for identifying TF occupancy via footprint analysis across conditions.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_003",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "How does TOBIAS identify transcription factor occupancy at specific genomic locations by analyzing ATAC-seq footprint patterns across different conditions?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:16:27.588398+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
