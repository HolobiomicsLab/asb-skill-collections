      }
    },
    {
      "@id": "asbval:assertion/card/10_1038_s41467_020_18035_1__task_002/scope_drift",
      "@type": "asbval:ScopeDriftAssertion",
      "asbval:drift_notes": [
        "The card focuses narrowly on the footprint scoring computational step. The paper's scope is broader\u2014it presents TOBIAS as a comprehensive framework covering bias correction, footprinting, differential binding analysis, and downstream visualization. The card's research question is well-aligned with one component of the paper's work.",
        "The card does not mention bias correction (ATACorrect module), which is a prerequisite step described in the paper before footprint scoring. The paper emphasizes that bias correction is critical for accurate footprint visibility."
      ],
      "asbval:n_drift_notes": 2,
      "asbval:target_artifact_id": "task_002",
      "asbval:target_artifact_kind": "card",
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:16:17.396369+00:00",
      "sepio:credibility_status": {
