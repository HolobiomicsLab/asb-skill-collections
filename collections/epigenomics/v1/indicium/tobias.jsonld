    {
      "@id": "asbval:assertion/skill/tf-binding-site-classification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS is a collection of command-line tools utilizing a minimal input of ATAC-seq reads, TF motifs and genome information (Fig. 1b) to perform all levels of footprinting analysis including bias correction (Fig. 1c), footprinting (Fig. 1d), and comparison between conditions (Fig. 1e)... This continuous footprint score is correlated with the presence of transcription factor binding sites in the genome, and a threshold is set to distinguish between bound and unbound sites.",
      "asbval:note": "Core claim supported: footprint scores are used to classify binding sites as bound/unbound; differential binding comparison across conditions is explicitly described.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tf-binding-site-classification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Classify transcription factor binding sites as bound or unbound by comparing footprint depletion scores at known motif locations across ATAC-seq conditions, using TOBIAS BINDetect to generate per-motif occupancy predictions and differential binding metrics.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:23:20.689742+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/tf-binding-site-classification/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS is a collection of command-line tools... to perform all levels of footprinting analysis including bias correction (Fig. 1c), footprinting (Fig. 1d), and comparison between conditions (Fig. 1e). Furthermore, TOBIAS includes a variety of auxiliary tools such as TF network inference and visualization of footprints",
      "asbval:note": "Paper describes TOBIAS as performing footprinting and differential binding analysis, but does not explicitly name a subcommand called 'BINDetect'. The paper refers to the overall framework and its modules (ATACorrect, footprinting module, differential binding module) but the specific tool name 'BINDetect' is not mentioned in the provided passages. The function is present but the tool name may be inaccurate or from supplementary methods not provided.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "tf-binding-site-classification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TOBIAS BINDetect \u2014 Core tool for computing binding occupancy predictions from footprint scores and motif matches; outputs per-motif occupancy table and differential binding statistics",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:23:20.689742+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/tf-binding-site-classification/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The corrected cutsites enable calculation of footprint scores with a scoring function taking into account both the accessibility and depth of the local footprint",
      "asbval:note": "Paper describes footprint score calculation from corrected cutsites, but does not explicitly name a tool called 'ScoreBigwig'. The function (converting corrected cutsites to footprint scores) is present in TOBIAS, but the specific subcommand name is not confirmed in provided passages.",
