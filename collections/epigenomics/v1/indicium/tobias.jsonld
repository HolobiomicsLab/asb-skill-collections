      "@id": "asbval:assertion/skill/differential-tf-occupancy-analysis/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To demonstrate the potential of TOBIAS to predict differential TF binding across multiple conditions, in particular in the investigation of processes involving only few cells, we analyzed a series of ATAC-seq datasets derived from both human and murine preimplantation embryos at different developmental stages... TOBIAS was used to calculate footprint scores for a list of 590 and 464 individual TFs across the entire process of PD of human and mouse embryos, respectively.",
      "asbval:note": "The paper demonstrates exactly this use case: comparing TF binding across multiple developmental timepoints using ATAC-seq data.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "differential-tf-occupancy-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have aligned ATAC-seq BAM files and peak annotations from two or more experimental conditions and want to discover which transcription factors show statistically significant changes in chromatin binding occupancy between those conditions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:21:48.774766+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/differential-tf-occupancy-analysis/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "If multiple conditions are investigated, the differential binding module summarizes individual site scores (upper black box) for each TF, and compares them between conditions (gray/red curve center) in order to define differentially bound TFs.",
      "asbval:note": "The paper explicitly states that differential analysis requires multiple conditions, consistent with the scope statement.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "differential-tf-occupancy-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input is single-condition ATAC-seq data with no biological replicate or comparison group \u2014 differential analysis requires at least two conditions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
