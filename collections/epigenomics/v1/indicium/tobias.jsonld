    {
      "@id": "asbval:assertion/skill/transcription-factor-motif-genomic-coordinate-annotation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS is a collection of command-line tools utilizing a minimal input of ATAC-seq reads, TF motifs and genome information (Fig. 1b) to perform all levels of footprinting analysis including bias correction (Fig. 1c), footprinting (Fig. 1d), and comparison between conditions (Fig. 1e)... This continuous footprint score is correlated with the presence of transcription factor binding sites in the genome, and a threshold is set to distinguish between bound and unbound sites.",
      "asbval:note": "Core research question is directly supported by paper's description of TOBIAS functionality.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcription-factor-motif-genomic-coordinate-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Assign genomic coordinates to transcription factor binding motifs using public sequence databases and classify them as bound or unbound based on chromatin accessibility thresholds.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:24:47.567639+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/transcription-factor-motif-genomic-coordinate-annotation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The TOBIAS bias correction module (named ATACorrect) utilizes a dinucleotide weight matrix (DWM) to estimate the background bias of the Tn5 transposase (Fig. 1c). This DWM is used to calculate an expected Tn5 signal for each genomic region, representing the influence of the Tn5 bias.",
      "asbval:note": "ATACorrect is explicitly named and its role in Tn5 bias correction is confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcription-factor-motif-genomic-coordinate-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TOBIAS ATACorrect \u2014 Corrects Tn5 insertion bias in ATAC-seq cutsite signal",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:24:47.567639+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
