    {
      "@id": "asbval:assertion/skill/transcription-factor-binding-depletion-quantification/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS utilizes a minimal input of ATAC-seq reads, TF motifs and genome information... to perform all levels of footprinting analysis including bias correction... footprinting... The corrected cutsites enable calculation of footprint scores",
      "asbval:note": "Scope accurately reflects the workflow: bias correction followed by footprint scoring on defined genomic regions (motif sites, peaks).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcription-factor-binding-depletion-quantification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill after bias-correcting ATAC-seq cutsite signal (using ATACorrect or equivalent) when you have a set of genomic regions of interest (e.g., ATAC-seq peaks, called footprints, or motif sites) and need to quantify the strength of transcription factor binding footprint",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:24:15.087029+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/transcription-factor-binding-depletion-quantification/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Strikingly, we observed that these defined footprints were not detectable without TOBIAS-mediated Tn5 bias correction... This demonstrates that bias correction effectively uncovers TF footprints, which were otherwise superimposed by Tn5 bias.",
      "asbval:note": "Paper demonstrates that bias correction is essential; footprints are not detectable without it.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcription-factor-binding-depletion-quantification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input ATAC-seq signal has not been corrected for Tn5 sequence bias\u2014apply ATACorrect first",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:24:15.087029+00:00",
      "sepio:credibility_status": {
