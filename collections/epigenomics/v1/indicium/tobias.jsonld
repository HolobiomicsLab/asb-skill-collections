    {
      "@id": "asbval:assertion/skill/motif-site-occupancy-comparison/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS is a comprehensive computational framework that we created for footprinting analysis... to perform all levels of footprinting analysis including bias correction, footprinting, and comparison between conditions. Furthermore, TOBIAS includes a variety of auxiliary tools such as TF network inference and visualization of footprints",
      "asbval:note": "The paper explicitly describes differential footprinting across multiple conditions as a core capability of TOBIAS.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "motif-site-occupancy-comparison",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compare transcription factor occupancy at known motif binding sites across two or more ATAC-seq conditions by applying footprint scoring and differential binding detection.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
