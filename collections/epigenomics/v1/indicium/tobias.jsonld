    {
      "@id": "asbval:assertion/skill/tf-binding-site-classification/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS is a collection of command-line tools utilizing a minimal input of ATAC-seq reads, TF motifs and genome information (Fig. 1b) to perform all levels of footprinting analysis including bias correction (Fig. 1c), footprinting (Fig. 1d), and comparison between conditions (Fig. 1e)... TF motifs were downloaded from JASPAR CORE 2018, the JASPAR PBM HOMEO collection and Hocomoco V11 databases.",
      "asbval:note": "Scope description aligns with paper's workflow: ATAC-seq input, bias correction, footprint scoring, motif matching, and differential binding across conditions are all confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tf-binding-site-classification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have aligned ATAC-seq BAM files, corrected Tn5 insertion bias and computed footprint scores (via TOBIAS ATACorrect and ScoreBigwig), a motif database in JASPAR or compatible format, and you need to assign occupancy states (bound/unbound) and confidence scores at specific TF b",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
