      }
    },
    {
      "@id": "asbval:assertion/skill/transcription-factor-binding-depletion-quantification/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DGF is a computational analysis of chromatin accessibility assays such as ATAC-seq, which employs DNA effector enzymes that only cut accessible DNA regions... the influence of Tn5 transposase bias in the context of ATAC-seq footprinting",
      "asbval:note": "Paper emphasizes that TOBIAS is designed for ATAC-seq (Tn5-based) assays and that Tn5 bias is specific to ATAC-seq, implying inapplicability to other assays.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "transcription-factor-binding-depletion-quantification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input regions are from a different assay (DNase-seq, ChIP-seq, MNase-seq) that do not exhibit Tn5 insertion bias patterns",
