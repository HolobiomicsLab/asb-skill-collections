    {
      "@id": "asbval:assertion/skill/chromatin-accessibility-quantification/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "As it has been shown that the Tn5 transposase has a large effect on footprinting, the first step of the TOBIAS footprinting pipeline is Tn5 bias correction... This demonstrates that failure to correct for Tn5 bias can lead to false negative footprints, while bias correction uncovers the true amount of measurable footprints to be above 50%.",
      "asbval:note": "The paper emphasizes the importance of Tn5 bias correction as a critical first step in the TOBIAS pipeline.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chromatin-accessibility-quantification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it when you need to account for Tn5 transposase sequence preference bias before downstream footprinting or regulatory region analysis",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:21:32.626277+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/chromatin-accessibility-quantification/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The skepticism towards DGF has been driven by the discovery that enzymes used in chromatin accessibility assays (e.g., DNase-I) are biased towards certain sequence compositions... The influence of Tn5 transposase bias in the context of ATAC-seq footprinting has, however, only been described very recently and still represents an uncertainty during discovery of true footprints.",
      "asbval:note": "The paper distinguishes between DNase-seq bias and Tn5 bias, confirming that TOBIAS is specific to Tn5-based ATAC-seq assays.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chromatin-accessibility-quantification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "DNase-seq or MNase-seq data: this skill is specific to Tn5 transposase-based assays and will not correctly model biases from alternative nucleases.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:21:32.626277+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
