        "@id": "http://purl.obolibrary.org/obo/ECO_0000302"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:23:20.689742+00:00",
