      }
    },
    {
      "@id": "asbval:assertion/skill/tf-binding-site-classification/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Passages do not discuss minimum read depth requirements or single-end vs. paired-end ATAC-seq considerations for TOBIAS.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "null",
      "asbval:target_artifact_id": "tf-binding-site-classification",
