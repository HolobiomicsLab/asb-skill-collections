    {
      "@id": "asbval:assertion/skill/chromatin-accessibility-occupancy-prediction/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Similarly to nucleosomes, bound TFs hinder cleavage of DNA, resulting in defined regions of decreased signal strength within larger regions of high signal \u2014 known as footprints. Surprisingly, although this concept shows considerable potential to survey genome-wide binding of multiple TFs in parallel from a single experiment, DGF analysis is rarely applied when investigating TF binding mechanisms.",
      "asbval:note": "The paper describes footprints as depletion of signal due to TF binding and the use of motifs to identify TF binding sites, which matches the scope statement.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chromatin-accessibility-occupancy-prediction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it specifically when you observe visible Tn5 insertion depletion (footprints) around regulatory regions and need to map those patterns to known TF motifs.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:21:13.871068+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
