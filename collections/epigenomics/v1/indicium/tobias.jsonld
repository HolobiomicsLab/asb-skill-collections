      }
    },
    {
      "@id": "asbval:assertion/skill/atac-seq-bam-read-alignment-processing/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The TOBIAS bias correction module (named ATACorrect) utilizes a dinucleotide weight matrix (DWM) to estimate the background bias of the Tn5 transposase (Fig. 1c). This DWM is used to calculate an expected Tn5 signal for each genomic region, representing the influence of the Tn5 bias (Fig. 1c; expected cutsites). Subtracting these expected cuts from the uncorrected signals yields a corrected track, highlighting the effect of protein binding.",
      "asbval:note": "ATACorrect is explicitly named and described as the bias correction module within TOBIAS that corrects Tn5 transposase bias.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "atac-seq-bam-read-alignment-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TOBIAS ATACorrect - Corrects Tn5 insertion bias in cut-site signal before position aggregation to improve footprint detection accuracy",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:19:00.569455+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/atac-seq-bam-read-alignment-processing/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not mention a tool named 'ScoreBigwig'. The paper describes footprint score calculation as part of the TOBIAS framework (Fig. 1d: 'Calculation of footprint scores'), but does not name a specific module called 'ScoreBigwig'. The footprinting step is described generically without reference to this specific tool name.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
