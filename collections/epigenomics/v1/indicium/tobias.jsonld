    {
      "id": "claim_003",
      "context": "explicit",
      "subject": "explicit",
      "qualifier": "consistent_with",
      "relation": "describes",
      "object": "The local distribution of Tn5 insertions contains information about transcription factor binding due to visible depletion of insertions around sites bound by protein, known as footprints.",
      "asserted_by": "doi:10.1038/s41467-020-18035-1",
      "@type": "asb:Claim",
      "source_task_kind_status": "ambiguous_multi_kind"
    },
    {
      "@type": "sepio:0000002",
      "id": "claim_003_evidence",
      "evidence_for": "claim_003",
      "text_selector": {
        "@type": "oa:TextQuoteSelector",
