      }
    },
    {
      "@id": "asbval:assertion/skill/chromatin-accessibility-footprint-visualization/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Individual gene views were generated by loading TOBIAS output tracks into IGV version 2.6.2 or using the TOBIAS Plot Tracks module, which is a wrapper for the svist4get visualization tool.",
