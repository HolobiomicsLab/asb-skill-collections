      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "ATACorrect \u2014 Bias-correct raw ATAC-seq cutsite signal prior to footprint scoring",
      "eco:evidence_type": {
