    {
      "@id": "asbval:assertion/skill/atac-seq-bam-read-alignment-processing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "TOBIAS is a collection of command-line tools utilizing a minimal input of ATAC-seq reads, TF motifs and genome information (Fig. 1b) to perform all levels of footprinting analysis including bias correction (Fig. 1c), footprinting (Fig. 1d), and comparison between conditions (Fig. 1e).",
      "asbval:note": "The research question describes the core function of TOBIAS: processing ATAC-seq BAM files to extract Tn5 insertion patterns around TF motifs for footprinting. This is directly supported by the paper's description of TOBIAS as a framework for footprinting analysis using ATAC-seq reads and TF motifs.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "atac-seq-bam-read-alignment-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Extract and aggregate Tn5 insertion positions from aligned ATAC-seq BAM files within fixed-width windows around genomic features (e.g., transcription factor binding motifs) to enable footprint detection and chromatin accessibility analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
