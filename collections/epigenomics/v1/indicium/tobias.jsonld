    {
      "@id": "asbval:assertion/skill/nucleotide-footprint-pattern-recognition/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recent advances have enabled the application of ATAC-seq in single cells, but this generates sparse matrices, rendering footprinting approaches on single cells elusive. However, we speculate that by creating aggregated pseudo-bulk signals from large clustered single-cell ATAC datasets, DGF analysis might also become possible in single cells.",
      "asbval:note": "Paper mentions pseudobulk aggregation as a speculative approach for single-cell data but does not confirm it as a validated workflow in the current study.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-020-18035-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "nucleotide-footprint-pattern-recognition",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Single-cell data requires aggregation into pseudobulk BAM files per cell cluster first.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:22:39.273536+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
