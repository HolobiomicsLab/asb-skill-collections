    {
      "@id": "asbval:assertion/skill/kmer-motif-synergy-assessment/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To calculate the Pearson correlation between pair-wise motifs, the shorter motif was padded with an equal distribution of A,C,G,T. Then the Pearson correlation was calculated at every possible offset, and the maximum correlation of all offset comparisons was recorded.",
      "asbval:note": "Paper computes Pearson correlations between motifs and between kmers and motifs, but this is described in the context of motif filtering and de novo motif assembly, not as a standalone output format. Paper does not explicitly describe CSV export or a formal 'correlation matrix' output product.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "kmer-motif-synergy-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "outputs",
      "asbval:target_claim_text": "Correlation matrix (CSV): Pearson correlations between motif and kmer deviations",
      "eco:evidence_type": {
