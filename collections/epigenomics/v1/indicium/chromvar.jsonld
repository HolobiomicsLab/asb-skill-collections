      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/atac-seq-clustering-performance-interpretation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we have developed chromVAR, a versatile R package for analyzing sparse chromatin accessibility data by measuring the gain or loss of chromatin accessibility within sets of genomic features while controlling for known technical biases in epigenomic data (Supplementary Software).",
      "asbval:note": "chromVAR is confirmed as an R package for sparse ATAC-seq analysis. Paper does evaluate kmers (kmer analysis is described in detail), and does compare clustering using tSNE on bias-corrected deviations to PCA. However, no comparison to SnapATAC is present in the provided passages. The paper does not benchmark chromVAR against SnapATAC.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
