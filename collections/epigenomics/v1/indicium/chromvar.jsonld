      }
    },
    {
      "@id": "asbval:assertion/skill/background-peak-selection-normalization/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We wrapped the MOODS library into an R package, motifmatchr, which enables fast determination of motif presence or positions within genomic regions. The package is available at www.github.com/GreenleafLab/motifmatchr",
      "asbval:note": "motifmatchr is confirmed as an R package for motif matching. The paper also states: 'The chromVAR package takes as inputs 1) aligned sequencing reads, 2) chromatin accessibility peaks (derived from either data aggregated across cells or external resources), and 3) a set of chromatin features representing either motif position weight matrices (PWMs) or genomic annotations', confirming motif matches are inputs to chromVAR analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "background-peak-selection-normalization",
