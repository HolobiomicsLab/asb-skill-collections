      "asbval:evidence_quote": "For each motif (or kmer or genomic annotation), a 'raw accessibility deviation' for each cell or sample is computed... A deviation Z-score is computed by dividing the bias-corrected deviation by the standard deviation of the background raw deviations",
      "asbval:note": "Paper describes computation of deviations and Z-scores but does not explicitly name the output object class as 'chromVARDeviations' or specify it as a 'RangedSummarizedExperiment' with named assays. The functional content (deviations and Z-scores) is present but the specific object structure/class naming is not verified in passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "chromVARDeviations object: RangedSummarizedExperiment with two assays (deviations and deviationScores) containing bias-corrected accessibility deviations and Z-scores for each motif (rows) and sample (columns)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
