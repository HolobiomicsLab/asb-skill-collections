    {
      "@id": "asbval:assertion/skill/motif-peak-overlap-matching/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The chromVAR package takes as inputs 1) aligned sequencing reads, 2) chromatin accessibility peaks (derived from either data aggregated across cells or external resources), and 3) a set of chromatin features representing either motif position weight matrices (PWMs) or genomic annotations",
      "asbval:note": "The paper describes chromVAR's workflow which includes matching motifs to peaks as a core step before computing deviations.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "yes",
