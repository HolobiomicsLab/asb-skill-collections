    {
      "@id": "asbval:assertion/skill/kmer-motif-synergy-assessment/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Notably, different TFs within the same family (e.g. GATA1 and GATA2) often bind highly similar motifs, and therefore chromVAR alone cannot distinguish the causative regulator binding a particular TF motif.",
      "asbval:note": "Paper acknowledges that highly similar motifs cannot be distinguished, supporting the rationale that redundancy assessment is unnecessary when annotations are identical or fully nested.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "kmer-motif-synergy-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Annotation sets are already known to be identical or fully nested (when NOT to use)",
