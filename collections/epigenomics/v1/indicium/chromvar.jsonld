    {
      "@id": "asbval:assertion/skill/gc-content-bias-calculation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "chromVAR first computes a \"raw accessibility deviation\" for each motif and cell... however this aggregation can also amplify technical biases between cells due to PCR amplification or variable Tn5 tagmentation conditions... To account for these technical confounders, \"background\" peak sets are created for each annotation, which comprise of an equal number of peaks matched for GC content and average accessibility... The raw accessibility deviations for these background peak sets are used to compute a bias corrected deviation and z-score",
      "asbval:note": "Paper describes the workflow where bias correction (including GC matching) is applied before computing bias-corrected deviations, confirming the logical ordering described in the card.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gc-content-bias-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "The skill is required before filterSamples, motif matching, and computeDeviations steps to ensure deviation scores reflect true biological variability rather than GC-driven sequencing artifacts.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:42:09.509547+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/genome-sequence-matching-for-nucleotide-patterns/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "chromVAR may also be applied to a collection of kmers\u2014DNA sequences of a specific length k\u2014in order to perform an unbiased analysis of DNA sequence features that correlate with chromatin accessibility variation across the cells or samples.",
      "asbval:note": "Paper explicitly describes matching kmers and motifs to peaks for chromatin accessibility analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "genome-sequence-matching-for-nucleotide-patterns",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Match short nucleotide sequences (kmers or transcription factor motifs) to a reference genome to generate binary annotation matrices for downstream chromatin accessibility analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
