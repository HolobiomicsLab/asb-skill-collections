    {
      "@id": "asbval:assertion/skill/chromatin-accessibility-bias-correction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "These technical biases can lead to differences in the number of observed fragment counts between cells for a given peak set with distinct GC content or mean accessibility (Supplementary Fig. 2). To account for these technical confounders, \"background\" peak sets are created for each annotation, which comprise of an equal number of peaks matched for GC content and average accessibility (Supplementary Figs. 2\u20135; Supplementary Note 2).",
      "asbval:note": "The paper explicitly describes GC content as a technical bias that must be corrected before computing deviations, and describes the background peak matching approach for GC content correction.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chromatin-accessibility-bias-correction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Correct GC content bias in single-cell or bulk ATAC-seq chromatin accessibility counts before computing deviation scores. This preprocessing step ensures that downstream motif deviation analysis is not confounded by the strong relationship between GC content and chromatin accessi",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
