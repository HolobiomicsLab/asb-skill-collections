      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compile accuracy metrics across multiple methods and datasets into a structured matrix, then compute summary statistics (mean, median, rank) to quantitatively rank method performance.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
