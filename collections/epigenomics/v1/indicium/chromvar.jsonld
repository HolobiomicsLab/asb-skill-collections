      }
    },
    {
      "@id": "asbval:assertion/skill/genome-sequence-matching-for-nucleotide-patterns/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "chromVAR first computes a 'raw accessibility deviation' for each motif and cell... This aggregation across peaks sharing a common motif yields a signal that is considerably less sparse than the signal within individual peaks",
      "asbval:note": "Paper describes using motif/kmer annotations to compute deviations and variability in sparse ATAC-seq data.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "yes",
