    {
      "@id": "asbval:assertion/skill/deviation-score-computation-and-interpretation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "chromVAR first computes a \"raw accessibility deviation\" for each motif and cell, representing the difference between the total number of fragments mapping to peaks containing the given motif and the total expected number of fragments based on the average of all input cells... To account for these technical confounders, \"background\" peak sets are created for each annotation, which comprise of an equal number of peaks matched for GC content and average accessibility... The raw accessibility deviations for these background peak sets are used to compute a bias corrected deviation and z-score for each annotation and cell",
      "asbval:note": "Core functionality of chromVAR is explicitly described; function name 'computeDeviations' not verbatim in passages but the computational workflow is fully documented",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "deviation-score-computation-and-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute bias-corrected deviation scores that quantify motif-associated variability in chromatin accessibility across samples using chromVAR's computeDeviations function",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:41:35.958964+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/deviation-score-computation-and-interpretation/001",
