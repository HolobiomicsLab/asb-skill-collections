    {
      "@id": "asbval:assertion/skill/kmer-motif-synergy-assessment/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In this visualization, motifs and kmers that have similar activity profiles across cells cluster together in the tSNE subspace, allowing the identification of major clusters representing several different TF families... By comparing the variation in chromatin accessibility across cells between highly similar kmers, we can identify critical bases associated with chromatin accessibility variation.",
      "asbval:note": "Paper demonstrates kmer-motif comparison and correlation analysis (e.g., 'AGATAAG' kmer vs GATA1 motif, normalized covariance computation), but does not explicitly name or implement formal 'synergy metrics' as a standalone analytical function. The paper computes normalized covariance between kmers and motifs but frames this as part of de novo motif assembly, not as a general-purpose synergy assessment tool.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "kmer-motif-synergy-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Quantify redundancy and synergy between kmer and motif annotation sets in chromatin accessibility data using correlation and variance-based synergy metrics.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:42:59.898914+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/kmer-motif-synergy-assessment/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "chromVAR, a versatile R package for analyzing sparse chromatin accessibility data by measuring the gain or loss of chromatin accessibility within sets of genomic features while controlling for known technical biases in epigenomic data",
      "asbval:note": "Paper confirms chromVAR is the core package and describes correlation/covariance computation between kmers and motifs (normalized covariance in de novo motif assembly section). However, the paper does not explicitly name functions called 'getAnnotationCorrelation' or 'getAnnotationSynergy'. The paper describes the underlying computation (normalized covariance, correlation in tSNE visualization) but does not confirm these as named exported functions in the chromVAR API.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "kmer-motif-synergy-assessment",
