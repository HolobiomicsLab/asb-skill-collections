    {
      "@id": "asbval:assertion/card/task_004/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The chromVAR package includes a collection of tools for such downstream analysis, including an interactive web application for exploring the relationship between key TF motifs and clustering of cells (Supplementary Figure 6). We have also incorporated tools for generating previously-described analyses characterizing the correlation and potential cooperativity between two TF binding sites within the same regulatory element",
      "asbval:note": "Paper mentions tools for analyzing 'correlation and potential cooperativity between two TF binding sites' but does not name the specific functions getAnnotationCorrelation or getAnnotationSynergy. The paper discusses correlation and cooperativity concepts but does not explicitly describe these named functions or their computational methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_004",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "How do getAnnotationCorrelation and getAnnotationSynergy quantify redundancy and synergy between two annotation sets in a chromVARDeviations object?",
