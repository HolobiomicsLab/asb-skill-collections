    {
      "@id": "asbval:assertion/skill/clustering-accuracy-metric-extraction/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Using tSNE with bias corrected deviations for motifs and 7mers, we clustered individual cells into distinct cell types and observe individual motifs that best distinguish each cell type (Fig. 2a). Notably, well defined, distinct clusters are formed in this tSNE projection when using the bias corrected deviations, but the clustering is confounded by technical biases when using raw deviations without the bias correction infrastructure.",
      "asbval:note": "Paper demonstrates that kmers (7mers) combined with bias-corrected deviations produce good clustering, but does not explicitly compare kmers+PCA to other chromVAR variants or declare it 'best'. The paper uses tSNE for visualization, not PCA for clustering itself.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "clustering-accuracy-metric-extraction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "kmers+PCA variant is identified as best chromVAR configuration for clustering tasks",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:41:23.832475+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/clustering-accuracy-metric-extraction/005",
