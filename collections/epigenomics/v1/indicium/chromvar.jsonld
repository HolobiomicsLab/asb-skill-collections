      }
    },
    {
      "@id": "asbval:assertion/skill/bias-corrected-z-score-interpretation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We wrapped the MOODS library into an R package, motifmatchr, which enables fast determination of motif presence or positions within genomic regions. The package is available at www.github.com/GreenleafLab/motifmatchr",
      "asbval:note": "motifmatchr is confirmed as a tool for motif matching. Its role in generating motif-to-peak annotation matrices is semantically consistent with the described motif matching workflow.",
