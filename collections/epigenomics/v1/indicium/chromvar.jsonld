    {
      "@id": "asbval:assertion/skill/z-score-based-statistical-testing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "chromVAR first computes a \"raw accessibility deviation\" for each motif and cell... A deviation Z-score is computed by dividing the bias-corrected deviation by the standard deviation of the background raw deviations for each iteration... For determining differentially accessible motifs between AML LSC and blast cells, an unequal variances t-test (two-sided) was used on the bias corrected deviations. For determining differential variability, a Brown\u2013Forsythe test was used on the deviation z-scores.",
      "asbval:note": "Paper confirms z-score computation, differential testing (t-test, Brown\u2013Forsythe), and variability ranking. However, no mention of 'bootstrapped confidence intervals' in the passages; paper uses background peak set sampling and statistical tests but does not explicitly describe bootstrap confidence interval computation as a core method.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "z-score-based-statistical-testing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute z-score deviations for genomic annotations (motifs, kmers) in sparse chromatin accessibility data, then apply statistical hypothesis testing and bootstrapped confidence intervals to rank annotations by variability and identify significant differential usage across sample ",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:45:03.150301+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
