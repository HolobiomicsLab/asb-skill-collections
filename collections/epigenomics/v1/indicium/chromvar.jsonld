      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Match transcription factor motifs to chromatin accessibility peaks to identify which peaks contain which DNA binding motifs. This is an essential preprocessing step that links motif occurrence to peak regions before computing deviation scores in chromatin accessibility analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
