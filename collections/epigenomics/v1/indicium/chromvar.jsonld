    {
      "@id": "asbval:assertion/skill/atac-seq-clustering-performance-interpretation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The clustering accuracy using the bias corrected deviations is also largely preserved after downsampling, and compares favorably to clustering using PCA or other peak-based approaches (Supplementary Fig. 7; see methods). Importantly, chromVAR provides robust results for 10,000 fragments per cell, a typical number of fragments generated from a single-cell using scATAC-seq4 (Supplementary Figure 7). By projecting the vector of bias corrected deviations from individual cells into two dimensions using tSNE11, chromVAR enables the reconstruction of the major hematopoietic lineages using 10,000 fragments per sample.",
      "asbval:note": "Paper reports clustering accuracy measured using normalized mutual information (NMI) in downsampling analysis (Supplementary Fig. 7), but does not report ARI or purity metrics. The paper compares chromVAR clustering to PCA and peak-based approaches, but does not benchmark against SnapATAC or provide comprehensive cross-method comparison tables as the card implies.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "atac-seq-clustering-performance-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Systematically extract, tabulate, and interpret clustering performance metrics (NMI, ARI, purity) from single-cell ATAC-seq benchmark studies to compare method performance across datasets.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:39:11.714340+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/atac-seq-clustering-performance-interpretation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The clustering accuracy using the bias corrected deviations is also largely preserved after downsampling, and compares favorably to clustering using PCA or other peak-based approaches (Supplementary Fig. 7; see methods).",
      "asbval:note": "Paper compares chromVAR (with tSNE projection of bias-corrected deviations) to PCA on peak counts, but does not mention SnapATAC or provide explicit benchmarking against SnapATAC. The card's framing of 'kmers+PCA vs. SnapATAC' comparison is not directly supported; paper does mention kmer analysis but not in direct comparison to SnapATAC.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "atac-seq-clustering-performance-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill enables practitioners to contextualize the relative strengths of dimensionality reduction + clustering pipelines (e.g., kmers+PCA vs. SnapATAC) against published benchmarks.",
      "eco:evidence_type": {
