      }
    },
    {
      "@id": "asbval:assertion/skill/bias-corrected-z-score-interpretation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "chromVAR first computes a \"raw accessibility deviation\" for each motif and cell, representing the difference between the total number of fragments mapping to peaks containing the given motif and the total expected number of fragments based on the average of all input cells... To account for these technical confounders, \"background\" peak sets are created for each annotation, which comprise of an equal number of peaks matched for GC content and average accessibility... The raw accessibility deviations for these background peak sets are used to compute a bias corrected deviation and z-score for each annotation and cell, providing a bias-corrected differential measure describing the gain or loss of accessibility of a given genomic annotation relative to the average cell profile",
      "asbval:note": "Research question is fully supported by the paper's description of z-score computation and interpretation for ranking and differential analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "bias-corrected-z-score-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Interpret deviation z-scores computed by chromVAR as bias-corrected measures of individual or sample-level deviations from expected chromatin accessibility patterns at annotated genomic features (motifs or kmers). This skill enables ranking and differential testing of annotations",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:40:03.651116+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/bias-corrected-z-score-interpretation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we have developed chromVAR, a versatile R package for analyzing sparse chromatin accessibility data by measuring the gain or loss of chromatin accessibility within sets of genomic features while controlling for known technical biases in epigenomic data",
      "asbval:note": "chromVAR is confirmed as the tool for computing bias-corrected deviations and z-scores. Specific function names (computeDeviations, computeVariability, differentialDeviations) are not explicitly named in passages but are semantically consistent with the described workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "yes",
