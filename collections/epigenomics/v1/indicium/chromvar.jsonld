      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper describes computation of variability as 'standard deviation of the z-scores across the cells or samples' (passage 4) but does not mention bootstrap resampling, confidence intervals, or uncertainty quantification around variability metrics. The paper computes variability deterministically, not via bootstrap methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
