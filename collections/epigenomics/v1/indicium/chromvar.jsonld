    {
      "@id": "asbval:assertion/skill/single-cell-chromatin-sample-filtering/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "chromVAR provides robust results for 10,000 fragments per cell, a typical number of fragments generated from a single-cell using scATAC-seq. By projecting the vector of bias corrected deviations from individual cells into two dimensions using tSNE, chromVAR enables the reconstruction of the major hematopoietic lineages using 10,000 fragments per sample.",
      "asbval:note": "Paper discusses robustness to low sequencing depth and downsampling, but does not explicitly describe a 'filterSamples()' function or dedicated sample-filtering workflow. The paper demonstrates that chromVAR is robust to sparse data (10,000 fragments per cell) but does not present a quality-control filtering step as a primary task. The research_question conflates robustness-to-sparsity with active sample filtering.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "single-cell-chromatin-sample-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Remove low-quality single cells or bulk samples from ATAC-seq or DNAse-seq chromatin accessibility data prior to downstream analysis. This quality control step eliminates samples with insufficient sequencing depth or low peak coverage that would compromise motif deviation or clus",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:44:01.053277+00:00",
      "sepio:credibility_status": {
