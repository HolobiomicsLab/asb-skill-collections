    {
      "@id": "asbval:assertion/skill/clustering-accuracy-metric-extraction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The clustering accuracy using the bias corrected deviations is also largely preserved after downsampling, and compares favorably to clustering using PCA or other peak-based approaches (Supplementary Fig. 7; see methods). Importantly, chromVAR provides robust results for 10,000 fragments per cell, a typical number of fragments generated from a single-cell using scATAC-seq",
      "asbval:note": "Paper reports clustering accuracy comparisons but uses normalized mutual information (NMI) as the metric, not ARI or purity. Quote: 'Clustering accuracy was measured using normalized mutual information'. NMI is present; ARI and purity are not mentioned in passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-nmeth-4401",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "clustering-accuracy-metric-extraction",
