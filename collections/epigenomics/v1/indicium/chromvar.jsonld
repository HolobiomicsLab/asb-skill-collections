    {
      "@id": "asbval:assertion/skill/bias-corrected-z-score-interpretation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The raw accessibility deviations for these background peak sets are used to compute a bias corrected deviation and z-score for each annotation and cell, providing a bias-corrected differential measure describing the gain or loss of accessibility of a given genomic annotation relative to the average cell profile",
