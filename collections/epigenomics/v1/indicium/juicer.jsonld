    {
      "@id": "asbval:assertion/skill/hi-c-normalization-and-bias-correction/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Juicer transforms raw sequence data into a list of Hi-C contacts (pairs of genomic loci)... Next, the catalog of contacts is used to create contact matrices... Juicer can adjust for these biases in multiple ways.",
      "asbval:note": "Paper confirms normalization occurs after contact matrix creation and before downstream analysis.",
