    {
      "@id": "asbval:assertion/skill/hi-c-fastq-read-preprocessing/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Structural features, such as loops and domains, are automatically annotated... Juicer contains a suite of algorithms that are designed to annotate contact matrices and thus identify features of genome folding. These features include loops, loop anchor motifs, and contact domains.",
      "asbval:note": "Paper confirms automatic annotation of loops and domains as part of Juicer pipeline.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "hi-c-fastq-read-preprocessing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Automated loop and domain annotation",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:08:52.972554+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/hi-c-fastq-read-preprocessing/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Loops are identified using the HiCCUPS algorithm (Rao et al., 2014), which searches for clusters of contact matrix entries in which the frequency of contact is enriched relative to the local background.",
      "asbval:note": "Paper explicitly names HiCCUPS as the loop detection algorithm used in Juicer.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "hi-c-fastq-read-preprocessing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "HiCCUPS algorithm for loop detection",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:08:52.972554+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/hi-c-fastq-read-preprocessing/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Contact domains are identified using a dynamic programming algorithm that relies on applying the Arrowhead transformation [Ai,i + d = (M* i,i-d \u2013 M* i,i+d )/(M* i,i-d + M* i,i+d )] to a normalized contact matrix M*",
      "asbval:note": "Paper explicitly describes Arrowhead algorithm for domain identification.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "hi-c-fastq-read-preprocessing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Arrowhead algorithm for contact domain identification",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:08:52.972554+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/hi-c-fastq-to-contact-map-pipeline/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Juicer allows users without a computational background to transform raw sequence data into normalized contact maps with one click. Juicer produces a hic file containing compressed contact matrices at many resolutions... First, Juicer transforms raw sequence data into a list of Hi-C contacts (pairs of genomic positions that were adjacent to each other in 3D space during the experiment). To accomplish this, read pairs are aligned to the genome, both duplicates and near-duplicates are removed, and read pairs that align to three or more locations are set aside... Next, the catalog of contacts is used to create contact matrices.",
      "asbval:note": "Core workflow is explicitly described in abstract and methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "hi-c-fastq-to-contact-map-pipeline",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "A unified workflow for converting raw Hi-C sequencing reads (FASTQ format) into contact maps (.hic binary files) via alignment, deduplication, and contact matrix construction.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:09:09.070328+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
