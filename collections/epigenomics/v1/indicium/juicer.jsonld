      }
    },
    {
      "@id": "asbval:assertion/skill/hic-contact-map-feature-annotation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Juicer contains a suite of algorithms that are designed to annotate contact matrices and thus identify features of genome folding. These features include loops, loop anchor motifs, and contact domains. Loops are identified using the HiCCUPS algorithm... Contact domains are identified using a dynamic programming algorithm that relies on applying the Arrowhead transformation... Juicer produces a hic file containing compressed contact matrices at many resolutions",
      "asbval:note": "Core claim fully supported: Juicer annotates loops, domains, and peaks on .hic files.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
