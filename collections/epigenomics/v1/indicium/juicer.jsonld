    {
      "@id": "asbval:assertion/skill/kilobase-resolution-contact-map-analysis/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Juicer comprises three tools, which are designed to be run one-after-another... Finally, Juicer contains a suite of algorithms that are designed to annotate contact matrices and thus identify features of genome folding. These features include loops, loop anchor motifs, and contact domains. Loops are identified using the HiCCUPS algorithm... Contact domains are identified using a dynamic programming algorithm that relies on applying the Arrowhead transformation...",
      "asbval:note": "The paper describes feature annotation algorithms (HiCCUPS, Arrowhead, APA) as part of Juicer but does not explicitly name a separate 'Juicer Tools' package. The paper mentions 'M.S.S. re-implemented all feature annotation algorithms in Java as fully-automated, end-to-end tools' but does not use the term 'Juicer Tools' as a distinct entity.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "kilobase-resolution-contact-map-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Juicer Tools",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:10:51.893690+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
