    {
      "@id": "asbval:assertion/skill/kilobase-resolution-contact-map-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Hi-C experiments explore the 3D structure of the genome, generating terabases of data to create high-resolution contact maps. Here, we introduce Juicer, an open-source tool for analyzing terabase-scale Hi-C datasets. Juicer allows users without a computational background to transform raw sequence data into normalized contact maps with one click.",
      "asbval:note": "Paper confirms Juicer generates Hi-C contact maps from raw sequence data at kilobase resolution (mentioned: 'we recently generated 6.5 billion reads and 1.6 Tb of DNA sequence in order to create a single 3D map of the genome at kilobase resolution'). However, the paper does NOT mention ENCODE's uniform processing workflow or validation procedures. The card conflates Juicer (confirmed) with ENCODE pipeline (not mentioned in passages).",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "kilobase-resolution-contact-map-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Generate and validate Hi-C contact maps at kilobase resolution from FASTQ raw sequencing data using the Juicer pipeline and ENCODE's uniform processing workflow.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:10:51.893690+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/kilobase-resolution-contact-map-analysis/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here, we introduce Juicer, an open-source tool for analyzing terabase-scale Hi-C datasets. Juicer allows users without a computational background to transform raw sequence data into normalized contact maps with one click.",
      "asbval:note": "Juicer is the primary subject of the paper and is confirmed as the core tool for Hi-C analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "kilobase-resolution-contact-map-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Juicer",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
