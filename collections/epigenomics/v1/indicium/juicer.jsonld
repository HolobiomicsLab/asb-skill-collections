      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it when you need to compare interaction frequencies between regions with different sequence properties, merge data across multiple replicates or experiments, or prepare matrices for downstream analysis (peak calling, domain detection, comparative genomics)",
      "eco:evidence_type": {
