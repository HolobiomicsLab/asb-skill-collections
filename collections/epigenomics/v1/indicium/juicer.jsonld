    {
      "@id": "asbval:assertion/skill/hi-c-fastq-to-contact-map-pipeline/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Juicer contains a suite of algorithms that are designed to annotate contact matrices and thus identify features of genome folding. These features include loops, loop anchor motifs, and contact domains. Loops are identified using the HiCCUPS algorithm... Contact domains are identified using a dynamic programming algorithm that relies on applying the Arrowhead transformation... Juicer includes an implementation of Aggregate Peak Analysis (Rao et al., 2014).",
      "asbval:note": "Paper confirms HiCCUPS, Arrowhead, and APA are part of Juicer's feature annotation suite, but does not explicitly name a separate 'Juicer Tools' command-line toolset. These algorithms are described as integrated into Juicer itself, not as a separate tool package.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "hi-c-fastq-to-contact-map-pipeline",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Juicer Tools (repo: https://github.com/aidenlab/juicer) role: Command-line toolset for contact map post-processing and feature annotation (e.g., HiCCUPS peak calling)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:09:09.070328+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/hi-c-map-artifact-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Juicer allows users without a computational background to transform raw sequence data into normalized contact maps with one click. Juicer produces a hic file containing compressed contact matrices at many resolutions, facilitating visualization and analysis at multiple scales.",
      "asbval:note": "Paper explicitly describes Juicer producing .hic files with normalized contact matrices.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "hi-c-map-artifact-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Verification that a Juicer Hi-C processing pipeline has completed successfully and produced a valid .hic output file containing processed Hi-C contact map data.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
