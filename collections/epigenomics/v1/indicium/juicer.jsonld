      "asbval:target_artifact_id": "hic-contact-map-feature-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill applies Juicer's command-line post-processing tools to annotate structural features (loops, domains, peaks) on pre-generated Hi-C contact map files (.hic format).",
