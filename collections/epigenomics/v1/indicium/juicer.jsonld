    {
      "@id": "asbval:assertion/skill/hi-c-normalization-and-bias-correction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Due to factors such as chromatin accessibility, certain loci are observed more frequently in Hi-C experiments. Juicer can adjust for these biases in multiple ways. The options include our original normalization scheme (Lieberman-Aiden et al., 2009), as well as a matrix balancing scheme that ensures that each row and column of the contact matrix sums to the same value (Knight and Ruiz, 2012).",
      "asbval:note": "Paper confirms normalization and bias correction are performed by Juicer, but does not explicitly mention restriction enzyme cutting efficiency, GC content, or mappability as specific artifacts being corrected. Paper mentions 'chromatin accessibility' as a bias factor but not the full list of technical artifacts claimed.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "hi-c-normalization-and-bias-correction",
      "asbval:target_artifact_kind": "skill_bundle",
