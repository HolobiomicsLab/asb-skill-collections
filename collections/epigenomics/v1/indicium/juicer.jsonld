    {
      "@id": "asbval:assertion/skill/genomic-loop-call-interpretation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Loops are identified using the HiCCUPS algorithm (Rao et al., 2014), which searches for clusters of contact matrix entries in which the frequency of contact is enriched relative to the local background. Because there are trillions of pixels in a kilobase-resolution Hi-C map, HiCCUPS is implemented using GPGPUs.",
      "asbval:note": "HiCCUPS confirmed as loop-detection algorithm with GPU acceleration (GPGPUs mentioned; CUDA not explicitly named but GPU acceleration confirmed).",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "genomic-loop-call-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "HiCCUPS (Peak-calling algorithm for chromatin loop detection; supports GPU acceleration via CUDA)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
