    {
      "@id": "asbval:assertion/skill/genomic-loop-call-interpretation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Juicer contains a suite of algorithms that are designed to annotate contact matrices and thus identify features of genome folding. These features include loops, loop anchor motifs, and contact domains. Loops are identified using the HiCCUPS algorithm",
      "asbval:note": "Paper explicitly describes Juicer's feature annotation capabilities for loops and domains on contact matrices.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
