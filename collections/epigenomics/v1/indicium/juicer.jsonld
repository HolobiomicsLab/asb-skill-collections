    {
      "@id": "asbval:assertion/skill/kilobase-resolution-genomics-analysis/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Loops are identified using the HiCCUPS algorithm (Rao et al., 2014), which searches for clusters of contact matrix entries in which the frequency of contact is enriched relative to the local background. Because there are trillions of pixels in a kilobase-resolution Hi-C map, HiCCUPS is implemented using GPGPUs.",
      "asbval:note": "Paper confirms HiCCUPS is used for loop annotation and mentions GPU implementation (GPGPUs), but does not explicitly name CUDA. The claim about CUDA is not verified in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1016-j-cels-2016-07-002",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "kilobase-resolution-genomics-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "HiCCUPS - Peak-calling tool for loop annotation; GPU version requires CUDA",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:11:09.197910+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
