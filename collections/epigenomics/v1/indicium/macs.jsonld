    {
      "@id": "asbval:assertion/skill/fragment-length-estimation-from-read-pairs/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper describes MACS (2008), not MACS3. The paper does not mention 'callpeak' as a subcommand. MACS in 2008 is a monolithic tool, not a suite with subcommands. No paired-end mode is described.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
