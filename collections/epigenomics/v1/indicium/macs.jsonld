    {
      "@id": "asbval:assertion/skill/bedpe-format-handling/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS empirically models the shift size of ChIP-Seq tags, and uses it to improve the spatial resolution of predicted binding sites... The distance between the modes of the Watson and Crick peaks in the alignment is defined as 'd', and MACS shifts all the tags by d/2 toward the 3' ends to the most likely protein-DNA interaction sites.",
      "asbval:note": "MACS v1 does estimate fragment length 'd' (the distance between Watson and Crick strand peaks). However, this is done from single-end tag distributions, not from paired-end BEDPE data as the card claims.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "bedpe-format-handling",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Fragment length estimate (d) in base pairs",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T17:59:27.273705+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/chip-seq-peak-calling-workflow/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS empirically models the shift size of ChIP-Seq tags, and uses it to improve the spatial resolution of predicted binding sites. MACS also uses a dynamic Poisson distribution to effectively capture local biases in the genome",
      "asbval:note": "Paper describes MACS (2008), not MACS3. The paper does not mention the specific subcommands (filterdup, predictd, pileup, bdgcmp, bdgopt, bdgpeakcall) or a decomposed workflow. The paper describes the core algorithm (tag shifting, dynamic lambda, peak calling) but not the modular command structure claimed in the card. MACS3 is a later version not discussed in this paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "chip-seq-peak-calling-workflow",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "A complete ChIP-Seq peak calling workflow that decomposes MACS3 callpeak into sequential subcommands (filterdup, predictd, pileup, bdgcmp, bdgopt, bdgpeakcall)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T17:59:42.293593+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/chip-seq-peak-calling-workflow/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS removes duplicate tags in excess of what is warranted by the sequencing depth (binomial distribution p-value <10-5)",
      "asbval:note": "Paper describes duplicate removal in MACS (2008), but does not name a separate 'filterdup' subcommand. The functionality exists but the specific tool name and modular structure are from MACS3, not the original MACS paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "chip-seq-peak-calling-workflow",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "macs3 filterdup",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T17:59:42.293593+00:00",
