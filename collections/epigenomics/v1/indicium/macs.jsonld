      }
    },
    {
      "@id": "asbval:assertion/skill/fragment-length-prediction-and-extension/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "\u03bb local is also effective in capturing the local genomic bias from a ChIP sample alone when a control is not available... MACS can be applied to ChIP-Seq experiments without controls, and to those with controls with improved performance.",
      "asbval:note": "Paper confirms that MACS models fragment length from ChIP data and can work with or without controls. The principle that modeling should be applied to ChIP rather than control is consistent with the paper's approach.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "fragment-length-prediction-and-extension",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Control sample is being processed \u2014 predictd should only be applied to ChIP data, not input/control data.",
      "eco:evidence_type": {
