      }
    },
    {
      "@id": "asbval:assertion/skill/chip-seq-peak-calling-workflow/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS takes advantage of this bimodal pattern to empirically model the shifting size to better locate the precise binding sites. Given a sonication size (bandwidth) and a high-confidence fold-enrichment (mfold), MACS slides 2bandwidth windows across the genome to find regions with tags more than mfold enriched",
      "asbval:note": "Paper describes the 'd' (shift distance) modeling algorithm in MACS, but does not name a separate 'predictd' subcommand. The functionality is present but the modular command structure is from MACS3.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "chip-seq-peak-calling-workflow",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "macs3 predictd",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T17:59:42.293593+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/chip-seq-peak-calling-workflow/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After MACS shifts every tag by d/2, it slides 2d windows across the genome to find candidate peaks with a significant tag enrichment",
      "asbval:note": "Paper describes tag extension and pileup-like operations, but does not name a separate 'pileup' subcommand. The functionality is implicit in the peak-calling algorithm but not exposed as a modular command in the original MACS paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "chip-seq-peak-calling-workflow",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "macs3 pileup",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T17:59:42.293593+00:00",
