      }
    },
    {
      "@id": "asbval:assertion/skill/narrow-peak-calling-score-threshold/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "bdgbroadcall is a MACS3 modular tool for broad peak calling. The original MACS paper (2008) does not describe this tool or distinguish between narrow and broad peak calling modes. The paper focuses on narrow peak detection for transcription factors.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
