    {
      "@id": "asbval:assertion/skill/duplicate-read-filtering-and-normalization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Sometimes the same tag can be sequenced repeatedly, more times than expected from a random genome-wide tag distribution. Such tags might arise from biases during ChIP-DNA amplification and sequencing library preparation, and are likely to add noise to the final peak calls. Therefore, MACS removes duplicate tags in excess of what is warranted by the sequencing depth (binomial distribution p-value <10-5).",
      "asbval:note": "Paper describes duplicate removal and normalization (linear scaling of control tag count to match ChIP tag count), but does not explicitly frame this as addressing violations of independent sampling assumptions for p-value/q-value calculations. The paper does use Poisson distribution for peak calling, which assumes independence, but the connection is implicit rather than explicit.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "duplicate-read-filtering-and-normalization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Remove redundant reads from ChIP-Seq data and normalize read counts across samples to enable unbiased statistical comparison. This skill is essential before peak calling, as duplicate reads inflate coverage at single genomic loci and violate the assumption of independent sampling",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:00:28.428358+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/duplicate-read-filtering-and-normalization/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
