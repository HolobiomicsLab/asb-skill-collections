    {
      "@id": "asbval:assertion/card/task_001/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS takes advantage of this bimodal pattern to empirically model the shifting size to better locate the precise binding sites... MACS randomly samples 1,000 of these high-quality peaks, separates their Watson and Crick tags, and aligns them by the midpoint between their Watson and Crick tag centers... The distance between the modes of the Watson and Crick peaks in the alignment is defined as 'd'",
      "asbval:note": "Paper describes fragment length d prediction as part of MACS algorithm, not as a separate subcommand 'macs3 predictd'. The card names a specific subcommand not documented in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
