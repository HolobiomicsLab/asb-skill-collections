    {
      "@id": "asbval:assertion/skill/chip-seq-peak-calling-workflow/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Overlapping enriched peaks are merged, and each tag position is extended d bases from its center. The location with the highest fragment pileup, hereafter referred to as the summit, is predicted as the precise binding location.",
      "asbval:note": "Paper describes peak calling from enriched regions, but does not name a separate 'bdgpeakcall' subcommand. The functionality is part of the integrated MACS algorithm, not a modular command.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
