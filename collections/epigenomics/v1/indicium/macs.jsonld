      }
    },
    {
      "@id": "asbval:assertion/skill/fragment-length-estimation-from-read-pairs/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS empirically models the shift size of ChIP-Seq tags, and uses it to improve the spatial resolution of predicted binding sites.",
      "asbval:note": "Paper describes empirical modeling of shift size 'd' (distance between Watson and Crick tag modes), which is conceptually related to fragment length estimation. However, the paper's approach uses tag density bimodality and strand separation, NOT paired-end read coordinates or cross-correlation analysis. The paper analyzes single-end tags, not paired-end reads. The card's specific methodology (cross-correlation of read pair coordinates) is not present in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "fragment-length-estimation-from-read-pairs",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Estimate the average sequencing fragment length from paired-end ChIP-Seq reads using cross-correlation analysis of read pair coordinates. This is a critical preliminary step that informs downstream pileup extension and peak calling sensitivity in ChIP-Seq analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:01:05.494169+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/fragment-length-estimation-from-read-pairs/001",
      "@type": "asbval:ClaimAssessment",
