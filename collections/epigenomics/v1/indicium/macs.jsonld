        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/chip-seq-peak-calling-workflow/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "No mention of 'bdgopt' or BEDGRAPH optimization operations in the paper. The paper does not describe a separate normalization/scaling step as a distinct command.",
