    {
      "@id": "asbval:assertion/card/task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS removes duplicate tags in excess of what is warranted by the sequencing depth (binomial distribution p-value <10-5)... MACS takes advantage of this bimodal pattern to empirically model the shifting size to better locate the precise binding sites... MACS estimates the d to be only 126 bp... When applied to CTCF ChIP-Seq data the MACS model estimated a d of 76 bp",
      "asbval:note": "Paper describes MACS (not MACS3) performing duplicate filtering and fragment length d estimation on CTCF ChIP-Seq. The card claims MACS3, but the paper describes the original MACS algorithm from 2008. MACS3 is a later version not mentioned in this paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "What are the read counts after duplicate filtering and the predicted fragment length d when running MACS3 callpeak on CTCF ChIP-Seq data?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
