    {
      "@id": "asbval:assertion/skill/fragment-length-prediction-and-extension/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "--gsize for mappable genome size to calculate \u03bb BG from tag count (default 2.7G bp, approximately the mappable human genome size)",
      "asbval:note": "Paper confirms --gsize parameter accepts explicit bp counts (e.g., 2.7G for human). However, no evidence that shorthand codes like 'hs' are supported in the 2008 MACS version. This may be a feature of later versions.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
