        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/chip-seq-peak-calling-workflow/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After MACS shifts every tag by d/2, it slides 2d windows across the genome to find candidate peaks with a significant tag enrichment (Poisson distribution p-value based on \u03bb BG , default 10-5)",
      "asbval:note": "Paper describes statistical comparison using Poisson distribution, but does not name a separate 'bdgcmp' subcommand or BEDGRAPH comparison tool. The statistical model exists but the modular command structure is from MACS3.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "chip-seq-peak-calling-workflow",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "macs3 bdgcmp",
      "eco:evidence_type": {
