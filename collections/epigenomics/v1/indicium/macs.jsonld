      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After extending ChIP sample reads to their predicted fragment length and constructing local lambda bias tracks (incorporating d-scaled, 1 kb, 10 kb, and genome-wide backgrounds).",
