      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not mention specific multiplication factors (0.254, 0.0254) or explicit normalization steps. Paper describes linear scaling of control tag counts to match ChIP tag counts, but not the specific factors named in the card.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
