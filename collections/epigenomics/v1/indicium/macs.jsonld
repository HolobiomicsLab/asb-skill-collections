    {
      "@id": "asbval:assertion/skill/chip-seq-peak-calling-workflow/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS is implemented in Python and freely available with an open source Artistic License at [16]",
      "asbval:note": "Paper confirms MACS is open-source and freely available, but does not specify the GitHub repository URL. The reference [16] points to http://liulab.dfci.harvard.edu/MACS/, not the macs3-project GitHub. The card references MACS3 (a later version) while the paper describes MACS (2008).",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
