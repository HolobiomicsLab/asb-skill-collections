    {
      "@id": "asbval:assertion/skill/chip-seq-signal-pileup-extension/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS shifts all the tags by d/2 toward the 3' ends to the most likely protein-DNA interaction sites... After MACS shifts every tag by d/2, it slides 2d windows across the genome to find candidate peaks with a significant tag enrichment",
      "asbval:note": "Paper describes tag shifting by d/2 and sliding windows for peak detection, but does not explicitly describe generating continuous pileup/bedgraph coverage tracks as an intermediate output. The paper focuses on peak calling directly, not on pileup generation as a separate intermediate step. MACS (2008) does not appear to have a 'pileup' subcommand; this is a feature of MACS3 (later version), which is not discussed in this 2008 paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "chip-seq-signal-pileup-extension",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Extend aligned ChIP-Seq reads to their predicted fragment length and generate genome-wide coverage (pileup) tracks. This is a critical intermediate step in peak calling that converts single-end or paired-end reads into continuous signal intensity maps needed for subsequent statis",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:00:11.897975+00:00",
      "sepio:credibility_status": {
