    {
      "@id": "asbval:assertion/skill/chip-seq-read-alignment-filtering/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS removes duplicate tags in excess of what is warranted by the sequencing depth (binomial distribution p-value <10-5). For example, for the 3.9 million FoxA1 ChIP-Seq tags, MACS allows each genomic position to contain no more than one tag and removes all the redundancies.",
      "asbval:note": "Paper describes duplicate removal as part of MACS peak calling workflow, but not as a separate prerequisite step. The card frames this as a standalone filtering step that precedes predictd and callpeak, whereas the paper integrates it into the unified MACS algorithm.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "chip-seq-read-alignment-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Filter redundant reads from ChIP-Seq alignment files and perform duplicate-aware read counting prior to peak calling",
