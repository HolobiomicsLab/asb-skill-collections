    {
      "@id": "asbval:assertion/card/task_001/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MACS removes duplicate tags in excess of what is warranted by the sequencing depth (binomial distribution p-value <10-5).",
      "asbval:note": "Paper describes duplicate filtering as part of MACS peak detection workflow, not as a separate subcommand. The card names it as 'macs3 filterdup' but the paper integrates this as part of the main MACS algorithm without separate command documentation.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
