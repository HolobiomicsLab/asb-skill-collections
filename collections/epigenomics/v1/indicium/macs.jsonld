    {
      "@id": "asbval:assertion/skill/duplicate-read-filtering-and-normalization/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The output includes one BED file containing the peak chromosome coordinates, and one xls file containing the genome coordinates, summit, p-value, fold_enrichment and FDR (if control is available) of each peak.",
      "asbval:note": "Paper confirms BED output and reports fold_enrichment (which reflects normalization), but does not explicitly describe separate 'deduplicated BED files' or standalone 'final read count reports' as distinct outputs. The outputs described are peak calls, not intermediate deduplicated read files.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2008-9-9-r137",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "duplicate-read-filtering-and-normalization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "deduplicated BED files and reports final read counts for normalization",
