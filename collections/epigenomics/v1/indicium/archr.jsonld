    {
      "@id": "asbval:assertion/skill/cross-modality-embedding-integration/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR also provides functionality to integrate scATAC-seq and scRNA-seq data using Seurat's infrastructure, matching the heterogeneous chromatin accessibility profiles and RNA expression. Single-cell epigenome-to-transcriptome integration is essential for understanding dynamic gene regulatory processes, and we anticipate this sort of analysis will become even more prevalent with the advent of platforms for simultaneous scATAC-seq and scRNA-seq.",
      "asbval:note": "Paper describes integration of paired scATAC-seq and scRNA-seq data from the same cells.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cross-modality-embedding-integration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "paired scATAC-seq peak matrices and scRNA-seq gene expression matrices from the same cells (multiome data)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:13:28.654038+00:00",
      "sepio:credibility_status": {
