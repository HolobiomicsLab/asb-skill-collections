    {
      "@id": "asbval:assertion/skill/slingshot-trajectory-embedding/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To demonstrate trajectory analysis in ArchR on the full hematopoiesis dataset, we again focused on the B cell lineage as an example (Fig. 4d). ArchR traces cells along the B cell differentiation trajectory and identifies 11,999 peak-to-gene links that have correlated regulatory dynamics (r > 0.5) across the B cell differentiation trajectory.",
      "asbval:note": "Paper demonstrates trajectory analysis inferring developmental progressions (B cell differentiation) from clustered cells.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "slingshot-trajectory-embedding",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "inferring continuous developmental progressions from discrete cell clusters",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:15:20.152464+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/slingshot-trajectory-embedding/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "One major application of single-cell analysis is the identification of cellular subsets through dimensionality reduction and clustering. To benchmark the performance of dimensionality reduction and clustering in ArchR, we compared ArchR to the two best-performing methods identified in previous assessments of scATAC-seq analysis tools, latent semantic indexing (LSI), implemented by Signac, and landmark diffusion maps (LDM), implemented by SnapATAC. For dimensionality reduction, ArchR uses an optimized iterative LSI method.",
      "asbval:note": "Paper confirms iterative LSI and clustering are prerequisite steps before trajectory analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "slingshot-trajectory-embedding",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Your cells are not yet clustered or you lack a computed dimensionality reduction embedding \u2014 run addIterativeLSI and clustering steps first.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:15:20.152464+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/slingshot-trajectory-embedding/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR also provides functionality to integrate scATAC-seq and scRNA-seq data using Seurat's infrastructure, matching the heterogeneous chromatin accessibility profiles and RNA expression. Single-cell epigenome-to-transcriptome integration is essential for understanding dynamic gene regulatory processes.",
      "asbval:note": "Paper confirms ArchR supports both scATAC-seq and scRNA-seq integration, supporting the claim that RNA-based analysis is possible with paired data.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "slingshot-trajectory-embedding",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You require trajectory analysis on RNA expression rather than ATAC chromatin accessibility \u2014 consider RNA-based trajectory tools or use paired scRNA-seq data with addGeneExpressionMatrix first.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:15:20.152464+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
