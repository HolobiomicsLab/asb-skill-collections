    {
      "@id": "asbval:assertion/skill/atac-seq-feature-matrix-construction/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Before downstream analysis, we removed cells generating low-quality data. To assess per-cell data quality, ArchR computes transcription start site (TSS) enrichment scores... To avoid both of these pitfalls, ArchR operates efficiently on a genome-wide tile matrix of 500-bp bins, allowing for the sensitivity to capture cell-type-specific biology at regulatory elements across the genome.",
      "asbval:note": "Paper confirms quality filtering and peak calling are upstream steps before ArchR analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "atac-seq-feature-matrix-construction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Peak matrix has not been quality-filtered or called \u2014 first perform peak calling and barcode filtering upstream",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:13:14.768489+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/cross-modality-embedding-integration/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR also provides functionality to integrate scATAC-seq and scRNA-seq data using Seurat's infrastructure, matching the heterogeneous chromatin accessibility profiles and RNA expression. Single-cell epigenome-to-transcriptome integration is essential for understanding dynamic gene regulatory processes... ArchR performs this cross-data alignment in parallel using slices of the scATAC-seq data",
      "asbval:note": "Paper explicitly describes scATAC-seq and scRNA-seq integration via ArchR using Seurat infrastructure for cross-platform alignment.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cross-modality-embedding-integration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Integration of paired scATAC-seq chromatin accessibility and scRNA-seq gene expression data into a unified reduced-dimension embedding space using ArchR's multiome workflow",
      "eco:evidence_type": {
