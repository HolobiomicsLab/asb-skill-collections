    {
      "@id": "asbval:assertion/skill/cross-modality-embedding-integration/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we present a software suite for single-cell analysis of regulatory chromatin in R (ArchR; https://www.archrproject.com/)",
      "asbval:note": "ArchR is explicitly described as an R package.",
