      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it as a prerequisite before trajectory analysis (Monocle3 or Slingshot), gene expression matrix integration, or any downstream analysis that requires dimensionality-reduced cell representations.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
