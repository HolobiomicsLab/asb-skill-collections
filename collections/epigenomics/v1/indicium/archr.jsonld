    {
      "@id": "asbval:assertion/skill/iterative-lsi-dimensionality-reduction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR implements a new estimated LSI dimensionality reduction by first creating an iterative LSI reduction from a subset of the total cells and then linearly projecting the remaining cells into this subspace using LSI projection",
      "asbval:note": "Paper describes iterative LSI for scATAC-seq dimensionality reduction (passage 8), but the claim asserts it 'jointly compresses' both scATAC-seq AND scRNA-seq into a unified embedding. The paper does integrate scATAC-seq and scRNA-seq data (passage 12), but uses Seurat's infrastructure for cross-platform alignment, not iterative LSI for joint compression. Iterative LSI in ArchR is applied to scATAC-seq data alone; scRNA-seq integration is a separate step using Seurat.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "iterative-lsi-dimensionality-reduction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Iterative latent semantic indexing (LSI) is a dimensionality reduction technique that jointly compresses scATAC-seq chromatin accessibility peaks and scRNA-seq gene expression data into a unified low-dimensional embedding for integrated multimodal analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
