    {
      "@id": "asbval:assertion/card/task_003/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR operates efficiently on a genome-wide tile matrix of 500-bp bins, allowing for the sensitivity to capture cell-type-specific biology at regulatory elements across the genome... ArchR stores both per-tile accessibility information and all ATAC-seq fragments in an Arrow file",
      "asbval:note": "Paper describes peak-by-cell matrices and gene matrices (passage [5], [6]), but does not document export to STREAM format. ArchR does export gene activity matrices and peak accessibility data, but no STREAM-specific export function is mentioned. The paper focuses on Arrow file format and HDF5 storage, not STREAM compatibility.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_003",
