    },
    {
      "@id": "asbval:assertion/skill/cross-modality-embedding-integration/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR performs this cross-data alignment in parallel using slices of the scATAC-seq data (Fig. 4a). When performed on the hematopoiesis dataset, this integration enabled scRNA-seq alignment for >220,000 cells in less than 1 h (Fig. 4b).",
      "asbval:note": "Paper describes the workflow as sequential: data ingestion, alignment (via Seurat), and dimensionality reduction (LSI).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cross-modality-embedding-integration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "sequential ingestion, alignment, and dimensionality reduction",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
