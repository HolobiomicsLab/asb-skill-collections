    {
      "@id": "asbval:assertion/skill/single-cell-atac-seq-dimensionality-reduction/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR identifies putative doublets in scATAC-seq data... To mitigate this issue, we designed a doublet detection-and-removal algorithm as part of ArchR... Before downstream analysis, we removed cells generating low-quality data.",
      "asbval:note": "Paper emphasizes quality control and doublet removal as prerequisites for downstream analysis including dimensionality reduction.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
