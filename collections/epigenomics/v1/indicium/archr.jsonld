    {
      "@id": "asbval:assertion/skill/slingshot-trajectory-embedding/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR facilitates cellular trajectory analysis to identify the predicted path of gene regulatory changes from one set of cells to another, a unique type of insight enabled by single-cell data. In addition to implementing both Slingshot and Monocle 3 (refs. 41\u201343), two scRNA-seq trajectory algorithms, ArchR also provides its own supervised trajectory analysis.",
      "asbval:note": "Paper confirms ArchR implements Slingshot for trajectory analysis on scATAC-seq data.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "slingshot-trajectory-embedding",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use Slingshot trajectory analysis within ArchR to compute pseudotime and developmental lineage assignments for single-cell ATAC-seq data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
