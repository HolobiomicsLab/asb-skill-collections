    {
      "@id": "asbval:assertion/skill/monocle3-trajectory-embedding/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In addition to implementing both Slingshot and Monocle 3 (refs. 40\u201343), two scRNA-seq trajectory algorithms, ArchR also provides its own supervised trajectory analysis. To demonstrate trajectory analysis in ArchR on the full hematopoiesis dataset, we again focused on the B cell lineage as an example (Fig. 4d). ArchR traces cells along the B cell differentiation trajectory and identifies 11,999 peak-to-gene links that have correlated regulatory dynamics (r > 0.5) across the B cell differentiation trajectory.",
      "asbval:note": "Paper confirms Monocle 3 is implemented in ArchR for trajectory analysis with pseudotime computation.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "monocle3-trajectory-embedding",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "monocle3 as underlying algorithm for trajectory learning, pseudotime computation, and manifold embedding; invoked by ArchR wrapper functions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
