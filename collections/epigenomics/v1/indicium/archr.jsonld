    {
      "@id": "asbval:assertion/skill/slingshot-trajectory-embedding/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR also provides methods to identify putative cis-regulatory elements based on correlated peak accessibility and gene expression, identifying 70,239 significant peak-to-gene linkages across the hematopoietic hierarchy. Finally, ArchR facilitates cellular trajectory analysis to identify the predicted path of gene regulatory changes from one set of cells to another, a unique type of insight enabled by single-cell data. In addition to implementing both Slingshot and Monocle 3, two scRNA-seq trajectory algorithms, ArchR also provides its own supervised trajectory analysis.",
      "asbval:note": "Paper explicitly states ArchR implements Slingshot for trajectory analysis. Pseudotime and lineage inference are core functions of Slingshot trajectory analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "slingshot-trajectory-embedding",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Use Slingshot trajectory analysis within ArchR to compute pseudotime and developmental lineage assignments for single-cell ATAC-seq data, inferring continuous developmental progressions from discrete cell clusters.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:15:20.152464+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/slingshot-trajectory-embedding/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we present a software suite for single-cell analysis of regulatory chromatin in R (ArchR; https://www.archrproject.com/) that enables fast and comprehensive analysis of single-cell chromatin accessibility data.",
      "asbval:note": "ArchR is confirmed as the primary software framework for scATAC-seq analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "slingshot-trajectory-embedding",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "ArchR (Primary analysis framework; holds the project object and manages trajectory computation and storage)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:15:20.152464+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/slingshot-trajectory-embedding/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In addition to implementing both Slingshot and Monocle 3 (refs. 41\u201343), two scRNA-seq trajectory algorithms, ArchR also provides its own supervised trajectory analysis. To do this analysis, ArchR initially creates a cellular trajectory based on the average positions (within a lower n-dimensional subspace) of a sequence of user-supplied clusters or groups. ArchR then aligns individual cells to this trajectory by computing the nearest cell-to-trajectory distance.",
      "asbval:note": "Paper confirms Slingshot is implemented in ArchR for trajectory analysis. The description of spline fitting through cluster centers is consistent with Slingshot's methodology.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "slingshot-trajectory-embedding",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Slingshot (Trajectory inference algorithm embedded in ArchR; computes pseudotime and lineage assignments via spline fitting through cluster centers)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:15:20.152464+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/slingshot-trajectory-embedding/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we present a software suite for single-cell analysis of regulatory chromatin in R (ArchR; https://www.archrproject.com/)",
      "asbval:note": "ArchR is explicitly an R package, confirming R as the underlying environment.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
