    {
      "@id": "asbval:assertion/skill/single-cell-atac-seq-dimensionality-reduction/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Before downstream analysis, we removed cells generating low-quality data. To assess per-cell data quality, ArchR computes transcription start site (TSS) enrichment scores",
      "asbval:note": "Paper describes quality filtering as a preprocessing step before dimensionality reduction, supporting the claim that LSI should be applied to preprocessed but not previously dimensionality-reduced data.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "single-cell-atac-seq-dimensionality-reduction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input data is already a low-dimensional embedding or has been previously dimensionality-reduced by another method\u2014apply this skill only on raw or minimally processed peak-by-cell matrices.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
