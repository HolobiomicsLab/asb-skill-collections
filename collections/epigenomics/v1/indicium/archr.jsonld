    {
      "@id": "asbval:assertion/skill/scatac-seq-peak-matrix-export/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR provides an intuitive, user-focused interface for complex single-cell analyses, including doublet removal, single-cell clustering and cell type identification, unified peak set generation, cellular trajectory identification, DNA element-to-gene linkage, transcription factor footprinting, mRNA expression level prediction from chromatin accessibility and multi-omic integration with single-cell RNA sequencing (scRNA-seq).",
      "asbval:note": "Paper confirms ArchR performs peak calling and trajectory analysis, but does NOT mention STREAM or any export function called 'exportPeakMatrixForSTREAM'. Paper explicitly states ArchR implements Slingshot and Monocle 3 for trajectory analysis (passage 12), not STREAM. No evidence of STREAM integration or peak matrix export to STREAM format.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "scatac-seq-peak-matrix-export",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
