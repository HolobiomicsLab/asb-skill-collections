    {
      "@id": "asbval:assertion/skill/single-cell-atac-seq-dimensionality-reduction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ArchR implements a new estimated LSI dimensionality reduction by first creating an iterative LSI reduction from a subset of the total cells and then linearly projecting the remaining cells into this subspace using LSI projection",
      "asbval:note": "Iterative LSI is explicitly described as a core ArchR feature for dimensionality reduction enabling clustering and trajectory analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41588-021-00790-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "single-cell-atac-seq-dimensionality-reduction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Reduce the dimensionality of scATAC-seq data using iterative latent semantic indexing (LSI) in ArchR to enable downstream clustering, visualization, and trajectory analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
