    {
      "@id": "asbval:assertion/card/task_001/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By default, it will extract bases/regions with a q-value <0.01 and %methylation difference >25%. These defaults can easily be changed when calling get.methyl Diff() function.",
      "asbval:note": "The paper explicitly describes the getMethylDiff() function (written as 'get.methyl Diff()' in the text) with the exact default thresholds mentioned in the research question.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2012-13-10-r87",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "When differentially methylated bases are extracted from a methylDiff object using getMethylDiff() with q-value < 0.01 and 25% methylation difference thresholds, what are the counts of hyper-methylated versus hypo-methylated bases?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:13:27.513254+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/card/task_001/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We have designed methylKit to allow a user to specify the parameters that define the DMCs/DMRs based on: q-value, %methylation difference, and type of differential methylation (hypo-/hyper-). By default, it will extract bases/regions with a q-value <0.01 and %methylation difference >25%.",
      "asbval:note": "The paper describes extraction of differentially methylated bases with specification of hyper- and hypo-methylation types, and Figure 5a shows visualization of hyper- and hypo-methylated base counts per chromosome.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2012-13-10-r87",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "methylDiff object containing differentially methylated bases with hyper- and hypo-methylated base counts",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:13:27.513254+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
