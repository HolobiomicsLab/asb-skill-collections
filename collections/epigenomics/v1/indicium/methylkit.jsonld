    {
      "@id": "asbval:assertion/skill/principal-component-analysis-visualization/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "methyl Kit can also be used to cluster samples hierarchically in a variety of ways. The user can specify the distance metric between samples ( ' 1 - correlation ' ' Euclidean ' , ' maximum ' , ' manhattan ' , ' canberra ' , ' binary ' or ' minkowski ' ) as well as the agglomeration method to be used in the hierarchical clustering algorithm (for example, ' Ward ' s method ' , or ' single/complete linkage ' , and so on).",
      "asbval:note": "Passage confirms hierarchical clustering with Ward's method and correlation distance is a separate feature from PCA, supporting the 'when NOT to use' guidance.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2012-13-10-r87",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "principal-component-analysis-visualization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: You need to perform clustering by correlation distance with Ward linkage \u2014 use clusterSamples() instead, which produces a dendrogram.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:19:40.573485+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
