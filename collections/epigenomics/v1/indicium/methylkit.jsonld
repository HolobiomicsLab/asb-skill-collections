      }
    },
    {
      "@id": "asbval:assertion/skill/hierarchical-dendrogram-interpretation/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Dendrogram plots will be color coded based on user defined groupings of samples.",
      "asbval:note": "While not explicitly stated, the requirement for multiple samples to generate meaningful dendrograms is a standard statistical principle confirmed by the paper's focus on multi-sample clustering and the example using seven breast cancer cell lines.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2012-13-10-r87",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "hierarchical-dendrogram-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Input is a single sample or fewer than two samples\u2014dendrograms require at least two samples to show relationships.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
