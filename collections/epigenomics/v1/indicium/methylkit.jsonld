    {
      "@id": "asbval:assertion/skill/methylbase-object-handling/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "methyl Kit can read and store (in memory) methylation data simultaneously for N-experiments, limited only by memory of the node or computer. The default setting of the processing algorithm requires that there be least 10 reads covering a base and each of the bases covering the genomic base position have at least 20 PHRED quality score.",
      "asbval:note": "Passages confirm methylKit's ability to handle multiple samples with coverage filtering; methylBase object creation via merging is implied in the multi-sample workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2012-13-10-r87",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "methylbase-object-handling",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Create and manipulate methylBase objects in methylKit by merging methylRaw samples across common genomic bases and applying coverage filters to ensure consistent sample representation for downstream differential methylation analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:18:58.434032+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
