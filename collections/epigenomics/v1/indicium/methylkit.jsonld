    {
      "@id": "asbval:assertion/skill/overdispersion-correction-application/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper describes two differential methylation methods: logistic regression and Fisher's exact test. No mention of 'MN' parameter, 'Methylation-specific Negative Binomial', or overdispersion correction in calculateDiffMeth() appears in any passage. The paper does not discuss overdispersion adjustment or negative binomial models for methylation analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2012-13-10-r87",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "overdispersion-correction-application",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply overdispersion correction in methylKit's calculateDiffMeth() function using the 'MN' (Methylation-specific Negative Binomial) parameter",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:19:25.233736+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/overdispersion-correction-application/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Following the differential methylation test and calculation of P-values, methyl Kit will use the sliding linear model (SLIM) method to correct P-values to q-values [31], which corrects for the problem of multiple hypothesis testing [32,33]. However, we also implemented the standard false discovery rate (FDR)-based method (Benjamini-Hochberg) as an option for P-value correction, which is faster but more conservative.",
      "asbval:note": "The paper discusses p-value and q-value correction methods (SLIM and Benjamini-Hochberg), but these are multiple-testing corrections, not overdispersion corrections. The claim about 'more stringent' distributions via overdispersion adjustment is not supported; the paper's stringency discussion relates to FDR methods, not variance adjustment.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2012-13-10-r87",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "overdispersion-correction-application",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "producing more stringent p-value and q-value distributions in differential methylation analysis",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:19:25.233736+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/overdispersion-correction-application/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not discuss overdispersion, excess variance, or binomial model assumptions in the context of bisulfite sequencing. No mention of biological or technical sources of variance beyond PCR duplication bias.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-gb-2012-13-10-r87",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "overdispersion-correction-application",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "variance in excess of binomial expectations, which is common in bisulfite sequencing due to biological and technical sources of variation",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:19:25.233736+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/overdispersion-correction-application/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not address overdispersion detection or correction in bisulfite sequencing analysis.",
