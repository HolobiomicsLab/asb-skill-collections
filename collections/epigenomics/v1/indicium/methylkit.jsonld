      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "methylKit: R package providing calculateDiffMeth(), dataSim(), and methylBase objects for differential methylation analysis with tunable overdispersion correction",
      "eco:evidence_type": {
