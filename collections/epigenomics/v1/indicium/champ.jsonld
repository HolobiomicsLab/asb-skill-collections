      }
    },
    {
      "@id": "asbval:assertion/skill/illumina-array-data-processing-epic/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ChAMP is an integrated analysis pipeline published in 2014 (Morris et al., 2014), which includes functions for filtering low-quality probes, adjustment for Infinium I and Infinium II probe design, batch effect correction, detecting differentially methylated positions (DMPs), finding differentially methylated regions (DMRs) and detection of copy number aberrations (CNA). The new version of ChAMP, extends and improves this analysis pipeline, adding novel and enhanced functionalities, including detection of differentially methylated genomic blocks (DMB)...",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx513",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "illumina-array-data-processing-epic",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "ChAMP - Primary analysis pipeline integrating data loading, quality control, normalization, batch correction, and DMR/block detection for EPIC and 450k methylation arrays",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:28:08.463605+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
