      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Array type is unknown or non-standard (e.g., mouse arrays or custom manifests); canonical probe counts apply only to human 450K and EPIC v1/v2.",
