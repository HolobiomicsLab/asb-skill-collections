      "@id": "asbval:assertion/skill/bead-count-threshold-filtering/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ChAMP is an integrated analysis pipeline published in 2014 (Morris et al., 2014), which includes functions for filtering low-quality probes, adjustment for Infinium I and Infinium II probe design, batch effect correction, detecting differentially methylated positions (DMPs), finding differentially methylated regions (DMRs) and detection of copy number aberrations (CNA).",
      "asbval:note": "Paper confirms ChAMP includes filtering of low-quality probes as part of quality control pipeline for both 450K and EPIC arrays.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx513",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "bead-count-threshold-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Quality control step eliminates unreliable measurements before downstream analysis on HumanMethylation450 or EPIC arrays",
      "eco:evidence_type": {
