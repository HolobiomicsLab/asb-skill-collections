    {
      "@id": "asbval:assertion/skill/interactive-visualization-interpretation-methylation-results/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The Illumina Infinium HumanMethylationEPIC BeadChip is the new platform for high-throughput DNA methylation analysis... Here we present a significantly updated and improved version of the Bioconductor package ChAMP, which can be used to analyze EPIC and 450k data... Notably, the new package provides a series of web-based graphical user interfaces (GUIs), which facilitate analyses and enhance user-experience.",
      "asbval:note": "Paper confirms ChAMP works with EPIC and 450k data and provides GUIs for analysis facilitation; scope aligns with paper's stated purpose.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx513",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "interactive-visualization-interpretation-methylation-results",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After running ChAMP detection functions (champ.Block(), DMR detection methods) on EPIC or 450k array data, when you need to inspect, validate, and interactively explore the spatial distribution, effect sizes, or prevalence of detected differentially methylated features",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:28:35.355133+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
