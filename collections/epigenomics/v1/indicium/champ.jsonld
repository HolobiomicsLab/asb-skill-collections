    {
      "@id": "asbval:assertion/skill/illumina-methylation-array-preprocessing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ChAMP is an integrated analysis pipeline published in 2014 (Morris et al., 2014), which includes functions for filtering low-quality probes, adjustment for Infinium I and Infinium II probe design, batch effect correction... Probes can be filtered based on detection P-values, chromosomal location, presence of single nucleotide polymorphisms in the probe sequence (Zhou et al., 2016) and cross-hybridization. For normalization, functional normalization (Fortin et al., 2014) has been added as an option alongside beta-mixture quantile normalization (Teschendorff et al., 2013).",
      "asbval:note": "Detection p-value filtering and normalization are explicitly mentioned. Type-2 probe correction (Infinium II adjustment) is mentioned as 'adjustment for Infinium I and Infinium II probe design'. Bead count filtering is not explicitly mentioned in passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx513",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "illumina-methylation-array-preprocessing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Preprocessing and quality control of Illumina methylation array data (450K and EPIC) via detection p-value and bead count filtering, followed by type-2 probe correction and normalization.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
