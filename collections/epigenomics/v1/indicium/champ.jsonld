    {
      "@id": "asbval:assertion/skill/dmr-detection-bumphunter/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The Illumina Infinium HumanMethylationEPIC BeadChip is the new platform for high-throughput DNA methylation analysis, effectively doubling the coverage compared to the older 450 K array. Here we present a significantly updated and improved version of the Bioconductor package ChAMP, which can be used to analyze EPIC and 450k data.",
      "asbval:note": "Paper explicitly states ChAMP analyzes both EPIC and 450k data.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx513",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "dmr-detection-bumphunter",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "EPIC or 450k methylation array data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:26:55.217561+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/dmr-detection-bumphunter/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For supervised analysis, besides limma-based DMP and ProbeLasso-based DMR analysis functions (Butcher and Beck, 2015), there is now added functionality for DMR detection using Bumphunter",
      "asbval:note": "Supervised analysis implies group comparisons; consistent with multi-group contrasts.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx513",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "dmr-detection-bumphunter",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "at least two sample groups (case/control, treatment/untreated, or similar contrasts)",
