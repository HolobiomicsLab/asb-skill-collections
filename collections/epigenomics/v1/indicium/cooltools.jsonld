    {
      "@id": "asbval:assertion/skill/contact-distance-binning-logarithmic/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To quantify P(s) at sub-kilobase resolution (Fig 2), cooltools avoids conversion from sparse-to-dense matrices. Instead, the calculation is done by iterating over chunks of pixels stored in coolers, assigning pixels to regions, and aggregating at each distance.",
      "asbval:note": "Paper describes P(s) calculation from cooler data but does not explicitly confirm the TSV format with those specific column names (dist_bp, contact_frequency, n_valid). The mechanism described is iterative aggregation from sparse cooler data, not necessarily from a pre-computed TSV table.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "contact-distance-binning-logarithmic",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input is a precomputed expected contact frequency table (TSV format with columns: dist_bp, contact_frequency, n_valid) derived from cooler files",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:01:48.891273+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/contact-distance-binning-logarithmic/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To reduce variation at large genomic separations due to increasing sparsity of the data, cooltools returns P(s) curves smoothed in log-space using a numba-accelerated approach. This also allows cooltools to more robustly compute the derivative of P(s) and observed-over-expected maps.",
      "asbval:note": "Log-space smoothing of P(s) curves is confirmed as a cooltools capability.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "contact-distance-binning-logarithmic",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Output is a log-binned P(s) contact probability curve with reduced noise and improved interpretability",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:01:48.891273+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/contact-frequency-aggregation-by-genomic-feature/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Pileups and average snippets: Different classes of genomic elements display distinct local contact patterns depending on their propensity to form features like boundaries or dots. These patterns are typically quantified by extracting local 2D contact maps, or snippets, and then averaging snippets to create pile-ups or average Hi-C maps.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
