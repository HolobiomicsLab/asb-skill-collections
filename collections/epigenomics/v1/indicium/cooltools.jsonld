    {
      "@id": "asbval:assertion/skill/cis-contact-frequency-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Contact frequency decreases rapidly with genomic separation within chromosomes, which arises because chromosomes are long polymers. This feature is interchangeably referred to as the: (i) expected because locus-specific features increase or decrease contact frequency relative to this major trend, (ii) scaling which is borrowed from the polymer physics literature, (iii) P(s), or contact probability, P, as a function of genomic separation, s.",
      "asbval:note": "The paper explicitly describes P(s) calculation for cis contacts and the distance-dependent decay pattern. The research question aligns with the 'Contacts-vs-distance & expected' module described in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cis-contact-frequency-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute and analyze contact frequency as a function of genomic distance within the same chromosome (cis contacts) using cooler-formatted Hi-C matrices. This is a foundational Hi-C analysis that reveals the prominent distance-dependent decay of chromatin contacts.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:01:19.471901+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/cis-contact-frequency-analysis/001",
