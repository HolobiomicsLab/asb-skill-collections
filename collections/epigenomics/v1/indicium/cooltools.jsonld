      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/genomic-coordinate-conversion/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For other types of genomic data besides Hi-C, the cooltools API accepts pandas dataframes, while the CLI reuses existing formats when possible: BED-like files for interval data and bedgraphs or bigwigs for genomic tracks.",
      "asbval:note": "Paper confirms cooltools works with BED-like formats and genomic interval data, and that outputs are pandas DataFrames. However, the paper does not explicitly describe a workflow for 'mapping bin indices back to genomic coordinates' or 'cross-referencing with external annotations' as a primary use case. The paper focuses on feature extraction, not coordinate conversion per se.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "genomic-coordinate-conversion",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When to use: map computed per-bin metrics (insulation scores, boundary calls, contact frequencies) back to genomic coordinates for export to BED/GFF format, cross-reference with external annotations, or validate that computed features fall within expected genomic ranges",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
