    {
      "@id": "asbval:assertion/skill/compartment-strength-quantification/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools calculates compartmentalization profiles using matrix eigenvector decomposition (Fig 3)... Cooltools allows users to request an arbitrary number of eigenvectors and can sort and orient eigenvectors according to a provided 'phasing track'... To quantify these preferences with cooltools saddle (Fig 4), the approach is to: (i) group bins with similar properties into classes, (ii) average over all map pixels specified by the bins in each pair of classes.",
      "asbval:note": "Passage describes the workflow: eigenvector extraction, binning/discretization into classes, and saddle computation for compartment quantification.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "compartment-strength-quantification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When you have a binned Hi-C cooler file, an associated eigenvector track (from prior eigs_cis calculation), and need to measure how strongly the genome is partitioned into active (A) and inactive (B) compartments.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
