    {
      "@id": "asbval:assertion/skill/cis-contact-frequency-analysis/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To quantify P(s) at sub-kilobase resolution (Fig 2), cooltools avoids conversion from sparse-to-dense matrices. Instead, the calculation is done by iterating over chunks of pixels stored in coolers, assigning pixels to regions, and aggregating at each distance... To reduce variation at large genomic separations due to increasing sparsity of the data, cooltools returns P(s) curves smoothed in log-space using a numba-accelerated approach.",
      "asbval:note": "The paper describes cooltools' P(s) calculation and smoothing functionality in detail.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cis-contact-frequency-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[0].role",
      "asbval:target_claim_text": "primary analysis library providing cis contact frequency computation and curve smoothing functions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
