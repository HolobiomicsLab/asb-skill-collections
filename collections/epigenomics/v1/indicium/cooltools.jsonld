    {
      "@id": "asbval:assertion/skill/contact-distance-binning-logarithmic/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools leverages the widely-adopted cooler format which handles storage and access for high-resolution datasets. Cooltools is built directly on top of the cooler storage format and library, which allows it to operate on sparse matrices and/or out-of-core, either on raw counts or normalized contact matrices.",
      "asbval:note": "Cooler's role in storing and providing access to Hi-C contact data is clearly established.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "contact-distance-binning-logarithmic",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "cooler stores and provides access to high-resolution Hi-C contact matrices from which expected contact frequencies are precomputed",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
