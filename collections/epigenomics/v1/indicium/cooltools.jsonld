    {
      "@id": "asbval:assertion/skill/saddle-matrix-computation-from-binned-tracks/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Leverage the Python data science stack to promote interoperability. Cooltools delegates to numpy, scipy, and pandas when possible and aims to follow the style of these APIs. To accelerate specific low-level computations, cooltools uses the just-in-time compiler numba",
      "asbval:note": "Paper confirms cooltools uses NumPy and SciPy as computational backends within Python.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "saddle-matrix-computation-from-binned-tracks",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Python execution environment and NumPy/SciPy backend",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:05:40.630076+00:00",
