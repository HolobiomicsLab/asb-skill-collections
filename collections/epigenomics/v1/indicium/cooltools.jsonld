      }
    },
    {
      "@id": "asbval:assertion/skill/contact-frequency-smoothing-log-space/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The shape of P(s) reflects folding patterns at different length scales, from those of adjacent nucleosomes to full chromosomes. P(s) varies through the cell cycle, across cell types, and is modified by structural maintenance of chromosomes complexes (SMCs) in interphase, mitosis, and meiosis.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
