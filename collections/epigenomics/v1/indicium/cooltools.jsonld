      }
    },
    {
      "@id": "asbval:assertion/skill/cooler-file-format-handling/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Currently, the standard binned formats used by the 4D Nucleome project [2] and others are: (i).cool, the hdf5-based storage format used by cooler [8], and (ii).hic, the custom binary format generated by Juicer [12]... only cooltools and FAN-C both have a Python API and accept input files with a standard binned Hi-C format.",
      "asbval:note": "Paper distinguishes .cool from .hic (Juicer) format; scope statement is consistent with paper's format discussion.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cooler-file-format-handling",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Your Hi-C data is in a different format (e.g., text-based .hic, Juicer, or raw BAM files); use format conversion tools first.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
