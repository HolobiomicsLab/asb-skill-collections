    {
      "@id": "asbval:assertion/skill/contact-frequency-aggregation-by-genomic-feature/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For other types of genomic data besides Hi-C, the cooltools API accepts pandas dataframes, while the CLI reuses existing formats when possible: BED-like files for interval data and bedgraphs or bigwigs for genomic tracks.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
