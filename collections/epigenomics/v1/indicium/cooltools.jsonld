    {
      "@id": "asbval:assertion/skill/contact-frequency-aggregation-by-genomic-feature/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For cis profiles, cooltools first adjusts the contact matrix for distance dependence before decomposition. For trans profiles, cooltools implements the ICE approach which masks cis portions of the map with randomly sampled trans data.",
      "asbval:note": "ICE normalization is mentioned as a supported approach in cooltools",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "contact-frequency-aggregation-by-genomic-feature",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input Hi-C data has not been normalized for sequencing depth or bin-level biases; apply iterative correction or ICE normalization first.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:02:01.456735+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/contact-frequency-aggregation-by-genomic-feature/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To calculate pileups (Fig 7), cooltools first retrieves snippets for the specified set of anchors, a procedure termed snipping. Pileups can be built either directly from observed contact map snippets or from snippets normalized by a specified expected table. This is especially useful when the pileups are created for regions with different P(s), and specific expected tables are used for different regions. Users can also specify their choice of balancing weights or whether to calculate pileups directly on raw data. Multiprocessing can be specified to speed up snipping for large sets of anchors.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "contact-frequency-aggregation-by-genomic-feature",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "cooltools provides pileup and aggregation API to stack Hi-C contacts around feature coordinates and compute average interaction matrices",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:02:01.456735+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/contact-frequency-aggregation-by-genomic-feature/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools leverages the widely-adopted cooler format which handles storage and access for high-resolution datasets. Cooler handles storage and access for high-resolution datasets via a sparse data model.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "contact-frequency-aggregation-by-genomic-feature",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "cooler stores and retrieves binned Hi-C contact matrices in a sparse, efficient HDF5-based format compatible with pileup operations",
      "eco:evidence_type": {
