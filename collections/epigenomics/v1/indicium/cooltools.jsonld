    {
      "@id": "asbval:assertion/skill/boundary-detection-thresholding/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not specify minimum resolution thresholds for insulation reliability. Paper mentions cooltools can calculate insulation at 1kb and 10kb resolution (S1 Fig benchmark), and references nucleotide-resolution pileups, but does not state that insulation becomes unreliable below 5 kb.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "no",
