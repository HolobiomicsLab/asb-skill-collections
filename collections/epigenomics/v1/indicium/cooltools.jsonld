      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Python is the host language for cooltools API and data manipulation (NumPy, Pandas for table I/O and processing)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
