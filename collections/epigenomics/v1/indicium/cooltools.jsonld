    {
      "@id": "asbval:assertion/skill/hi-c-coverage-track-computation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools leverages the widely-adopted cooler format which handles storage and access for high-resolution datasets. Cooltools provides a paired command line interface (CLI) and Python application programming interface (API)... cooltools enables the effective use of the latest and largest genome folding datasets.",
      "asbval:note": "Paper confirms cooltools works with cooler files (.cool, .mcool) for Hi-C analysis. Coverage computation is described as a tool for quality control and analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "hi-c-coverage-track-computation",
