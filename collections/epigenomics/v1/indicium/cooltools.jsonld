    {
      "@id": "asbval:assertion/skill/hi-c-coverage-track-computation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools provides a paired command line interface (CLI) and Python application programming interface (API)... Here we introduce cooltools (https://github.com/open2c/cooltools), a suite of computational tools that enables flexible, scalable, and reproducible analysis of high-resolution contact frequency data.",
      "asbval:note": "Paper explicitly states cooltools is a Python package with Python API. Python is the execution environment.",
