    {
      "@id": "asbval:assertion/skill/tsv-file-io-and-formatting/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools provides a paired command line interface (CLI) and Python application programming interface (API)... Cooltools leverages the widely-adopted cooler format which handles storage and access for high-resolution datasets... The user-facing API and CLI both have a standard format for arguments and take a cooler as their first input. For other types of genomic data besides Hi-C, the cooltools API accepts pandas dataframes, while the CLI reuses existing formats when possible: BED-like files for interval data and bedgraphs or bigwigs for genomic tracks.",
      "asbval:note": "Paper confirms cooltools works with tabular data via pandas dataframes and accepts various formats (BED-like, bedgraphs, bigwigs), but does not explicitly demonstrate TSV I/O for expected contact frequency tables or mention logbin_expected smoothing in the context of TSV file interchange. The paper focuses on cooler HDF5 format as primary input.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "tsv-file-io-and-formatting",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Load, validate, and save tabular genomic data (e.g., precomputed expected contact frequency tables) as tab-separated values with proper column headers and numeric precision. This skill ensures reproducible interchange of Hi-C-derived frequency tables and their smoothed derivative",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:06:06.308998+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/tsv-file-io-and-formatting/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To reduce variation at large genomic separations due to increasing sparsity of the data, cooltools returns P(s) curves smoothed in log-space using a numba-accelerated approach.",
      "asbval:note": "Paper mentions log-space smoothing of P(s) curves but does not name the function 'logbin_expected' explicitly. The smoothing is described as a numba-accelerated approach applied to P(s) calculation, not as a separate TSV-based operation.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "tsv-file-io-and-formatting",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
