    {
      "@id": "asbval:assertion/skill/saddle-matrix-computation-from-binned-tracks/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools calculates compartmentalization profiles using matrix eigenvector decomposition (Fig 3). For cis profiles, cooltools first adjusts the contact matrix for distance dependence before decomposition... Cooltools allows users to request an arbitrary number of eigenvectors and can sort and orient eigenvectors according to a provided \"phasing track\"",
      "asbval:note": "Paper describes eigenvector computation from Hi-C matrices and their use in downstream analyses like saddle plots.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "saddle-matrix-computation-from-binned-tracks",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have a cooler Hi-C contact matrix file and an associated eigenvector track (from prior eigs_cis calculation or similar)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:05:40.630076+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/saddle-matrix-computation-from-binned-tracks/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A second prominent signal in mammalian interphase contact maps is plaid patterns that appear both within and between chromosomes, termed chromosome compartments. These plaid patterns reflect tendencies of chromosome regions to make more frequent contacts with regions of the same type: active regions have increased contact frequency with other active regions, and inactive regions tend to contact other inactive regions more frequently.",
      "asbval:note": "Paper describes A/B compartment interaction patterns and their quantification via saddle plots.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "saddle-matrix-computation-from-binned-tracks",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "quantify the preferential interaction patterns between A and B chromatin compartments",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:05:40.630076+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
