    {
      "@id": "asbval:assertion/skill/editable-development-mode-installation-and-verification/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools leverages the widely-adopted cooler format which handles storage and access for high-resolution datasets. Cooltools is built directly on top of the cooler storage format and library, which allows it to operate on sparse matrices and/or out-of-core, either on raw counts or normalized contact matrices.",
      "asbval:note": "Paper explicitly confirms cooler is a core dependency and upstream library that cooltools builds upon.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "editable-development-mode-installation-and-verification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "cooler as upstream library dependency for .cool file format handling",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:02:53.877274+00:00",
      "sepio:credibility_status": {
