    {
      "@id": "asbval:assertion/skill/cooler-file-format-handling/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools enables users to extract key features seen in 3C maps, including: the decay of contact frequency with genomic distance, plaid patterns of active and inactive compartments, domains, and dots. Cooltools quantifies these folding features from raw contact data efficiently... The user-facing API and CLI both have a standard format for arguments and take a cooler as their first input.",
      "asbval:note": "Paper confirms cooler as input format for cooltools functions; coverage and insulation are explicitly documented modules.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cooler-file-format-handling",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When to use: You have a Hi-C dataset stored in cooler format (e.g., from a public repository, GEO, or Zenodo, or generated by a contact-calling pipeline) and need to programmatically load it, inspect its structure (bins, chromosomes, resolution), verify data integrity, or pass it",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:02:29.073779+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/cooler-file-format-handling/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Return widely-used Python data structures, pandas dataframes, and numpy arrays, for user-facing outputs... Cooltools delegates to numpy, scipy, and pandas when possible",
      "asbval:note": "Paper confirms cooler outputs to numpy/pandas; scope statement is consistent with paper's design philosophy of interoperability.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cooler-file-format-handling",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Input is already loaded as a numpy/scipy sparse matrix or pandas DataFrame and you do not need cooler's metadata or hierarchical access features.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
