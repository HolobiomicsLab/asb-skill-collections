      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:06:06.308998+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/tsv-file-io-and-formatting/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools leverages the widely-adopted cooler format which handles storage and access for high-resolution datasets... Cooler handles storage and access for high-resolution datasets via a sparse data model.",
      "asbval:note": "Cooler is confirmed as the HDF5 storage format for Hi-C data. Paper confirms cooler is the primary input format for cooltools.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
