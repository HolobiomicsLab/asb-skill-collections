      }
    },
    {
      "@id": "asbval:assertion/skill/contact-distance-binning-logarithmic/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To reduce variation at large genomic separations due to increasing sparsity of the data, cooltools returns P(s) curves smoothed in log-space using a numba-accelerated approach.",
      "asbval:note": "Paper describes log-space smoothing of P(s) curves but does not explicitly name a 'logbin_expected' function or describe logarithmic binning as a discrete binning operation. The paper states cooltools performs log-space smoothing but does not detail the specific binning mechanism claimed in the card.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "contact-distance-binning-logarithmic",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply logarithmic binning to genomic distance values in a precomputed contact frequency table, grouping distances into log-spaced bins and smoothing contact frequencies within each bin to produce a log-binned P(s) contact probability curve.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
