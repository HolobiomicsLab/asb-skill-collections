    {
      "@id": "asbval:assertion/skill/cooler-file-format-handling/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools provides a paired command line interface (CLI) and Python application programming interface (API)... To fully leverage the advantages of cooler, however, requires a corresponding analysis framework in Python.",
      "asbval:note": "Paper confirms cooler is foundational for downstream analysis; cooltools is built on cooler for this purpose.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cooler-file-format-handling",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
