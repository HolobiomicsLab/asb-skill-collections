    {
      "@id": "asbval:assertion/skill/contact-frequency-aggregation-by-genomic-feature/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To calculate pileups (Fig 7), cooltools first retrieves snippets for the specified set of anchors, a procedure termed snipping. Pileups can be built either directly from observed contact map snippets or from snippets normalized by a specified expected table.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
