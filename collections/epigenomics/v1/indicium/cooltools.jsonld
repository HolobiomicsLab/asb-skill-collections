    {
      "@id": "asbval:assertion/skill/contact-frequency-smoothing-log-space/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To reduce variation at large genomic separations due to increasing sparsity of the data, cooltools returns P(s) curves smoothed in log-space using a numba-accelerated approach. This also allows cooltools to more robustly compute the derivative of P(s) and observed-over-expected maps.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "contact-frequency-smoothing-log-space",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply logarithmic binning and smoothing to precomputed expected contact frequency tables to produce log-binned, smoothed contact probability P(s) curves suitable for Hi-C distance decay analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:02:17.504208+00:00",
      "sepio:credibility_status": {
