    {
      "@id": "asbval:assertion/skill/contact-frequency-smoothing-log-space/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools provides a paired command line interface (CLI) and Python application programming interface (API), which respectively facilitate workflows on high-performance computing clusters and in interactive analysis environments. Leverage the Python data science stack to promote interoperability. Cooltools delegates to numpy, scipy, and pandas when possible.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
