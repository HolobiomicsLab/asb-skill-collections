    {
      "@id": "asbval:assertion/skill/python-pandas-data-manipulation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Cooltools provides a paired command line interface (CLI) and Python application programming interface (API), which respectively facilitate workflows on high-performance computing clusters and in interactive analysis environments.",
      "asbval:note": "Confirmed: cooltools is a Python package with a Python API. Paper emphasizes Python ecosystem integration (numpy, scipy, pandas, scikit-learn).",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
