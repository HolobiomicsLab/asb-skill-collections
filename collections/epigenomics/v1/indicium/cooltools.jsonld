      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/contact-distance-binning-logarithmic/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "No mention of a function named 'logbin_expected' appears in any passage. The paper describes log-space smoothing of P(s) curves using numba acceleration but does not name this specific function or confirm it is called 'logbin_expected'.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
