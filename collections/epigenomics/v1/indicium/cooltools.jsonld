    {
      "@id": "asbval:assertion/skill/eigenvector-digitization-into-compartment-bins/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To obtain cis compartments profiles, observed maps are first divided by expected. Observed/expected maps are decomposed into a sum of eigenvectors and associated eigenvalues.",
      "asbval:note": "Paper describes eigenvector computation from Hi-C matrices via eigendecomposition.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
