    {
      "@id": "asbval:assertion/skill/python-package-api-interface-design/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we introduce cooltools (https://github.com/open2c/cooltools), a suite of computational tools that enables flexible, scalable, and reproducible analysis of high-resolution contact frequency data... Cooltools provides a paired command line interface (CLI) and Python application programming interface (API)... The high-level API enables users to reproducibly perform routine analysis. The low-level API allows for troubleshooting challenges posed by new organisms or cell states and developing new advanced analyses.",
      "asbval:note": "Paper explicitly describes cooltools as a Python package with paired API and CLI, modular design, and documentation via interactive notebooks.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1012067",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "python-package-api-interface-design",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Design and document a well-structured Python package API that exposes utility functions through organized subpackages (e.g., cooltools.lib) with clear imports, stable interfaces, and comprehensive Sphinx documentation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T18:05:05.207285+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
