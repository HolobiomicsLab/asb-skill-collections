    {
      "@id": "asbval:assertion/skill/barcode-fragment-mapping/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We utilized a human single-cell atlas of chromatin accessibility for this comparison. This atlas, which we previously published, comprises 92 scATAC-seq samples, around 650,000 cells, and more than 23 billion raw reads, totaling a data size of 1.6 TB.",
      "asbval:note": "Paper mentions use of 10x ATAC-seq data in benchmarking (e.g., '10x brain 5k', '10x PBMC 10k', '10x Multiome' in Table 1), but does not explicitly discuss 10X BAM files as input to pp.make_fragment_file.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "barcode-fragment-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope - inputs",
