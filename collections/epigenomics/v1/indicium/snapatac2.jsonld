    {
      "@id": "asbval:assertion/skill/cluster-umap-layout-reproducibility-benchmarking/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The core of SnapATAC2 is its embedding/clustering module, which introduces a new algorithm for reducing data dimensions. This module also helps in identifying unique cell clusters and revealing biological patterns... We applied this matrix-free multi-view spectral embedding algorithm to a 10x Genomics Multiome dataset, which jointly profiles chromatin accessibility and the transcriptome for 9,181 human peripheral blood mononuclear cells (PBMCs).",
      "asbval:note": "Paper demonstrates the full pipeline: spectral embedding (tl.spectral equivalent), Leiden clustering (tl.leiden), and UMAP visualization on multiome data.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cluster-umap-layout-reproducibility-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have executed an end-to-end SnapATAC2 pipeline on the pbmc10k_multiome dataset... after calling tl.spectral, tl.leiden, and tl.umap",
