      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We have implemented these algorithmic advancements in a Python package called SnapATAC2... The core of SnapATAC2 is its embedding/clustering module, which introduces a new algorithm for reducing data dimensions.",
      "asbval:note": "SnapATAC2 confirmed as providing spectral embedding (tl.spectral function mentioned in Methods). CSR matrix infrastructure implied by sparse matrix handling.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
