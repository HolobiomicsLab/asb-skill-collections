      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To further improve scalability when handling large-scale single-cell data, on-disk data structures and out-of-core algorithms are used whenever possible. These modifications facilitate the analysis of large datasets without overburdening system resources.",
      "asbval:note": "Paper discusses scalability for large datasets and uses efficient data structures, but does not explicitly mention CSR format or a specific 10-million-cell threshold. The paper demonstrates scalability up to 200,000 cells in benchmarks and mentions handling 'hundreds of millions of cells' conceptually via Nystr\u00f6m method, but does not detail CSR format initialization as a primary task.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "large-scale-single-cell-matrix-loading",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Load and initialize single-cell count matrices with \u226510 million cells in compressed sparse row (CSR) format for scalable downstream analysis",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
