    {
      "@id": "asbval:assertion/skill/spectral-embedding-dimension-reduction-parameters/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We applied graph-based clustering using the Leiden algorithm and assessed the clustering quality with the adjusted Rand index (ARI)",
      "asbval:note": "Leiden algorithm confirmed as used for clustering after spectral embedding.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
