      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "AnnData is a container format for sparse matrix storage and lazy evaluation; supports CSR and other sparse formats via backed/on-disk storage",
