      }
    },
    {
      "@id": "asbval:assertion/skill/large-scale-single-cell-matrix-loading/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For massive datasets with hundreds of millions of cells, storing the cell-by-feature count matrix itself may already be a challenge. To circumvent this memory constraint, we choose to sample a subset of cells from the full dataset and use these as landmarks to perform out-of-sample embedding using the Nystr\u00f6m method.",
      "asbval:note": "Paper mentions 'hundreds of millions of cells' and Nystr\u00f6m method for out-of-sample embedding, but the primary benchmarks use up to 200,000 cells. The 10-million-cell threshold is not explicitly stated in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "large-scale-single-cell-matrix-loading",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have a single-cell count matrix with 10 million or more cells",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:46:08.264434+00:00",
      "sepio:credibility_status": {
