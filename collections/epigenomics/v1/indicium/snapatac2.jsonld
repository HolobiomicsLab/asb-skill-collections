    {
      "@id": "asbval:assertion/skill/spectral-embedding-dimension-reduction-parameters/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "UMAP visualization of the embeddings generated by the best performing method (SnapATAC2)... t-distributed stochastic neighbor embedding and uniform manifold approximation and projection (UMAP) are two widely used algorithms for this purpose",
      "asbval:note": "UMAP confirmed as visualization method applied to embeddings.",
