    {
      "@id": "asbval:assertion/skill/peak-calling-pseudo-bulk-aggregation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We began by converting each cell's square region-by-region contact map into a vector. These vectors were then used to construct a sparse matrix representing all cells' contact maps. We used the 'snapatac2.pp.select_features' function to identify the top 500,000 features based on total counts.",
      "asbval:note": "Paper describes tile-based matrix construction and sparse matrix handling for single-cell data, consistent with the scope description.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "peak-calling-pseudo-bulk-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input is sparse, per-cell insertion counts organized in a tile matrix; cells have been assigned to discrete clusters",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
