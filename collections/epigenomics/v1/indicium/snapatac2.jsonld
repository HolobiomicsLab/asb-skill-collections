        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/sparse-matrix-validation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We began by converting each cell's square region-by-region contact map into a vector. These vectors were then used to construct a sparse matrix representing all cells' contact maps. We used the 'snapatac2.pp.select_features' function to identify the top 500,000 features based on total counts.",
      "asbval:note": "Paper mentions SnapATAC2 functions for feature selection and matrix construction but does not explicitly name pp.add_tile_matrix, pp.make_peak_matrix, or pp.make_gene_matrix. The paper does reference matrix generation and feature selection but not the specific function names claimed.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "sparse-matrix-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After generating a count matrix from fragment data using pp.add_tile_matrix, pp.make_peak_matrix, or pp.make_gene_matrix in SnapATAC2.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:48:35.390303+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
