      "asbval:target_claim_text": "SnapATAC2 is the primary framework for loading, initializing, and storing CSR-backed matrices; integrates scipy.sparse backend with AnnData",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
