    {
      "@id": "asbval:assertion/skill/leiden-clustering-resolution-optimization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After dimensionality reduction, we applied graph-based clustering using the Leiden algorithm34 and assessed the clustering quality with the adjusted Rand index (ARI), which measures the similarity between two data clusterings and has been routinely used to assess the performance of clustering algorithms22,35. We hypothesized that high-quality embeddings should yield clusters consistent with the ground-truth cell-type labels, and hence resulted in high ARI scores.",
      "asbval:note": "Paper explicitly applies Leiden clustering to spectral embeddings across multiple omics types (scATAC-seq, scRNA-seq, scHi-C) and validates cluster quality against reference labels.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "leiden-clustering-resolution-optimization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply Leiden clustering to single-cell omics data (ATAC-seq, RNA-seq, Hi-C, methylation) with parameter tuning to identify optimal resolution values that yield biologically meaningful cluster assignments.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:46:29.053577+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/leiden-clustering-resolution-optimization/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We generated a k-NN graph from cell embeddings with k set at 50. Using this graph, we applied the Leiden algorithm34 to obtain cell clusters.",
      "asbval:note": "Paper describes applying Leiden algorithm to k-NN graphs derived from spectral embeddings.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "leiden-clustering-resolution-optimization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "running the tl.leiden method on spectral embeddings",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:46:29.053577+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/leiden-clustering-resolution-optimization/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To assess the bio-conservation quality of the cell embeddings generated by each method, we used a suite of metrics: the ARI, adjusted mutual information (AMI), cell-type average silhouette width (cell-type ASW)43 and graph integration local inverse Simpson's index (graph iLISI)43.",
      "asbval:note": "Paper validates cluster quality using ARI and other metrics comparing to known cell-type labels.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "leiden-clustering-resolution-optimization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "validating cluster quality through comparison with reference assignments",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:46:29.053577+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/leiden-clustering-resolution-optimization/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Given that the number of cell types in our benchmarking datasets is known, we fine-tuned the Leiden algorithm's resolution parameter between 0.1 and 3.0 in increments of 0.1 to match the actual number of clusters.",
      "asbval:note": "Paper explicitly describes resolution parameter tuning for Leiden algorithm.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "leiden-clustering-resolution-optimization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "parameter tuning to identify optimal resolution values",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:46:29.053577+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
