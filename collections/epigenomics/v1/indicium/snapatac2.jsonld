    {
      "@id": "asbval:assertion/skill/spectral-embedding-scalability-benchmarking/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The key innovation of our algorithm is the use of a matrix-free spectral embedding algorithm to project single-cell omics data into a low-dimensional space... This strategy substantially shortens the time and space complexity, making it linearly proportional to the number of cells in the single-cell data.",
      "asbval:note": "Paper validates linear scaling up to 200,000 cells (Fig. 1c,d), not 10 million cells. The card claims benchmarking at '10 million or more cells' but paper's largest benchmark is 200,000 cells. The linear complexity claim is supported, but the specific scale (10M+) is not demonstrated in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectral-embedding-scalability-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Benchmark the matrix-free spectral embedding algorithm (tl.spectral) in SnapATAC2 to validate its claimed linear time and space complexity when applied to single-cell datasets of 10 million or more cells.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:49:08.382946+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
