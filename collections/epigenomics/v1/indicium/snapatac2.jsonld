    {
      "@id": "asbval:assertion/skill/tile-matrix-generation-counting-strategy-selection/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The core of SnapATAC2 is its embedding/clustering module, which introduces a new algorithm for reducing data dimensions... we used the 'snapatac2.tl.spectral' function to generate the lower-dimensional embedding of the data.",
      "asbval:note": "The paper explicitly mentions 'snapatac2.tl.spectral' function used for dimensionality reduction.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tile-matrix-generation-counting-strategy-selection",
