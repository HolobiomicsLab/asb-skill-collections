    {
      "@id": "asbval:assertion/skill/anndata-backed-object-manipulation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To further improve scalability when handling large-scale single-cell data, on-disk data structures and out-of-core algorithms are used whenever possible. These modifications facilitate the analysis of large datasets without overburdening system resources.",
      "asbval:note": "Paper confirms SnapATAC2 uses on-disk data structures and out-of-core algorithms for scalability, but does not explicitly mention 'backed AnnData objects' or the specific AnnData backing mechanism. The paper states SnapATAC2 'adopts the AnnData format' and is 'modular and adaptable' but does not detail the backed AnnData workflow or fragment data storage in backed mode as the primary mechanism.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "anndata-backed-object-manipulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Manipulate fully backed AnnData objects to store and access single-cell omics fragment data and count matrices without loading entire datasets into memory. This skill enables scalable preprocessing and matrix operations on datasets exceeding 10 million cells by leveraging on-disk",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:42:47.775553+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
