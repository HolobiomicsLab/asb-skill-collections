    {
      "@id": "asbval:assertion/skill/cosine-similarity-metric-application/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SnapATAC2 is modular and adaptable, and allows users to tailor their analysis to specific requirements and integrate with other software packages from the scverse ecosystem, such as SCANPY and scvi-tools.",
      "asbval:note": "Integration with SCANPY (case-insensitive match) is confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
