      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/sparse-matrix-validation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The preprocessing module handles raw BAM files, assesses data quality, creates count matrices and spots doublets, ensuring a strong base for downstream analysis.",
      "asbval:note": "Paper mentions quality assessment and count matrix creation but does not explicitly detail validation of matrix dimensions, sparsity structure, or non-zero entry distribution. The paper focuses on downstream analysis (dimensionality reduction, clustering) rather than matrix validation itself.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "sparse-matrix-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill verifies that tile-based or peak-based count matrices possess expected dimensions, contain appropriately distributed non-zero entries across cells and genomic features, and reflect genuine chromatin accessibility signal.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
