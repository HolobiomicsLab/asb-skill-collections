    {
      "@id": "asbval:assertion/skill/peak-calling-pseudo-bulk-aggregation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The preprocessing module handles raw BAM files, assesses data quality, creates count matrices and spots doublets, ensuring a strong base for downstream analysis. The core of SnapATAC2 is its embedding/clustering module, which introduces a new algorithm for reducing data dimensions. This module also helps in identifying unique cell clusters and revealing biological patterns. The functional enrichment module offers detailed data interpretation like differential accessibility and motif analysis.",
      "asbval:note": "Paper describes SnapATAC2's preprocessing, clustering, and functional enrichment modules but does NOT explicitly mention MACS3 peak calling or pseudo-bulk aggregation by cluster. The paper focuses on spectral embedding for dimensionality reduction and clustering via Leiden algorithm, but peak-calling methodology is not detailed in the provided passages. The card claims MACS3 is used; the paper does not name MACS3 in the passages provided.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "peak-calling-pseudo-bulk-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Aggregate single-cell ATAC-seq fragments into pseudo-bulk samples grouped by cluster assignment, then call peaks using MACS3 to identify chromatin-accessible regions that are consistent within cell populations.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:47:40.250801+00:00",
      "sepio:credibility_status": {
