    {
      "@id": "asbval:assertion/skill/large-scale-single-cell-matrix-loading/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This strategy substantially shortens the time and space complexity, making it linearly proportional to the number of cells in the single-cell data.",
      "asbval:note": "Paper explicitly emphasizes linear time and space complexity as a core innovation.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "large-scale-single-cell-matrix-loading",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "memory efficiency and linear-time complexity are critical",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
