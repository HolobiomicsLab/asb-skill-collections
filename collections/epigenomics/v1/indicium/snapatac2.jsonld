    {
      "@id": "asbval:assertion/skill/tile-matrix-generation-counting-strategy-selection/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SnapATAC2 offers a unique advantage in its seamless compatibility with other software tools widely used in the single-cell analytics ecosystem. By adopting the AnnData format, it facilitates effortless integration with established packages like SCANPY, scvi-tools and SCENIC+.",
      "asbval:note": "Paper confirms SnapATAC2 uses AnnData format for data storage and integration.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tile-matrix-generation-counting-strategy-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "AnnData - Data container that stores tile matrix, cell metadata, and tile coordinates",
