    {
      "@id": "asbval:assertion/skill/single-cell-epigenomics-peak-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SnapATAC2 is a comprehensive, high-performance solution for single-cell omics data analysis... The core of SnapATAC2 is its embedding/clustering module, which introduces a new algorithm for reducing data dimensions... The functional enrichment module offers detailed data interpretation like differential accessibility and motif analysis.",
      "asbval:note": "Paper describes SnapATAC2's spectral embedding for dimensionality reduction and functional enrichment including motif analysis on scATAC-seq data.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "single-cell-epigenomics-peak-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Identifies and characterizes chromatin accessibility peaks in single-cell ATAC-seq data using spectral embedding and peak-calling algorithms. This skill enables discovery of cell-type-specific regulatory regions and their enrichment for transcription factor motifs.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T19:48:15.274155+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/single-cell-epigenomics-peak-analysis/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We have implemented these algorithmic advancements in a Python package called SnapATAC2. This package is a major revamp of the original SnapATAC, offering substantial improvements such as increased speed, reduced memory usage, more reliable performance and a comprehensive analysis framework for diverse single-cell omics data. SnapATAC2 is freely available at https://github.com/kaizhang/SnapATAC2/.",
      "asbval:note": "SnapATAC2 is the primary tool described in the paper for single-cell ATAC-seq analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-023-02139-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "single-cell-epigenomics-peak-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "SnapATAC2",
      "eco:evidence_type": {
