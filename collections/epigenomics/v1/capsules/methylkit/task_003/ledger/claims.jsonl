{"claim_id": "claim_001", "text": "methylKit is an R package for DNA methylation analysis and annotation from high-throughput bisulfite sequencing.", "claim_type": "explicit", "source_excerpt": "for DNA methylation analysis and annotation from high-throughput bisulfite sequencing.", "source_anchor": {"source_path": "/Users/nothiasl/git/AgenticScienceBuilder/outputs/asbb_epigenomics/coll_methylkit/synthesized_package", "source_section": "intro", "page": null, "char_span": [1171, 1257], "figure_id": null, "table_id": null}, "source_type": "text", "evidence_type": "knowledge", "trace_status": "exact_match", "evidence_type_uri": "http://purl.obolibrary.org/obo/ECO_0000302", "source_type_uri": "http://purl.obolibrary.org/obo/IAO_0000311", "super_pattern": null, "source_doi": null, "spine_entity_ids": ["methylKit_system"]}
