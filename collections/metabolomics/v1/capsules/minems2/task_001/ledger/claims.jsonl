{"claim_id": "claim_005", "text": "The dataset contains 51 MS/MS spectra from secondary metabolites of Penicillium nordicum.", "claim_type": "explicit", "source_excerpt": "The dataset contains **51 MS/MS spectra** from secondary metabolites of *Penicillium nordicum* (one spectrum per compound) acquired on an HPLC system (Luna C18 column; Phenomenex) coupled to an LTQ Orbitrap XL hybrid (Thermo Fisher Scientific) operated in the positive ionization mode at a HCD20 collision energy and a resolution of 7,500 [@Hautbergue2019].", "source_anchor": {"source_path": "/Users/nothiasl/git/AgenticScienceBuilder/outputs/asbb_pilot/coll_minems2/synthesized_package", "source_section": "intro", "page": null, "char_span": [1156, 1397], "figure_id": null, "table_id": null}, "source_type": "text", "evidence_type": "data", "trace_status": "exact_match", "evidence_type_uri": "http://purl.obolibrary.org/obo/ECO_0000006", "source_type_uri": "http://purl.obolibrary.org/obo/IAO_0000311", "super_pattern": {"context": "Penicillium nordicum metabolomics study", "subject": "dataset", "qualifier": "has_property", "relation": "contains 51 MS/MS spectra", "object": "51 spectra"}, "source_doi": null, "spine_entity_ids": ["TOOL_INSTRUMENT", "COMP_PENICILLIUM_NORDICUM"]}
