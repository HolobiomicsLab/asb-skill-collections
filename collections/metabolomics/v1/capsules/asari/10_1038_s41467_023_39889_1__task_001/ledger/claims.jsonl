{"claim_id": "claim_026", "text": "LOWESS regression is used to obtain a function describing the relationship of RT values between good_landmark_peaks and selected_reference_landmark_peaks.", "claim_type": "explicit", "source_excerpt": "Perform a LOWESS (Locally Weighted Scatterplot Smoothing) regression to obtain a function to describe the relationship of the RT values between good_landmark_peaks and selected_reference_landmark_peaks.", "source_anchor": {"source_path": "/Users/nothiasl/git/AgenticScienceBuilder/outputs/asbb_pilot/coll_asari/synthesized_package", "source_section": "methods", "page": null, "char_span": [4035, 4234], "figure_id": null, "table_id": null}, "source_type": "text", "evidence_type": "knowledge", "trace_status": "exact_match", "evidence_type_uri": "http://purl.obolibrary.org/obo/ECO_0000302", "source_type_uri": "http://purl.obolibrary.org/obo/IAO_0000311", "super_pattern": null, "source_doi": "10.1038/s41467-023-39889-1", "spine_entity_ids": ["TOOL_LOWESS"]}
