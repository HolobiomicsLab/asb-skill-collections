{"claim_id": "claim_023", "text": "A set of landmark elution peaks are determined in the reference sample by the criterion: mSelectivity > 0.99.", "claim_type": "explicit", "source_excerpt": "A set of landmark elution peaks are determined in this reference sample by the criteria: mSelectivity > 0.99, min_peak_height is satisfied (default 1e5), prominence > 20% of peak height and the peak is the only peak on its mass track.", "source_anchor": {"source_path": "/Users/nothiasl/git/AgenticScienceBuilder/outputs/asbb_pilot/coll_asari/synthesized_package", "source_section": "methods", "page": null, "char_span": [3668, 3901], "figure_id": null, "table_id": null}, "source_type": "text", "evidence_type": "knowledge", "trace_status": "exact_match", "evidence_type_uri": "http://purl.obolibrary.org/obo/ECO_0000302", "source_type_uri": "http://purl.obolibrary.org/obo/IAO_0000311", "super_pattern": null, "source_doi": "10.1038/s41467-023-39889-1", "spine_entity_ids": ["ALG_LANDMARK_PEAKS", "METRIC_MSELECTIVITY", "PARAM_MIN_PEAK_HEIGHT"]}
