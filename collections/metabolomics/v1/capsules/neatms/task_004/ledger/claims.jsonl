{"claim_id": "claim_026", "text": "Three batches of data are required for neural network training: one for training, one for testing, and one for validation.", "claim_type": "explicit", "source_excerpt": "We can now create our batches of data, 3 batches are required, one for training, one for testing and one for validation.", "source_anchor": {"source_path": "/Users/nothiasl/git/AgenticScienceBuilder/outputs/asbb_pilot/coll_neatms/synthesized_package", "source_section": "methods", "page": null, "char_span": [3856, 3977], "figure_id": null, "table_id": null}, "source_type": "text", "evidence_type": "knowledge", "trace_status": "exact_match", "evidence_type_uri": "http://purl.obolibrary.org/obo/ECO_0000302", "source_type_uri": "http://purl.obolibrary.org/obo/IAO_0000311", "super_pattern": null, "source_doi": null, "spine_entity_ids": []}
