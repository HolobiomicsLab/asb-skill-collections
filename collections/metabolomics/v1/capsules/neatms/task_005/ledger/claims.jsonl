{"claim_id": "claim_058", "text": "Using the same sample type, sample preparation, and instrumentation results in a more specific and accurate model.", "claim_type": "explicit", "source_excerpt": "Using the same sample type (plasma, tissue, cells...), same sample preparation (i.e. extraction protocol), same instrumentation (LC column, MS...) will result in a  more specific and more accurate model for the data analysed.", "source_anchor": {"source_path": "/Users/nothiasl/git/AgenticScienceBuilder/outputs/asbb_pilot/coll_neatms/synthesized_package", "source_section": "methods", "page": null, "char_span": [10451, 10667], "figure_id": null, "table_id": null}, "source_type": "text", "evidence_type": "knowledge", "trace_status": "exact_match", "evidence_type_uri": "http://purl.obolibrary.org/obo/ECO_0000302", "source_type_uri": "http://purl.obolibrary.org/obo/IAO_0000311", "super_pattern": null, "source_doi": null, "spine_entity_ids": []}
