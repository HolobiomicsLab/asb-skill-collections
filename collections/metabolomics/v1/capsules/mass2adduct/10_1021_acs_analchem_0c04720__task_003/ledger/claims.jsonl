{"claim_id": "claim_017", "text": "In the massdiff output, column A represents the parent ion peak mass.", "claim_type": "explicit", "source_excerpt": "`A` is the parent ion peak mass", "source_anchor": {"source_path": "/Users/nothiasl/git/AgenticScienceBuilder/outputs/asbb_pilot/coll_mass2adduct/synthesized_package", "source_section": "methods", "page": null, "char_span": [3577, 3608], "figure_id": null, "table_id": null}, "source_type": "text", "evidence_type": "knowledge", "trace_status": "exact_match", "evidence_type_uri": "http://purl.obolibrary.org/obo/ECO_0000302", "source_type_uri": "http://purl.obolibrary.org/obo/IAO_0000311", "super_pattern": null, "source_doi": "10.1021/acs.analchem.0c04720", "spine_entity_ids": ["TOOL_MASSDIFF_FN", "CONCEPT_MASSDIFF"]}
