    {
      "@id": "asbval:assertion/skill/molecular-fingerprint-parsing/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Structure annotation of fragmentation spectra through CSI:FingerID; only the candidate that is top ranked by CSI:FingerID is considered... CSI:FingerID with default parameters was used to rank structure candidates.",
      "asbval:note": "CSI:FingerID is confirmed as a tool used for ranking structure candidates based on spectrum queries. The paper describes it as a method that predicts molecular fingerprints and ranks candidates.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-021-01045-9",
