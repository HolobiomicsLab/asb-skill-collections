    {
      "@id": "asbval:assertion/skill/structured-result-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "COSMIC complements compound class annotation tools such as CANOPUS45. COSMIC targets molecular structure annotations but annotates only a fraction of the compounds in a sample; in contrast, CANOPUS annotates practically all compounds in a sample for which fragmentation spectra have been measured but is restricted to annotating compound classes.",
      "asbval:note": "Paper mentions CANOPUS as a complementary tool for compound-class annotation but does NOT describe validation of CANOPUS results, schema conformance checking, or data integrity validation workflows. The paper uses CANOPUS for compound class assignment (Extended Data Fig. 10: 'Compound classes in Extended Data Fig. 10 were assigned by NPClassifier89') but does not discuss validating CANOPUS web service responses or checking for required fields/schemas. The card's research question focuses on validation of web service results; the paper does not address this validation task.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-021-01045-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "structured-result-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate that structured annotation results from web service queries (e.g., CANOPUS compound-class predictions) contain required fields and conform to expected schemas before downstream analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:32:26.879799+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/structured-result-validation/001",
