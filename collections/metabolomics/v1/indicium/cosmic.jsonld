    {
      "@id": "asbval:assertion/skill/hierarchical-spectrum-object-construction/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SIRIUS 4 was used to process LC\u2013MS/MS runs and MassIVE datasets provided in mzML or mzXML format. Feature detection in SIRIUS 4 is similar in spirit to a targeted analysis. Instead of searching for all features in a run, SIRIUS first collects all fragmentation spectra and their precursor information and then searches for features that are associated with those fragmentation spectra (precursor ions, adduct ions and isotope peaks). Adducts and isotopes were detected using predefined lists of mass differences. Fragmentation spectra assigned to the same feature (precursor ion) are merged using an agglomerative clustering algorithm based on cosine distance.",
      "asbval:note": "Paper confirms SIRIUS ingests, parses, and organizes LC-MS/MS data with hierarchical feature/spectrum organization. However, paper does not explicitly confirm SIRIUS is a 'Java framework' or detail its serialization format\u2014these are implementation details not discussed in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-021-01045-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "hierarchical-spectrum-object-construction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[role]",
      "asbval:target_claim_text": "Java framework for ingesting, parsing, and internally representing LC-MS/MS data; provides the serialization format and hierarchical object model for spectrum construction",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:29:57.757099+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-metadata-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SIRIUS 4 was used to process LC\u2013MS/MS runs and MassIVE datasets provided in mzML or mzXML format. Feature detection in SIRIUS 4 is similar in spirit to a targeted analysis. Instead of searching for all features in a run, SIRIUS first collects all fragmentation spectra and their precursor information and then searches for features that are associated with those fragmentation spectra (precursor ions, adduct ions and isotope peaks). Adducts and isotopes were detected using predefined lists of mass differences.",
      "asbval:note": "Paper describes SIRIUS processing mzML/mzXML files and detecting precursor ions, adducts, isotopes, and collision energies, but does NOT describe explicit validation/quality-checking of metadata ranges or completeness checks before downstream analysis. The paper focuses on feature detection and molecular formula determination, not metadata validation as a standalone task.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-021-01045-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mass-spectrometry-metadata-validation",
