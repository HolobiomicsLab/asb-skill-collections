    {
      "@id": "asbval:assertion/skill/spectral-data-format-parsing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SIRIUS 4 was used to process LC\u2013MS/MS runs and MassIVE datasets provided in mzML or mzXML format. Feature detection in SIRIUS 4 is similar in spirit to a targeted analysis. Instead of searching for all features in a run, SIRIUS first collects all fragmentation spectra and their precursor information and then searches for features that are associated with those fragmentation spectra (precursor ions, adduct ions and isotope peaks).",
      "asbval:note": "Paper confirms SIRIUS processes mzML/mzXML formats and constructs indexed MS1/MS/MS hierarchies. However, the card's framing as a standalone 'skill' for format parsing is not how the paper presents it\u2014SIRIUS is used as part of the COSMIC workflow for molecular formula determination and structure annotation, not as a dedicated parsing utility. The parsing is a component of a larger pipeline, not an isolated task.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-021-01045-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectral-data-format-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Parse and validate LC-MS/MS spectral data from vendor-neutral file formats (mzML, mzXML, vendor formats) into a structured, in-memory representation with indexed MS1 and MS/MS hierarchies.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:31:33.987448+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
