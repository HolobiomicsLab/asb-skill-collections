    {
      "@id": "asbval:assertion/skill/molecular-fingerprint-parsing/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Notably, COSMIC complements compound class annotation tools such as CANOPUS45. COSMIC targets molecular structure annotations but annotates only a fraction of the compounds in a sample; in contrast, CANOPUS annotates practically all compounds in a sample for which fragmentation spectra have been measured but is restricted to annotating compound classes.",
      "asbval:note": "CANOPUS is mentioned as a complementary tool that uses fingerprint-based information for chemical classification. The paper confirms CANOPUS consumes fingerprint predictions for compound class annotation.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-021-01045-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-fingerprint-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "CANOPUS - Downstream tool that consumes molecular fingerprint predictions to assign systematic chemical classifications",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:30:40.287923+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/molecular-fingerprint-parsing/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "COSMIC's confidence score combines E-value estimation and a linear support vector machine (SVM) with enforced directionality... Besides the calibrated score, COSMIC's confidence score uses features such as score differences to other candidates, the total peak intensity explained by the fragmentation tree and the cardinality of the molecular fingerprints",
      "asbval:note": "The paper describes extracting and using fingerprint cardinality and other features from CSI:FingerID outputs, but the primary task is not parsing web service responses\u2014it is building a confidence scoring layer (COSMIC) on top of CSI:FingerID rankings. The paper does not focus on the mechanics of parsing raw JSON responses from a web service endpoint.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-021-01045-9",
      "asbval:supported_raw": "partial",
