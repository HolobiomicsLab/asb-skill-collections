    {
      "@id": "asbval:assertion/skill/molecular-fingerprint-parsing/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Data processing through SIRIUS... SIRIUS 4 was used to process LC\u2013MS/MS runs and MassIVE datasets provided in mzML or mzXML format... We use both isotope patterns and fragmentation patterns to determine the molecular formula de novo using SIRIUS 4 with default parameters and mass accuracy of 10 ppm. CSI:FingerID with default parameters was used to rank structure candidates.",
      "asbval:note": "SIRIUS is confirmed as the framework that processes spectra and integrates with CSI:FingerID for fingerprint-based ranking. The paper describes SIRIUS as the preprocessing step before CSI:FingerID is applied.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-021-01045-9",
      "asbval:supported_raw": "yes",
