    {
      "@id": "asbval:assertion/skill/api-endpoint-communication/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "COSMIC complements compound class annotation tools such as CANOPUS45. COSMIC targets molecular structure annotations but annotates only a fraction of the compounds in a sample; in contrast, CANOPUS annotates practically all compounds in a sample for which fragmentation spectra have been measured but is restricted to annotating compound classes.",
      "asbval:note": "Paper mentions CANOPUS as a complementary tool for compound-class annotation but does not describe submitting data to remote SIRIUS web service endpoints or retrieving predictions via API. The paper focuses on COSMIC workflow using local SIRIUS 4 processing, not web service API communication. CANOPUS is mentioned only as a separate tool, not as part of a web service submission workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-021-01045-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "api-endpoint-communication",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Submit mass spectrometry data (fingerprints or spectra) to remote SIRIUS web service endpoints and retrieve structured compound-class predictions with confidence scores. This skill enables programmatic access to CANOPUS and related predictors without local installation.",
