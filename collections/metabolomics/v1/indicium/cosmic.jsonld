      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validates and quality-checks spectral metadata extracted from LC-MS/MS data files (mzML, mzXML, vendor formats) to ensure precursor m/z, retention time, collision energy, and fragment ion assignments are complete and within acceptable ranges before downstream analysis in SIRIUS.",
      "eco:evidence_type": {
