    {
      "@id": "asbval:assertion/skill/mass-spectrometry-metadata-validation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "COSMIC complements compound class annotation tools such as CANOPUS45. COSMIC targets molecular structure annotations but annotates only a fraction of the compounds in a sample; in contrast, CANOPUS annotates practically all compounds in a sample for which fragmentation spectra have been measured but is restricted to annotating compound classes.",
      "asbval:note": "Paper mentions CANOPUS assigns compound classes but does NOT describe it receiving validated fragmentation patterns from SIRIUS or being part of the COSMIC workflow. CANOPUS is mentioned only as a complementary tool, not as a downstream consumer of SIRIUS output in this paper's workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-021-01045-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mass-spectrometry-metadata-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "CANOPUS \u2014 Accepts validated fragmentation patterns to assign systematic chemical classifications and natural product annotations",
