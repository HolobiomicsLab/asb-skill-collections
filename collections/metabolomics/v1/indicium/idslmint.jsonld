    {
      "@id": "asbval:assertion/card/task_001/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The model weights are exported at the directory outlined in the configuration file (.yaml), for the minimal LOSS value achieved during the training phase.",
      "asbval:note": "The paper describes model weight export and training, but does not explicitly discuss model instantiation in evaluation mode or validation of initialization. The paper focuses on training and prediction workflows rather than explicit model instance validation.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00804-5",
