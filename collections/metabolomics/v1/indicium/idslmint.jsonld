        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/card/task_001/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The training in ESI+ and ESI\u2212 took 70 and 45 h, respectively on 35 CPU processing threads.",
      "asbval:note": "The paper reports training timing but does not describe logging of input/output shapes or forward pass execution logs as part of the standard workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00804-5",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
