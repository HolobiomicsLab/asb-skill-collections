    {
      "@id": "asbval:assertion/skill/dataframe-and-numericlist-manipulation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The Spectra package natively supports import of MS data from mzML, mzXML and netCDF files and through its add-on packages MsBackendMgf, MsBackendMsp and MsBackendMassbank from files in MGF, MSP or MassBank format. It is thus possible to use for example results from MS-DIAL or MZmine as input for matchSpectra by importing them with qry <- Spectra('mzmine_result.mgf', source = MsBackendMgf()).",
      "asbval:note": "Paper describes MsBackend implementations (MsBackendMgf, MsBackendMsp, MsBackendMassbank) and their integration with Spectra, but does not provide detailed documentation on constructing custom MsBackend classes using parallel data structures (DataFrame + NumericList). The paper focuses on using existing backends rather than implementing new ones from scratch.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo12020173",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "dataframe-and-numericlist-manipulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Construct and manipulate parallel data structures (data.frame for spectra metadata, NumericList for peak m/z and intensity values) to implement custom MsBackend classes that integrate with the Spectra package infrastructure.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:10:56.366353+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/dataframe-and-numericlist-manipulation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The infrastructure provides both high-level functions specifically designed for users less experienced with bioinformatic tools as well as low-level core functionality that can be easily integrated and re-used also in other R software packages. This ecosystem comprises the R packages MetaboAnnotation, Spectra, MsBackendMassbank, CompoundDb, MetaboCoreUtils and MsCoreUtils that are maintained under the umbrella of the RforMassSpectrometry initiative.",
      "asbval:note": "Spectra is confirmed as a core package in the ecosystem. The paper describes MsBackend implementations and their integration with Spectra, confirming the framework role.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo12020173",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "dataframe-and-numericlist-manipulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Spectra - Framework that consumes MsBackend implementations via the @backend slot; defines the virtual MsBackend class and API contract",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:10:56.366353+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
