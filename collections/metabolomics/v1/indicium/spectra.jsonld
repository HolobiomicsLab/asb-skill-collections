      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "r-object-size-measurement-and-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when evaluating alternative implementations of data storage or retrieval strategies in R objects\u2014specifically when deciding whether to eagerly populate all columns in a data frame slot (e.g., @spectraVars with all core spectra variables) versus lazily filling mis",
      "eco:evidence_type": {
