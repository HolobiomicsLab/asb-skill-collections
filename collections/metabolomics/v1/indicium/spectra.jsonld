    {
      "@id": "asbval:assertion/skill/dataframe-construction-from-backend-sources/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In the programming and statistical environment R, many software packages for metabolomics data annotation and identification already exist. Among more recently developed R tools are MetaboAnalystR 2.0, patRoon and metID.",
      "asbval:note": "Paper extensively discusses R packages and R-based implementation throughout. The ecosystem is built in R and uses S4 classes (implied by Bioconductor context and explicit mention of 'object-oriented approach').",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo12020173",
      "asbval:supported_raw": "yes",
