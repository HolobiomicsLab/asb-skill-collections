      "id": "claim_001",
      "context": "explicit",
      "subject": "explicit",
      "qualifier": "consistent_with",
      "relation": "describes",
      "object": "MiMeNet more accurately predicts metabolite abundances than MelonnPan, with mean Spearman correlation coefficients increasing from 0.108 to 0.309 in the IBD (PRISM) dataset.",
      "asserted_by": "doi:10.1371/journal.pcbi.1009021",
      "@type": "asb:Claim",
      "source_task_kind": "reproduction",
      "source_task_kind_status": "resolved",
      "about_entity": [
