    {
      "@id": "asbval:assertion/skill/network-component-identification-and-filtering/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The coupling to molecular networks such as those generated by GNPS was therefore included as a feature of the mineMS2 software, as described in a dedicated vignette (the precomputed molecular network is provided as a file, in addition to the library of MS/MS spectra). The package thus enables to (1) automatically extracts connected components, cliques of a selected minimum size, and pairs of spectra of a specified minimum similarity",
      "asbval:note": "Exact match: connected components, cliques, minimum size, and similarity-based pairs are all explicitly mentioned as features of mineMS2 for network component extraction.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01051-y",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "network-component-identification-and-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Extract and filter distinct network components (connected components, cliques, and high-similarity node pairs) from MS/MS molecular networks, applying cosine similarity and minimum size thresholds to isolate spectra groups suitable for pattern explanation analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:53:58.054672+00:00",
      "sepio:credibility_status": {
