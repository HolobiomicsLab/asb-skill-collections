      "asbval:target_claim_text": "igraph \u2014 Parse GraphML network, extract connected components, cliques, and apply graph filters for component identification",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000302"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
