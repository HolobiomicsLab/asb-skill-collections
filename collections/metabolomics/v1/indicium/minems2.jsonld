    {
      "@id": "asbval:assertion/skill/graph-based-metabolite-similarity-assessment/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In molecular networks, as generated by the GNPS platform [27], each vertex is a spectrum and an edge indicates a high pairwise similarity according to the modified cosine score... The coupling to molecular networks such as those generated by GNPS was therefore included as a feature of the mineMS2 software, as described in a dedicated vignette (the precomputed molecular network is provided as a file, in addition to the library of MS/MS spectra).",
      "asbval:note": "GNPS is confirmed as source of molecular networks used for component extraction and pattern interpretation.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01051-y",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "graph-based-metabolite-similarity-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "GNPS \u2014 Source of molecular networks (GraphML format) that define spectrum similarity relationships and network structure for component extraction and pattern interpretation",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:53:41.827718+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
