      }
    },
    {
      "@id": "asbval:assertion/skill/network-component-identification-and-filtering/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Finally, mineMS2 patterns of highest recall for these components were selected (findPatternsExplainingComponents method), with the precision and size of the patterns being used to split ties... patterns explaining each component were found, with a minimum recall of 0.9 and a mean F1-score of 0.89",
      "asbval:note": "mineMS2 explicitly ranks patterns by recall, precision, and size to identify best-explaining patterns per network component via the findPatternsExplainingComponents method.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01051-y",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "network-component-identification-and-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "mineMS2 \u2014 Accept extracted network components and rank fragmentation patterns by recall, precision, and size metrics to identify best-explaining patterns per component",
      "eco:evidence_type": {
