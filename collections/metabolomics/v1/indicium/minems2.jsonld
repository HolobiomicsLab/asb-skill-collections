    {
      "@id": "asbval:assertion/skill/graph-based-metabolite-similarity-assessment/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We propose an innovative de novo strategy for searching for exact fragmentation patterns within collections of MS/MS spectra. This approach is based on (i) a new representation of spectra as graphs of m/z differences, and (ii) an efficient frequent-subgraph mining algorithm... Importantly, such approaches do not require any information from spectral or molecular databases, nor any knowledge about molecular formulas.",
      "asbval:note": "Core research question is directly supported by abstract and introduction.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01051-y",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "graph-based-metabolite-similarity-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Extract and compare fragmentation patterns represented as m/z-difference graphs across MS/MS spectra to identify metabolite similarities independent of external databases or molecular formulas.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:53:41.827718+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/graph-based-metabolite-similarity-assessment/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our approach, named mineMS2, relies on a new representation of spectra as fragmentation graphs of m/z differences, and on a dedicated suite of mining algorithms for these particular graphs... The mineMS2 software is publicly available as an R package (https://github.com/odisce/mineMS2).",
      "asbval:note": "mineMS2 confirmed as R package with stated functionality for graph construction and pattern mining.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01051-y",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "graph-based-metabolite-similarity-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "mineMS2 \u2014 Core package for discretizing m/z differences, constructing fragmentation graphs, extracting frequent closed subgraphs (patterns), and ranking patterns by recall-precision-size metrics",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:53:41.827718+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
