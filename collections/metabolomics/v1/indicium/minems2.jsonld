      }
    },
    {
      "@id": "asbval:assertion/skill/fragmentation-pattern-extraction-and-ranking/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "mineMS2 detects m/z differences that MS2LDA does not consider because they are not neutral losses but differences between peaks from two distinct fragmentation paths... all m/z differences for mineMS2 versus fragments and precursor losses for MS2LDA",
      "asbval:note": "Paper explicitly states mineMS2 includes non-neutral-loss m/z differences (differences between alternative fragmentation paths), making it unsuitable if only neutral losses are desired. Claim text is incomplete in the card.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01051-y",
