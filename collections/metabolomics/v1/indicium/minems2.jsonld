      }
    },
    {
      "@id": "asbval:assertion/skill/fragmentation-pattern-extraction-and-ranking/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The spectra are converted to Directed Acyclic Graphs... Frequency testing: Subgraphs with frequencies below the specified threshold are discarded.",
      "asbval:note": "Frequency threshold is a core parameter; minimum 2 is implicit in pattern mining.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01051-y",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "fragmentation-pattern-extraction-and-ranking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input collection contains fewer than 2 spectra (frequency threshold count\u22652 cannot be met)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:53:02.518643+00:00",
      "sepio:credibility_status": {
