      }
    },
    {
      "@id": "asbval:assertion/skill/fragmentation-pattern-extraction-and-ranking/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not mention igraph by name. While mineMS2 package includes methods to extract connected components and cliques (findGNPSComponents, findPatternsExplainingComponents), the paper does not specify igraph as the underlying library. The paper states 'The package thus enables to (1) automatically extracts connected components, cliques of a selected minimum size, and pairs of spectra of a specified minimum similarity' but does not name igraph.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01051-y",
