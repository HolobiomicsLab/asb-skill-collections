      }
    },
    {
      "@id": "asbval:assertion/skill/graph-based-metabolite-similarity-assessment/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Importantly, such approaches do not require any information from spectral or molecular databases, nor any knowledge about molecular formulas... This approach is based on (i) a new representation of spectra as graphs of m/z differences, and (ii) an efficient frequent-subgraph mining algorithm.",
      "asbval:note": "Paper explicitly states independence from databases and molecular formulas.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01051-y",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "graph-based-metabolite-similarity-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use this skill when external spectral databases or precursor molecular formulas are unavailable or when you want to discover pattern-based similarities independent of network similarity thresholds.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:53:41.827718+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/graph-based-metabolite-similarity-assessment/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The spectra are converted to Directed Acyclic Graphs built on a common set of edge labels extracted from the whole spectra collection... FSM algorithms extract all or a subset of the subgraphs from a set of graphs with a frequency above a specified threshold.",
      "asbval:note": "Paper discusses frequency thresholds and pattern mining on collections, implying minimum collection size requirement.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01051-y",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "graph-based-metabolite-similarity-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: When only a single spectrum or <2 spectra are available (patterns require count\u22652 for frequency definition)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
