    {
      "@id": "asbval:assertion/skill/neural-network-architecture-extension/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The phase of the molecule is introduced to the molecular fi ngerprint vector following message passing. This process is carried out for experimental spectra models, where each entry is speci fi ed as one of the fi ve supported phases. The phase features are represented as a one-hot vector of size fi ve. This vector is concatenated to the end of the molecular fi ngerprint vector.",
      "asbval:note": "Paper demonstrates exactly this pattern: taking the base Chemprop MPNN output (molecular fingerprint) and concatenating domain-specific features (phase information) before feeding to the FFNN readout.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acs_jcim_1c00055",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "neural-network-architecture-extension",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have a working base MPNN model (e.g., chemprop) and need to add task-specific feature processing layers (spectral, electronic, or domain features) to improve predictions on a specialized molecular property or spectrum.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:12:44.490657+00:00",
      "sepio:credibility_status": {
