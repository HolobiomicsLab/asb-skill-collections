    {
      "@id": "asbval:assertion/card/task_002/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not describe extraction of spectral features as a tensor/matrix from test molecules. Instead, it describes: (1) input molecules as SMILES strings converted to 2D graphs, (2) output as predicted absorbance vectors (1801 normalized absorbances), and (3) phase features as one-hot vectors. No intermediate 'spectral features tensor' is extracted from test molecules.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acs_jcim_1c00055",
