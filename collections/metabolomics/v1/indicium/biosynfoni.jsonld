    {
      "@id": "asbval:assertion/skill/distribution-statistics-summarization/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We used the second version (September 2024) of the COCONUT database [15, 33] as our primary natural product structure source. Any compounds from the .sdf+ file that could not be read by RDKit were left out... We matched the three-star database compounds to the extracted classifications using their compound IDs... Natural products were identified through InChI comparison to COCONUT compounds... Substructure keys are defined in SMILES ARbitrary Target Specification (SMARTS)...",
      "asbval:note": "RDKit is used to parse SDF files and InChI identifiers; SMILES/SMARTS are used for substructure definition. This aligns with the card's claim about parsing molecular structures.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01081-6",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "distribution-statistics-summarization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[2].role",
      "asbval:target_claim_text": "Parse molecular structures (SMILES, InChI, SDF) required as input to biosynfoni fingerprinting",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
