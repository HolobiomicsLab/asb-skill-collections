    {
      "@id": "asbval:assertion/skill/distribution-statistics-summarization/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We used Python [32] (v3.13.1) and the cheminformatic RDKit [21] package (v2024.09.4) as our main tools in Biosynfoni's creation and testing... To implement the fingerprint, we used RDKit's Chem.Mol.GetSubstructMatches function for substructure key detection.",
      "asbval:note": "RDKit is explicitly used for molecular structure parsing and substructure matching, consistent with the card's claim about parsing molecular structures.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01081-6",
