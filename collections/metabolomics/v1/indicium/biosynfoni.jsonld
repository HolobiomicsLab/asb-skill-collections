    {
      "@id": "asbval:assertion/skill/distribution-statistics-summarization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We investigated Biosynfoni's applicability domain and its performance in biosynthetic similarity representation, chemical space visualisation, and natural product classification... The average atom coverage of 97% indicates Biosynfoni captures almost all of the atoms in the natural products' structures at least once with its 39 substructure keys... We calculated Tanimoto similarity scores for compounds from biosynthetic reaction chains... we computed Tanimoto similarity between the two compounds for each fingerprint type.",
      "asbval:note": "Paper does compute pairwise similarity coefficients (Tanimoto) and analyzes distributional properties (atom coverage, substructure occurrence, co-occurrence patterns shown in Fig. 1a). However, the paper does not explicitly compute or report 'bit-frequency distributions' or 'sparsity metrics' in the traditional sense\u2014instead it reports substructure occurrence counts and atom coverage. The research question conflates fingerprint statistics with fingerprint application/validation tasks.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-025-01081-6",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "distribution-statistics-summarization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute summary statistics and distributional characteristics of molecular fingerprint vector collections, including bit-frequency distributions, sparsity metrics, and pairwise similarity coefficients.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:23:15.524809+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/distribution-statistics-summarization/001",
      "@type": "asbval:ClaimAssessment",
