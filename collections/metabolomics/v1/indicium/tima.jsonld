    {
      "@id": "asbval:assertion/card/10_5281_zenodo_5797920__task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "R scripts in the form of markdown notebooks were written to perform 1) cleaning and standardization of the outputs (1_taxo_cleaner.Rmd) 2) taxonomically informed scoring and re-ranking (2_taxo_scorer.Rmd)... Scripts are available at https://github.com/oolonek/taxo_scorer.",
      "asbval:note": "Paper describes a taxonomically informed scoring system implemented as R scripts (markdown notebooks), not a formal R package named 'tima'. The workflow exists but is distributed as individual scripts rather than a packaged system. The research question conflates the methodology with a specific package implementation that is not named or described in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fpls-2019-01329",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "What is the complete end-to-end workflow architecture of the TIMA (Taxonomically Informed annotation) system as implemented in the tima R package?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:16:38.892914+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
