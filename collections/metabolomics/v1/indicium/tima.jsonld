    {
      "@id": "asbval:assertion/skill/tima-entry-point-validation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "R scripts in the form of markdown notebooks were written to perform 1) cleaning and standardization of the outputs (1_taxo_cleaner.Rmd) 2) taxonomically informed scoring and re-ranking (2_taxo_scorer.Rmd).",
      "asbval:note": "The paper does use R for scripting and analysis (R notebooks, R scripts mentioned in passages 9-12), but the card's evidence_spans incorrectly cite the paper's own DOI as if it were an external reference. The card claims source_paper_doi is null when it should reference the paper being validated (10.3389/fpls.2019.01329). The version_used field '10.3389' appears to be a malformed DOI fragment, not an R version number.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fpls-2019-01329",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "tima-entry-point-validation",
      "asbval:target_artifact_kind": "skill_bundle",
