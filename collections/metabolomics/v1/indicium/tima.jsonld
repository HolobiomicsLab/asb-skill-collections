    {
      "@id": "asbval:assertion/skill/spectral-library-matching-and-scoring/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Computational metabolite annotation automatically links spectral data to candidate structures via a score, which is usually established between the acquired data and experimental or theoretical spectral databases (DB)... The design of a metascore is a way to capture complementary experimental attributes and improve the annotation process. Here, we show that integrating the taxonomic position of analyzed samples and candidate structures enhances confidence in metabolite annotation.",
      "asbval:note": "Paper demonstrates spectral matching and scoring with taxonomic integration (ISDB-DNP, MS-Finder, Sirius), but does not mention LOTUS, MassBank, or in-house libraries. The core concept of spectral matching with taxonomic scoring is present; the specific databases named in the card are not all validated in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fpls-2019-01329",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectral-library-matching-and-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Match experimental MS/MS spectra against reference spectral libraries and score similarity to identify metabolites. This skill integrates multiple spectral databases (LOTUS, ISDB, MassBank, in-house libraries) with customizable scoring algorithms to rank candidate compound matche",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
