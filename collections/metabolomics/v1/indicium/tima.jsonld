    {
      "@id": "asbval:assertion/skill/mass-spectrometry-data-processing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The MS data were converted from .RAW (Thermo) standard data format to .mzXML format using the MSConvert software... The converted files were treated using the MZMine software suite v. 2.38... Eventually the resulting aligned peaklist was filtered using the peak-list rows filter option in order to keep only features associated with MS2 scans.",
      "asbval:note": "Paper performs MS data conversion and validation using MZMine (v2.38) and MSConvert, not a dedicated 'tima' R package. The paper does convert to standardized formats (.mzXML, .mgf) and validates data, but uses different tools than claimed in the card.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fpls-2019-01329",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mass-spectrometry-data-processing",
