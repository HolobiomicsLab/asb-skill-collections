      }
    },
    {
      "@id": "asbval:assertion/skill/figure-table-interpretation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Mass deviations and mass difference deviations are still modeled by normal distributions... For intensities, previous models consider only either relative errors or absolute errors, and cannot deal with both types simultaneously.",
      "asbval:note": "Paper discusses mass accuracy and intensity error modeling but does not explicitly state the 10 ppm threshold or 3:1 SNR threshold as criteria for reliability. The paper addresses mass accuracy considerations but not the specific thresholds mentioned in the scope.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-019-0344-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "figure-table-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input spectrum has insufficient mass accuracy (>10 ppm error) or signal-to-noise ratio (<3:1) \u2014 fragmentation tree and formula assignment will be unreliable.",
