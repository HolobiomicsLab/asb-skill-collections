    {
      "@id": "asbval:assertion/skill/scientific-task-formulation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SIRIUS 4 integrates high-resolution isotope pattern analysis and fragmentation trees with structural elucidation to provide a combined and coherent assessment of molecular structures from MS/MS data for large datasets. Users can now analyze full liquid chromatography\u2013mass spectrometry (LC-MS) datasets, rather than just one spectrum at a time",
      "asbval:note": "The paper explicitly describes the workflow of taking LC-MS/MS data (fragmentation trees, isotope patterns) and converting them into structured computational tasks for molecular identification.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-019-0344-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "scientific-task-formulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Formulate a well-defined scientific task by grounding analysis objectives in paper-specific instrument outputs, data formats, and computational methods. This skill ensures that downstream tools receive precisely scoped inputs\u2014e.g., LC-MS/MS fragmentation trees, isotope patterns, ",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:29:28.949997+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
