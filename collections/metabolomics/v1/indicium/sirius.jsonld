      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/evidence-linking/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SIRIUS 4 is written in Java... SIRIUS 4 integrates high-resolution isotope pattern analysis and fragmentation trees with structural elucidation... CSI:FingerID is seamlessly integrated into SIRIUS 4 via a RESTful (representational state transfer) web service",
      "asbval:note": null,
