    {
      "@id": "asbval:assertion/skill/collision-cross-section-calculation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we describe the development of a multiomic CCS calibration tool, MOCCal, to automate the assignment of unknown features to the power law calibration that provides the most accurate CCS value... MOCCal calibrates every experimental arrival time with up to three class-specific calibration curves... we demonstrate that MOCCal provides accurately calibrated TW CCS N2 values for small molecules, lipids, and peptides.",
      "asbval:note": "Core research question is directly supported by abstract and introduction. The paper explicitly addresses converting arrival times to CCS values using calibration curves for multiomic samples without prior identification.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "collision-cross-section-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Transform raw TWIM-MS arrival-time measurements into calibrated collision cross section (CCS) values using reference compound calibration curves. This skill enables quantitative ion-mobility characterization for high-dimensional multi-omic datasets without requiring prior feature",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:29:55.640045+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
