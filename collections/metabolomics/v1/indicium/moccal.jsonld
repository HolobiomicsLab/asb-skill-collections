      }
    },
    {
      "@id": "asbval:assertion/skill/biomolecular-class-ccs-mapping/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal utilizes biomolecule-specific TWIM CCS calibration equations based on the power law to generate calibrated CCS values",
      "asbval:note": "Paper specifies power law (non-linear) regression models, not linear or non-linear generically. The card's claim of 'linear or non-linear' is broader than what the paper implements; MOCCal uses power law specifically.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "biomolecular-class-ccs-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "conversion of raw TWIM-MS arrival times to calibrated CCS using class-dependent linear or non-linear regression models",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:28:50.471159+00:00",
