    },
    {
      "@id": "asbval:assertion/skill/twim-ms-data-processing/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "When raw data are loaded, arrival time data for the calibrants are extracted using the open-source software DEIMoS... For the raw calibration data itself to be used, DEIMoS is a prerequisite download required for the functionality of MOCCal.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
