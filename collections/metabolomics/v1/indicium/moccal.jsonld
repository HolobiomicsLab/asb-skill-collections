    {
      "@id": "asbval:assertion/skill/twim-ms-calibration-mapping/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal, to automate the assignment of unknown features to the power law calibration that provides the most accurate CCS value... MOCCal calibrates every experimental arrival time with up to three class-specific calibration curves... we propose a novel method that can be used to assign multiomic features to their corresponding biomolecular class for TWCCSN2 value determination without prior identification.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "twim-ms-calibration-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Transform raw arrival-time measurements from traveling-wave ion mobility mass spectrometry (TWIM-MS) into collision cross section (CCS) values by establishing and applying a calibration mapping function derived from reference compounds with known CCS values. This skill enables do",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
