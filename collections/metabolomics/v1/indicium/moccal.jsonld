    {
      "@id": "asbval:assertion/skill/biomolecular-class-label-assignment/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal then uses the biomolecular DTCCSN2 vs m/z trendlines to identify the calibration curve that provided the most accurate calibrated TWCCSN2. A correctly calibrated feature should fall within a few \u00c52 of the DTCCSN2 vs m/z trendline for its true biochemical class... the \u0394CCS between the trendline DTCCSN2 value and the calibrated TWCCSN2 value is determined... The calibrated TWCCSN2 value with the smallest \u0394CCS to the corresponding trendline is selected as the correct match.",
      "asbval:note": "The core method of class assignment via \u0394CCS minimization is clearly described and validated in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "biomolecular-class-label-assignment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Class assignment via comparison of calibrated TWCCSN2 values to DTCCSN2 vs m/z trendlines using \u0394CCS minimization",
