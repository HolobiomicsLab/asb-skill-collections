    {
      "@id": "asbval:assertion/skill/ion-mobility-feature-classification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal utilizes biomolecule-specific TWIM CCS calibration equations based on the power law to generate calibrated CCS values for a molecular feature of unknown identity... MOCCal is currently set up to perform CCS calibrations for lipids, small molecules, and peptides (z = 1 to z = 3) in positive ionization mode.",
      "asbval:note": "Paper demonstrates class assignment for lipids, small molecules, and peptides (z=1-3), NOT carbohydrates or proteins as general classes. Carbohydrates are not mentioned; proteins are only addressed via peptide digests (tryptic peptides), not intact proteins. The claim overstates the scope of biomolecular classes supported.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "ion-mobility-feature-classification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Assigns biomolecular class labels (e.g., lipid, protein, carbohydrate) to TWIM-MS features based on their physico-chemical properties (arrival time and m/z) without requiring prior feature identification.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:30:25.717741+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/ion-mobility-feature-classification/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal calibrates every experimental arrival time with up to three class-specific calibration curves and uses the difference (in \u00c52) between the calibrated TW CCS N2 value and DT CCS N2 vs m/z regression lines to determine the best calibration curve.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ion-mobility-feature-classification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This enables immediate class-stratified analysis and class-specific CCS calibration on unidentified experimental data.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
