    {
      "@id": "asbval:assertion/skill/arrival-time-to-ccs-conversion/013",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For calibration input into MOCCal, a spreadsheet containing the calibrant names, m/z values, drift tube CCS (\u00c52) values, biomolecular class, and charge state is required.",
      "asbval:note": "Paper explicitly requires calibration standards; absence of these makes MOCCal inapplicable.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
