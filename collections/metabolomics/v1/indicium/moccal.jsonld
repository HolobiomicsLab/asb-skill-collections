      }
    },
    {
      "@id": "asbval:assertion/skill/biomolecular-class-ccs-mapping/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Based on provided charge states, features with two or more charges will be calibrated with only the peptide z = 2 or z = 3 calibration curves. For each feature in the spreadsheet with a charge state of 1, MOCCal will calculate up to three calibrated TWCCSN2 values using each set of class-specific calibration parameters",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "biomolecular-class-ccs-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill after biomolecular class labels have been assigned to features in a TWIM-MS dataset and you have raw ion mobility arrival time measurements.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:28:50.471159+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/biomolecular-class-ccs-mapping/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "It is highly documented that calibrants that are structurally similar to the analyte provide the most accurately calibrated TWCCSN2 values... MOCCal is currently set up to perform CCS calibrations for lipids, small molecules, and peptides (z = 1 to z = 3) in positive ionization mode.",
      "asbval:note": "Paper supports lipids, small molecules, and peptides; carbohydrates are not mentioned as a supported class in MOCCal.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "biomolecular-class-ccs-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it when you need to convert arrival times to standardized CCS values where calibration accuracy depends critically on the biomolecular class (e.g., lipids, proteins, carbohydrates may require different calibration models).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
