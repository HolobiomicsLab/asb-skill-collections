    {
      "@id": "asbval:assertion/skill/arrival-time-to-ccs-conversion/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Arrival times from traveling wave ion mobility (TWIM) devices must undergo a calibration process to obtain CCS values... Here we describe the development of a multiomic CCS calibration tool, MOCCal, to automate the assignment of unknown features to the power law calibration that provides the most accurate CCS value.",
      "asbval:note": "Core research question is directly supported by abstract and introduction.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "arrival-time-to-ccs-conversion",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Convert raw arrival-time measurements from TWIM-MS into calibrated collision cross section (CCS) values by establishing a mapping function from reference compounds with known CCS values.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:28:29.841559+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/arrival-time-to-ccs-conversion/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "CCS values, unlike drift times, are comparable across different laboratories and instrumentation. Comparison of CCS values between laboratories using CCS databases can be helpful in the assignment of an identification to an unknown feature.",
      "asbval:note": "Semantic equivalence: paper establishes that CCS values enable cross-laboratory comparability.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "arrival-time-to-ccs-conversion",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This enables standardized, comparable ion mobility measurements across multi-omic datasets.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
