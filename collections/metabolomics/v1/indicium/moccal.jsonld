    {
      "@id": "asbval:assertion/skill/twim-ms-data-processing/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The CCS calibration process begins by selecting calibration standards for the biomolecular classes that are expected to be within the data... Parameters are optimized for class-specific power law regressions using the calibrant's arrival time and reference drift tube CCS value.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "twim-ms-data-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "establish a CCS calibration curve from known standards",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:31:20.727902+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/twim-ms-data-processing/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal will calculate up to three calibrated TWCCSN2 values using each set of class-specific calibration parameters... MOCCal then uses the biomolecular DTCCSN2 vs m/z trendlines to identify the calibration curve that provided the most accurate calibrated TWCCSN2... The assignment process is demonstrated in Figure 2 for a small molecule, a lipid, and a singly charged peptide.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "twim-ms-data-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "assign unidentified features to biomolecular classes (e.g., lipids, metabolites, peptides) based on physico-chemical properties alone",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:31:20.727902+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/twim-ms-data-processing/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The calibrated TWCCSN2 value with the smallest \u0394CCS to the corresponding trendline is selected as the correct match, and that calibrated TWCCSN2 value is retained... Comparison of CCS values between laboratories using CCS databases can be helpful in the assignment of an identification to an unknown feature.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "twim-ms-data-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "compute class-appropriate CCS values for downstream feature matching or annotation",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
