    {
      "@id": "asbval:assertion/skill/ion-mobility-arrival-time-conversion/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The use of multiple omics analysis, such as proteomics, metabolomics, and lipidomics, in combination has grown in popularity given the wealth of information that can be obtained about an organism, disease state, or condition when a systems-level view is taken. However, with this added sample complexity, challenges with data collection, data analysis, and feature identification also increase. The rapid gas-phase and structural separation of ion mobility mass spectrometry (IM-MS) is a promising approach for complex multiomic sample analysis",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ion-mobility-arrival-time-conversion",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill is essential for quantifying biomolecular structural properties in high-dimensional multi-omic ion mobility workflows",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:30:10.846549+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/ion-mobility-arrival-time-conversion/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Experimental data can be imported as a spreadsheet containing feature identifiers along with their corresponding m/z, charge state, retention time, and arrival time values. Based on provided charge states, features with two or more charges will be calibrated with only the peptide z = 2 or z = 3 calibration curves.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ion-mobility-arrival-time-conversion",
