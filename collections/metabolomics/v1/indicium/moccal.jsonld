    {
      "@id": "asbval:assertion/skill/twim-ms-data-processing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal, to automate the assignment of unknown features to the power law calibration that provides the most accurate CCS value... MOCCal calibrates every experimental arrival time with up to three class-specific calibration curves... we have developed an automated tool, MOCCal, for the assignment of features to a calibrant set/CCS calibration curve without any a priori knowledge of the feature's classification or identity.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "twim-ms-data-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply MOCCal to perform collision cross section (CCS) calibration, biomolecular class assignment, and class-specific CCS calculation on traveling-wave ion mobility mass spectrometry (TWIM-MS) data without requiring prior feature identification.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:31:20.727902+00:00",
      "sepio:credibility_status": {
