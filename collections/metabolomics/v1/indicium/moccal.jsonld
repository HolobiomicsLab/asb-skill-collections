      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have a feature table containing raw ion mobility arrival time measurements paired with experimentally assigned biomolecular class labels",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
