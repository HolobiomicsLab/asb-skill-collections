    {
      "@id": "asbval:assertion/skill/ion-mobility-reference-matching/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Arrival times from traveling wave ion mobility (TWIM) devices must undergo a calibration process to obtain CCS values... Here we describe the development of a multiomic CCS calibration tool, MOCCal, to automate the assignment of unknown features to the power law calibration that provides the most accurate CCS value.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ion-mobility-reference-matching",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Transform raw arrival-time measurements from traveling-wave ion mobility mass spectrometry (TWIM-MS) into calibrated collision cross section (CCS) values by establishing a mapping function between reference compounds with known CCS values and their corresponding arrival times.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
