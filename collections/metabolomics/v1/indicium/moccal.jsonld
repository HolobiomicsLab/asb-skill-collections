      }
    },
    {
      "@id": "asbval:assertion/skill/ion-mobility-feature-classification/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal is open-source and freely available online at github.com/HinesLab/MOCCal... User-friendly GUIs have been implemented in MOCCal to allow for easy accessibility by users at any level of programming competency.",
      "asbval:note": "Paper confirms MOCCal is a Python application with GUIs, but does not explicitly state it is available as a 'standalone executable' separate from the Python script. The paper mentions 'stand-alone MOCCal application' but in context this refers to using pre-processed data without raw data input, not a compiled binary distinct from Python.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "partial",
