      }
    },
    {
      "@id": "asbval:assertion/skill/biomolecular-class-ccs-mapping/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal is designed for the assignment of features to a calibrant set/CCS calibration curve without any a priori knowledge of the feature's classification or identity... MOCCal then uses the biomolecular DTCCSN2 vs m/z trendlines to identify the calibration curve that provided the most accurate calibrated TWCCSN2.",
      "asbval:note": "The paper actually describes MOCCal as performing class assignment WITHOUT prior knowledge of feature identity, which contradicts the scope statement that class labels must be pre-assigned. MOCCal performs identity-agnostic class assignment as part of its workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "biomolecular-class-ccs-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Do not use if features lack explicit class labels or if CCS calibration is class-agnostic.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:28:50.471159+00:00",
      "sepio:credibility_status": {
