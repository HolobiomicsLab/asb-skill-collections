      }
    },
    {
      "@id": "asbval:assertion/skill/arrival-time-to-ccs-conversion/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal, or Multi-Omic CCS Calibrator, is a Python application... MOCCal calibrates every experimental arrival time with up to three class-specific calibration curves and uses the difference (in \u00c5 2 ) between the calibrated TW CCS N2 value and DT CCS N2 vs m / z regression lines to determine the best calibration curve.",
      "asbval:note": "Verbatim presence of MOCCal as Python application with CCS calibration functionality.",
