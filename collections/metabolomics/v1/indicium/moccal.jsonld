    {
      "@id": "asbval:assertion/skill/ion-mobility-arrival-time-conversion/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MOCCal will calculate up to three calibrated TWCCSN2 values using each set of class-specific calibration parameters for small molecules, lipids, and peptides (z = 1). MOCCal then uses the biomolecular DTCCSN2 vs m/z trendlines to identify the calibration curve that provided the most accurate calibrated TWCCSN2.",
      "asbval:note": "The paper describes MOCCal as performing class assignment as part of its workflow, so the card's claim that class assignment should be done first is consistent with the tool's design.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ion-mobility-arrival-time-conversion",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
