    {
      "@id": "asbval:assertion/skill/arrival-time-to-ccs-conversion/014",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For DTIMS experiments, the amount of time it takes an ion to traverse the drift region of the spectrometer, referred to as the drift time, can be converted to a collision cross section (CCS, in \u00c52) value... However, CCS values cannot be obtained directly from the TWIM platforms. Instead, arrival times from TWIM experiments are calibrated to experimental CCS values from DTIM platforms.",
      "asbval:note": "Paper distinguishes DTIM (drift-time) from TWIM (arrival-time); MOCCal is specific to TWIM.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "arrival-time-to-ccs-conversion",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "NOT applicable for drift-time (not arrival-time) ion mobility spectrometry",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
