    {
      "@id": "asbval:assertion/skill/ion-mobility-reference-matching/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For multiomic mixtures, several different types of calibrants must be used to obtain the most accurate CCS values from TWIM platforms. Here we describe the development of a multiomic CCS calibration tool, MOCCal... Using real and simulated multiomic samples, we demonstrate that MOCCal provides accurately calibrated TW CCS N2 values for small molecules, lipids, and peptides.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04290",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ion-mobility-reference-matching",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have raw arrival-time data from TWIM-MS and need to convert it to collision cross section (CCS) values for multi-omic analysis.",
      "eco:evidence_type": {
