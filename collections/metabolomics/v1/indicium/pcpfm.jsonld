      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This analysis was performed using a batch-correction variation of our default workflow... First, the QC metrics generated by Asari are summarized... Next, hierarchical clustering of the inter-sample pearson correlation across all features was performed revealing two clusters of samples, representing a clear batch effect that was traced back to a recalibration of the instrument after batch 8",
      "asbval:note": "Paper demonstrates batch correction on multi-batch data (17 batches, 1685 samples), implying single-batch data would not benefit from this approach.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "batch-correction-quality-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope \u2014 When NOT to use",
      "asbval:target_claim_text": "Single-batch study or all samples from one batch; inter-batch variance cannot be meaningfully assessed.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
