    {
      "@id": "asbval:assertion/skill/feature-intensity-normalization-and-batch-correction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "normalization is implemented using numpy and can be performed in a one-pass or two-pass approach. In the two-pass approach, normalization is done within a batch of samples and then the batches are scaled to one another using their median TIC values based on the conserved features.",
      "asbval:note": "Exact match: TIC-based normalization with two-pass approach using median TIC values on conserved (common) features, followed by batch correction.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-intensity-normalization-and-batch-correction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Normalize LC-MS feature intensities using total ion chromatogram (TIC) scaling on common features, optionally followed by batch-aware correction to remove systematic intensity variation across experimental batches.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:57:27.000401+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/feature-intensity-normalization-and-batch-correction/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "batch correction using a wrapper around pycombat... after normalization and batch correction via pycombat, both the log TICs and PCA show more consistency and no sub-clustering, suggesting the batch effect was largely mitigated.",
      "asbval:note": "Demonstrated in Fig 4C-D: batch correction removes batch-driven clustering while preserving biological signal (sunitinib treatment effect remains detectable).",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-intensity-normalization-and-batch-correction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "removes confounding batch effects while preserving biological signal in metabolomics feature tables",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
