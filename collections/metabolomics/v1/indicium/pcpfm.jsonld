      "@id": "asbval:assertion/card/10_1371_journal_pcbi_1011912__task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The pcpfm package is written in Python 3 and JSON is used extensively for intermediary data... The inputs to our pipeline minimally consist of .mzML or .raw files and a metadata CSV file... The final output consists of a feature table detailing the observed m/z and retention time values for observed features mapped to unique identifiers, an annotation table mapping these identifiers to annotations and metadata for those annotations, and a third table summarizing the acquisition and experiment-level metadata.",
      "asbval:note": "Paper explicitly describes sequential processing from raw data to normalized feature tables. Figure 2A shows five major sections: assembly, data processing, quality control, annotation and reporting.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
