      }
    },
    {
      "@id": "asbval:assertion/skill/metabolite-quality-control-filtering/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Blank masking, missing value imputation, and feature removal is implemented using custom routines in Pandas and numpy... Outlier samples can be removed using any of the Z-scores or other 1-D metrics described above via a user-provided filter; however, by default, samples that have an absolute value for their number of features Z-score greater than 2.5 are dropped.",
      "asbval:note": "Passage describes blank masking and sample removal (outlier samples) as implemented QC operations.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolite-quality-control-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it when your dataset contains blank samples (to identify and remove contaminants), QC/control samples marked in metadata, or when you observe that many features appear sporadically across samples.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
