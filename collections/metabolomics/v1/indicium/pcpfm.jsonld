    {
      "@id": "asbval:assertion/skill/lc-ms-feature-extraction-and-alignment/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Empirical compounds are constructed from a feature table using Khipu [44]... The isotopes and adducts from pre-annotation are modeled as a grid structure, made computable by the khipu package [34], which is also incorporated in the pcpfm pipeline.",
      "asbval:note": "khipu is confirmed in the paper but its role is post-feature-extraction (empirical compound construction from Asari feature tables), not directly in the feature extraction and alignment step itself. The card lists khipu as a tool for this task, but khipu operates downstream of Asari's feature detection. This is a scope misalignment: khipu is part of the broader pipeline but not part of the 'lc-ms-feature-extraction-and-alignment' task specifically.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "lc-ms-feature-extraction-and-alignment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "khipu - used for pre-annotation to group features to empirical compounds",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:59:00.469016+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-tolerance-calibration/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Empirical compounds are constructed from a feature table using Khipu [44] and most methods for empirical compounds concern annotation.",
      "asbval:note": "Paper confirms khipu constructs empirical compounds from feature tables and groups isotopologues and adducts, but does not explicitly name the 'build_empCpds' command or discuss configurable m/z and retention time tolerances in khipu. The paper states 'The isotopes and adducts from pre-annotation are modeled as a grid structure, made computable by the khipu package' but does not detail tolerance configuration parameters.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mass-spectrometry-tolerance-calibration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Configures m/z and retention time tolerances in khipu's build_empCpds command to group features into empirical compounds by matching isotopes and adducts.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:59:17.507099+00:00",
      "sepio:credibility_status": {
