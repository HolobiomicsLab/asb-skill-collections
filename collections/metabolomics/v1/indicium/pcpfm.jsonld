      }
    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-tolerance-calibration/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By building empirical compounds first, i.e. pre-annotation via the khipu package, MS1 annotation is improved because the search of databases does not query many degenerate features",
      "asbval:note": "Paper demonstrates that empirical compound construction (via khipu) improves annotation specificity by reducing degenerate feature queries, supporting the claim that tolerance-based clustering affects downstream annotation.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-tolerance-calibration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Tolerance selection directly affects the specificity and sensitivity of feature clustering and downstream metabolite annotation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
