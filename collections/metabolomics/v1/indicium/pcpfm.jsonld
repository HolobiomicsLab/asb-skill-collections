    {
      "@id": "asbval:assertion/skill/empirical-compound-construction-from-feature-clustering/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Empirical compounds are constructed from a feature table using Khipu [44] and most methods for empirical compounds concern annotation... The inferred neutral mass of an empirical compound is compared to known metabolites to generate level 4 annotations (via JMS, https://github.com/shuzhao-li-lab/JMS)... Multiple annotations of different sources are chained in the empirical compound data structure (Fig 1B), which is amendable to future enhancements, e.g., context specific databases.",
      "asbval:note": "Fully supported. Paper describes empirical compound construction from feature tables using Khipu, with JSON serialization and downstream MS1/MS2 annotation.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "empirical-compound-construction-from-feature-clustering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Groups individual LC-MS features into empirical compounds by clustering features within configurable m/z and retention time windows, then annotates isotopologues and adducts based on observed mass differences and charge state patterns. This pre-annotation step produces a structur",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:56:44.406332+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/empirical-compound-construction-from-feature-clustering/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Empirical compounds are constructed from a feature table using Khipu [44]... The isotopes and adducts from pre-annotation are modeled as a grid structure, made computable by the khipu package [34], which is also incorporated in the pcpfm pipeline.",
      "asbval:note": "Khipu is confirmed as the tool for empirical compound construction with isotope and adduct annotation. Specific command name 'build_empCpds' not found in passages, but functional role is clearly supported.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "yes",
