    {
      "@id": "asbval:assertion/skill/inter-sample-variance-calculation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "hierarchical clustering of the inter-sample pearson correlation across all features was performed revealing two clusters of samples, representing a clear batch effect that was traced back to a recalibration of the instrument after batch 8 (Fig 4B). The log TICs of a random subset of samples and PCA plots were generated to further investigate these batches and identify abnormal samples (Fig 4C and 4D). The standard two-pass normalization does not adaquetly correct the batch effect; however, after normalization and batch correction via pycombat, both the log TICs and PCA show more consistency and no sub-clustering, suggesting the batch effect was largely mitigated.",
      "asbval:note": "Paper demonstrates batch effect detection and correction validation using PCA, t-SNE, correlation clustermaps, and log TICs, but does not explicitly calculate 'median inter-batch variance' as a specific metric. The paper validates batch correction through visual inspection (PCA, clustermaps) and qualitative assessment ('more consistency'), not through the specific quantitative metric of median inter-batch variance for high-intensity features.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1011912",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "inter-sample-variance-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Calculate median inter-batch variance for high-intensity features across sample groups to quantify the magnitude of batch effects in multi-batch metabolomics feature tables before and after correction.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:57:55.129910+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
