    {
      "@id": "asbval:assertion/skill/regression-metric-computation-and-comparison/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We evaluated the performance of the two most accurate ML models trained to predict CCS values: GraphCCS [22], and SigmaCCS [6]. We retrained these models using the reported hyperparameters on the datasets used in this work... We benchmarked all the models using three different settings... We evaluated the performance of the models on a test set using several metrics. We employed correlation metrics such as coefficient of determination (R2), Pearson and Spearman correlation. Additionally, we used mean absolute error (MAE), mean squared error (MSE), root mean squared error (RMSE), relative standard deviation (RSD), and the relative error in percentage between the predicted CCS values and the experimental ones (% CCS error).",
      "asbval:note": "Paper explicitly compares multiple GNN architectures (GraphCCS, SigmaCCS, Mol2CCS) using RMSE, MAE, and other regression metrics on held-out test sets across different evaluation settings.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "regression-metric-computation-and-comparison",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute and compare regression performance metrics (RMSE, MAE, prediction accuracy) across alternative model architectures on held-out test sets to quantify predictive performance differences.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:22:53.901914+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/regression-metric-computation-and-comparison/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our results revealed that the original high accuracy reported when the models were trained on CCSBase does not generalize to other chemical spaces... Additionally, we demonstrate how an extension of the architecture of GNN (Mol2CCS) including other additional features improves the generalizability of SigmaCCS, particularly for dimers and other uncommon adducts.",
      "asbval:note": "Paper explicitly compares Mol2CCS (extended architecture) against SigmaCCS (baseline) to validate whether architectural improvements enhance CCS prediction accuracy.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "regression-metric-computation-and-comparison",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill validates whether alternative GNN architectures improve or degrade collision cross section prediction accuracy relative to a baseline.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:22:53.901914+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
