    {
      "@id": "asbval:assertion/skill/molecular-ccs-prediction-model-training/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In this study, we evaluated state-of-the-art Graph Neural Networks (GNNs), trained to predict CCS values using the largest publicly available dataset to date.",
