    {
      "@id": "asbval:assertion/skill/message-passing-variant-selection-and-adaptation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We evaluated the performance of the two most accurate ML models trained to predict CCS values: GraphCCS [22], and SigmaCCS [6]. We retrained these models using the reported hyperparameters on the datasets used in this work.",
      "asbval:note": "Paper does maintain fixed train/test splits (80/20 stratified by Murcko scaffold) and compares models on CCS prediction (continuous property) with consistent hyperparameters. However, the paper does not systematically explore attention-based or generalized message-passing variants. GraphCCS uses Graph Convolutional Networks (GCN), SigmaCCS uses Edge-Conditioned Convolutions (ECC)\u2014both are existing architectures, not newly implemented alternatives.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "message-passing-variant-selection-and-adaptation",
