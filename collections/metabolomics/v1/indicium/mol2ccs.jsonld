    {
      "@id": "asbval:assertion/skill/regression-metric-computation-and-comparison/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We performed an 80/20 train test split on each of these groups stratified on the Murcko scaffold... After performing these splits, we combined all of the train splits and all of the test splits to create our training and test sets... For models that were trained solely on a single database (i.e., METLIN-CCS or CCSBase), we used these same data splits confined to that particular database.",
      "asbval:note": "Paper carefully controls data splits to ensure fair comparison across architectures, supporting the principle that different data splits would confound results.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "regression-metric-computation-and-comparison",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Models were trained on different datasets or data splits \u2014 results would conflate architecture and dataset effects.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:22:53.901914+00:00",
      "sepio:credibility_status": {
