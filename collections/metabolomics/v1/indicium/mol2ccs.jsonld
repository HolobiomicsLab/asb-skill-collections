    {
      "@id": "asbval:assertion/skill/atom-feature-extraction-chemistry/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In this analysis, the SMILES strings available in both datasets are the base representation leveraged to generate molecular fingerprints and graph representations.",
      "asbval:note": "Paper explicitly uses SMILES from METLIN-CCS and CCSBase as input for feature extraction and graph construction.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "atom-feature-extraction-chemistry",
