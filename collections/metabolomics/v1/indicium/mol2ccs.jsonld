    {
      "@id": "asbval:assertion/skill/molecular-graph-construction-from-smiles/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To construct them, we first read the SMILES representation of each molecule using RDKit (v2023.09.5) [8] and subsequently used the ETKDG and MMFF94 conformer generators to obtain the 3D conformers for each molecule. Lastly, from these conformers, we obtained the atoms, bonds and their attributes.",
      "asbval:note": "Paper explicitly describes SMILES-to-graph conversion with atom/bond feature extraction using RDKit.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-graph-construction-from-smiles",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Convert SMILES strings into graph tensor representations suitable for graph neural network input by canonicalizing structures and extracting atom and bond features.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
