    {
      "@id": "asbval:assertion/skill/feature-ablation-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not perform feature ablation, masking, or post-hoc attribution analysis on GNN inputs. The paper benchmarks GNN models (GraphCCS, SigmaCCS, Mol2CCS) for CCS prediction and evaluates their generalizability across chemical spaces, but does not conduct systematic feature removal or importance ranking. The paper does extend SigmaCCS with additional features (fingerprints, descriptors, molecule types, instrument type) but this is architectural extension, not ablation analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "feature-ablation-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Systematically remove or mask individual molecular structural features (node and edge attributes) from graph neural network inputs and measure the resulting change in predicted collision cross section, enabling post-hoc attribution analysis to rank features by importance for mode",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
