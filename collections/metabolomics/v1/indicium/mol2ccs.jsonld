      }
    },
    {
      "@id": "asbval:assertion/skill/model-hyperparameter-transfer-and-tuning/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper explicitly conducts grid search for Mol2CCS hyperparameters (passage [6]: 'We chose these parameters based on a grid search experiment conducted on a subset of the dataset'). No evidence of hyperparameter transfer or rapid exploration without search.",
