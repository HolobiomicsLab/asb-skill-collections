      "asbval:note": "Paper explicitly uses reported hyperparameters for baseline models and conducts grid search for Mol2CCS, demonstrating awareness that matched training conditions are necessary for fair comparison.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
