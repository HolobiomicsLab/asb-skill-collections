    {
      "@id": "asbval:assertion/skill/molecular-graph-construction-from-smiles/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For this work, we leveraged two of the largest public resources for CCS values: CCSBase [17] and METLIN-CCS [1]. CCSBase (v1.3) combines 22 different datasets, providing a total of 16,989 CCS values measured on three different instruments from 6,744 distinct molecules... METLIN-CCS (downloaded on 14/04/2024) is currently the largest CCS database with over 65,000 CCS values from 27,633 distinct small synthetic molecules.",
      "asbval:note": "Paper explicitly uses CCSBase and METLIN-CCS as source datasets with SMILES strings.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-graph-construction-from-smiles",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When to use: You have raw SMILES strings from a chemical database (e.g., CCSBase, METLIN, or custom sources)",
