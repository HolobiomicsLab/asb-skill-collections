    {
      "@id": "asbval:assertion/skill/atom-bond-feature-importance-ranking/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not perform post-hoc attribution analysis, ablation studies, or gradient-based saliency scoring on GNN predictions. Paper benchmarks GNN models (SigmaCCS, GraphCCS, Mol2CCS) for CCS prediction accuracy and generalizability, but does not interpret which node/edge features drive predictions via attribution methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "atom-bond-feature-importance-ranking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Post-hoc attribution analysis of graph neural network predictions to identify and rank which molecular structural features (node and edge attributes) drive model predictions of collision cross section",
      "eco:evidence_type": {
