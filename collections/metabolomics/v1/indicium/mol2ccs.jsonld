    {
      "@id": "asbval:assertion/skill/gradient-based-saliency-mapping/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To construct them, we first read the SMILES representation of each molecule using RDKit (v2023.09.5) [8] and subsequently used the ETKDG and MMFF94 conformer generators to obtain the 3D conformers for each molecule. Lastly, from these conformers, we obtained the atoms, bonds and their attributes.",
      "asbval:note": "RDKit is confirmed as used for parsing SMILES and generating molecular graph representations (atoms, bonds, features). However, the card's claim about gradient-based saliency mapping is not supported by the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gradient-based-saliency-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "RDKit \u2014 Parses SMILES strings and generates molecular graph representations (atoms, bonds, features) as input to the GNN model.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:19:30.303354+00:00",
      "sepio:credibility_status": {
