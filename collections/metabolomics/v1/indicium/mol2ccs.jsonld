    {
      "@id": "asbval:assertion/skill/molecular-ccs-prediction-model-training/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In this work we benchmark the state-of-the-art models on the new METLIN-CCS database and assess their generalizability. We evaluated the performance of the two most accurate ML models trained to predict CCS values: GraphCCS [22], and SigmaCCS [6].",
      "asbval:note": "Paper benchmarks GraphCCS and SigmaCCS on both METLIN-CCS and CCSBase with standardized train/test splits stratified by Murcko scaffold.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-ccs-prediction-model-training",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "comparative evaluation of different GNN architectures on standardized train/test splits from curated databases (METLIN-CCS, CCSBase)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:21:32.877981+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/molecular-ccs-prediction-model-training/002",
      "@type": "asbval:ClaimAssessment",
