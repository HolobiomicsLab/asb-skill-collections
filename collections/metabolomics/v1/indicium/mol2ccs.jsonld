    {
      "@id": "asbval:assertion/skill/feature-ablation-analysis/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not perform feature ablation or masking. Instead, it extends the SigmaCCS architecture by adding additional features (Morgan fingerprints, molecular weight, structural classes, molecule type, instrument type) in parallel to the GNN module. This is feature augmentation, not ablation analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "feature-ablation-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "feature-ablation-analysis: Systematically remove or mask individual molecular structural features (node and edge attributes) from graph neural network inputs and measure the resulting change in predicted collision cross section",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
