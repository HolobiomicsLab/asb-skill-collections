    {
      "@id": "asbval:assertion/skill/molecular-structure-attribution/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper benchmarks GNN models (SigmaCCS, GraphCCS, Mol2CCS) for CCS prediction and evaluates their generalizability across chemical spaces. It does NOT perform ablation studies, gradient-based attribution, or post-hoc interpretation of which molecular structural features drive predictions. The paper focuses on model performance metrics (R\u00b2, RMSE, MAE) and generalization gaps, not feature attribution or model interpretability.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
