    {
      "@id": "asbval:assertion/skill/gradient-based-saliency-mapping/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not discuss gradient-based attribution maps, saliency mapping, or post-hoc interpretability methods for explaining GNN predictions. The paper focuses on benchmarking model performance, generalizability across datasets, and confidence models for filtering predictions\u2014not on explaining individual predictions via gradient-based methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "gradient-based-saliency-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute gradient-based attribution maps that identify which input features (node and edge attributes in molecular graphs) most strongly influence neural network predictions of collision cross section. This post-hoc interpretability method uses backpropagation to quantify the sens",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:19:30.303354+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/gradient-based-saliency-mapping/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not address feature attribution or explanation of individual predictions. It evaluates model performance metrics (R\u00b2, RMSE, MAE, MRE) and generalizability but does not discuss identifying which structural features drive predictions.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "gradient-based-saliency-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have a trained graph neural network model for CCS prediction and need to identify which molecular structural features drive individual predictions or systematic biases.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:19:30.303354+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/gradient-based-saliency-mapping/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "PyTorch is not mentioned in the paper. The paper does not discuss gradient-based saliency mapping or use of PyTorch for this purpose. The paper mentions RDKit and scikit-learn but not PyTorch.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "gradient-based-saliency-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "PyTorch \u2014 Enables gradient computation and backpropagation for saliency map generation via torch.autograd.backward() and tensor.grad attribute.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:19:30.303354+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/gradient-based-saliency-mapping/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "TensorFlow is not mentioned in the paper. The paper does not discuss gradient-based attribution or TensorFlow implementation.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-024-00899-w",
