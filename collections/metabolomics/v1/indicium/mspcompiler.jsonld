    {
      "@id": "asbval:assertion/claim/claim_001",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "The goal of mspcompiler is to offer ways to compile either EI or tandem mass spectral libraries from various sources such as NIST, MoNA, and GPNS.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-2c05389",
      "asbval:source_excerpt": "The goal of mspcompiler is to offer ways to compile either EI or tandem\nmass spectral libraries from various sources, such as NIST (if you have\nit installed), MoNA, and GPNS, and organize them into a neat and\nup-to-date msp file that can be used in MS-DIAL.",
      "asbval:substring_in_paper": false,
