    {
      "@id": "asbval:assertion/skill/evidence-linking/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "NP Analyst, an open online platform for Compound Activity Mapping that accepts bioassay data of almost any type, and is compatible with mass spectrometry data from major instrument manufacturers via the mzML format. In addition, NP Analyst will accept processed mass spectrometry data from the MZmine 2 and GNPS open-source platforms, making it a versatile tool for integration with existing discovery workflows.",
      "asbval:note": "The paper demonstrates evidence linking through detailed workflow documentation, supplementary materials references, and reproducible outputs (job numbers, URLs, downloadable results files).",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_1c01108",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "evidence-linking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Link scientific claims to their supporting evidence by reviewing indexed article artifacts, connecting reported findings to outputs, and identifying missing materials or reproducibility information.",
