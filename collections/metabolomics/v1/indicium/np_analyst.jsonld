    {
      "@id": "asbval:assertion/skill/evidence-linking/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Each results file is assigned a unique job number which is used to create a permanent hyperlink to the results pages, providing a facile mechanism for collaborators to retrieve and share data. ... Upon completion, the results section is displayed, including interactive tabs for scatter plot, network, and community views, as well as a downloads page to export the results files. Export options include a graphML network file for use in network visualization tools (Cytoscape, Gephi) and CSV for use in spreadsheets and graph plotting tools (e.g., Excel, Tableau, Jmp, Spotfire).",
      "asbval:note": "Paper provides extensive reproducibility infrastructure: persistent job URLs, downloadable outputs in multiple formats, detailed documentation links, and public sample data accessible via www.npanalyst.org.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_1c01108",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "evidence-linking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Assess reproducibility and traceability of scientific article's findings by verifying claims are grounded in actual outputs, code, or supplementary materials",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:07:40.619220+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/evidence-linking/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For full instructions on bioassay file formatting requirements see the online documentation at https://liningtonlab.github.io/npanalyst_documentation/NPAnalyst/file-import/ ... Instructions for both of these export methods are provided in the software documentation (https://liningtonlab.github.io/npanalyst_documentation/).",
      "asbval:note": "Paper references extensive online documentation but does not include complete reproducibility details in the article itself. Some implementation details (e.g., exact R-tree algorithm parameters, statistical thresholds) are not fully specified in the passages provided.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_1c01108",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "evidence-linking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Identify missing materials or reproducibility information",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:07:40.619220+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/evidence-linking/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We validated this new platform by analyzing a 'low-resolution' antimicrobial bioassay data set for 925 natural product prefractions. From these results, three communities were selected for further study, leading to the isolation of three classes of bioactive metabolites including two new compounds (dracolactam C (3) and amychelin C (6)). ... Screening of purified amychelin C in the BioMAP assay recapitulated the spectrum of activity predicted from the original community, confirming this molecule as the predominant active component in this community.",
      "asbval:note": "Paper provides detailed case studies (Communities 12, 15, 16) tracing from NP Analyst predictions through isolation, characterization, and experimental validation of bioactivity.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_1c01108",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "evidence-linking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Connect reported findings to outputs through validation examples",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:07:40.619220+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
