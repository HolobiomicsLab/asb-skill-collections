    {
      "@id": "asbval:assertion/skill/intensity-dependent-missing-value-simulation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "T_ISO introduces an additional process for the intensity-dependent missing value in ISO mode",
      "asbval:note": "Paper confirms intensity-dependent missing value is applied in ISO mode, but does NOT explicitly state it simulates 'photon-counting and detector artifacts'. The paper describes it as setting 'the missing ratio of ions proportional to their intensities' (passage 4) to reflect MSI data characteristics, but the specific framing as 'photon-counting detector artifacts' is an interpretation not present in the source text.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05002",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "intensity-dependent-missing-value-simulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "A data augmentation technique that selectively removes pixels from ion images based on their intensity levels, applied exclusively in ISO mode of the DeepION pipeline to simulate realistic photon-counting and detector artifacts in mass spectrometry imaging.",
