    {
      "@id": "asbval:assertion/skill/col-mode-augmentation-pipeline-implementation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Two modes of DeepION, denoted as COL and ISO, are designed for the cases of regular colocalized ions from different molecules and isotope ions from the same molecule, respectively. As modality-specific data augmentation is critical to the performance of models trained by contrastive learning, we propose two data augmentation strategies especially for the COL and ISO mods by considering the characteristics of the Poisson distribution and missing patterns in MSI. The operations of Poisson noise and random missing value are carried out in the COL mode of DeepION, which aims to simulate the data distributions within MSI, whereas the intensity-dependent missing value operation is conducted additively in ISO mode",
      "asbval:note": "Claim is well-supported. Paper explicitly describes COL mode augmentation with Poisson noise and random missing value operations, and contrasts with ISO mode.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05002",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "col-mode-augmentation-pipeline-implementation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Implementation of the COL (co-localized ions) data augmentation pipeline for ion images in mass spectrometry imaging, which applies four sequential augmentation operations to generate contrastive image pairs for deep learning models.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:56:16.433309+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
