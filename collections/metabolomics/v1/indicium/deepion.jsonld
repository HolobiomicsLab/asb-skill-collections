      "@id": "asbval:assertion/skill/convolutional-neural-network-encoding/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Two modes of DeepION, denoted as COL and ISO, are designed for the cases of regular colocalized ions from different molecules and isotope ions from the same molecule, respectively.",
      "asbval:note": "COL and ISO modes for colocalized and isotope ion discovery confirmed. Encoder is core module in contrastive learning pipeline.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05002",
      "asbval:supported_raw": "yes",
