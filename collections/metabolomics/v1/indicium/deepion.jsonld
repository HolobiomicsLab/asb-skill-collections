    {
      "@id": "asbval:assertion/skill/contrastive-learning-encoder-construction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The encoder module is used to learn an ion image representation function f(\u2022|\u03b8f) to extract the high-level features from ion images for downstream tasks. It consists of twin networks that share identical parameters and adopt the pretrained Resnet18 as the backbone network... Taking the ion image x as an example, the encoder takes two augmented views x1 and x2 from ion image x as inputs. Then, two ion image representations r1 (d = 512) and r2 (d = 512) corresponding to the same image x are obtained",
      "asbval:note": "Fully supported: shared-weight ResNet18, twin networks with identical parameters, 512-dimensional outputs, paired augmented inputs.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05002",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "contrastive-learning-encoder-construction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Build a shared-weight ResNet18 encoder module that processes pairs of augmented ion images to produce 512-dimensional representation vectors for contrastive learning in mass spectrometry imaging.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:56:32.522970+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/contrastive-learning-encoder-construction/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A contrasting loss is employed to maximize the similarity with a stop-gradient operation on h2 to prevent the reaction from collapsing during training... the loss function of the DeepION model is as follows... where the encoder on x2 receives no gradient from h2 in the first term but receives gradients from h2 in the second term (and vice versa for x1).",
      "asbval:note": "Fully supported: contrastive loss maximizes similarity, stop-gradient operation prevents collapse.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05002",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "contrastive-learning-encoder-construction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill applies contrastive loss to maximize similarity between augmentations of the same image while avoiding representation collapse.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
