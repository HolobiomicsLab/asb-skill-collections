    {
      "@id": "asbval:assertion/skill/intensity-dependent-missing-value-simulation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the intensity-dependent missing value operation is conducted additively in ISO mode by setting the missing ratio of ions proportional to their intensities",
      "asbval:note": "Paper confirms the mechanism (missing ratio proportional to intensity), but does not explicitly state this relationship is 'critical for learning robust representations of isotope ions'. The paper shows ISO mode achieves 75.90% and 92.76% accuracy but does not attribute this specifically to the intensity-dependent missing value mechanism in isolation.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05002",
