      }
    },
    {
      "@id": "asbval:assertion/skill/spectrum-feature-vectorization/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PS2MS builds a supplementary synthetic NPS database by enumerating possible derivatives based on the core structure of a preselected illicit drug. The system leverages two deep learning models, NEIMS and DeepEI, to predict the mass spectrum of the enumerated substances in the NPS database and the structure representations (i.e., fingerprints) of the unidentified analyte, respectively.",
      "asbval:note": "PS\u00b2MS is confirmed as the target system that processes spectra for NPS identification. The paper confirms it receives mass spectra as input.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectrum-feature-vectorization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "PS\u00b2MS \u2014 Target deep learning system that receives vectorized spectra as input for NPS classification inference",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:19:31.477136+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectrum-feature-vectorization/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we employed NEIMS to predict the mass spectrum of all derivatives within our synthetic NPS database. As the original NEIMS was initially trained solely using spectra from the NIST library, which covered a broader range of chemicals yet with only a small fraction dedicated to drugs, its performance significantly declined when tested with spectra of illicit drugs in our experiments.",
      "asbval:note": "NEIMS is confirmed to generate predicted mass spectra for the NPS database. However, the paper does not explicitly state that these predicted spectra are 'themselves vectorized for fingerprint comparison'\u2014that role is attributed to DeepEI, which converts spectra to fingerprints. The card's claim conflates NEIMS's role (spectrum prediction) with fingerprint generation (DeepEI's role).",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectrum-feature-vectorization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "NEIMS \u2014 Generates predicted mass spectra for synthetic NPS database compounds; used in PS\u00b2MS pipeline to create reference spectra that are themselves vectorized for fingerprint comparison",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:19:31.477136+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectrum-feature-vectorization/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PS2MS employs the DeepEI deep learning model to convert the analyte's mass spectrum into its corresponding fingerprint, all without the need for explicit structure information. A similarity metric based on the fingerprints of both the analyte and its derivatives can then be readily calculated.",
      "asbval:note": "DeepEI is confirmed to convert mass spectra to fingerprints and these fingerprints are used in similarity scoring (SMSF metric).",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectrum-feature-vectorization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "DeepEI \u2014 Predicts chemical fingerprints from vectorized spectra; processes the same m/z\u2013intensity inputs to extract fingerprint features used in similarity scoring",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:19:31.477136+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectrum-feature-vectorization/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "GitHub repository URL not mentioned in paper passages. Cannot verify from provided text.",
