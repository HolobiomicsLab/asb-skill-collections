    },
    {
      "@id": "asbval:assertion/skill/confidence-score-interpretation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By forming Gaussian distributions of similarity scores for cathinone-like and noncathinone-like drugs from SWGDRUG data sets, the threshold was defined at the point where two probability functions intersect. We found that a similarity threshold of 0.55 can effectively differentiate between similar and dissimilar substances",
      "asbval:note": "Paper does apply thresholds to filter predictions (SMSF score \u2265 0.55), but the mechanism is threshold-based filtering of similarity scores rather than model confidence probabilities. The threshold is derived from Gaussian distributions of similarity metrics, not from standard confidence/probability outputs. The concept is functionally similar but the terminology and mechanism differ from typical 'confidence score' interpretation.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "confidence-score-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Interpret and apply confidence thresholds to deep learning model predictions for NPS classification from mass spectrometry data. This skill filters predictions by model confidence to assign reliable NPS class labels and exclude low-confidence matches.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:17:41.950631+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/confidence-score-interpretation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PS2MS employs the DeepEI deep learning model to convert the analyte's mass spectrum into its corresponding fingerprint... A similarity metric based on the fingerprints of both the analyte and its derivatives can then be readily calculated.",
