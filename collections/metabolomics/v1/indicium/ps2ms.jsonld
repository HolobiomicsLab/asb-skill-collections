    {
      "@id": "asbval:assertion/skill/structural-similarity-calculation-fingerprint-based/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The fingerprints of all of the derivatives in the NPS database can be easily transformed using their known structure representation during enumeration. However, since the structure of the analyte is absent, PS2MS employs the DeepEI30 deep learning model to convert the analyte's mass spectrum into its corresponding fingerprint.",
      "asbval:note": "Paper uses fingerprints but does not name RDKit or any specific cheminformatics library. Fingerprints are derived from structure representations during enumeration (method unspecified) and from mass spectra via DeepEI (a neural network, not a traditional cheminformatics tool). The functional role (fingerprint computation) is present but the specific tool is not identified.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "structural-similarity-calculation-fingerprint-based",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[RDKit or similar cheminformatics library]",
