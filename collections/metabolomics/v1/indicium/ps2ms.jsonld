      }
    },
    {
      "@id": "asbval:assertion/skill/statistical-distribution-analysis-across-cohorts/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not mention Pandas. While the paper computes stratified statistics (sensitivity, specificity, F1 score by cohort), the tool used for aggregation is not specified.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "statistical-distribution-analysis-across-cohorts",
