    {
      "@id": "asbval:assertion/skill/confidence-score-extraction-from-neural-networks/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PS2MS, an AI-powered predictive system designed specifically to address the limitations of identifying the emergence of unidentified novel illicit drugs... The system leverages two deep learning models, NEIMS and DeepEI, to predict the mass spectrum of the enumerated substances in the NPS database and the structure representations (i.e., fingerprints) of the unidentified analyte, respectively.",
      "asbval:note": "PS2MS is the central system described in the paper and uses deep learning models NEIMS and DeepEI.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "confidence-score-extraction-from-neural-networks",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "PS2MS as source deep learning model for NPS detection",
