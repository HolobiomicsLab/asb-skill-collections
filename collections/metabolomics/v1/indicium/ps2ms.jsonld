      }
    },
    {
      "@id": "asbval:assertion/skill/structural-similarity-calculation-fingerprint-based/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The distribution of metrics used to match between the predicted and true spectra is depicted in Figure 3c.",
      "asbval:note": "Paper does visualize similarity score distributions (Figure 3c, 4b, 4c, 5b) but does not explicitly name Matplotlib or Seaborn. Visualizations are present but tool attribution is not stated. No explicit stratification by novelty categories is shown.",
