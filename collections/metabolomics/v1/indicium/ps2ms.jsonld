    {
      "@id": "asbval:assertion/skill/structural-similarity-calculation-fingerprint-based/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The system leverages two deep learning models, NEIMS and DeepEI, to predict the mass spectrum of the enumerated substances in the NPS database and the structure representations (i.e., fingerprints) of the unidentified analyte, respectively.",
      "asbval:note": "Paper uses deep learning models (NEIMS, DeepEI) to generate predictions and confidence scores (SMSF), but does not explicitly mention PyTorch or TensorFlow. The paper does not discuss extracting confidence scores stratified by novelty; instead, it reports SMSF scores for all test compounds without novelty-based stratification.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "partial",
