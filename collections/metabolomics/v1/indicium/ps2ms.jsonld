    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-data-preprocessing/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PS2MS, an AI-powered predictive system, designed specifically for this purpose. When the mass spectrum of an analyte, retrieved via GC/EI-MS, does not match any established reference spectra during the conventional screening procedure, PS2MS builds a supplementary synthetic NPS database by enumerating possible derivatives based on the core structure of a preselected illicit drug.",
      "asbval:note": "PS\u00b2MS confirmed as the primary system for NPS identification and prediction.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-data-preprocessing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "PS\u00b2MS - Target deep learning prediction system that consumes preprocessed spectra to infer NPS class labels and confidence scores",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:18:20.814628+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-data-preprocessing/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we employed NEIMS to predict the mass spectrum of all derivatives within our synthetic NPS database. As the original NEIMS was initially trained solely using spectra from the NIST library, which covered a broader range of chemicals yet with only a small fraction dedicated to drugs, its performance significantly declined when tested with spectra of illicit drugs in our experiments.",
      "asbval:note": "NEIMS is confirmed as the spectrum prediction model used within PS\u00b2MS.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-data-preprocessing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "NEIMS - Generates predicted mass spectra for synthetic NPS database compounds; output spectra may require equivalent preprocessing",
      "eco:evidence_type": {
