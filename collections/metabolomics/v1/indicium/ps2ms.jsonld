      }
    },
    {
      "@id": "asbval:assertion/skill/confidence-score-extraction-from-neural-networks/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The validation of PS2MS was carried out through anonymized testing of known synthetic cathinones, showcasing high specificity and sensitivity... 20 known derivatives of cathinone (i.e., positive samples) and 20 noncathinone (i.e., negative samples).",
      "asbval:note": "Paper does evaluate PS2MS on test compounds and stratifies by drug class (cathinone vs. noncathinone), but does not explicitly assess confidence variation across structural novelty classes (e.g., training-similar vs. out-of-distribution analogues).",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
