    {
      "@id": "asbval:assertion/skill/spectrum-feature-vectorization/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we obtained mass spectrum data from the Scientific Working Group for the Analysis of Seized Drugs (SWGDRUG) for training and testing NEIMS. We then meticulously sampled, partitioned, and subsequently retrained NEIMS.",
      "asbval:note": "Paper does not specify version numbers for NEIMS, DeepEI, or PS\u00b2MS, so null is appropriate.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
