      }
    },
    {
      "@id": "asbval:assertion/skill/molecular-descriptor-extraction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Directed message passing neural networks (D-MPNN18) operate on molecular graphs based on chemical structures in the simplified molecular input line entry system (SMILES19) notation to build neural representations of molecules for property prediction including mass spectra.",
      "asbval:note": "Paper mentions SMILES notation and neural representations for molecular property prediction, but does NOT explicitly describe extracting atom types, bond connectivity, and graph topology into fixed-size tensors. The paper uses NEIMS (which takes ECFPs\u2014extended circular fingerprints) and DeepEI (which converts mass spectra to fingerprints), not explicit graph-to-tensor conversion. The card's framing of 'fixed-size numerical tensors' and 'atom types, bond connectivity, graph topology' extraction is not directly supported; the paper's actual approach uses fingerprints and pre-trained models rather than explicit feature engineering from SMILES.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c05019",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "molecular-descriptor-extraction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Extract atom types, bond connectivity, and graph topology features from canonical molecular structures to create fixed-size numerical tensors for deep learning input. This skill bridges chemical structure representation (SMILES) to machine-learning-ready feature matrices required",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:18:36.614991+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
