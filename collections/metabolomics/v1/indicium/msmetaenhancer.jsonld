    {
      "@id": "asbval:assertion/skill/asynchronous-converter-instantiation/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The tool processes the spectral library by iteratively executing all steps for each entry... These steps consist of specifying what service should be used to obtain a particular metadata attribute based on another already existing attribute.",
      "asbval:note": "Paper confirms that annotation steps are tuples of (source_attr, target_attr, service), but does not explicitly describe __init__ method specifications or class-level converter definitions. The example shows manual job specification: jobs = [('inchikey', 'inchi', 'CIR'), ('inchikey', 'iupac_name', 'CTS'), ...], not automatic discovery from converter class __init__ methods.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-04494",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "asynchronous-converter-instantiation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "each converter defines its own (source_attr, target_attr, conversion_method) specifications in its __init__ method",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:49:11.256070+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
