    {
      "@id": "asbval:assertion/skill/chemical-structure-representation-conversion/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The software package MSMeta Enhancer is a tool to enhance the metadata content of records in mass spectral library files. It takes as input a single .msp file with multiple mass spectra records and a list of annotation steps. These steps consist of specifying what service should be used to obtain a particular metadata attribute based on another already existing attribute... Besides querying external services, we also support converters to compute identifiers based on existing ones.",
      "asbval:note": "Confirmed: MSMetaEnhancer orchestrates both web services and local compute converters for .msp metadata enrichment.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-04494",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chemical-structure-representation-conversion",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[MSMetaEnhancer].role",
      "asbval:target_claim_text": "Container application that registers and orchestrates converters (both web and compute) to enrich .msp mass spectrometry metadata",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:50:03.138714+00:00",
      "sepio:credibility_status": {
