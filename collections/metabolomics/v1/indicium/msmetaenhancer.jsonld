    {
      "@id": "asbval:assertion/card/https___doi_org_10_21105_joss_04494__task_001/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "It annotates given mass spectra records in the library file by adding missing metadata such as SMILES, InChI, and CAS numbers to the individual entries... The tool processes the spectral library by iteratively executing all steps for each entry until no new metadata is found... app.save_spectra('annotated_spectra_file.msp', file_format='msp')",
      "asbval:note": "Output format (.msp) and metadata fields (SMILES, InChI, CAS) explicitly confirmed in abstract and example workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-04494",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
