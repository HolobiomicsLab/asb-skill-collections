    {
      "@id": "asbval:assertion/skill/smiles-inchi-round-trip-validation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The package retrieves the respective information by querying several external databases using existing metadata (e.g., SMILES or CAS number), converting different representations or database identifiers... Additionally, instead of querying external databases, computing the identifiers is also supported (e.g. molecular weight from SMILES).",
      "asbval:note": "Paper describes local identifier computation (e.g., molecular weight from SMILES) but does not explicitly address SMILES\u2194InChI bidirectional conversion validation or round-trip testing methodology. The scope of the task card is narrower and more specific than what the paper documents.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-04494",
      "asbval:supported_raw": "partial",
