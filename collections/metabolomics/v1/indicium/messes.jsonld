      }
    },
    {
      "@id": "asbval:assertion/skill/unit-test-design-for-data-processing/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The '--delete' option... Modification directives can also be used to modify the data as necessary for tasks such as renaming... it can be used to prepend, append, delete, overwrite, or regex substitute values... The option is very flexible and can be used to specify either a different sheet name in the given Excel file, a different Excel file...",
      "asbval:note": "Paper documents override, delete, and modification operations (prepend, append, delete, overwrite, regex), but does not explicitly mention 'code evaluation', 'conditional test filtering', or 'sorting' as directive features in the passages provided.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo13070842",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "unit-test-design-for-data-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "directives support parameterized resolution paths (override, code evaluation, conditional test filtering, sorting, field concatenation)",
      "eco:evidence_type": {
