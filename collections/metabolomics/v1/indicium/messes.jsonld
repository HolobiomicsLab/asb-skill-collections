      "asbval:target_claim_field": "tools[0].role",
      "asbval:target_claim_text": "Provides the convert command that applies matrix-type conversion directives to transform JSON-intermediate data into target formats; the directive engine implements field mapping, collation, filtering, sorting, and custom code execution",
