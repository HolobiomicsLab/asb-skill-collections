    {
      "@id": "asbval:assertion/skill/unit-test-design-for-data-processing/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MESSES uses the jsonschema library to validate user JSON input against an expected schema generated by MESSES in JSON Schema format... MESSES uses the jsonschema library to perform the lion's share of the validate command",
      "asbval:note": "Paper confirms jsonschema is used for validation of JSON against schema.",
