      }
    },
    {
      "@id": "asbval:assertion/skill/unit-test-design-for-data-processing/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This workflow starts with metadata and data in tabular format that is extracted into an intermediate MESSES JSON format which is further converted into the final mwTab deposition formats.",
      "asbval:note": "Paper describes the tabular-to-JSON-to-domain-format workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo13070842",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "unit-test-design-for-data-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "tabular data is transformed via conversion directives into JSON intermediate formats and then into domain-specific schemas",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:14:51.237459+00:00",
      "sepio:credibility_status": {
