      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:14:51.237459+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/unit-test-design-for-data-processing/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "It is recommended to use the --format option and specify 'mwtab'. It is also recommended to create a protocol-dependent schema and use the --pds option with the schema to perform additional validation. A protocol-dependent schema is provided in the Supplementary Materials.",
      "asbval:note": "Paper describes validation against Protocol Dependent Schema as part of the workflow, supporting the claim that unit tests precede schema validation.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo13070842",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "unit-test-design-for-data-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
