    {
      "@id": "asbval:assertion/skill/conditional-record-resolution/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Next, MESSES uses the jsonschema library to validate user JSON input against an expected schema generated by MESSES in JSON Schema format. JSON Schema is a declarative schema language for describing an expected data schema for the purpose of validating and annotating JSON representations of structured data. MESSES uses the jsonschema library to perform the lion's share of the validate command as well as to validate user input in the convert command.",
      "asbval:note": "jsonschema is confirmed as a third-party library used by MESSES for validation in both validate and convert commands.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo13070842",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "conditional-record-resolution",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "jsonschema \u2014 Validates resolved JSON output against Experiment Description Specification and format-specific schemas (e.g., mwTab schema) to ensure compliance before writing to file",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:09:47.699239+00:00",
      "sepio:credibility_status": {
