    {
      "@id": "asbval:assertion/skill/compound-reliability-filtering-by-rsd-threshold/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "mzQuality is distributed as an R package for which version 4.0 or later is required. ... mzQuality provides an accessible solution to improve the data quality without requiring prior programming skills.",
      "asbval:note": "R is confirmed as the language for mzQuality. The paper emphasizes the tool is user-friendly and does not require programming skills, but R is the underlying platform.",
