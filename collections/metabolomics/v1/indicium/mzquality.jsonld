    {
      "@id": "asbval:assertion/skill/r-package-api-usage/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "mzQuality is distributed as an R package for which version 4.0 or later is required. It is available through GitHub: https://github.com/hankemeierlab/mzQuality. For additional information on installation and usage, see the manual on GitHub.",
      "asbval:note": "Paper confirms mzQuality is an R package with documented API and GitHub repository. However, the paper does NOT explicitly mention SummarizedExperiment objects or type-aware object chaining. The paper describes mzQuality as processing 'peak-integrated data independently of vendor software' and provides sequential steps (IS normalization \u2192 outlier detection \u2192 batch correction \u2192 quality assessment), but does not document the internal use of SummarizedExperiment or explicit function-chaining API calls like readData() \u2192 buildExperiment() \u2192 doAnalysis(). The research question assumes a specific programmatic API structure that is not detailed in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-jasms-5c00073",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "r-package-api-usage",
