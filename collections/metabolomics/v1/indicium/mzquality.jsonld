    {
      "@id": "asbval:assertion/skill/summarized-experiment-object-construction/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The peak areas of compounds and IS, if applicable, need to be exported for use in mzQuality. We strongly recommend using a tab-separated format while exporting; an example can be found in GitHub: https://github.com/hankemeierlab/mzQuality. Additionally, it is important that numbers and symbols are compatible with R. The input file should include the following columns with the specified headers (Table ): aliquot, type, batch, compound, area, and datetime of the sample measurement.",
      "asbval:note": "Paper describes tab-delimited input format and validation requirements, but does not name a readData function. Paper states 'mzQuality performs a validation on the input file to ensure all necessary information is included and to detect any formatting errors' but does not attribute this to a separate readData function or describe handoff to buildExperiment.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-jasms-5c00073",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "summarized-experiment-object-construction",
      "asbval:target_artifact_kind": "skill_bundle",
