    {
      "@id": "asbval:assertion/claim/claim_001",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "mzQuality features outlier detection, batch-correction using pooled study quality control samples (SQC), filters for removing unreliable compounds, various plots for inspecting, and generating reports for further processing.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-jasms-5c00073",
      "asbval:source_excerpt": "mzQuality is a user-friendly R package for quality control of metabolomics \nstudies. It features outlier detection, batch-correction using pooled study \nquality control samples (SQC), filters for removing unreliable compounds, \nvarious plots for inspecting, and generating reports",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_001",
      "asbval:target_artifact_kind": "ledger_claim",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:26:14.258949+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/claim/claim_002",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "mzQuality is available as an interactive Shiny dashboard application called mzQualityDashboard.",
