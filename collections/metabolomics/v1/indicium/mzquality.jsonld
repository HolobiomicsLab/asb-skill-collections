    {
      "@id": "asbval:assertion/skill/compound-reliability-filtering-by-rsd-threshold/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The RSDqc is calculated per compound according to eq. The standard deviation (SD) of the corrected ratios of all QC samples from all batches (SD_corrected_ratio_QC_all_batches) is divided by the mean of all of these ratios (Mean_corrected_ratio_QC_all_batches). Based on the recommendations of the metabolomics quality assurance and quality control consortium, we set the threshold for the RSDqc at 30%. ... Compounds are organized into three tabs based on quality and user-defined or default settings: the 'High confidence' tab includes compounds with RSDqc values below 15%, the 'With Caution' tab includes compounds with RSDqc values ranging between 15% and 30%, and the 'Low Signal to Noise' tab including compounds with either background signal >40% or RSDqc values >30%.",
      "asbval:note": "The paper explicitly describes RSD-based filtering of compounds using QC samples with a 30% threshold, matching the research question.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-jasms-5c00073",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "compound-reliability-filtering-by-rsd-threshold",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Filter metabolomics compounds based on Relative Standard Deviation (RSD) of pooled quality-control (QC) samples to exclude unreliable analytes before reporting.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:30:53.696225+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/compound-reliability-filtering-by-rsd-threshold/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "mzQuality is distributed as an R package for which version 4.0 or later is required. It is available through GitHub: https://github.com/hankemeierlab/mzQuality. ... mzQuality performs several important quality control steps, such as identifying sample outliers, calculating background signal, performing batch correction, detecting trends in total signal intensity for either metabolite or IS, and calculating metrics that highlight variations in metabolite/IS ratios.",
      "asbval:note": "Paper confirms mzQuality is an R package that calculates RSDqc and filters compounds by quality thresholds. However, the paper does not mention 'doAnalysis' function or 'rowData$use' assignment explicitly\u2014these appear to be Bioconductor-specific implementation details not detailed in the paper. The functional role (RSD calculation and compound filtering) is confirmed, but the specific function/object names are not verified.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-jasms-5c00073",
