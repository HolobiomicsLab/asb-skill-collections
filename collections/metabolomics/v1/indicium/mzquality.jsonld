    {
      "@id": "asbval:assertion/skill/metabolomics-quality-control-report-generation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This output folder includes all of the previously mentioned plots and Excel files that can be used for statistical analysis in tools such as R. The Excel file lists all measured compounds, categorized by confidence level. Compounds are organized into three tabs based on quality and user-defined or default settings: the \"High confidence\" tab includes compounds with RSDqc values below 15%, the \"With Caution\" tab includes compounds with RSDqc values ranging between 15% and 30%, and the \"Low Signal to Noise\" tab including compounds with either background signal >40% or RSDqc values >30%.",
      "asbval:note": "Core functionality confirmed: mzQuality generates organized output folders with plots and Excel files categorizing compounds by confidence levels.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-jasms-5c00073",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolomics-quality-control-report-generation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Generate organized quality-control reports from mass spectrometry metabolomics data by creating structured directories containing publication-ready plots, tab-delimited tables, and Excel exports that categorize compounds and samples by confidence levels.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:32:41.594727+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
