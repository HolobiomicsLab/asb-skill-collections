    {
      "@id": "asbval:assertion/claim/claim_006",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "mzQuality follows the recommendations of the mQACC for quality control by leveraging on proper batch design and the addition of various quality control samples.",
