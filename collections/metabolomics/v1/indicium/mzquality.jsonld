    {
      "@id": "asbval:assertion/claim/claim_007",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "mzQuality is capable of recommending different internal standards by exhaustively calculating the Relative Standard Deviation of QC samples (RSDQC) of batch-corrected ratios.",
