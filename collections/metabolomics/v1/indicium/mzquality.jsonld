    {
      "@id": "asbval:assertion/skill/batch-corrected-data-extraction/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "mzQuality, a user-friendly, open-source R-Shiny app designed to assess and correct technical variations in mass spectrometry-based metabolomics data.",
      "asbval:note": "Paper confirms mzQuality is an R-Shiny app for assessing and correcting data. However, the tool is called 'mzQuality' (not 'mzQualityDashboard'), and the paper does not explicitly mention a separate 'mzQualityDashboard' tool. The Shiny interface is part of mzQuality itself, not a separate tool.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-jasms-5c00073",
