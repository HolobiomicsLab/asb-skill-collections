    {
      "@id": "asbval:assertion/skill/tabular-data-field-comparison/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For initial implementation studies, we will use Parquet (https://parquet.apache.org/), an open source, data file format designed for efficient storage and retrieval, including compression and encoding schemes to ensure scalability without sacrificing flexibility. Parquet access is available for many programming languages.",
      "asbval:note": "Paper confirms mzPeak will use Parquet format and that Parquet access is available for many programming languages (including Python via pyarrow), but does not explicitly name pyarrow as a tool used in the paper's own workflow. The paper describes mzPeak's design choice to use Parquet, not a specific task using pyarrow for comparison.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-5c00435",
      "asbval:supported_raw": "partial",
