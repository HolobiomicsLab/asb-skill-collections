      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-data-format-parsing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "mzPeak is designed to overcome the limitations of the aforementioned formats by adopting a hybrid model that combines efficient binary storage for numerical data and human-readable metadata storage... For initial implementation studies, we will use Parquet (https://parquet.apache.org/), an open source, data file format designed for efficient storage and retrieval... mzPeak will be released with a reference implementation in a low level programming language (e.g., C++) with bindings for multiple programming languages (e.g., Python), to ensure broad accessibility",
      "asbval:note": "Paper discusses mzPeak design and future reference implementation with language bindings, but does not explicitly describe parsing/reading workflows or conversion into tabular representations (DataFrames, Arrow Tables). The paper is a design/vision paper, not an implementation guide. The claim assumes working implementations exist; the paper states these are planned ('will be released').",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-5c00435",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mass-spectrometry-data-format-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
