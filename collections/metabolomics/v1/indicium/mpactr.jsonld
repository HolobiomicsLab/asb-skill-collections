    {
      "@id": "asbval:assertion/skill/metabolomics-feature-table-filtering/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "mpactR automates pre-processing of liquid chromatography-tandem mass spectrometry (LC-MS/MS) data from microbiological samples to correct mispicked peaks, resolve inter-sample variation in abundance across technical replicates, account for in-source ion fragmentation, and remove background noise to yield high-quality mass spectrometry features.",
      "asbval:note": "Core functionality directly stated in abstract.",
      "asbval:perspicacite_kb": "asb-paper-10-1128-mra-00997-24",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolomics-feature-table-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply a chain of independent filter operations to LC-MS peak tables to remove artifactual or low-quality features (mispicked ions, carryover contaminants, non-reproducible peaks, and in-source fragments) while preserving biologically meaningful metabolite signals.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:46:54.563828+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/metabolomics-feature-table-filtering/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "mpactR is designed using the R6 object-oriented programming system with reference semantics, allowing for minimal memory footprint while executing at least as fast as MPACT.",
      "asbval:note": "R6 reference semantics and memory efficiency explicitly confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1128-mra-00997-24",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolomics-feature-table-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Each filter operates via reference semantics on R6 objects, enabling memory-efficient in-place updates to the peak abundance matrix and metadata.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
