      }
    },
    {
      "@id": "asbval:assertion/card/task_001/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In order to allow for easy integration of downstream analysis methods such as statistical learning, we implemented this workflow in KNIME, a powerful platform for information mining (39).",
