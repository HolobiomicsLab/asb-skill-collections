    {
      "@id": "asbval:assertion/skill/workflow-reconstruction/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The algorithm is not limited to metabolites but is applicable to a wide range of small molecules (e.g. lipidomics, peptidomics), as well as to other separation technologies.",
      "asbval:note": "Paper focuses on metabolomics (label-free quantification of metabolites from LC-MS). While it mentions applicability to peptidomics and other small molecules, the primary scope is metabolomics, not both proteomics and metabolomics equally.",
      "asbval:perspicacite_kb": "asb-paper-10-1074-mcp-m113-031278",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "workflow-reconstruction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Reconstruct and validate mass spectrometry analysis workflows across proteomics and metabolomics pipelines.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:38:49.888996+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/workflow-reconstruction/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A typical data-processing pipeline includes centroiding, signal processing, feature detection, and retention time alignment... The algorithm is based on a sensitive detection of mass traces, which are then assembled into features based on mass-to-charge spacing, co-elution information, and a support vector machine\u2013based classifier.",
      "asbval:note": "Paper describes a specific pipeline for metabolite feature detection but does not explicitly address workflow verification, data provenance tracing, or CTD scheme parameter handling as general use cases.",
      "asbval:perspicacite_kb": "asb-paper-10-1074-mcp-m113-031278",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "workflow-reconstruction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When to use: When you have a partially documented or undocumented MS analysis pipeline and need to verify its correctness, trace data provenance through multiple processing stages, integrate tools via unified parameter handling (CTD scheme).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:38:49.888996+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
