      "@id": "asbval:assertion/skill/workflow-reconstruction/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The algorithm is available as part of the open-source software package OpenMS... The presented algorithm is implemented as part of the OpenMS framework. OpenMS, together with TOPP (The OpenMS Proteomics Pipeline), was designed as a versatile and functional framework for developing mass spectrometry data analysis tools, providing rich functionality ranging from basic data structures to sophisticated algorithms for data analysis and visualization.",
      "asbval:note": "Paper confirms OpenMS and TOPP integration but does not specify '150+ TOPP Tools' or explicitly mention 'CTD scheme' in provided passages. CTD (Common Tool Definition) is a standard OpenMS feature but not explicitly named in these excerpts.",
      "asbval:perspicacite_kb": "asb-paper-10-1074-mcp-m113-031278",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "workflow-reconstruction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "OpenMS - Core C++ library providing 150+ TOPP Tools for LC-MS data processing, parameter handling via CTD scheme, and unified workflow orchestration.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:38:49.888996+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
