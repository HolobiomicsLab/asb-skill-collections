    {
      "@id": "asbval:assertion/skill/gnps-network-processing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MolNetEnhancer is a software package available in Python and R that unites the output of several metabolome mining and annotation tools, including mass spectral molecular networking through GNPS, unsupervised substructure discovery through MS2LDA and in silico structure annotation... The workflow enhances the currently available molecular networking methods based on either MS-Cluster [29] (classical) or MZmine2 [30] (also called \"feature-based molecular networking\")... Substructure information retrieved through MS2LDA is integrated with mass spectral molecular networks... Most abundant chemical classes per molecular family are retrieved based on GNPS structural library hits and in silico chemical structural annotation and integrated within the mass spectral molecular networks.",
      "asbval:note": "Core claim fully supported by abstract and methods sections.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gnps-network-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill integrates MS2LDA-derived Mass2Motif substructural information and chemical class annotations onto mass spectral molecular networks created through the GNPS platform, supporting both classical and feature-based network modes.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:40:30.294956+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
