    {
      "@id": "asbval:assertion/card/task_001/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MolNetEnhancer is a software package available in Python and R that unites the output of several metabolome mining and annotation tools, including mass spectral molecular networking through GNPS, unsupervised substructure discovery through MS2LDA",
      "asbval:note": "GNPS (Global Natural Products Social Molecular Networking platform) is explicitly mentioned as a core component integrated by MolNetEnhancer.",
