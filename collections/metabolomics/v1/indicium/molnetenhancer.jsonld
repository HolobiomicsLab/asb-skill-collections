    {
      "@id": "asbval:assertion/skill/gnps-network-processing/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MolNetEnhancer discovers molecular families (MFs), subfamilies, and subtle structural differences between family members. The workflow enhances the currently available molecular networking methods based on either MS-Cluster [29] (classical) or MZmine2 [30] (also called \"feature-based molecular networking\")... Substructure information retrieved through MS2LDA is integrated with mass spectral molecular networks... Most abundant chemical classes per molecular family are retrieved based on GNPS structural library hits and in silico chemical structural annotation and integrated within the mass spectral molecular networks.",
      "asbval:note": "Scope statement aligns with paper's central contribution.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gnps-network-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "This skill integrates MS2LDA-derived Mass2Motif substructural information and chemical class annotations onto mass spectral molecular networks created through the GNPS platform, supporting both classical and feature-based network modes.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:40:30.294956+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/gnps-network-processing/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Substructural information retrieved through MS2LDA is integrated in two ways within the mass spectral molecular networks. Shared substructures or motifs between two molecular features are visualized as multiple edges connecting the nodes. Furthermore, motifs found within a molecular feature can be visualized as pie charts, where the relative abundance of each motif represents the overlap score... To retrieve the most abundant chemical classes per molecular family, all chemical structures obtained through GNPS library matching, and in silico chemical structural annotation are submitted to automated chemical classification and taxonomy structure using ClassyFire [16].",
      "asbval:note": "Motif mapping to nodes/edges and chemical class annotation confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gnps-network-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "It enables structural interpretation of molecular families by mapping motif probabilities and chemical class labels to network nodes and edges.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:40:30.294956+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
