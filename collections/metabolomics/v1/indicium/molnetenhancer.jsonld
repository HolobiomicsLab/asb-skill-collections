    {
      "@id": "asbval:assertion/skill/motif-to-node-mapping/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Currently, two distinct methods from raw data to MNs exist. One method takes all MS2 spectra found in the input files and uses MS-Cluster to prepare a set of representative 'consensus' MS2 spectra for molecular networking, and the other method uses MZmine2 for data preprocessing, which performs molecular feature detection at the MS1 level and associates each MS1 feature with its respective MS2 spectra to send off to GNPS Molecular Networking. The here proposed MolNetEnhancer workflow can enrich both these molecular networking methods with Mass2Motif presence and chemical class annotations.",
      "asbval:note": "Paper explicitly confirms support for both classical (MS-Cluster) and feature-based (MZmine2) molecular networking modes.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "motif-to-node-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Map MS2LDA-derived Mass2Motif substructural information onto nodes in GNPS mass spectral molecular networks (classical or feature-based mode)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:42:30.360592+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/motif-to-node-mapping/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow enhances the currently available molecular networking methods based on either MS-Cluster [29] (classical) or MZmine2 [30] (also called 'feature-based molecular networking') and results in annotated molecular networks that can be explored in Cytoscape [31]. Interactive Jupyter example notebooks and a step by step tutorial guide the user to build enhanced mass spectral molecular networks, which are outputted in the graphml format for visualization in Cytoscape.",
      "asbval:note": "Paper confirms graphml format output; inputs from GNPS and MS2LDA are described in the workflow steps.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "motif-to-node-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Inputs include GNPS classical molecular network file (graphml or JSON format) and MS2LDA experiment with Mass2Motif assignments",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:42:30.360592+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/ms2lda-feature-annotation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Substructural information retrieved through MS2LDA is integrated in two ways within the mass spectral molecular networks. Shared substructures or motifs between two molecular features are visualized as multiple edges connecting the nodes. Furthermore, motifs found within a molecular feature can be visualized as pie charts, where the relative abundance of each motif represents the overlap score",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ms2lda-feature-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Annotate mass spectral molecular network nodes with MS2LDA-derived substructural motifs (Mass2Motifs) to reveal recurrent fragmentation patterns and enable motif-based edge coloring and node labeling.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:42:46.958652+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/ms2lda-feature-annotation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Currently, two distinct methods from raw data to MNs exist. One method takes all MS2 spectra found in the input files and uses MS-Cluster to prepare a set of representative 'consensus' MS2 spectra for molecular networking, and the other method uses MZmine2 for data preprocessing, which performs molecular feature detection at the MS1 level and associates each MS1 feature with its respective MS2 spectra to send off to GNPS Molecular Networking. The here proposed MolNetEnhancer workflow can enrich both these molecular networking methods with Mass2Motif presence and chemical class annotations.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
