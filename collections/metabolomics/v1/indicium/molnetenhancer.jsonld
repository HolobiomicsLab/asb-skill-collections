    {
      "@id": "asbval:assertion/skill/molecular-network-attribute-enrichment/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MolNetEnhancer, a workflow that combines the outputs from molecular networking, MS2LDA, in silico annotation tools (such as Network Annotation Propagation or DEREPLICATOR), and the automated chemical classification through ClassyFire to provide a more comprehensive chemical overview of metabolomics data whilst at the same time illuminating structural details for each fragmentation spectrum.",
      "asbval:note": "Core research question is directly supported by abstract and methods sections.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-network-attribute-enrichment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Integrate chemical class and MS2LDA substructural motif information onto nodes and edges of a GNPS mass spectral molecular network, enabling functional and structural annotation of molecular families.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:58.968159+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/molecular-network-attribute-enrichment/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MolNetEnhancer discovers molecular families (MFs), subfamilies, and subtle structural differences between family members... Substructural information retrieved through MS2LDA is integrated in two ways within the mass spectral molecular networks. Shared substructures or motifs between two molecular features are visualized as multiple edges connecting the nodes.",
      "asbval:note": "Paper demonstrates enrichment of network topology with structural motifs and chemical class information.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-network-attribute-enrichment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This enriches network topology with chemical semantics that reveal shared structural motifs and taxonomic patterns across related compounds.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:58.968159+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
