    {
      "@id": "asbval:assertion/skill/molecular-network-graph-manipulation/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Currently, two distinct methods from raw data to MNs exist. One method takes all MS2 spectra found in the input files and uses MS-Cluster to prepare a set of representative 'consensus' MS2 spectra for molecular networking, and the other method uses MZmine2 for data preprocessing... The here proposed MolNetEnhancer workflow can enrich both these molecular networking methods... Interactive Jupyter example notebooks and a step by step tutorial guide the user to build enhanced mass spectral molecular networks, which are outputted in the graphml format for visualization in Cytoscape.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-network-graph-manipulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[GNPS].role",
      "asbval:target_claim_text": "Provides the classical and feature-based molecular network generation and outputs the graphml/JSON network files that serve as input to the enrichment workflow.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
