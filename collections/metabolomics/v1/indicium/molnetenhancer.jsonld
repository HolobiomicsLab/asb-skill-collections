    {
      "@id": "asbval:assertion/card/task_001/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here, we introduce MolNetEnhancer a software package available in Python and R that unites the output of many of the above-mentioned metabolome mining and annotation tools",
      "asbval:note": "The paper explicitly states MolNetEnhancer is available as a Python package.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
