    {
      "@id": "asbval:assertion/skill/mass-spectral-network-annotation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Before using the MolNetEnhancer workflow, the user will run each metabolome mining tool separately: Perform mass spectral molecular networking analysis through the Global Natural Products Social Molecular Networking platform. Perform in silico chemical structural annotation using for example Network Annotation Propagation (NAP) and DEREPLICATOR through the GNPS platform. Perform unsupervised substructure discovery using MS2LDA.",
      "asbval:note": "Paper confirms that MS2LDA and in silico annotation tools must be run separately before MolNetEnhancer, supporting the 'when NOT to use' constraint.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectral-network-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: You do not have MS2LDA results or chemical class assignments\u2014the tool requires these external annotations as input.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:11.149179+00:00",
