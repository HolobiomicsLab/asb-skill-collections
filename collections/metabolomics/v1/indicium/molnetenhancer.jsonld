    {
      "@id": "asbval:assertion/skill/gnps-network-processing/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MolNetEnhancer is a software package available in Python and R that unites the output of several metabolome mining and annotation tools, including mass spectral molecular networking through GNPS... The workflow enhances the currently available molecular networking methods based on either MS-Cluster [29] (classical) or MZmine2 [30] (also called \"feature-based molecular networking\")... results in annotated molecular networks that can be explored in Cytoscape [31]... The MolNetEnhancer workflow results in one graphml network file that contains all the structural information obtained from the individual tools.",
      "asbval:note": "GNPS as input source confirmed; GraphML output format explicitly mentioned.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gnps-network-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "GNPS - Generates the classical or feature-based mass spectral molecular network (GraphML/JSON) that serves as input",
      "eco:evidence_type": {
