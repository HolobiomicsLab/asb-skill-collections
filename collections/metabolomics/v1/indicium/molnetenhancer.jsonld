    {
      "@id": "asbval:assertion/skill/substructural-motif-annotation/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "These metabolome mining tools typically take MS/MS spectra as input, such as the open formats Mascott Generic Format (MGF), the mzML, or mzXML format, and generate tables where a fragmented mass feature is linked to other fragmented mass features or substructure patterns.",
      "asbval:note": "The paper emphasizes that both tools take MGF input and must be aligned; the card's warning about mismatches is a reasonable inference from the requirement that both tools process the same spectral data.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "substructural-motif-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope \u2014 When NOT to use (second condition)",
      "asbval:target_claim_text": "Your MS2LDA experiment was run on a different MGF file than the one used for GNPS network creation, causing precursor m/z and spectral metadata mismatches.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
