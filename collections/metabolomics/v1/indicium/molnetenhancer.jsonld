      }
    },
    {
      "@id": "asbval:assertion/skill/gnps-network-processing/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Perform unsupervised substructure discovery using MS2LDA (http://ms2lda.org)... Substructural information retrieved through MS2LDA is integrated in two ways within the mass spectral molecular networks... motifs found within a molecular feature can be visualized as pie charts, where the relative abundance of each motif represents the overlap score, a score measuring how much of the motif is present in the spectrum [32].",
      "asbval:note": "MS2LDA role and overlap score metric confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
