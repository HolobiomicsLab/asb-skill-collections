    {
      "@id": "asbval:assertion/skill/molecular-network-annotation-integration/012",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow enhances the currently available molecular networking methods based on either MS-Cluster [29] (classical) or MZmine2 [30] (also called 'feature-based molecular networking') and results in annotated molecular networks",
      "asbval:note": "Paper indicates both methods are supported but implies consistency is needed between input types",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo9070144",
      "asbval:supported_raw": "yes",
