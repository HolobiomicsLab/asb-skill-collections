      "asbval:target_artifact_id": "molecular-network-annotation-integration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Network nodes have no GNPS library matches and you require chemical class annotations (no input data for that layer) - when NOT to use",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
