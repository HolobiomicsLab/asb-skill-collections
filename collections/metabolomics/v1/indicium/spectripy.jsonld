    {
      "@id": "asbval:assertion/card/https___doi_org_10_21105_joss_08070__task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Spectri Py provides an R interface to Python enabling interoperability between the two programming languages... The open-source Spectri Py R package builds upon reticulate and provides functionality to efficiently translate between R and Python MS data structures... includes functionality to directly apply spectral similarity, filtering, normalization, etc. routines from the Python matchms library on MS data in R.",
      "asbval:note": "The paper explicitly describes SpectriPy's core function: wrapping Python MS package functionality (matchms) for use in R workflows with Spectra objects.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "How does SpectriPy wrap Python mass spectrometry package functionality to enable seamless integration into R-based Spectra analysis workflows?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:56:21.159820+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/card/https___doi_org_10_21105_joss_08070__task_001/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The open-source Spectri Py R package builds upon reticulate and provides functionality to efficiently translate between R and Python MS data structures.",
      "asbval:note": "SpectriPy (case-insensitive match: Spectri Py) is the primary subject of the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
