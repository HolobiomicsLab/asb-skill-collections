    {
      "@id": "asbval:assertion/skill/cross-language-function-invocation-and-validation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Each of these software packages covers different and in part complementary aspects in the analysis of MS data, but their integration into a single workflow remains a challenge, in particular across programming languages. To avoid the need for repeated implementation of algorithms in different programming languages we developed the Spectri Py package.",
      "asbval:note": "Scope rationale is supported; paper confirms complementary algorithms across languages and the motivation for SpectriPy.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cross-language-function-invocation-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Your R-based Spectra analysis workflow requires a specific mass spectrometry algorithm (e.g., CosineGreedy similarity scoring, spectral normalization, or advanced filtering) that is available only in a Python MS package (matchms, spectrum_utils) and not yet in native R.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
