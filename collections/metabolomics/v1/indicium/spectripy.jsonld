      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "excellent software libraries for such data analysis are available in both R and Python, including R packages from the Rfor Mass Spectrometry initiative such as Spectra, Ms Core Utils, Metabo Annotation, and Com- pound Db",
      "asbval:note": "Spectra confirmed as R package from R for Mass Spectrometry initiative; used as container object in SpectriPy workflows.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
