      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "As such, Spectri Py provides an easy way to compare spectra similarity functions from commonly-used R and Python libraries, e.g. during LC-MS/MS data annotation.",
      "asbval:note": "Implicit support: the paper demonstrates comparing R's native Spectra functions with Python's matchms functions, suggesting users should choose based on availability and preference.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "r-python-interoperability-via-wrapper",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Your desired MS operation is already available as a native R function in Spectra or related packages",
