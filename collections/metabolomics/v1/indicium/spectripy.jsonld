    },
    {
      "@id": "asbval:assertion/card/https___doi_org_10_21105_joss_08070__task_001/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "It can convert between R's Spectra::Spectra and Python's matchms.Spectrum and spectrum_utils.spectrum.Msms Spectrum objects... Spectri Py allows translation between R and Python MS data structures. In particular, Spectri Py provides the functions rspec_to_pyspec() and pyspec_to_rspec() to convert between R's Spectra::Spectra",
      "asbval:note": "Spectra is explicitly named as the R MS data structure that SpectriPy integrates with.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Spectra",
      "eco:evidence_type": {
