    {
      "@id": "asbval:assertion/skill/r-python-interoperability-via-wrapper/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The reticulate R package (Ushey et al., 2025) provides an R interface to Python enabling interoperability between the two programming languages. The open-source Spectri Py R package builds upon reticulate and provides functionality to efficiently translate between R and Python MS data structures... During installation, Spectri Py automatically configures a Python environment and installs all required libraries.",
      "asbval:note": "reticulate confirmed as foundation for SpectriPy and automatic Python environment setup is confirmed. However, specific version requirement 'v1.41+' and specific function 'py_require()' are not mentioned in passages; automatic installation is confirmed but mechanism not detailed.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "r-python-interoperability-via-wrapper",
