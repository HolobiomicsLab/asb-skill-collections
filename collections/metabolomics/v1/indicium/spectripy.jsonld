    {
      "@id": "asbval:assertion/skill/r-python-interoperability-via-wrapper/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Spectri Py provides an easy way to compare spectra similarity functions from commonly-used R and Python libraries... Spectri Py's compare Spectri Py() and filter Spectri Py() functions allow spectra comparison, and filtering and processing routines, respectively, from the matchms Python library to be called directly from R. These functions internally translate the MS data from a Spectra::Spectra object to the respective Python MS data structures, execute the Python functions, and collect and convert the results to R data types",
      "asbval:note": "Core claim fully supported: SpectriPy wraps matchms and spectrum_utils functionality into R functions that handle object translation automatically.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "r-python-interoperability-via-wrapper",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "SpectriPy wraps Python mass spectrometry package functionality (matchms, spectrum_utils) into R function signatures, enabling seamless invocation of Python MS algorithms within R-based Spectra workflows without manual object marshalling.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:59:49.038731+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
