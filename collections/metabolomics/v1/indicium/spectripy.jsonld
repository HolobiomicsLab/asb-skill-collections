    {
      "@id": "asbval:assertion/skill/cross-language-function-invocation-and-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Spectri Py's compare Spectri Py() and filter Spectri Py() functions allow spectra comparison, and filtering and processing routines, respectively, from the matchms Python library to be called directly from R. These functions internally translate the MS data from a Spectra::Spectra object to the respective Python MS data structures, execute the Python functions, and collect and convert the results to R data types",
      "asbval:note": "Core research question is directly supported by the paper's description of SpectriPy's wrapper functions and their return of R-native objects.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cross-language-function-invocation-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Invoke Python mass spectrometry package functions from within R-based Spectra workflows using language-bridging wrappers (e.g., SpectriPy), then validate that the wrapped call executes without error and returns properly typed R-native objects.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:57:57.513563+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/cross-language-function-invocation-and-validation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The open-source Spectri Py R package builds upon reticulate and provides functionality to efficiently translate between R and Python MS data structures. It can convert between R's Spectra::Spectra and Python's matchms.Spectrum and spectrum_utils.spectrum.Msms Spectrum objects",
      "asbval:note": "SpectriPy (case-insensitive match: Spectri Py) confirmed as R package with bidirectional conversion capability.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cross-language-function-invocation-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "SpectriPy - R package that wraps Python MS package functions (matchms, spectrum_utils) into R functions and handles bidirectional conversion between Spectra and Python spectral objects",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
