    {
      "@id": "asbval:assertion/card/https___doi_org_10_21105_joss_08070__task_001/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Spectri Py: Enhancing Cross-Language Mass Spectrometry Data Analysis with R and Python",
      "asbval:note": "Python is one of the two primary programming languages for which SpectriPy provides integration.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
