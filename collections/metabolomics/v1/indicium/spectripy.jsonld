    {
      "@id": "asbval:assertion/skill/cross-language-function-invocation-and-validation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Python libraries like matchms (Huber et al., 2020), spectrum_utils (Bittremieux, 2020), Pyteomics (Goloborodko et al., 2013), and py OpenMS (R\u00f6st et al., 2014)... includes functionality to directly apply spectral similarity, filtering, normalization, etc. routines from the Python matchms library on MS data in R.",
      "asbval:note": "matchms confirmed as Python library wrapped by SpectriPy for similarity, filtering, and normalization. However, the paper demonstrates 'Cosine Hungarian' similarity (not CosineGreedy or ModifiedCosine specifically named). The functional role (similarity scoring) is confirmed but specific algorithm names differ.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-08070",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "cross-language-function-invocation-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "matchms - Python library providing spectral similarity algorithms (CosineGreedy, ModifiedCosine) and normalization; wrapped by SpectriPy for use in R",
