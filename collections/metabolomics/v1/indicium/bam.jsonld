    {
      "@id": "asbval:assertion/card/task_002/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "BAM was implemented using two different code environments. First, PROXIMAL2 was applied and its results were analyzed using Python 3.9, PubChemPy (version 1.0.4), BioServices (version 1.11.2), scikit-learn (version 1.1.2), NumPy (version 1.23.2), NetworkX (version 2.5), RDKit (version 2022.03.5), KCF-Convoy (version 0.0.5), Pandas (version 1.4.3), Matplotlib (version 3.5.3), and Seaborn (version 0.12.2). Second, GNN-SOM was applied using Python 3.10, RDKit (version 2022.03.5), PyTorch (version 1.12.1), and PyTorch Geometric (version 2.1.0).",
      "asbval:note": "RDKit is explicitly listed as a software dependency used in BAM implementation.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01565",
      "asbval:supported_raw": "yes",
