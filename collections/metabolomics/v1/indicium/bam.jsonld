      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/pipeline-end-to-end-execution-and-validation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For this, we use GNN-SOM, a tool that employs a graph neural network to predict the likelihood of each atom in a molecule being the target of a biotransformation operation. GNN-SOM was trained on enzymatic interactions from the KEGG database to classify each atom within a graph representation of a molecule as the site-of-metabolism for a given enzyme. BAM uses GNN-SOM to rank the generated derivatives based on the likelihood of their corresponding site-of-metabolism.",
      "asbval:note": "GNN-SOM is explicitly used for ranking candidate structures by predicting site-of-metabolism.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01565",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pipeline-end-to-end-execution-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "GNN-SOM - Dependency for site-of-metabolism prediction to rank biotransformation candidates",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
