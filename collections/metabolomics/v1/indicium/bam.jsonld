      }
    },
    {
      "@id": "asbval:assertion/skill/reference-prediction-comparison-evaluation/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The generated derivative candidates are ranked based on the predicted likelihood of each atom within the anchor molecule serving as a reaction center... BAM uses GNN-SOM to rank the generated derivatives based on the likelihood of their corresponding site-of-metabolism, with each derivative being assigned the likelihood of the specific atom to which the biotransformation rule was applied.",
      "asbval:note": "BAM generates ranked candidate structures with likelihood scores for each candidate.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01565",
