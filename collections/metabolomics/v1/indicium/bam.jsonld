      "@id": "asbval:assertion/skill/reference-prediction-comparison-evaluation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To determine a data set of known suspects to evaluate BAM, a set of 30,184 structurally unique, annotated spectrum pairs were derived from neighboring annotated nodes from this global molecular network, yielding 60,368 total anchor\u2013suspect pairs.",
      "asbval:note": "The paper explicitly uses a validation dataset with known ground-truth structures derived from the global molecular network.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01565",
