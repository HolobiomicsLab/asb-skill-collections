    {
      "@id": "asbval:assertion/skill/molecular-network-construction-for-metabolomics/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The global molecular network was recently constructed from 521 million MS/MS spectra in 1335 public projects deposited to the GNPS/MassIVE... Molecular networking uses spectral alignment via modified cosine similarity to visualize spectra and any corresponding annotations as a network, which enables additional interpretation of query spectra... BAM operates by identifying and applying biotransformation rules to an 'anchor' molecule\u2014a known compound whose MS/MS spectrum exhibits high similarity to a given query spectrum.",
      "asbval:note": "The research question accurately describes the paper's approach: constructing global molecular networks from untargeted MS/MS data, using anchor compounds with known structures to seed annotation of unknown suspects via biotransformation rules.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01565",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-network-construction-for-metabolomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Construct global molecular networks from untargeted metabolomics data to link structurally related compounds and enable propagation of molecular structure annotations. This skill bridges suspect discovery with biotransformation-based annotation by organizing metabolites into netw",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
