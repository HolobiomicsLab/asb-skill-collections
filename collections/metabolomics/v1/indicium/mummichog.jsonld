    {
      "@id": "asbval:assertion/skill/untargeted-metabolomics-feature-analysis/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After ionized molecules are scanned in the spectrometer, the spectral peaks are extracted, quantified and aligned into a feature table. At this point, each feature is identified by a mass-to-charge ratio (m/z) and retention time in chromatography, but its chemical identity is not known.",
      "asbval:note": "Scope description aligns with paper's description of untargeted metabolomics workflow and the problem mummichog solves.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1003123",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "untargeted-metabolomics-feature-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have a feature table from untargeted metabolomics (with m/z, retention time, and p-values from differential abundance testing) but lack or wish to bypass metabolite annotation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:24:09.297553+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/untargeted-metabolomics-feature-analysis/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our goal is to predict biological activity in a network of metabolites directly from the feature table, bypassing the bottleneck of metabolite identification",
      "asbval:note": "Scope aligns with paper's stated goal.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1003123",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "untargeted-metabolomics-feature-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You want to predict which metabolic pathways and functional modules are active based on the spatial organization of features within known metabolic networks, rather than identifying individual compounds.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:24:09.297553+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
