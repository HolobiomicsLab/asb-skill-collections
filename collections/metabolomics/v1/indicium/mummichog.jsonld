    {
      "@id": "asbval:assertion/skill/metabolic-network-mapping/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "mummichog computes all possibly matched metabolites, and searches the reference metabolic network for all the modules that can be formed by these tentative metabolites... The activity score should reflect both the enrichment of 'input metabolites' and the modularity.",
      "asbval:note": "Mummichog does perform m/z-to-metabolite mapping and functional activity prediction. However, paper does not explicitly describe 'signal propagation' as a mechanism; instead it uses permutation-based statistical testing and module activity scoring. The functional description is partially aligned but not fully accurate to the paper's actual algorithm.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1003123",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "metabolic-network-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Mummichog role: Core Python package that performs metabolic network initialization, m/z-to-node mapping, signal propagation, and functional activity prediction",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:23:07.160748+00:00",
      "sepio:credibility_status": {
