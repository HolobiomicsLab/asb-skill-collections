      "@id": "asbval:assertion/skill/feature-to-metabolite-network-propagation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we report a novel approach of predicting network activity from untargeted metabolomics without upfront identification of metabolites... if a list of significant spectral features reflects a biological activity, the true metabolites they represent should show enrichment on a local structure in the metabolic network [22], while the falsely matched metabolites are distributed more randomly.",
      "asbval:note": "Core research question is directly supported by paper's stated goal and methodology.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pcbi-1003123",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-to-metabolite-network-propagation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Map untargeted metabolomics feature m/z values onto a metabolic network and propagate signal through connected nodes to infer functional activity and pathway involvement without explicit metabolite identification.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
