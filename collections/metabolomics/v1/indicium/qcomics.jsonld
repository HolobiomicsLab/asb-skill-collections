      }
    },
    {
      "@id": "asbval:assertion/skill/injection-sequence-annotation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "QC samples are analyzed at the beginning of the analytical run to equilibrate the instrument, as well as at intermittent points throughout the experiment to monitor system stability and correct experimental variability sources during data processing.",
      "asbval:note": "Paper discusses QC sample injection at regular intervals and their role in quality assessment, but does NOT mention Sciex Multiquant software, TXT export formats, or automated annotation of QCpool samples. The paper describes manual QC workflows and uses generic software (Excel, MetaboAnalyst) for QC implementation, not vendor-specific Sciex tools.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acs_analchem_3c03660",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "injection-sequence-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Identifies and annotates quality control pool (QCpool) samples within metabolomics or lipidomics injection sequences exported from Sciex Multiquant, recording their positions and validating regular interval spacing to support quality assessment workflows.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:56:25.679884+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/injection-sequence-annotation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Analyze real samples in random order and intercalate QCs across the sequence (e.g., one QC after every 10 samples). If the sample size is small, the frequency of QC injection may be increased to ensure a minimum of 10% QC samples across the analytical run.",
      "asbval:note": "Paper describes regular interval QC injection and validation of spacing, but does not mention Sciex Multiquant or automated annotation workflows. QComics protocol uses Excel and MetaboAnalyst, not vendor-specific software.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acs_analchem_3c03660",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "injection-sequence-annotation",
