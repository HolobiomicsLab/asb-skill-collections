      }
    },
    {
      "@id": "asbval:assertion/skill/qcpool-cv-calculation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After MS-based analysis, a set of metabolites that can regularly be detected in QC samples (hereinafter referred to as \"chemical descriptors\") must be selected to assess method reproducibility and data quality... Then, the examination of PCA scores plots enables exploring if samples show a continuous drift... the peak intensity of each chemical descriptor should be plotted with respect to their run order to check for time-related trends in the data... method precision and accuracy must be estimated by applying the following acceptance criteria to chemical descriptors detected in QC samples: (i) RSD < 30% for peak intensity",
      "asbval:note": "The paper uses RSD (relative standard deviation, equivalent to CV) as the primary metric for assessing reproducibility of QC samples injected at regular intervals. This directly supports the research question.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acs_analchem_3c03660",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "qcpool-cv-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Calculate per-compound coefficient of variation (CV) from pooled quality control (QCpool) sample intensities measured at regular intervals during a metabolomics or lipidomics sequence. CV quantifies technical reproducibility and is a primary metric for assessing data quality befo",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
