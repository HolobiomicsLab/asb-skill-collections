    {
      "@id": "asbval:assertion/skill/multiquant-file-parsing/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After MS-based analysis, a set of metabolites that can regularly be detected in QC samples (hereinafter referred to as \"chemical descriptors\") must be selected to assess method reproducibility and data quality.",
      "asbval:note": "Paper emphasizes working with raw sequence data and QC sample metadata before feature extraction and statistical analysis, consistent with the 'raw sequence metadata' scope boundary.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acs_analchem_3c03660",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "multiquant-file-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: The analytical sequence data is already preprocessed into a feature table or peak intensity matrix (use this skill only on raw sequence metadata)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:57:28.550881+00:00",
