    {
      "@id": "asbval:assertion/skill/metabolomics-data-quality-metrics/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To verify the presence of gradual changes along the analytical run, and thus evaluating the need of implementing data normalization approaches, the peak intensity of each chemical descriptor should be plotted with respect to their run order to check for time-related trends in the data... Then, the examination of PCA scores plots enables exploring if samples show a continuous drift... method precision and accuracy must be estimated by applying the following acceptance criteria to chemical descriptors detected in QC samples: (i) RSD < 30% for peak intensity, (ii) RSD < 2% for RT, (iii) RSD < 15% for peak width, (iv) m/z error <10 ppm",
      "asbval:note": "Paper uses RSD (relative standard deviation), not CV (coefficient of variation), though these are mathematically equivalent (CV = RSD). Paper assesses drift and reproducibility via RSD and time-series plots, not explicitly 'QCpool' terminology. The concept is supported but the specific term 'QCpool' and explicit CV naming differ from paper's RSD language.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acs_analchem_3c03660",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "metabolomics-data-quality-metrics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute coefficient of variation (CV) and signal-trend metrics from QCpool (quality control pool) samples injected at regular intervals during liquid chromatography\u2013mass spectrometry (LC-MS) sequences to rapidly assess technical reproducibility and instrumental drift in metabolom",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:56:58.605951+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/metabolomics-data-quality-metrics/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the precision estimators can also be employed to discard peaks with a technical variation exceeding biological interindividual differences, as these molecular features are likely to introduce great variability in data and, consequently, hinder subsequent statistical modeling.",
      "asbval:note": "Paper explicitly supports filtering compounds based on quality metrics prior to downstream analysis.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acs_analchem_3c03660",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolomics-data-quality-metrics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "detection of compounds with poor quality metrics before downstream analysis",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:56:58.605951+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
