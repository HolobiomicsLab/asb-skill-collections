      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Parse Sciex Multiquant text export files to extract sample metadata, injection sequence information, and quality control pool (QCpool) sample positions for metabolomics and lipidomics quality assessment workflows.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
