        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/quality-overview-visualization/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "As implemented in QComics, the analysis of PCA scores using the Hotelling T2 statistics enables easily identifying outliers as those study samples located far-away the 95% Hotelling T2 ellipse in the PCA scores plot",
      "asbval:note": "Paper explicitly describes use of PCA and Hotelling T2 test for outlier detection in QComics.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acs_analchem_3c03660",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "quality-overview-visualization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "PCA-based clustering and Hotelling T2 ellipse for outlier detection",
      "eco:evidence_type": {
