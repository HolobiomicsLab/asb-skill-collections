      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it when baseline screening requires ranking many features by likelihood of being true PFAS rather than false positives or structurally unrelated compounds.",
      "eco:evidence_type": {
