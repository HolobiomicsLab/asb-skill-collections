    {
      "@id": "asbval:assertion/skill/precursor-product-mass-pairing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "a list of typical PFAS diagnostic fragments (DFs, approximately 900 fragments) from literature are automatically matched with all fragmentation spectra",
