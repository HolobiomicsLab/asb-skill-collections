    {
      "@id": "asbval:assertion/skill/precursor-product-mass-pairing/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Input MS raw data can be converted vendor-independently from data-dependent acquisition (ddMS2) files into the mzML data format (.mzML)",
