    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-feature-table-construction/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After feature finding in the MS1 data, MS2 spectra can be aligned to their respective precursors by specifying an m/z and RT tolerance.",
      "asbval:note": "MS2 alignment parameters confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
