    {
      "@id": "asbval:assertion/skill/high-resolution-mass-spectrometry-interpretation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Only mzML files with centroided spectra and one collision energy (CE) should be used... Input MS raw data can be converted vendor-independently from data-dependent acquisition (ddMS2) files into the mzML data format",
      "asbval:note": "Scope claim is fully supported; paper specifies centroided mzML from data-dependent acquisition as required input.",
