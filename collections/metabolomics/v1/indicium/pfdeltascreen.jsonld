    {
      "@id": "asbval:assertion/skill/ms2-diagnostic-fragment-matching/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Since NTS is typically a time-consuming and often partially manual process, efficient prioritization techniques are needed to separate detected matrix components from the analytes of interest (often a data reduction from ~ 5000 detected compounds to 10\u2013100 identified analytes or even less)",
      "asbval:note": "The paper describes the non-target screening context with large feature sets requiring prioritization.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ms2-diagnostic-fragment-matching",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "This is especially valuable in non-target screening where thousands of features are detected but only a subset are true PFAS.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
