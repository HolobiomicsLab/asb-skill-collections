    {
      "@id": "asbval:assertion/card/10_1007_s00216_023_05070_2__task_001/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PF\u0394Screen is a fully automated tool for detection and prioritization of potential PFAS features (LC- or GC-HRMS with ESI or APCI source) in raw mass spectrometric data written in Python (3.9.13)",
      "asbval:note": "The tool is written in Python and uses pyOpenMS for feature detection.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
