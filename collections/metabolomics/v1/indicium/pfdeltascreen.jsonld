    {
      "@id": "asbval:assertion/skill/feature-grouping-by-mass-defect/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Besides the MD and MD/C-m/C approach, the Kendrick mass defect (KMD) analysis to detect homologous series of PFAS (e.g., with CF2 or CF2O as repeating units) is of great relevance since it allows the grouping of structurally related PFAS, simplifying their identification... To detect homologues series (HS), the KMD (with a predefined repeating unit required; e.g., CF2) is calculated and corresponding features belonging to a certain HS are aligned by providing a unique HS number (parameters: mass tolerance, minimum number of homologues).",
      "asbval:note": "Claim is fully supported. Paper explicitly describes KMD analysis for grouping homologous PFAS series with repeating units (CF2, CF2O) using mass tolerance parameters.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-grouping-by-mass-defect",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Groups high-resolution mass spectrometry features into homologous series by computing Kendrick mass defect (KMD) values and clustering features with equivalent or near-equivalent KMD within a user-specified tolerance. This identifies structurally related PFAS compounds that diffe",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:29:10.977344+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/feature-grouping-by-mass-defect/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We developed PF\u0394 Screen , a Python-based open-source tool with a simple graphical user interface (GUI) to perform efficient feature prioritization using several PFAS-specific techniques such as the highly promising MD/C-m/C approach, Kendrick mass defect analysis, diagnostic fragments (MS 2 ), fragment mass differences (MS 2 ), and suspect screening.",
      "asbval:note": "Tool name confirmed (case-insensitive match: PF\u0394Screen in paper, PF\u0394Screen in card). Role as KMD analysis orchestrator is supported.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-grouping-by-mass-defect",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "PF\u0394Screen",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:29:10.977344+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
