    {
      "@id": "asbval:assertion/skill/molecular-formula-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For all MS1 features, the number of carbon atoms, MD, and both MD/C and m/C dimensions are determined... The chemical mass defect (MD) of PFAS is typically lower (MDF = \u2212 0.0016 Da) than the one of hydrocarbons (MDH = + 0.0078 Da)... Recently, a promising approach based on the MD normalized to the carbon number (MD/C) vs. the mass normalized to the carbon number (m/C) was proposed to separate PFAS much more efficiently from other hydrocarbon features in HRMS data",
      "asbval:note": "The paper explicitly describes calculating mass defect from elemental composition (carbon number derived from M+1 isotope) and using MD/C-m/C for PFAS prioritization in non-target screening.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-formula-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate assigned molecular formulas in high-resolution mass spectrometry (HRMS) features by calculating exact mass from elemental composition and comparing it to observed m/z to derive mass defect metrics. This skill underpins prioritization of potential PFAS in non-target scree",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:31:42.197653+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
