      }
    },
    {
      "@id": "asbval:assertion/skill/hrms-feature-annotation-integration/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "If feature finding by an external software is desired (e.g., vendor software), the following steps can also be performed by loading a feature table (.csv, that requires m/z, RT, and intensities of the [M] and [M+1] isotopes) into PF\u0394Screen without feature detection via OpenMS. However, the raw mzML files are still needed to assign MS2 data to the features in the feature table",
      "asbval:note": "Passage explicitly describes the workflow for integrating external feature lists and applying the full prioritization pipeline (MD/C-m/C, KMD, MS2 diagnostics).",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "hrms-feature-annotation-integration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Integrate custom HRMS feature lists (from external feature-finding procedures) into PF\u0394Screen's prioritization pipeline, validating metadata and applying MD/C-m/C, KMD, and MS2 fragment diagnostics to features regardless of detection source.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
