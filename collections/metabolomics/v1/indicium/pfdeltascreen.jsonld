    {
      "@id": "asbval:assertion/skill/high-resolution-mass-spectrometry-interpretation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "efficient prioritization techniques are needed to separate detected matrix components from the analytes of interest (often a data reduction from ~ 5000 detected compounds to 10\u2013100 identified analytes or even less)",
      "asbval:note": "Paper confirms the goal of prioritizing true PFAS from false positives and matrix components.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
