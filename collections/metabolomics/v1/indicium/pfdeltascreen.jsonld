    {
      "@id": "asbval:assertion/skill/feature-grouping-by-mass-defect/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Since NTS is typically a time-consuming and often partially manual process, efficient prioritization techniques are needed to separate detected matrix components from the analytes of interest... The intrinsic properties of PFAS (with a certain fluorine percentage) allow the use of several techniques for their prioritization [21, 26]... the Kendrick mass defect (KMD) analysis to detect homologous series of PFAS (e.g., with CF2 or CF2O as repeating units) is of great relevance since it allows the grouping of structurally related PFAS, simplifying their identification",
      "asbval:note": "Scope claim is supported: KMD analysis is presented as a prioritization technique for identifying homologous PFAS series in NTS workflows.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-grouping-by-mass-defect",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have a feature list with m/z values from HRMS data and need to identify homologous PFAS series to prioritize suspect screening.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
