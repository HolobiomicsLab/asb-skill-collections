      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill identifies characteristic fragmentation patterns that distinguish PFAS from background features.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
