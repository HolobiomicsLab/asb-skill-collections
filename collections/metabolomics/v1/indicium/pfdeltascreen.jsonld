    {
      "@id": "asbval:assertion/card/10_1007_s00216_023_05070_2__task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Input MS raw data can be converted vendor-independently from data-dependent acquisition (ddMS2) files into the mzML data format (.mzML) by using the MSConvert software from ProteoWizard [40, 41]. Only mzML files with centroided spectra and one collision energy (CE) should be used... Feature detection from vendor-independent MS raw data (mzML, data-dependent acquisition) is performed via pyOpenMS (or custom feature lists) with subsequent calculations for prioritization and identification of PFAS in both HPLC- and GC-HRMS data.",
      "asbval:note": "The paper explicitly describes pyOpenMS ingesting centroided mzML files for feature detection, producing feature lists with m/z, RT, and intensity values.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "How does pyOpenMS ingest centroided mzML files and produce a feature list with m/z, retention time, and intensity values?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:24:37.501006+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/card/10_1007_s00216_023_05070_2__task_001/001",
