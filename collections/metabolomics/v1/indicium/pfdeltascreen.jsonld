    {
      "@id": "asbval:assertion/skill/feature-annotation-filtering/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PF\u0394Screen is a fully automated tool for detection and prioritization of potential PFAS features (LC- or GC-HRMS with ESI or APCI source) in raw mass spectrometric data written in Python (3.9.13) (Fig. 2). PF\u0394Screen is structured in several individual Python functions that are executed from one main file that allows data and parameter input via a simple GUI programmed with the tkinter library",
      "asbval:note": "Role description is accurate; paper confirms GUI, MD/C-m/C, KMD, MS2 fragment matching, pyOpenMS integration, and output formats.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-annotation-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "PF\u0394Screen role: GUI application that implements MD/C-m/C filtering, Kendrick mass defect analysis, and MS2 fragment matching; orchestrates feature detection via pyOpenMS and outputs annotated results tables and interactive plots",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:28:55.055302+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
