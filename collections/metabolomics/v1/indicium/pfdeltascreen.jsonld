    {
      "@id": "asbval:assertion/skill/mass-spectrometry-feature-table-construction/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The FeatureFinding tab (1) allows detection of feature via pyOpenMS in MS raw data followed by MS2 alignment and blank correction resulting in a feature list for a sample of interest. PFAS feature prioritization (2) includes techniques such as the MD/C-m/C approach, KMD analysis, fragment matching, and fragment mass differences",
      "asbval:note": "Feature extraction is explicitly used for downstream PFAS prioritization in the workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
