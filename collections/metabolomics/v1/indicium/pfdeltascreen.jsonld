    {
      "@id": "asbval:assertion/card/10_1007_s00216_023_05070_2__task_001/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The first step usually performed in NTS is detection of features in the MS raw data characterized by chromatographic peak shapes of coeluting isotopes, resulting in a list of m/z, retention time (RT), and peak area.",
      "asbval:note": "The paper explicitly states that feature detection produces m/z, RT, and peak area (intensity) values.",
