    {
      "@id": "asbval:assertion/skill/feature-annotation-filtering/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recently, a promising approach based on the MD normalized to the carbon number (MD/C) vs. the mass normalized to the carbon number (m/C) was proposed to separate PFAS much more efficiently from other hydrocarbon features in HRMS data",
      "asbval:note": "Claim accurately describes the MD/C-m/C approach as presented in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-annotation-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "The MD/C-m/C approach filters and ranks potential per- and polyfluoroalkyl substance (PFAS) features from non-target high-resolution mass spectrometry data by normalizing mass defect to the number of carbon atoms, then applying a threshold criterion to flag PFAS candidates.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:28:55.055302+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/feature-annotation-filtering/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "if the number of features can be preliminarily reduced by the MD/C-m/C approach before applying those techniques, a faster and more accurate NTS workflow can be performed, decreasing both computational and manual effort",
      "asbval:note": "Paper confirms that MD/C-m/C reduces false positives and improves accuracy.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-annotation-filtering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This prioritization technique reduces false positives in feature lists generated from LC- or GC-HRMS raw data.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
