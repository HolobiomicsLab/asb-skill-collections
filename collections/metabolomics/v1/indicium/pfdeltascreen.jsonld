      }
    },
    {
      "@id": "asbval:assertion/skill/precursor-product-mass-pairing/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Only mzML files with centroided spectra and one collision energy (CE) should be used. If profile data was acquired and MS2 spectra from several different CEs per precursor m/z are present, the peak picking (for centroiding) and subset functions (to keep only one desired CE) from MSConvert can be used to generate the correct mzML input files.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "precursor-product-mass-pairing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input is profile (centroided=false) MS2 data; the skill requires centroided spectra for reliable m/z matching.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:33:17.126447+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/precursor-product-mass-pairing/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For all MS2 spectra, fragment mass differences are calculated comprehensively... Furthermore, a list of typical PFAS diagnostic fragments (DFs, approximately 900 fragments) from literature are automatically matched with all fragmentation spectra",
