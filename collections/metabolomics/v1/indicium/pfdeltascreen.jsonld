      }
    },
    {
      "@id": "asbval:assertion/skill/mass-defect-calculation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For all MS1 features, the number of carbon atoms, MD, and both MD/C and m/C dimensions are determined. To detect homologues series (HS), the KMD (with a predefined repeating unit required; e.g., CF2) is calculated",
      "asbval:note": "Paper describes MD calculation as prerequisite for MD/C and KMD calculations in the workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-defect-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Mass defect calculation is the necessary first step before applying MD/C-m/C ratio filtering or Kendrick mass defect (KMD) analysis for PFAS homologue clustering.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:30:16.325593+00:00",
