    },
    {
      "@id": "asbval:assertion/skill/pfas-characteristic-mass-difference-detection/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We developed PF\u0394Screen, a Python-based open-source tool with a simple graphical user interface (GUI) to perform efficient feature prioritization using several PFAS-specific techniques such as the highly promising MD/C-m/C approach, Kendrick mass defect analysis, diagnostic fragments (MS2), fragment mass differences (MS2), and suspect screening... PFAS feature prioritization (2) includes techniques such as the MD/C-m/C approach, KMD analysis, fragment matching, and fragment mass differences which generates a strongly reduced feature list of potential PFAS.",
      "asbval:note": "PF\u0394Screen is confirmed as the integrated tool implementing all these techniques together.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pfas-characteristic-mass-difference-detection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "PF\u0394Screen \u2014 Integrated tool that implements diagnostic fragment detection alongside MD/C-m/C and KMD analysis for end-to-end PFAS prioritization",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:32:37.497282+00:00",
      "sepio:credibility_status": {
