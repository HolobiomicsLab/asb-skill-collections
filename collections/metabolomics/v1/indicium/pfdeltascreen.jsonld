    {
      "@id": "asbval:assertion/skill/precursor-product-mass-pairing/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In the MS2 data, lists of PFAS-specific diagnostic fragments (DFs) as well as fragment mass differences and neutral losses can be used to prioritize fragmentation spectra",
