    {
      "@id": "asbval:assertion/skill/high-resolution-mass-spectrometry-interpretation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PF\u0394Screen, an open-source Python-based software tool with a simple graphical user interface (GUI) that combines the discussed techniques to efficiently prioritize PFAS in LC- or GC-HRMS data acquired with electrospray (ESI) or atmospheric pressure chemical ionization (APCI)... PFAS feature prioritization (2) includes techniques such as the MD/C-m/C approach, KMD analysis, fragment matching, and fragment mass differences",
      "asbval:note": "Claim is fully supported; paper explicitly describes combining mass-defect filtering (MD/C-m/C), Kendrick mass defect (KMD) analysis, and MS2 fragment matching for PFAS prioritization in LC/GC-HRMS.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "high-resolution-mass-spectrometry-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Interpret LC- or GC-HRMS data to prioritize potential PFAS features using complementary mass-defect filtering, Kendrick analysis, and MS2 fragment matching.",
