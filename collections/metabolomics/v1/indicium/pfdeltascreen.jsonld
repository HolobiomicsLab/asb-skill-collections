    {
      "@id": "asbval:assertion/skill/mass-defect-calculation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The chemical mass defect (MD) of PFAS is typically lower (MDF = \u2212 0.0016 Da) than the one of hydrocarbons (MDH = + 0.0078 Da) and has been used to remove detected features outside a predefined MD range",
      "asbval:note": "Mass defect is explicitly described as a computational metric for PFAS identification based on difference between observed and theoretical masses.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-defect-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Mass defect calculation is a quantitative technique for identifying PFAS-like features in non-target HRMS data by computing the difference between observed m/z values and theoretical exact masses.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:30:16.325593+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-defect-calculation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recently, a promising approach based on the MD normalized to the carbon number (MD/C) vs. the mass normalized to the carbon number (m/C) was proposed to separate PFAS much more efficiently from other hydrocarbon features in HRMS data... Besides the MD and MD/C-m/C approach, the Kendrick mass defect (KMD) analysis to detect homologous series of PFAS",
      "asbval:note": "Paper explicitly describes MD as foundational, with MD/C and KMD as downstream applications.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-defect-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "It serves as a foundational metric for downstream PFAS prioritization filters including MD/C ratio normalization and Kendrick mass defect analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:30:16.325593+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-defect-calculation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Feature detection from vendor-independent MS raw data (mzML, data-dependent acquisition) is performed via pyOpenMS (or custom feature lists)... For feature detection, the FeatureFinderMetabo algorithm is used, which is designed for metabolites and small molecules",
      "asbval:note": "pyOpenMS confirmed as feature detection tool providing m/z and RT values.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-defect-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "pyOpenMS - Feature detection in MS raw data; provides m/z values and retention times for input to mass defect calculation",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
