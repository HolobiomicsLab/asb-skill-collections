    {
      "@id": "asbval:assertion/skill/feature-grouping-by-mass-defect/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "KMD, DFs, fragment mass differences, and especially suspect screening with large lists (e.g., PFASMASTER, gathering over 12,000 compounds [36]) in combination with complex samples (thousands of features) are prone to a high number of false-positive detections (depending on mass tolerance) that often need to be excluded manually, which is a time-consuming process.",
      "asbval:note": "Paper confirms KMD is a prioritization heuristic subject to false positives, not a definitive identification method.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-grouping-by-mass-defect",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input is already a structurally annotated feature table with confirmed compound identities (KMD grouping is a prioritization heuristic, not a confirmation method).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:29:10.977344+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/feature-grouping-by-mass-defect/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Even with extremely high mass resolution, naturally occurring compounds can still mimic certain PFAS-specific repeating units such as CF2, complicating KMD analysis and making retention time shifts a necessary criterion [37].",
      "asbval:note": "Paper confirms KMD analysis is optimized for homologous series with repeating units and can be confounded by non-PFAS compounds with similar mass patterns.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-grouping-by-mass-defect",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Data contains non-PFAS or structurally diverse analytes without repeating mass-defect units (KMD analysis is optimized for homologous series with systematic mass offsets).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:29:10.977344+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
