      "@id": "asbval:assertion/skill/mzml-file-parsing/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Input MS raw data can be converted vendor-independently from data-dependent acquisition (ddMS2) files into the mzML data format (.mzML) by using the MSConvert software from ProteoWizard [40, 41]. Only mzML files with centroided spectra and one collision energy (CE) should be used. If profile data was acquired and MS2 spectra from several different CEs per precursor m/z are present, the peak picking (for centroiding) and subset functions (from MSConvert) can be used to generate the correct mzML input files.",
      "asbval:note": "MSConvert is explicitly described as the tool for converting vendor raw data to mzML with centroiding capability.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mzml-file-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "MSConvert \u2014 Utility to convert vendor raw mass spectrometry files to vendor-independent mzML format with centroiding options",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:32:21.228236+00:00",
      "sepio:credibility_status": {
