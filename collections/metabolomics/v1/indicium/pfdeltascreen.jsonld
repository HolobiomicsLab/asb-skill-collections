      }
    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-feature-table-construction/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For feature detection, the FeatureFinderMetabo algorithm is used, which is designed for metabolites and small molecules [47\u201349].",
      "asbval:note": "Paper uses FeatureFinderMetabo, not FeatureFinderCentroided. Both are OpenMS algorithms but serve different purposes; FeatureFinderMetabo is designed for metabolites and small molecules.",
