      "asbval:evidence_quote": "Feature detection from vendor-independent MS raw data (mzML, data-dependent acquisition) is performed via pyOpenMS (or custom feature lists)",
      "asbval:note": "[SUBSTRING-MATCH for pyOpenMS | role: feature detection tool]",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
