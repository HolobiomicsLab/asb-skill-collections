    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-feature-table-construction/012",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Blank correction is performed by setting an m/z and RT tolerance as well as a fold change with the desired increase of abundance in the sample compared to the blank.",
