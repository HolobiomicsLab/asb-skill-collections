      }
    },
    {
      "@id": "asbval:assertion/skill/high-resolution-mass-spectrometry-interpretation/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For all MS1 features, the number of carbon atoms, MD, and both MD/C and m/C dimensions are determined... Furthermore, a list of typical PFAS diagnostic fragments (DFs, approximately 900 fragments) from literature are automatically matched with all fragmentation spectra",
      "asbval:note": "Paper confirms use of MS1 molecular formulas and MS2 diagnostic fragments for PFAS filtering.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "high-resolution-mass-spectrometry-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Specifically, use it when you have MS1 m/z values with assigned molecular formulas and corresponding MS2 spectra, and need to apply chemical intelligence (fluorine-rich mass patterns, known PFAS diagnostic fragments) to filter a non-target feature set.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
