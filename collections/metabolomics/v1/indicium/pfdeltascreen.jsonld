      }
    },
    {
      "@id": "asbval:assertion/skill/mass-defect-calculation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For all MS1 features, the number of carbon atoms, MD, and both MD/C and m/C dimensions are determined... The carbon number can be easily estimated for all HRMS features by using the relative abundance of the M+1 isotope (13C).",
      "asbval:note": "Paper implies molecular formula (or at least carbon number) is required for MD calculation.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-defect-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope - When NOT to use",
      "asbval:target_claim_text": "Input feature list lacks assigned molecular formulas\u2014mass defect calculation requires formula to compute theoretical exact mass; use formula assignment tools first.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:30:16.325593+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-defect-calculation/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Since NTS is typically a time-consuming and often partially manual process, efficient prioritization techniques are needed to separate detected matrix components from the analytes of interest... NTS approaches led to the identification of more than 750 novel PFAS in various samples",
      "asbval:note": "Paper emphasizes NTS context where mass defect filtering is essential; targeted analysis would not require this prioritization.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-defect-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope - When NOT to use",
      "asbval:target_claim_text": "Data are from targeted MS/MS experiments with pre-selected PFAS compounds\u2014mass defect filtering is designed for non-target screening and adds no value when analytes are already known.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:30:16.325593+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-defect-calculation/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "high-resolution mass spectrometry (HRMS) is necessary for a more comprehensive characterization of PFAS... The chemical mass defect (MD) of PFAS is typically lower (MDF = \u2212 0.0016 Da)",
      "asbval:note": "Paper explicitly requires HRMS; mass defect calculations depend on high mass accuracy (ppm-level precision).",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-defect-calculation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope - When NOT to use",
      "asbval:target_claim_text": "Input is low-resolution MS data (e.g., unit mass resolution)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
