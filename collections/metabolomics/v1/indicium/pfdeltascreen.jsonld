    {
      "@id": "asbval:assertion/card/10_1007_s00216_023_05070_2__task_005/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not describe generation of a dedicated 'filter validation report' with explicit per-feature pass/fail status for each criterion. The output is a prioritized feature table with annotations, but not a separate validation report documenting which features passed/failed each filter step.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "task_005",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
