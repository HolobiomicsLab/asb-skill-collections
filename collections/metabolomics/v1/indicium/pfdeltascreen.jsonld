      }
    },
    {
      "@id": "asbval:assertion/skill/custom-data-schema-mapping/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "If feature finding by an external software is desired (e.g., vendor software, alternative open-source tools), the following steps can also be performed by loading a feature table (.csv, that requires m/z, RT, and intensities of the [M] and [M+1] isotopes) into PF\u0394Screen without feature detection via OpenMS.",
      "asbval:note": "Paper explicitly describes accepting external feature lists in CSV format with required columns (m/z, RT, intensities).",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "custom-data-schema-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Parse and validate user-supplied feature lists (CSV/TSV/XLSX format) into a standardized internal feature object representation compatible with downstream PFAS prioritization workflows",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:28:35.443544+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/custom-data-schema-mapping/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "If feature finding by an external software is desired (e.g., vendor software, alternative open-source tools), the following steps can also be performed by loading a feature table (.csv, that requires m/z, RT, and intensities of the [M] and [M+1] isotopes) into PF\u0394Screen without feature detection via OpenMS.",
      "asbval:note": "Explicitly states PF\u0394Screen can work with external feature-finding tools without relying on pyOpenMS.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "custom-data-schema-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill enables PF\u0394Screen to accept features from external feature-finding tools or vendor software rather than relying solely on pyOpenMS-detected features",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
