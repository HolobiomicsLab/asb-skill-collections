      }
    },
    {
      "@id": "asbval:assertion/skill/custom-data-schema-mapping/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "If feature finding by an external software is desired (e.g., vendor software, alternative open-source tools), the following steps can also be performed by loading a feature table (.csv, that requires m/z, RT, and intensities of the [M] and [M+1] isotopes) into PF\u0394Screen without feature detection via OpenMS. However, the raw mzML files are still needed to assign MS2 data to the features in the feature table",
      "asbval:note": "Paper describes the exact use case: loading pre-computed feature tables from external tools into PF\u0394Screen.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "custom-data-schema-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use this skill when a practitioner has pre-computed features from an external feature-finding procedure and wishes to incorporate them into PF\u0394Screen's PFAS prioritization pipeline",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:28:35.443544+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
