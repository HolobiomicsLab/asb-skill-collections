    },
    {
      "@id": "asbval:assertion/skill/precursor-product-mass-pairing/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The PFAS prioritization workflow is intended in an iterative manner: after feature detection, the MD/C-m/C plot should firstly be manually inspected... After determination of these cutoffs, the PFAS feature prioritization can be executed again... where the respective parameters can be adjusted accordingly",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "precursor-product-mass-pairing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it after feature detection if MS2 data is available and you want to leverage known PFAS fragmentation patterns as a prioritization signal alongside molecular formula and Kendrick mass defect approaches.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:33:17.126447+00:00",
      "sepio:credibility_status": {
