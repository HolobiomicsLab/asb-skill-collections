    {
      "@id": "asbval:assertion/card/10_1007_s00216_023_05070_2__task_002/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After execution, a folder is generated named after the sample file where important results are saved, including a summary in an Excel sheet which is formatted as a table that can be easily inspected, sorted, and subset for a faster overview of the results as well as an additional CSV file that includes the same data... For all MS1 features, the number of carbon atoms, MD, and both MD/C and m/C dimensions are determined.",
      "asbval:note": "Paper describes output as Excel/CSV tables containing MD/C and m/C dimensions for features, which aligns with the claim of filtered feature lists with MD/C scores and prioritization flags.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
