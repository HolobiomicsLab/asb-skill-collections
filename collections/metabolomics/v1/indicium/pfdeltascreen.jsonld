    {
      "@id": "asbval:assertion/skill/chromatographic-feature-extraction/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "With PF\u0394Screen, a single sample with a corresponding (optional) blank can be processed at a time. Blank correction is performed by setting an m/z and RT tolerance as well as a fold change with the desired increase of abundance in the sample compared to the blank.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
