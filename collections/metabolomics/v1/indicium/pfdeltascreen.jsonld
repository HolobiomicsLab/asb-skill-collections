    {
      "@id": "asbval:assertion/skill/centroided-ms-feature-detection/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Only mzML files with centroided spectra and one collision energy (CE) should be used. If profile data was acquired and MS2 spectra from several different CEs per precursor m/z are present, the peak picking (for centroiding) and subset functions (from MSConvert) can be used to generate the correct mzML input files.",
      "asbval:note": "Confirmed that centroided spectra are required and MSConvert can be used for centroiding.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "centroided-ms-feature-detection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "mzML files contain profile (non-centroided) spectra \u2014 centroided spectra are required; convert using MSConvert with centroiding enabled",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:28:07.813400+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
