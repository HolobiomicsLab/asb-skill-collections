      }
    },
    {
      "@id": "asbval:assertion/skill/ms2-diagnostic-fragment-matching/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "a list of typical PFAS diagnostic fragments (DFs, approximately 900 fragments) from literature are automatically matched with all fragmentation spectra (which is easily extendable)",
      "asbval:note": "The paper describes a ~900-fragment database that is extendable, confirming the need for a reference database.",
      "asbval:perspicacite_kb": "asb-paper-10-1007-s00216-023-05070-2",
