    {
      "@id": "asbval:assertion/claim/claim_001",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "Mass Spec Query Language (MassQL) is a domain specific language designed to express queries in a mass spectrometry centric fashion.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
      "asbval:source_excerpt": "The Mass Spec Query Language (MassQL) is a domain specific language meant to be a succinct way to\nexpress a query in a mass spectrometry centric fashion.",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_001",
      "asbval:target_artifact_kind": "ledger_claim",
