      }
    },
    {
      "@id": "asbval:assertion/skill/domain-specific-language-grammar-design/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The MassQL computational ecosystem is made of several key components that ensure its extensibility and usability for the community. These components are a formal definition of the MassQL grammar, a MassQL language parser, a reference implementation of the MassQL query engine... The MassQL reference query engine is written in Python and utilizes pyteomics to read open MS data files from mzML, mzXML and MGF formats into data frames.",
      "asbval:note": "Paper describes all three components: formal grammar definition, parser, and query engine implementation.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "domain-specific-language-grammar-design",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "MassQL provides lexer, parser, and query execution engine",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:37:50.135681+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/domain-specific-language-grammar-design/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MassQL aims to enable noncomputational researchers to easily search their MS (across MS1 and MS/MS) data for patterns of interest without the need for programming skills or a dedicated computational collaborator... the MassQL ecosystem lowers the barrier of entry to MS data interrogation for chemists and biologists lacking programming skills.",
      "asbval:note": "Paper explicitly states the goal of enabling non-programmers to query mass spectrometry data without programming skills.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "domain-specific-language-grammar-design",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "enable non-programmers or domain experts to formulate complex, unambiguous queries over specialized data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:37:50.135681+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/domain-specific-language-grammar-design/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The MassQL language enables searching for patterns in MS1 data (for example, isotopic patterns and adduct mass shift) and MS/MS fragmentation spectra (for example, presence/absence of fragments and neutral losses), as well as applying chromatographic and ion mobility constraints... The MassQL formal grammar builds upon common MS terminology (Methods), which makes MassQL queries easy to write and alter for scientists with basic familiarity with MS.",
      "asbval:note": "MassQL encodes mass spectrometry-specific patterns and constraints directly into the language syntax rather than using generic query mechanisms.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "domain-specific-language-grammar-design",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "bakes in domain assumptions rather than requiring generic SQL or API calls",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:37:50.135681+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
