    {
      "@id": "asbval:assertion/skill/mass-spectrometry-query-semantics/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we introduce a new language, the Mass Spectrometry Query Language (MassQL), and an accompanying software ecosystem that addresses these issues by enabling the community to directly query mass spectrometry data with an expressive set of user-defined mass spectrometry patterns.",
      "asbval:note": "The paper explicitly describes MassQL as a language for querying MS data with expressive patterns. The parser component is confirmed in passage [8]: 'MassQL parser. The parser transforms a query into an internal data structure that can be used by any programming language.'",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-query-semantics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Design and implement a domain-specific query language (DSL) parser that translates mass-spectrometry-centric query strings into structured, unambiguous representations while preserving natural language readability.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:38:30.156387+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-query-semantics/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The MassQL language enables searching for patterns in MS1 data (for example, isotopic patterns and adduct mass shift) and MS/MS fragmentation spectra (for example, presence/absence of fragments and neutral losses), as well as applying chromatographic and ion mobility constraints. In addition, MassQL provides language support for user-defined tolerances, such as ion intensity and mass accuracy.",
      "asbval:note": "Paper confirms MS-specific constructs including m/z ranges, intensity thresholds, and fragmentation patterns. SQL-inspired syntax is implicit in the language design (Boolean operators AND, OR, NOT mentioned in passage [3]).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-query-semantics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill bridges SQL-inspired syntax with MS-specific constructs (m/z ranges, intensity thresholds, fragmentation patterns)",
