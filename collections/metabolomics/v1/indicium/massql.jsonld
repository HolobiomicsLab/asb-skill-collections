    {
      "@id": "asbval:assertion/skill/syntax-tree-construction-parsing/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The main goal of MassQL is to provide noncomputational scientists with the flexibility to encode complex MS patterns into concise and expressive queries... Together with the accompanying software infrastructure created through community efforts, the MassQL ecosystem lowers the barrier of entry to MS data interrogation for chemists and biologists lacking programming skills.",
      "asbval:note": "Paper emphasizes expressiveness, human readability, and mapping to machine-executable form as core design goals.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "syntax-tree-construction-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill is essential for implementing expressive, unambiguous query languages that map human-readable syntax to structured, machine-executable representations.",
