    {
      "@id": "asbval:assertion/skill/domain-specific-language-grammar-design/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we introduce the Mass Spectrometry Query Language (MassQL), an open-source language for flexible and mass spectrometer manufacturer-independent searching... The MassQL language implements a succinct and expressive grammar to search for chemically and biologically relevant molecules in the MS data by leveraging these patterns... The MassQL formal grammar builds upon common MS terminology (Methods), which makes MassQL queries easy to write and alter for scientists with basic familiarity with MS.",
      "asbval:note": "The paper explicitly describes designing a formal grammar for MassQL that balances expressiveness and human readability for domain experts without programming skills.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "domain-specific-language-grammar-design",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Design and implement a domain-specific language (DSL) grammar that encodes field-centric assumptions and constraints into an extended syntax, balancing expressiveness, precision, scalability, and human readability. This skill involves defining formal grammar rules, implementing a",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:37:50.135681+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/domain-specific-language-grammar-design/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MassQL parser. The parser transforms a query into an internal data structure that can be used by any programming language. The parsing is done by using the lark Python library (https://github.com/lark-parser/lark) and specific Python code to transform a MassQL query to a parse tree and into the internal data structure that organizes all query conditions and qualifiers.",
      "asbval:note": "Paper explicitly describes parser implementation using lark library to convert query strings to structured internal representations.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "domain-specific-language-grammar-design",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "implementing a lexer and parser to convert query strings into structured representations",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:37:50.135681+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/domain-specific-language-grammar-design/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "[SUBSTRING-MATCH for MassQL | role: reference implementation of mass-spectrometry-centric DSL]",
      "asbval:note": "MassQL is the primary subject of the paper and is explicitly described as a domain-specific language for mass spectrometry data querying.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
