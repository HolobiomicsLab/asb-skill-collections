    {
      "@id": "asbval:assertion/claim/claim_002",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "MassQL is inspired by SQL but bakes in assumptions of mass spectrometry to make querying more natural for mass spectrometry users.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41592-025-02660-z",
      "asbval:source_excerpt": "It is inspired by SQL,\nbut it attempts to bake in assumptions of mass spectrometry to make querying much more\nnatural for mass spectrometry users.",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_002",
      "asbval:target_artifact_kind": "ledger_claim",
