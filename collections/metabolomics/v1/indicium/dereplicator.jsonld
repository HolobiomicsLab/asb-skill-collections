    {
      "@id": "asbval:assertion/skill/class-specific-modification-rule-application/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not describe a workflow for generating plausible PTM variants based on RiPP class specification. The paper identifies RiPPs via spectral matching but does not enumerate class-specific PTM variants as a preparatory step.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
