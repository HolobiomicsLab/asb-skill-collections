      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-library-matching-ripp/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In 17 out of 24 cases, the compounds had a known biosynthetic gene cluster (BGC) reported in the MIBiG database, and in all these cases we cross-validated DEREPLICATOR+ identifications by searching their BGCs against the known genome of their producers (BLAST search found very similar homologs).",
      "asbval:note": "The paper demonstrates cross-validation of DEREPLICATOR+ identifications with BGC information, but the workflow described is reverse: DEREPLICATOR+ identifies compounds from spectra first, then validates against known BGCs. The card describes a forward workflow (BGC prediction \u2192 structure database \u2192 spectral matching), which is not the primary workflow demonstrated in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectral-library-matching-ripp",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Particularly valuable when antiSMASH or manual BGC annotation has identified putative RiPP gene clusters and you need to confirm their expression and structure via mass spectrometry.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:00:11.970513+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-network-propagation-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DEREPLICATOR+ enables high-throughput identification of variants of known natural products by spectral networks... Enlarging the set of MSMs by molecular networking... DEREPLICATOR+ constructs the molecular network of all spectra and selects connected components with at least one identified spectrum.",
      "asbval:note": "Paper describes propagating identifications through molecular networks/spectral networks, but the focus is on DEREPLICATOR+ (not MetaMiner or NPDtools). The paper does identify RiPPs and other natural products, but the primary tool for this propagation is DEREPLICATOR+, not MetaMiner. The card conflates tools.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
