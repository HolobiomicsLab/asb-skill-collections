    {
      "@id": "asbval:assertion/card/task_005/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DEREPLICATOR+ identified 32% more PNPs, and overall 77% more compounds than DEREPLICATOR at 0.02 Da tolerance... At 1% FDR DEREPLICATOR+ recovered 27/34 identifications from NIST, 8/12 identifications from LipidBlast, and 9/12 identifications from MoNA",
      "asbval:note": "Paper does compare DEREPLICATOR and DEREPLICATOR+ performance (passage 6), but does NOT compare VarQuest or MetaMiner. The comparison is between DEREPLICATOR variants, not across the three tools claimed in the research question. No 'mode-dependent sensitivity differences' (e.g., standard vs. blind mode) are discussed.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_005",
