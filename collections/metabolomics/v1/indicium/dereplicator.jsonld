    {
      "@id": "asbval:assertion/skill/tandem-mass-spectra-peptide-matching/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DEREPLICATOR constructs theoretical spectra of peptide natural products by disconnecting all the bridges and 2-cuts representing amide bonds, and measuring the masses of the connected components... DEREPLICATOR+ algorithm for dereplicating spectra against diverse metabolites... computing statistical significance of MSMs and evaluating the false discovery rate (FDR)",
      "asbval:note": "Paper describes Dereplicator and Dereplicator+ extensively with FDR computation. VarQuest is mentioned only once in passing ('DEREPLICATOR and VarQuest tools for identifying PNPs and their variants') without detailed methodology. The card claims all three tools are equivalent for this task, but the paper focuses on Dereplicator and Dereplicator+; VarQuest's role is not fully characterized in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "tandem-mass-spectra-peptide-matching",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Match centroided tandem mass spectra (MS/MS) against peptidic natural product (PNP) structure databases using Dereplicator, VarQuest, or Dereplicator+ to identify known or novel peptidic metabolites with quantified confidence scores and false discovery rates.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
