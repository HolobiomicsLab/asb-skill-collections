      }
    },
    {
      "@id": "asbval:assertion/skill/cross-tool-result-concordance-analysis/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To benchmark DEREPLICATOR+, we used the AntiMarin database (60,908 compounds and 29,491 unique compounds) and the Dictionary of Natural Products (254,727 compounds and 83,889 unique compounds). We searched all spectra from the following reversed-phase liquid chromatography high-resolution mass spectrometry datasets... DEREPLICATOR identified 73 unique compounds (166 MSMs) in SpectraActiSeq. At 0% FDR (corresponding to the p value threshold 10\u22128), DEREPLICATOR identified 66 unique compounds (148 MSMs). In contrast, at 1% FDR (score threshold of 6), DEREPLICATOR+ identified 488 compounds and 8194 MSMs",
      "asbval:note": "Paper demonstrates comparison of DEREPLICATOR and DEREPLICATOR+ on identical test spectra (SpectraActiSeq, SpectraLibrary, SpectraGNPS). However, MetaMiner is not discussed in the paper, and VarQuest is not compared on identical inputs.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "cross-tool-result-concordance-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have executed multiple NPDtools database search pipelines (Dereplicator, VarQuest, Dereplicator+, or MetaMiner in different modes) on identical test spectra or RiPP sequence inputs",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:55:00.802508+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/cross-tool-result-concordance-analysis/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After searching nearly two hundred million tandem mass spectra in the GNPS molecular networking infrastructure, DEREPLICATOR+ identifies five times more molecules than the previous approaches... DEREPLICATOR+ enables high-throughput identification of variants of known natural products by spectral networks.",
      "asbval:note": "Paper demonstrates practical application of tool comparison for large-scale discovery and variant detection.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cross-tool-result-concordance-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "This is particularly valuable when deciding which pipeline to deploy on large discovery sets, or when troubleshooting unexpected detection patterns",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:55:00.802508+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/false-discovery-rate-interpretation/000",
      "@type": "asbval:ClaimAssessment",
