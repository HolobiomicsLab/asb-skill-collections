    {
      "@id": "asbval:assertion/skill/blind-search-mode-parameter-optimization/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recently, we introduced DEREPLICATOR32 for searching spectral datasets against the database of peptidic natural products (PNPs) that include nonribosomal peptides (NRPs), and ribosomally synthesized and post-translationally modified peptides (RiPPs). DEREPLICATOR constructs theoretical spectra of peptide natural products by disconnecting all the bridges and 2-cuts representing amide bonds, and measuring the masses of the connected components.",
      "asbval:note": "The paper describes DEREPLICATOR as matching spectra against peptidic natural products including RiPPs, but does not describe a 'blind-search mode' for arbitrary PTMs. DEREPLICATOR uses a restrictive fragmentation model limited to amide bonds, not a PTM-agnostic approach.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "blind-search-mode-parameter-optimization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Dereplicator for tandem mass spectra matching against post-translationally modified RiPPs structure database",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:54:27.173008+00:00",
      "sepio:credibility_status": {
