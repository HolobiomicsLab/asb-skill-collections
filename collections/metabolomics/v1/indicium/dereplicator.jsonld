    {
      "@id": "asbval:assertion/skill/ripp-peptide-identification-from-spectra/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we describe DEREPLICATOR+ algorithm for dereplicating spectra against diverse metabolites... DEREPLICATOR+ improves on the previous approaches for identifying peptidic natural products, and extends them for identification of polyketides, terpenes, benzenoids, alkaloids, flavonoids, and other classes of natural products.",
      "asbval:note": "The paper's scope is broader than RiPPs alone. While DEREPLICATOR (the predecessor) was designed for RiPPs and PNPs, DEREPLICATOR+ extends to multiple metabolite classes. The card's scope is narrowly focused on RiPPs, which is a subset of what the paper accomplishes.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "ripp-peptide-identification-from-spectra",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Identify ribosomally synthesized and post-translationally modified peptides (RiPPs) by matching tandem mass spectrometry data against a RiPP structure database constructed from genomic biosynthetic gene clusters.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:58:46.738238+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
