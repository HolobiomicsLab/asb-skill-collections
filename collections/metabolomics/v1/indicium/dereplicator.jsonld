    {
      "@id": "asbval:assertion/skill/post-translational-modification-detection/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "DEREPLICATOR constructs theoretical spectra of peptide natural products by disconnecting all the bridges and 2-cuts representing amide bonds, and measuring the masses of the connected components. By applying spectral networks, DEREPLICATOR enabled identification of variants of known PNPs.",
      "asbval:note": "Paper describes DEREPLICATOR for identifying peptidic natural products (PNPs) including RiPPs, but does not explicitly focus on PTM detection or enumeration. The paper emphasizes spectral matching against metabolite databases and variant identification via molecular networks, not PTM-specific enumeration or validation. The scope is broader (all natural products) rather than PTM-focused.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "post-translational-modification-detection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Identifies and validates post-translational modifications (PTMs) on peptides by matching experimental tandem mass spectra against databases of putative modified RiPP structures",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:57:38.302047+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
