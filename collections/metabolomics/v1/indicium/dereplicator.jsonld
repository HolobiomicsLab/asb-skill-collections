    {
      "@id": "asbval:assertion/skill/metabologenomic-database-construction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recently, we introduced DEREPLICATOR for searching spectral datasets against the database of peptidic natural products (PNPs) that include nonribosomal peptides (NRPs), and ribosomally synthesized and post-translationally modified peptides (RiPPs). DEREPLICATOR constructs theoretical spectra of peptide natural products by disconnecting all the bridges and 2-cuts representing amide bonds, and measuring the masses of the connected components.",
      "asbval:note": "Paper describes DEREPLICATOR's approach to matching spectra against peptide structures, but does not describe a tool called 'MetaMiner' for BGC identification and RiPP database construction from genomes. The paper focuses on spectral matching (downstream) rather than genome-to-structure database construction (upstream). The research question conflates two distinct workflows: genome mining (not covered in this paper) and spectral matching (the paper's focus).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "metabologenomic-database-construction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Construct a searchable RiPP structure database by identifying putative biosynthetic gene clusters (BGCs) and precursor peptides from genome assemblies, then enumerating post-translationally modified variants according to class-specific rules. This intermediate database enables do",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:57:19.453872+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
