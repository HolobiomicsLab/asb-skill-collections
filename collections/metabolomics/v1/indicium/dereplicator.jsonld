    {
      "@id": "asbval:assertion/skill/class-specific-modification-rule-application/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After assembling the short reads using metaSPAdes and genome mining using antiSMASH, one of the NRPS-PKS gene clusters is assigned as the putative almiramide biosynthetic gene cluster based on the amino acid sequence and the PK genes.",
      "asbval:note": "Paper describes genome mining and BGC identification using antiSMASH (not MetaMiner) and metaSPAdes, followed by spectral matching via DEREPLICATOR. The workflow exists but uses different tools (antiSMASH instead of MetaMiner) and does not explicitly describe class-specific modification rule enumeration as an intermediate step.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
