    {
      "@id": "asbval:assertion/skill/ripp-peptide-identification-from-spectra/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recently, we introduced DEREPLICATOR for searching spectral datasets against the database of peptidic natural products (PNPs) that include nonribosomal peptides (NRPs), and ribosomally synthesized and post-translationally modified peptides (RiPPs). DEREPLICATOR constructs theoretical spectra of peptide natural products by disconnecting all the bridges and 2-cuts representing amide bonds, and measuring the masses of the connected components.",
      "asbval:note": "Paper describes DEREPLICATOR for identifying RiPPs via spectral matching, but the paper focuses on DEREPLICATOR+ which extends beyond RiPPs to polyketides, terpenes, benzenoids, alkaloids, flavonoids. The card's research question is narrowly scoped to RiPPs only, whereas the paper's main contribution is broader metabolite identification. The genomic BGC construction aspect is mentioned but not the primary focus of this paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "ripp-peptide-identification-from-spectra",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Identify ribosomally synthesized and post-translationally modified peptides (RiPPs) by matching tandem mass spectrometry data against a RiPP structure database constructed from genomic biosynthetic gene clusters.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:58:46.738238+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
