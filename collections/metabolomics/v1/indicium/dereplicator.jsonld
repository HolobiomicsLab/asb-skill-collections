    {
      "@id": "asbval:assertion/skill/class-specific-modification-rule-application/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recently, we introduced DEREPLICATOR for searching spectral datasets against the database of peptidic natural products (PNPs) that include nonribosomal peptides (NRPs), and ribosomally synthesized and post-translationally modified peptides (RiPPs). DEREPLICATOR constructs theoretical spectra of peptide natural products by disconnecting all the bridges and 2-cuts representing amide bonds, and measuring the masses of the connected components.",
      "asbval:note": "Paper discusses RiPPs and PTM but does not explicitly describe class-specific modification rule enumeration (lantibiotic, lassopeptide, cyanobactin rules). The paper focuses on spectral matching of RiPPs via DEREPLICATOR, not on generating PTM variants via class-specific rules. The scope card describes a skill for generating candidate structures with class-specific rules; the paper does not detail this enumeration process.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "class-specific-modification-rule-application",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Enumerate putative post-translationally modified (PTM) variants of RiPP precursor peptides by applying class-specific modification rules (e.g., lantibiotic, lassopeptide, cyanobactin) to generate candidate structure databases.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:54:42.425614+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/class-specific-modification-rule-application/001",
