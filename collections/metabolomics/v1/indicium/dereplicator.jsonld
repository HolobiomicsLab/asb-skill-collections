    {
      "@id": "asbval:assertion/skill/cross-tool-result-concordance-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recently, we introduced DEREPLICATOR for searching spectral datasets against the database of peptidic natural products (PNPs)... While DEREPLICATOR search of GNPS identified hundreds of peptides and their variants, it is limited to dereplicating PNPs and cannot identify other classes of natural products such as polyketides and terpenes. Here we describe DEREPLICATOR+ algorithm for dereplicating spectra against diverse metabolites.",
      "asbval:note": "Paper compares DEREPLICATOR and DEREPLICATOR+ extensively on identical datasets (SpectraActiSeq, SpectraLibrary, SpectraGNPS, etc.), demonstrating tool-specific identifications and performance differences. However, VarQuest is mentioned only once in passing ('Recently, we introduced DEREPLICATOR and VarQuest for searching spectral datasets...') with no comparative analysis on identical test spectra. The card claims comparison of three tools; the paper provides detailed comparison of only two (DEREPLICATOR vs DEREPLICATOR+).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "cross-tool-result-concordance-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compare hit patterns and detection sensitivity across multiple natural product database search pipelines (Dereplicator, VarQuest, Dereplicator+) on the same test spectra",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:55:00.802508+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/cross-tool-result-concordance-analysis/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "At 1% FDR (score threshold of 6), DEREPLICATOR+ identified 488 compounds and 8194 MSMs (1.2% of all spectra in SpectraActiSeq dataset). At 0% FDR (score threshold of 9), it identified 154 compounds (2666 MSMs), a twofold increase as compared to DEREPLICATOR... DEREPLICATOR+ not only identified more unique compounds at the same FDR, but also identified more spectra per compounds (average of 2.2 spectra per compound for DEREPLICATOR, versus 16.7 spectra per compound for DEREPLICATOR+).",
      "asbval:note": "Paper explicitly compares tool-specific identifications and performance differences across multiple FDR thresholds and datasets.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cross-tool-result-concordance-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "identify tool-specific identifications, common detections, and mode-dependent performance differences",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:55:00.802508+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/cross-tool-result-concordance-analysis/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recently, we introduced DEREPLICATOR for searching spectral datasets against the database of peptidic natural products (PNPs) that include nonribosomal peptides (NRPs), and ribosomally synthesized and post-translationally modified peptides (RiPPs). DEREPLICATOR constructs theoretical spectra of peptide natural products by disconnecting all the bridges and 2-cuts representing amide bonds, and measuring the masses of the connected components.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "cross-tool-result-concordance-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Dereplicator - Database search pipeline for identification of peptidic natural products through spectral matching against RiPP structure database",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:55:00.802508+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/cross-tool-result-concordance-analysis/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recently, we introduced DEREPLICATOR and VarQuest for searching spectral datasets against the database of peptidic natural products (PNPs)... DEREPLICATOR enabled identification of variants of known PNPs.",
      "asbval:note": "Paper mentions VarQuest once in passing but provides no functional description or comparative analysis. The card claims it is 'modification-tolerant' but the paper does not explicitly characterize VarQuest's role. The paper does describe variant identification capability for DEREPLICATOR via spectral networks, not explicitly for VarQuest.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
