    {
      "@id": "asbval:assertion/skill/spectral-library-matching-ripp/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We searched all spectra from the following reversed-phase liquid chromatography high-resolution mass spectrometry datasets specified in Supplementary Table 1 and Supplementary Note 1.",
      "asbval:note": "The paper describes using LC-MS/MS data and searching against databases of natural products (including RiPPs), but does not explicitly discuss input format specifications (MGF, mzXML, mzML, mzData) or the integration of genomic data for predicting RiPP structures. The paper focuses on DEREPLICATOR+ searching against existing chemical structure databases (AntiMarin, DNP) rather than predicted structures from BGCs.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectral-library-matching-ripp",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use this skill when you have tandem mass spectrometry data (LC-MS/MS in MGF, mzXML, mzML, or mzData format) and genomic data from a target organism, and you want to identify RiPPs by matching experimental spectra against a database of predicted post-translationally modified RiPP ",
      "eco:evidence_type": {
