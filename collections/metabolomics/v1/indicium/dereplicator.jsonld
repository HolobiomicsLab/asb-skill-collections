    {
      "@id": "asbval:assertion/skill/biosynthetic-gene-cluster-mining-with-genomic-data/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Recently, we introduced DEREPLICATOR32 for searching spectral datasets against the database of peptidic natural products (PNPs) that include nonribosomal peptides (NRPs), and ribosomally synthesized and post-translationally modified peptides (RiPPs). DEREPLICATOR constructs theoretical spectra of peptide natural products by disconnecting all the bridges and 2-cuts representing amide bonds, and measuring the masses of the connected components.",
      "asbval:note": "DEREPLICATOR is described as a standalone tool for identifying PNPs and RiPPs from mass spectra, not as a 'core engine within MetaMiner.' The paper describes DEREPLICATOR and DEREPLICATOR+ as independent tools, not as components of a MetaMiner pipeline. The claim conflates DEREPLICATOR's role.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "biosynthetic-gene-cluster-mining-with-genomic-data",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Dereplicator (core scoring and matching engine within MetaMiner)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:54:11.040746+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/biosynthetic-gene-cluster-mining-with-genomic-data/005",
