    {
      "@id": "asbval:assertion/skill/biosynthetic-gene-cluster-mining-with-genomic-data/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In 17 out of 24 cases, the compounds had a known biosynthetic gene cluster (BGC) reported in the MIBiG database, and in all these cases we cross-validated DEREPLICATOR+ identifications by searching their BGCs against the known genome of their producers (BLAST search found very similar homologs).",
      "asbval:note": "The paper describes DEREPLICATOR+ as a tool for identifying natural products (including RiPPs) from mass spectra using chemical structure databases. While the paper does validate identifications using BGC information and genome mining (antiSMASH), the primary workflow is MS/MS-based dereplication against chemical structure databases, not metabologenomics integration. The paper uses genomic data for validation, not as the primary input for identification.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "biosynthetic-gene-cluster-mining-with-genomic-data",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Integrates tandem mass spectrometry data with genomic sequences to identify RiPPs by mining biosynthetic gene clusters",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:54:11.040746+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/blind-search-mode-parameter-optimization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper describes DEREPLICATOR+ as a general metabolite dereplication tool that extends beyond peptides to polyketides, terpenes, benzenoids, alkaloids, and flavonoids. No mention of a 'blind-search mode' for PTM-agnostic RiPP identification or relaxed structural constraints for arbitrary PTMs. The paper focuses on fragmentation graph construction and metabolite-spectrum matching, not PTM-blind searching.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-018-06082-8",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "blind-search-mode-parameter-optimization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "A mode of natural product database search that relaxes structural constraints to identify peptides with arbitrary post-translational modifications (PTMs) without prior knowledge of modification types.",
