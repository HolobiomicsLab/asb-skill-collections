      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "multi-assay-data-integration-and-harmonization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill ensures assay identity is preserved in column names and sample correspondence is maintained across all blocks before statistical integration.",
