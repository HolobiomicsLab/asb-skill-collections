      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "peakPantheR - Provides ROI (region of interest) files encoding reference retention time and m/z for automated metabolite annotation",
