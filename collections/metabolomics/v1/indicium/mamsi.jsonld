    },
    {
      "@id": "asbval:assertion/card/10_1371_journal_pcbi_1011814__task_001/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We employ a multiblock-partial least-squares model (MB-PLS)... Multiblock partial least-squares is a multivariate regression technique used for multimodal data integration.",
      "asbval:note": "Paper uses MB-PLS (multiblock partial least squares) extensively but does not name a specific Python package called 'mbpls'. The paper describes the MB-PLS algorithm and its implementation but does not cite a specific library by that name. The actual implementation library is not specified in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
