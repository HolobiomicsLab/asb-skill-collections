    {
      "@id": "asbval:assertion/skill/metabolite-feature-annotation-aggregation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To investigate whether the MB-PLS derived correlation clusters are structurally related, we used retention time (RT) matching and mass-to-charge ratio (m/z) differences to find possible isotopologues and adducts both within and across the assays. We call these structurally linked features structural groups.",
      "asbval:note": "Core research question is directly supported by the paper's structural search methodology.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolite-feature-annotation-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Automated annotation and structural linking of statistically significant untargeted LC-MS features into metabolite clusters defined by mass-to-charge ratio (m/z), retention time (RT), and structural properties (isotopologues, adducts, cross-assay links).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:41:49.314153+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/metabolite-feature-annotation-aggregation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here, we propose the MAMSI (Multi-Assay Mass Spectrometry Integration) workflow that utilizes an MB-PLS model for integrating multiple metabolomic LC-MS assays.",
      "asbval:note": "MAMSI is the primary workflow presented in the paper. The structural search tool is explicitly described as part of MAMSI.",
