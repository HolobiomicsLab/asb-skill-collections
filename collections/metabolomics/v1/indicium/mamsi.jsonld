    {
      "@id": "asbval:assertion/skill/networkx-object-generation-and-export/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We computed a dissimilarity matrix D (M \u00d7 M) where dij=|1\u2212rij| where r ij is the correlation coefficient between the i th and j th feature. We then applied agglomerative hierarchical clustering using the farthest point (complete) linkage and selected the optimal number of clusters by the highest mean silhouette score. To investigate whether the MB-PLS derived correlation clusters are structurally related, we used retention time (RT) matching and mass-to-charge ratio (m/z) differences to find possible isotopologues and adducts both within and across the assays.",
      "asbval:note": "Paper describes the workflow of identifying statistically significant features, assigning them to correlation clusters via hierarchical clustering, and then identifying structural relationships (isotopologues, adducts, cross-assay links).",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "networkx-object-generation-and-export",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After identifying statistically significant features and assigning them to structural clusters (isotopologue groups, adduct groups, cross-assay links) and correlation clusters via MamsiStructSearch.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:43:45.658706+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/permutation-test-p-value-estimation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We used multiblock variable importance in projection (MB-VIP) to estimate feature importance and coupled it with permutation testing to obtain empirical p-values.",
      "asbval:note": "Exact match: permutation testing coupled with MB-VIP for empirical p-value computation in LC-MS metabolomics context.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
