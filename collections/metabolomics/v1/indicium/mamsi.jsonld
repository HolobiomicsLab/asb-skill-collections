      }
    },
    {
      "@id": "asbval:assertion/skill/metabolite-feature-annotation-aggregation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Additionally, our structural search tool can use region of interest (ROI) files from peakPantheR software, enabling automated annotation (minimum level 3) of features based on m/z and RT for a given chromatography.",
      "asbval:note": "peakPantheR is explicitly mentioned as providing ROI files for automated annotation.",
