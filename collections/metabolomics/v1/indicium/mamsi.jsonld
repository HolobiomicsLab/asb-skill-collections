    {
      "@id": "asbval:assertion/skill/adduct-mass-matching-and-clustering/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we used retention time (RT) matching and mass-to-charge ratio (m/z) differences to find possible isotopologues and adducts both within and across the assays. We call these structurally linked features structural groups.",
      "asbval:note": "The paper describes the exact functionality: matching m/z and RT to identify isotopologues and adducts as structural groups, which is the core of adduct-mass matching and clustering.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "adduct-mass-matching-and-clustering",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill groups LC-MS features that share a common neutral mass by calculating hypothetical neutral masses from common electrospray ionisation adducts and matching them within a mass tolerance window. It is essential for linking multiply-charged or adducted ions of the same mol",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:37:02.363038+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
