    {
      "@id": "asbval:assertion/skill/k-fold-cross-validation-model-selection/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We estimated the number of LVs using a grid search combined with k-fold cross-validation (CV). The grid search process is explained in detail in the Supporting Information (SI).",
      "asbval:note": "Paper uses grid search COMBINED WITH k-fold CV, not k-fold CV alone. The paper does not explicitly state that selection criterion is 'where performance plateaus'\u2014instead it uses a grid search approach with k-fold CV for validation. The exact selection mechanism is deferred to SI.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "k-fold-cross-validation-model-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Use k-fold cross-validation to estimate the optimal number of latent variables in a multi-block PLS model by iteratively training on k\u22121 folds and evaluating on the held-out fold, selecting the latent variable count where model performance plateaus.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:40:12.137891+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/k-fold-cross-validation-model-selection/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We estimated the number of LVs using a grid search combined with k-fold cross-validation (CV)... To evaluate the model, we used Monte Carlo CV (MCCV), with 1000 random train-test splits, using 20% of the samples in each split for evaluation. This approach allowed us to calculate not only predictive performance using standard machine learning performance metrics but also to calculate the error margins of these metrics.",
      "asbval:note": "The paper demonstrates use of cross-validation to prevent overfitting and provide data-driven model evaluation in the context of multi-assay metabolomics.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "k-fold-cross-validation-model-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This prevents overfitting and provides a data-driven criterion for model complexity in multi-assay metabolomics integration.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:40:12.137891+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
