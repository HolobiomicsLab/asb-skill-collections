    {
      "@id": "asbval:assertion/skill/data-summarization-and-tabulation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We then applied agglomerative hierarchical clustering using the farthest point (complete) linkage and selected the optimal number of clusters by the highest mean silhouette score. To investigate whether the MB-PLS derived correlation clusters are structurally related, we used retention time (RT) matching and mass-to-charge ratio (m/z) differences to find possible isotopologues and adducts both within and across the assays.",
      "asbval:note": "Paper performs structural clustering and reports cluster counts and feature groupings (e.g., 'formed 17 correlation clusters', '103 features were detected to form 36 structural groups'), but does NOT explicitly demonstrate parameterized comparison across adduct mode selections or systematic tabulation of cluster statistics across conditions. The paper reports results for fixed configurations, not side-by-side parameter sweep comparisons.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "data-summarization-and-tabulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Extract and compute summary statistics from structural clustering outputs (cluster count, size distribution, feature coverage) and tabulate results across parameterized conditions (e.g., adduct mode selection) to enable side-by-side comparison of method effects on LC-MS feature g",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:38:39.227470+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/data-summarization-and-tabulation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here, we propose the MAMSI (Multi-Assay Mass Spectrometry Integration) workflow that utilizes an MB-PLS model for integrating multiple metabolomic LC-MS assays... The statistically significant MB-PLS features were clustered based on their intensity correlations... To investigate whether the MB-PLS derived correlation clusters are structurally related, we used retention time (RT) matching and mass-to-charge ratio (m/z) differences to find possible isotopologues and adducts both within and across the assays. We call these structurally linked features structural groups.",
      "asbval:note": "MAMSI framework explicitly performs structural clustering via isotopologue and adduct detection. Paper confirms this is a core function of the workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "data-summarization-and-tabulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "MAMSI (MamsiStructSearch) \u2014 Generates structural clusters from LC-MS features via isotopologue and adduct signature detection; outputs are the input to this summarization skill",
