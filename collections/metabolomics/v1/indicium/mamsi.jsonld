    {
      "@id": "asbval:assertion/skill/mb-vip-feature-importance-ranking/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To demonstrate and evaluate the approach, we used three multiassay data sets predicting biological sex, Alzheimer's disease status, and blood bilirubin levels as the outcomes of interest.",
      "asbval:note": "Paper demonstrates MB-PLS on both discriminant (sex, AD status) and regression (bilirubin levels) tasks with multi-assay LC-MS data.",
