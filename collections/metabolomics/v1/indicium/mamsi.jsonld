    {
      "@id": "asbval:assertion/card/10_1371_journal_pcbi_1011814__task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we propose a workflow to integrate multiassay metabolomics data, designed to enable biomarker discovery and elucidation of unknown metabolites. We employ a multiblock-partial least-squares model (MB-PLS) coupled with multiblock variable importance in projection to estimate the importance of predictors to the outcome variable... To evaluate the model, we used Monte Carlo CV (MCCV), with 1000 random train-test splits",
      "asbval:note": "Research question directly aligns with paper's stated objectives and methods.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "What are the model performance metrics and statistically significant metabolomic features identified when applying the full MAMSI pipeline (MB-PLS model fitting, MB-VIP feature selection, and cross-validation) to multi-assay LC-MS metabolomics datasets?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:33:03.161753+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/card/10_1371_journal_pcbi_1011814__task_001/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The MAMSI software is freely available online as an open-source Python package.",
      "asbval:note": "Paper explicitly states MAMSI is a Python package.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
