    {
      "@id": "asbval:assertion/skill/multiblock-pls-model-fitting/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The MB-PLS algorithm is an extension of the PLS model... each block X b (N \u00d7 M b ) is used to fit a PLS model of responses Y to calculate the block scores t b (N \u00d7 1). Then the block scores are combined with Y-scores to form the super scores t T (N \u00d7 R) and a PLS model between t T and Y is fit.",
      "asbval:note": "Paper describes MB-PLS for multi-assay integration and classification/regression tasks (supported). However, the paper does NOT explicitly name or reference the NIPALS algorithm in the passages provided. The mathematical description given is consistent with NIPALS-based PLS, but the algorithm name is not verbatim present. The claim about 'NIPALS algorithm' cannot be verified from these passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "multiblock-pls-model-fitting",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Fit a Multi-Block Partial Least Squares (MB-PLS) discriminant model to integrate and analyze multi-assay LC-MS metabolomics blocks (e.g., HPOS, LPOS, LNEG) for classification or regression tasks. MB-PLS leverages the NIPALS algorithm to model covariance structure across blocks wh",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:43:29.394561+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
