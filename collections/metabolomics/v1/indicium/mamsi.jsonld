    {
      "@id": "asbval:assertion/skill/multi-assay-data-integration-and-harmonization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we propose a workflow to integrate multiassay metabolomics data, designed to enable biomarker discovery and elucidation of unknown metabolites... MB-PLS extends this concept by introducing multiple X blocks... each block X b (N \u00d7 M b ) is used to fit a PLS model of responses Y to calculate the block scores t b (N \u00d7 1).",
      "asbval:note": "The paper explicitly describes integrating multiple LC-MS assays (HILIC+, Lipid RPC+, Lipid RPC\u2013) into blocks for MB-PLS modeling. The research question aligns with the core workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c01327",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "multi-assay-data-integration-and-harmonization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Load, prefix, and harmonize multi-assay LC-MS metabolomics intensity matrices (e.g., HPOS, LPOS, LNEG) into a unified block structure suitable for Multi-Block PLS modelling and cross-assay feature linking.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:43:10.994317+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
