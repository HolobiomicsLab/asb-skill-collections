      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After fitting a Multi-Block PLS (MB-PLS) discriminant or regression model on multi-assay LC-MS intensity data",
