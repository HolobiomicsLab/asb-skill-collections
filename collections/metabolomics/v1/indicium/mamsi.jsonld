      "asbval:target_claim_text": "MAMSI (MamsiStructSearch) - Core framework for structural clustering, isotopologue/adduct detection, and optional ROI-based annotation of LC-MS features",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
