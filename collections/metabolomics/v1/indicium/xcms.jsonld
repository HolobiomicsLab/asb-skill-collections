    {
      "@id": "asbval:assertion/skill/lc-ms-feature-grouping-and-compounding/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The core data structures of xcms were completely rewritten to gain full support for LC-MS/MS data... These new data structures rely on the established MS data infrastructures of MSnbase and packages from the RforMassSpectrometry initiative",
      "asbval:note": "Paper confirms MSnbase provides data infrastructure for MS data structures used by xcms.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c04338",
