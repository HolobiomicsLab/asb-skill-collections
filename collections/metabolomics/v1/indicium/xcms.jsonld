      "asbval:target_claim_text": "MsFeatures \u2014 Consumes XcmsExperiment/MsExperiment objects and applies grouping parameters (SimilarRtimeParam, AbundanceSimilarityParam, EicSimilarityParam) to group related features",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
