      "asbval:target_artifact_id": "mass-chromatogram-alignment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Spectra as backend for storing and accessing MS2 spectra associated with aligned chromatographic peaks and feature groups",
      "eco:evidence_type": {
