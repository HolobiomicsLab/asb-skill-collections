      }
    },
    {
      "@id": "asbval:assertion/skill/metabolomics-data-structure-handling/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The MsFeatures package adds yet another layer of versatility in postanalysis by grouping LC-MS features that represent the signal of ions and isotopes of the same compound.",
      "asbval:note": "MsFeatures is confirmed to perform feature grouping, but the specific grouping parameters (SimilarRtimeParam, AbundanceSimilarityParam, EicSimilarityParam) are not mentioned in the passages. The functional role is correct but parameter names are not verified.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c04338",
