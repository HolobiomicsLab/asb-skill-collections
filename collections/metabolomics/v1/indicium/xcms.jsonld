      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "MsExperiment \u2014 Container class for integrating Spectra, xcms results, and sample metadata into a unified multi-modal metabolomics object",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
