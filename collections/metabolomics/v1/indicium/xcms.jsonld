      }
    },
    {
      "@id": "asbval:assertion/skill/metabolomics-data-structure-handling/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "These new data structures rely on the established MS data infrastructures of MSnbase and packages from the RforMassSpectrometry initiative, in particular, the Spectra and Chromatograms R packages.",
      "asbval:note": "MSnbase is explicitly identified as foundational infrastructure for xcms and Spectra. The role as providing base classes and validation framework is semantically supported.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c04338",
