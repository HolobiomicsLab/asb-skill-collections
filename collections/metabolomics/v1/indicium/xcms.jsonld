    {
      "@id": "asbval:assertion/skill/mass-spectrometry-data-visualization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Tailored plotting functions have been developed for different stages of the analysis, whether working with the full, raw MS data or examining results at various preprocessing steps. Specifically, users can generate base peak chromatograms (BPCs) from raw data, EICs with highlighted chromatographic peaks during peak detection, and density plots for feature grouping, allowing for visual insights throughout the workflow",
      "asbval:note": "Research question is well-supported by passage describing EIC visualization and feature grouping visualization capabilities.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c04338",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-data-visualization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Visualization of LC-MS feature groups and extracted ion chromatograms (EICs) to inspect peak shape similarity, retention time alignment, and abundance patterns across samples. Used to validate feature grouping decisions and identify anomalies (e.g., co-eluting features with shift",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:31:30.213679+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
