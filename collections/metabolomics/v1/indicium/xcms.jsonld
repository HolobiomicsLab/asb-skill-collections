      }
    },
    {
      "@id": "asbval:assertion/skill/chromatographic-peak-shape-comparison/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The MsFeatures package adds yet another layer of versatility in postanalysis by grouping LC-MS features that represent the signal of ions and isotopes of the same compound.",
      "asbval:note": "Paper confirms MsFeatures provides feature grouping functionality, but does not explicitly name 'EicSimilarityParam' as a parameter class from MsFeatures in the provided passages. The parameter class is mentioned in the context of xcms preprocessing but not explicitly attributed to MsFeatures.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c04338",
