      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/feature-group-refinement-multicriteria/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Each major preprocessing step, such as peak detection, retention time alignment, and chromatographic peak grouping, is now handled by a dedicated function, with multiple algorithms available for each step. These algorithms are configured via dedicated parameter classes, allowing users to easily define and customize settings based on the specific requirements of their experiment.",
      "asbval:note": "Paper confirms xcms uses parameter classes for preprocessing steps including 'chromatographic peak grouping' and mentions 'multiple algorithms available for each step,' but does not explicitly name the specific parameter classes SimilarRtimeParam, AbundanceSimilarityParam, or EicSimilarityParam in the provided passages. The groupFeatures() function is not mentioned by name in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c04338",
