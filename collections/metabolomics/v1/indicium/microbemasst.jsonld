    {
      "@id": "asbval:assertion/skill/spectral-match-result-consolidation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The microbeMASST web app displays query results in interactive taxonomic trees, which can be downloaded as HTML files... In addition, three data tables are generated, linking the search job to other resources in the GNPS/MassIVE ecosystem.",
      "asbval:note": "Paper describes generation of structured outputs (taxonomic trees, HTML files, data tables) for visualization and analysis.",
