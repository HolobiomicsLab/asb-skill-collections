      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-match-result-consolidation/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The microbeMASST web application was built using Dash and Flask open-source libraries for Python (https://github.com/mwang87/GNPS_MASST/blob/master/dash_microbemasst.py)",
      "asbval:note": "GNPS_MASST repository is mentioned as containing the microbeMASST web application code, but the paper does not describe it as a parent repository for multiple domain MASSTs. Only microbeMASST is documented.",
