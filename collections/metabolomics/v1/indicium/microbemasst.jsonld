    },
    {
      "@id": "asbval:assertion/skill/search-result-aggregation-and-normalization/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The microbeMASST web application was built using Dash and Flask open-source libraries for Python (https://github.com/mwang87/GNPS_MASST/blob/master/dash_microbemasst.py).",
      "asbval:note": "GNPS_MASST repository is mentioned as containing code for microbeMASST specifically, but the paper does not describe it as a parent repository for 'all standalone MASST web applications' (plantMASST, tissueMASST, etc. are not mentioned).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
