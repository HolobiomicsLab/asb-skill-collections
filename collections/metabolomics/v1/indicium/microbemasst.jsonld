      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Consolidate and normalize spectral search results from multiple domain-specific MASST tools (microbeMASST, plantMASST, tissueMASST, microbiomeMASST, foodMASST)",
      "eco:evidence_type": {
