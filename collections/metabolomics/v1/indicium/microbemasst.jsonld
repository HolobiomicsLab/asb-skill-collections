    {
      "@id": "asbval:assertion/skill/metadata-harmonization-across-sources/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST leverages the Fast Search Tool (https://fasst.gnps2.org/fastsearch/) API and the sample-specific associated metadata to generate taxonomic trees... users can leverage microbeMASST Python code to perform batch searches of thousands of MS/MS spectra by providing either a formatted MS/MS file (.mgf) or a list of Universal Spectrum Identifiers (USIs)",
      "asbval:note": "Paper describes batch processing and aggregation for microbeMASST specifically, with Python code for batch searches. However, the paper does NOT describe aggregation across multiple domain-specific MASST tools (plantMASST, tissueMASST, microbiomeMASST, foodMASST). The card claims a cross-domain aggregation skill that is not evidenced in the paper. The paper only discusses microbeMASST as a single domain tool.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "metadata-harmonization-across-sources",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Ingest, parse, normalize, and aggregate search output files from multiple domain-specific MASST tools into a unified, structured format compatible with visualization and downstream analysis. This skill enables integration of spectrum identifiers, match scores, and metadata fields",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:21:06.669312+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
