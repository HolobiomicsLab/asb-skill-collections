    {
      "@id": "asbval:assertion/skill/summary-visualization-artifact-generation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To create the final taxonomic tree, the JSON file of the complete microbeMASST taxonomic tree is filtered according to the results and converted into a D3 JavaScript object that can be visualized as an HTML file. ... users can leverage microbeMASST Python code to perform batch searches of thousands of MS/MS spectra by providing either a formatted MS/MS file (.mgf) or a list of Universal Spectrum Identifiers (USIs)",
      "asbval:note": "Paper demonstrates HTML tree generation and JSON conversion for microbeMASST only. No evidence of cross-domain aggregation (plantMASST, tissueMASST, microbiomeMASST, foodMASST) or unified multi-domain visualization. The research_question overstates scope by claiming consolidation across five domain-specific tools when paper only describes microbeMASST implementation.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "summary-visualization-artifact-generation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Generate interactive HTML trees, JSON structures, and TSV summary tables from aggregated multi-domain MASST search outputs to enable unified visualization and interpretation of spectrum matches across domain-specific databases. This skill consolidates fragmented search results fr",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:23:15.179158+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
