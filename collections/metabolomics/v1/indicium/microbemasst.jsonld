    {
      "@id": "asbval:assertion/skill/spectrum-metadata-parsing/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST leverages the Fast Search Tool (https://fasst.gnps2.org/fastsearch/) API and the sample-specific associated metadata to generate taxonomic trees. Fast searches are based on indexing all the MS/MS spectra present in GNPS/MassIVE according to the mass and intensity of their precursor ions",
      "asbval:note": "Paper confirms Fast Search API exists and is used by microbeMASST. However, no mention of jobs.py as the invoker, and no evidence that it indexes Metabolomics Workbench, Metabolights, or NORMAN \u2014 only GNPS/MassIVE is mentioned.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectrum-metadata-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Fast Search API (https://fasst.gnps2.org/fastsearch/) \u2014 Batch search engine invoked via jobs.py; executes spectrum-to-library matching across GNPS/MassIVE, Metabolomics Workbench, Metabolights, and NORMAN indexed data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:22:36.442581+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectrum-metadata-parsing/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "users can leverage microbeMASST Python code to perform batch searches of thousands of MS/MS spectra by providing either a formatted MS/MS file (.mgf) or a list of Universal Spectrum Identifiers (USIs)",
      "asbval:note": "Paper confirms batch search capability via Python code. However, no mention of jobs.py by name, and no evidence of 'dispatching to multiple domain-specific MASSTs' \u2014 only microbeMASST is documented. The card's claim of multi-domain routing is not supported.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectrum-metadata-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "jobs.py (https://github.com/robinschmid/microbe_masst/blob/master/code/jobs.py) \u2014 Batch execution and metadata routing orchestrator; parses input spectra, applies search parameters, and dispatches to multiple domain-specific MASSTs",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:22:36.442581+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/structured-data-compilation-from-readme/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper describes microbeMASST as a search tool and its reference database, but does not discuss or demonstrate a task of extracting/validating resources from README documentation into structured inventory formats. The paper is about the tool itself, not about a methodology for documenting or inventorying tools from READMEs.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "structured-data-compilation-from-readme",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Extract and validate enumerated resources (tools, URLs, publications, metadata) from repository README documentation into a structured inventory format (CSV/JSON). This skill ensures reproducible discovery and verification of multi-component scientific software ecosystems where h",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
