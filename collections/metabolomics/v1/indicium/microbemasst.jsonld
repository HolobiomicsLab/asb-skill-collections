    {
      "@id": "asbval:assertion/skill/routing-module-testing-and-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST is a community-sourced tool that works within the GNPS ecosystem. Users can search tandem MS (MS/MS) spectra obtained from their experiments against the GNPS/MassIVE repository and retrieve matching samples exclusively acquired from extracts of bacterial, fungal or archaeal monocultures.",
      "asbval:note": "Paper describes microbeMASST as a single domain-specific application within GNPS ecosystem. No evidence of conditional routing logic across six standalone MASST applications (plant, tissue, microbiome, food, metadata variants). The paper focuses exclusively on microbeMASST implementation and validation, not a routing module that dispatches to multiple domain-specific endpoints.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "routing-module-testing-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate that conditional routing logic correctly maps user-submitted MS/MS spectra to the appropriate domain-specific MASST application (microbe, plant, tissue, microbiome, food, or metadata) based on domain-context metadata.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:21:37.280704+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/routing-module-testing-and-validation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The microbeMASST web application was built using Dash and Flask open-source libraries for Python (https://github.com/mwang87/GNPS_MASST/blob/master/dash_microbemasst.py).",
      "asbval:note": "Paper confirms GNPS_MASST repository exists and contains microbeMASST web application code (dash_microbemasst.py), but provides no evidence of conditional routing logic for six domain-specific MASST variants or integration layer across multiple endpoints. Repository is cited only for microbeMASST implementation.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "routing-module-testing-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "GNPS_MASST: Source codebase containing the conditional routing logic, endpoint definitions, and integration layer for all six domain-specific MASST applications",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:21:37.280704+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/routing-module-testing-and-validation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST, a taxonomically informed mass spectrometry (MS) search tool, tackles limited microbial metabolite annotation in untargeted metabolomics experiments. Leveraging a curated database of >60,000 microbial monocultures, users can search known and unknown MS/MS spectra and link them to their respective microbial producers via MS/MS fragmentation patterns.",
      "asbval:note": "microbeMASST is confirmed as a functional MS/MS search tool for microbial spectra, though the paper does not describe it as one of six routing endpoints or discuss routing logic.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
