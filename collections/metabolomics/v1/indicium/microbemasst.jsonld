    {
      "@id": "asbval:assertion/skill/routing-module-testing-and-validation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "users can leverage microbeMASST Python code to perform batch searches of thousands of MS/MS spectra by providing either a formatted MS/MS file (.mgf) or a list of Universal Spectrum Identifiers (USIs), which represent paths to spectra in public datasets. This is particularly useful for creating integrated data analysis pipelines using the standard outputs (.mgf) of already established data processing tools, such as MZmine. ... batch searches can be performed using a customizable Python script that can read either a .tsv file containing a list of USIs or a single .mgf file (https://github.com/robinschmid/microbe_masst).",
      "asbval:note": "Paper confirms batch search Python scripts exist (referenced at https://github.com/robinschmid/microbe_masst), but evidence shows these scripts execute searches within microbeMASST only, not across multiple domain-specific MASST applications. No evidence of cross-domain batch execution.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "routing-module-testing-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "jobs.py: Batch submission script that executes spectrum searches across all domain-specific MASSTs",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:21:37.280704+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/search-result-aggregation-and-normalization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST is a community-sourced tool that works within the GNPS ecosystem. Users can search tandem MS (MS/MS) spectra obtained from their experiments against the GNPS/MassIVE repository and retrieve matching samples exclusively acquired from extracts of bacterial, fungal or archaeal monocultures.",
      "asbval:note": "Paper describes microbeMASST as a single domain-specific tool for microbial metabolomics. No mention of plantMASST, tissueMASST, microbiomeMASST, foodMASST, or metadataMASST. No aggregation workflow across multiple MASST tools is described. The card claims a cross-domain aggregation task that is not present in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "search-result-aggregation-and-normalization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Combine and normalize search output files from multiple domain-specific MASST tools (microbeMASST, plantMASST, tissueMASST, microbiomeMASST, foodMASST) into unified, structured artifacts compatible with metadataMASST visualization.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:22:01.450605+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/search-result-aggregation-and-normalization/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "metadataMASST is not mentioned anywhere in the paper. The paper only describes microbeMASST and its integration with GNPS/MassIVE ecosystem.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "search-result-aggregation-and-normalization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "metadataMASST (Target visualization and exploration platform that consumes aggregated search output)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:22:01.450605+00:00",
