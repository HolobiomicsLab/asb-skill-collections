    {
      "@id": "asbval:assertion/card/10_5281_zenodo_492844724__task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST (https://masst.gnps2.org/microbemasst/), a search tool that leverages public MS repository data to identify the microbial origin of known and unknown metabolites and map them to their microbial producers. microbeMASST is a community-sourced tool that works within the GNPS ecosystem",
      "asbval:note": "Paper documents microbeMASST with live URL and publication details. However, the paper does not enumerate other domain-specific MASST variants (plantMASST, tissueMASST, etc.) or reference a 'domainMASSTs repository'. Only microbeMASST is described in detail in the provided passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "What are the complete set of domain-specific MASST standalone web applications, their live URLs, and their associated publications as documented in the domainMASSTs repository?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:17:29.866453+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/card/10_5281_zenodo_492844724__task_001/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST, a taxonomically informed mass spectrometry (MS) search tool, tackles limited microbial metabolite annotation in untargeted metabolomics experiments.",
      "asbval:note": "microbeMASST is the primary subject of the paper and is extensively documented.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
