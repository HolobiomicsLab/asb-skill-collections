    {
      "@id": "asbval:assertion/skill/spectral-match-result-consolidation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST is based on the recently introduced Fast Search Tool (https://fasst.gnps2.org/fastsearch/). This tool, originally designed for proteomics, drastically improves search speed by several orders of magnitude by indexing all the MS/MS spectra present in GNPS/MassIVE",
      "asbval:note": "Fast Search Tool (API) is explicitly mentioned as the backend for microbeMASST searches.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-match-result-consolidation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Fast Search API",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:22:19.193418+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-match-result-consolidation/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "users can leverage microbeMASST Python code to perform batch searches of thousands of MS/MS spectra by providing either a formatted MS/MS file (.mgf) or a list of Universal Spectrum Identifiers (USIs)",
      "asbval:note": "Paper mentions batch search capability via Python code; passage [7] references 'a custom Python script of microbeMASST' for batch processing. The specific script name 'jobs.py' is not mentioned in passages, but batch Python scripting is confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-match-result-consolidation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "jobs.py",
      "eco:evidence_type": {
