      }
    },
    {
      "@id": "asbval:assertion/skill/search-result-aggregation-and-normalization/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST, a taxonomically informed mass spectrometry (MS) search tool, tackles limited microbial metabolite annotation in untargeted metabolomics experiments. Leveraging a curated database of >60,000 microbial monocultures, users can search known and unknown MS/MS spectra and link them to their respective microbial producers via MS/MS fragmentation patterns.",
      "asbval:note": "microbeMASST is confirmed as a domain-specific tool for microbial metabolomics. However, the card's framing of it as one tool among many to be aggregated is not supported\u2014the paper focuses on microbeMASST as a standalone tool.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "search-result-aggregation-and-normalization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "microbeMASST (Domain-specific MASST tool generating searchable microbial metabolomics results to be aggregated)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:22:01.450605+00:00",
      "sepio:credibility_status": {
