    {
      "@id": "asbval:assertion/skill/domain-context-to-application-routing/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "batch searches can be performed using a customizable Python script that can read either a .tsv file containing a list of USIs or a single .mgf file (https://github.com/robinschmid/microbe_masst)",
      "asbval:note": "Paper mentions a customizable Python script for batch searches at the robinschmid/microbe_masst repository, but does not specifically name it 'jobs.py'. The script exists and performs batch orchestration, but the exact filename is not confirmed in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "domain-context-to-application-routing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "jobs.py",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:20:48.422782+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/domain-context-to-application-routing/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST leverages the Fast Search Tool (https://fasst.gnps2.org/fastsearch/) API and the sample-specific associated metadata to generate taxonomic trees. Fast searches are based on indexing all the MS/MS spectra present in GNPS/MassIVE",
      "asbval:note": "Fast Search Tool (FASST) API is confirmed as the underlying service for spectral searching in microbeMASST.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "domain-context-to-application-routing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Fast Search API",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:20:48.422782+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/domain-context-to-application-routing/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "As of September 2023, microbeMASST includes 60,781 liquid chromatography (LC)\u2013MS/MS files comprising >100 million MS/MS spectra mapped to 541 strains, 1,336 species, 539 genera, 264 families, 109 orders, 41 classes and 16 phyla",
      "asbval:note": "Paper confirms microbeMASST searches microbial spectral library, but the numbers differ: paper reports 541 strains, 1,336 species, 539 genera (as of Sept 2023), not 561 genera, 1379 species, 542 strains as claimed in the card. No evidence of 'routed spectra with microbial context label' mechanism.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "domain-context-to-application-routing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[microbeMASST].role",
      "asbval:target_claim_text": "Domain-specific MASST for microbial metabolomics search; receives routed spectra with 'microbial' context label and searches against curated microbial spectral library (561 genera, 1379 species, 542 strains).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:20:48.422782+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/domain-context-to-application-routing/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper describes microbeMASST as a single tool for microbial metabolomics. There is no discussion of a conditional routing mechanism that dispatches to multiple domain-specific MASST variants. The scope describes a multi-domain routing system that is not present in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "domain-context-to-application-routing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "A conditional routing mechanism that maps user-submitted mass spectra to domain-specific MASST applications based on explicit domain-context metadata",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
