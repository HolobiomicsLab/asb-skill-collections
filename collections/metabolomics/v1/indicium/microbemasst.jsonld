    {
      "@id": "asbval:assertion/skill/summary-visualization-artifact-generation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST is based on the recently introduced Fast Search Tool (https://fasst.gnps2.org/fastsearch/). This tool, originally designed for proteomics, drastically improves search speed by several orders of magnitude by indexing all the MS/MS spectra present in GNPS/MassIVE and restricting the search space to the user input parameters.",
      "asbval:note": "Fast Search API is confirmed for GNPS/MassIVE indexing, but paper does not mention Metabolomics Workbench, Metabolights, or NORMAN as indexed data sources. Paper only confirms GNPS/MassIVE.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "summary-visualization-artifact-generation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Fast Search API - Backend API used in jobs.py batch processing to execute rapid searches across indexed data in GNPS/MassIVE, Metabolomics Workbench, Metabolights, and NORMAN",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:23:15.179158+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
