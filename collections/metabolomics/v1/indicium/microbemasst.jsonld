    {
      "@id": "asbval:assertion/skill/search-result-aggregation-and-normalization/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper describes microbeMASST as a single tool with batch search capability and integration with GNPS/MassIVE. It does not describe a workflow for aggregating outputs from multiple domain-specific MASST tools (plantMASST, tissueMASST, microbiomeMASST, foodMASST) or integration with metadataMASST. The card's scope describes a cross-domain aggregation task that is entirely absent from the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
