    {
      "@id": "asbval:assertion/skill/spectral-match-result-consolidation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "microbeMASST is a community-sourced tool that works within the GNPS ecosystem. Users can search tandem MS (MS/MS) spectra obtained from their experiments against the GNPS/MassIVE repository",
      "asbval:note": "Paper describes microbeMASST only. No mention of plantMASST, tissueMASST, microbiomeMASST, or foodMASST. The paper does not discuss consolidation across multiple domain-specific MASST tools. Only microbeMASST is documented in this paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41564-023-01575-9",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectral-match-result-consolidation",
