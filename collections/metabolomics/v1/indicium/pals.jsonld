      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply the PLAGE decomposition method to metabolite groupings beyond canonical pathways\u2014such as Molecular Families from GNPS or Mass2Motifs from MS2LDA\u2014to compute activity scores and rank metabolite sets by differential abundance across experimental conditions.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
