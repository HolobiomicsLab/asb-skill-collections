    {
      "@id": "asbval:assertion/card/10_1186_1471_2105_6_225__task_003/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For the MF analysis, Global Natural Products Social Molecular Networking (GNPS) example data were taken from the American Gut Project. ... Both FBMN and MS2LDA are accessible as workflows from Global Natural Products Social Molecular Networking (GNPS, [2]), which provides community resources to run large-scale molecular networking and annotations of spectra.",
      "asbval:note": "GNPS is used as a source for molecular family data and workflows.",
