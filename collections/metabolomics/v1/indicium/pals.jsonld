    {
      "@id": "asbval:assertion/card/10_1186_1471_2105_6_225__task_004/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Assessing changes to the p-values of the true changing pathways with higher number of decoy features reveals that increasing the number of decoy features generally produces higher p-values (Figure 1)... Additionally, the effect of introducing an increasing number of missing features from the pathways was explored... The results in Figure 4 show that as the number of missing features increases, mPLAGE consistently returns lower mean p-values with smaller variances than ORA or GSEA.",
      "asbval:note": "Paper does plot perturbation level (x-axis: decoy feature %, missing feature %) against method performance (y-axis: p-values, F1 scores), and does test noise and missing features separately. However, the y-axis metric is p-value or F1 score, NOT rank-order correlation or top-K retention. Combined perturbation (Gaussian noise + peak removal together) is not explicitly tested.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_004",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "Stability curve plot: x-axis = noise/peak-removal level, y-axis = correlation coefficient or retention %; separate lines for noise alone, peak removal alone, and combined perturbation",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:33:05.423838+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/card/10_1186_1471_2105_6_225__task_004/scope_drift",
      "@type": "asbval:ScopeDriftAssertion",
      "asbval:drift_notes": [
        "Card requests rank-order stability analysis (Spearman/Kendall correlation, top-K retention), but paper evaluates robustness via p-value calibration and F1 score performance.",
        "Card specifies combined Gaussian noise + peak removal perturbations; paper tests decoy features (simulating noise/misannotation) and missing features separately, not in combination.",
        "Card focuses on 'top-scoring pathways' stability; paper evaluates overall method performance (precision, recall, F1) across all pathways, not specifically top-K rank preservation."
      ],
      "asbval:n_drift_notes": 3,
      "asbval:target_artifact_id": "task_004",
      "asbval:target_artifact_kind": "card",
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:33:05.423838+00:00",
      "sepio:credibility_status": {
