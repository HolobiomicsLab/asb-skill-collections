      }
    },
    {
      "@id": "asbval:assertion/skill/activity-score-robustness-assessment/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PALS can be run either as a standalone tool, imported as a Python library, or used via a Web interface allowing users with a wide range of expertise and requirements to use it... To assist beginners, a Web interface is provided to run PALS in an intuitive and user-friendly manner",
      "asbval:note": "Paper confirms Web interface exists but does not specify Streamlit as the framework. Card claims 'Streamlit-based' but paper only says 'Web interface' without naming the underlying technology.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "activity-score-robustness-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "PALS Viewer - Web interface (Streamlit-based) for visual inspection of activity score rankings",
