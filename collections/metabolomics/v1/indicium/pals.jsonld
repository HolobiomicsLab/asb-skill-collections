        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/peak-removal-robustness-testing/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "[SUBSTRING-MATCH for ORA | role: Alternative pathway ranking method] A comparison of mPLAGE with two other commonly used methods (overrepresentation analysis (ORA) and gene set enrichment analysis (GSEA)) is also given and reveals that mPLAGE is more robust to missing features and noisy data than the alternatives.",
      "asbval:note": "ORA is included in PALS as a benchmarking method for robustness comparison.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
