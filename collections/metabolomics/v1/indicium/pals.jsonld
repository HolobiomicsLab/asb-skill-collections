    {
      "@id": "asbval:assertion/skill/robustness-analysis-under-perturbation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To assess the robustness of mPLAGE, benchmarking experiments were performed... To mimic the inclusion of formulae that arise due to incorrect identification/annotation, decoy features were generated... To simulate missing features, which often occurs in real metabolomics data, features were also randomly removed from pathways with a uniform probability of 0.2... The performance of mPLAGE was compared to widely used overrepresentation (ORA) analysis and gene set enrichment analysis (GSEA) methods",
      "asbval:note": "Exact match: paper performs systematic robustness evaluation with noise (decoy features) and missing data perturbations, comparing mPLAGE, ORA, and GSEA.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "robustness-analysis-under-perturbation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Systematically evaluate the stability of pathway activity scoring results under controlled degradation of input data (noise injection, missing peaks) to demonstrate comparative robustness across competing methods.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:42:42.298868+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
