      }
    },
    {
      "@id": "asbval:assertion/skill/metabolite-set-activity-scoring/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For the MF analysis, Global Natural Products Social Molecular Networking (GNPS) example data were taken from the American Gut Project... To analyse both MFs and Mass2Motifs, Python code is provided in PALS to retrieve information on the metabolite sets as well as the peak intensity table from GNPS",
      "asbval:note": "GNPS confirmed as source of Molecular Families data analyzed by PALS.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
