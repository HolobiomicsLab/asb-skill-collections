    {
      "@id": "asbval:assertion/skill/activity-score-robustness-assessment/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The robustness of mPLAGE was evaluated on both synthetic and real data experiments and compared to both ORA and GSEA methods. The results demonstrated that the mPLAGE method is robust to noise and missing values, which is particularly important for metabolomics data.",
      "asbval:note": "Paper explicitly evaluates robustness of PLAGE (mPLAGE) against noise and missing features in metabolomics data.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "activity-score-robustness-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Evaluate the robustness of pathway or metabolite-set activity scores computed via PLAGE decomposition against noise and missing peaks in metabolomics intensity data.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:36:20.386000+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/activity-score-robustness-assessment/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In this experiment, an increasing number of decoy features were added to the seven pathways comprised of significantly changing features. This scenario reflects the case of attempting to find pathways, or sets of metabolites, with high activity levels when the number of significantly changing metabolites are small compared to noisy data, nonchanging or wrongly annotated metabolites.",
      "asbval:note": "Paper systematically perturbs peak intensity matrices with decoy features and missing data to assess stability of activity scores.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "activity-score-robustness-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill assesses whether activity scores remain stable and interpretable across perturbations of the input peak intensity matrix",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:36:20.386000+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/activity-score-robustness-assessment/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here, we present PALS (Pathway Activity Level Scoring), a Python library, command line tool, and Web application that performs the ranking of significantly changing metabolite sets over different experimental conditions.",
      "asbval:note": "PALS is the primary tool described in the paper for activity level scoring.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "activity-score-robustness-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "PALS (Pathway Activity Level Scoring)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:36:20.386000+00:00",
