    {
      "@id": "asbval:assertion/skill/robustness-analysis-under-perturbation/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "GSEA is a general method not specific to PALS. While GSEA is included in PALS for comparison purposes, it is not a PALS-specific tool and should not be attributed to the PALS repository.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
