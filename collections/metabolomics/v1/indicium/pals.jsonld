      }
    },
    {
      "@id": "asbval:assertion/skill/principal-component-extraction-from-pathway-subsets/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The results demonstrated that the mPLAGE method is robust to noise and missing values, which is particularly important for metabolomics data... At higher levels (250%, 500%, and 1000%), GSEA appears most sensitive to the perturbation, while mPLAGE performs best amongst the methods compared.",
      "asbval:note": "Paper explicitly compares mPLAGE robustness to ORA and GSEA on synthetic and real data.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "principal-component-extraction-from-pathway-subsets",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This approach is more robust to noise and missing peaks than Over-Representation Analysis or Gene Set Enrichment Analysis alternatives",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
