      }
    },
    {
      "@id": "asbval:assertion/skill/pathway-level-activity-scoring/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "One such FCS method is pathway level analysis of gene expression (PLAGE) [7], which performs singular value decomposition (SVD)",
      "asbval:note": "Title matches the original PLAGE method description in the paper, though the exact title string is not verbatim in passages.",
