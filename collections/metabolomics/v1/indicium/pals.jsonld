    {
      "@id": "asbval:assertion/skill/metabolite-set-activity-scoring/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To anaylse Mass2Motifs, a data set from the GNPS-MS2LDA workflow, consisting of 70 Rhamnacea species from two clades and various genera, was used... To analyse both MFs and Mass2Motifs, Python code is provided in PALS to retrieve information on the metabolite sets as well as the peak intensity table from GNPS",
      "asbval:note": "MS2LDA confirmed as source of Mass2Motifs data analyzed by PALS.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolite-set-activity-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "MS2LDA - Source of Mass2Motifs spectral groupings that can be analyzed as metabolite sets alongside pathways",
