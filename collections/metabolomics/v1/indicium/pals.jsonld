      }
    },
    {
      "@id": "asbval:assertion/skill/activity-score-robustness-assessment/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To anaylse Mass2Motifs, a data set from the GNPS-MS2LDA workflow, consisting of 70 Rhamnacea species from two clades and various genera, was used... the second method employs a topic-modelling approach (MS2LDA, [5]) to generate groups of peaks (called Mass2Motifs) based on the shared presence of fragment and neutral loss features in their fragmentation spectra.",
      "asbval:note": "Paper uses MS2LDA-derived Mass2Motifs for robustness testing with PALS.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "activity-score-robustness-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "MS2LDA - Source of Mass2Motifs metabolite groupings for non-pathway robustness testing",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:36:20.386000+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/activity-score-robustness-assessment/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Metabolites, pathways, and the mapping of metabolites to pathways are obtained in PALS by querying from a local copy of the KEGG database [29] or by querying a Reactome instance running on top of a local Neo4j graph database",
      "asbval:note": "Paper confirms Reactome is queried by PALS for pathway and metabolite data.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
