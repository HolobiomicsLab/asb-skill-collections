    {
      "@id": "asbval:assertion/card/10_1186_1471_2105_6_225__task_005/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here, we present PALS (Pathway Activity Level Scoring), a Python library, command line tool, and Web application that performs the ranking of significantly changing metabolite sets over different experimental conditions.",
      "asbval:note": "PALS is the primary tool described throughout the paper.",
