      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolite-set-activity-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "PALS (Pathway Activity Level Scoring)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:37:15.530438+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/metabolite-set-activity-scoring/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To facilitate the use of the activity analysis described in this project, PALS (Pathway Activity Level Scoring) software was developed. PALS can be run either as a standalone tool, imported as a Python library, or used via a Web interface allowing users with a wide range of expertise and requirements to use it... To assist beginners, a Web interface is provided to run PALS in an intuitive and user-friendly manner",
      "asbval:note": "Paper confirms web interface exists but does not specify 'Streamlit-based' implementation. The card's claim about Streamlit is not verified in the passages.",
