    {
      "@id": "asbval:assertion/card/10_1186_1471_2105_6_225__task_004/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not report Spearman or Kendall correlation coefficients for rank-order stability, nor does it report top-K retention percentages. Instead, paper reports p-values, precision, recall, and F1 scores as evaluation metrics.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "task_004",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "Rank-order stability metrics: a table with noise level (% Gaussian + % peak removal) as rows and Spearman/Kendall correlation coefficient and top-K retention percentage as columns",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
