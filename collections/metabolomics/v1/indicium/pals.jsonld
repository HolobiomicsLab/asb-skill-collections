    {
      "@id": "asbval:assertion/skill/robustness-analysis-under-perturbation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "ORA and GSEA are not PALS-specific tools; they are general methods. ORA and GSEA are included in the PALS library for comparison, but they are not hosted at the PALS GitHub repository as standalone tools. The card incorrectly attributes both ORA and GSEA to the PALS repository.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "no",
