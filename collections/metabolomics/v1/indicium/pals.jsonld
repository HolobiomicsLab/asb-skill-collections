      }
    },
    {
      "@id": "asbval:assertion/skill/peak-removal-robustness-testing/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The modularity of PALS also means it is not limited to pathways, and any user-defined grouping of features (representing metabolite sets) can be readily analysed... The robustness of mPLAGE was evaluated on both synthetic and real data experiments and compared to both ORA and GSEA methods.",
      "asbval:note": "PALS is used to execute all three methods (mPLAGE, ORA, GSEA) on synthetic and real datasets with varying levels of missing features.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "peak-removal-robustness-testing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[0].role",
      "asbval:target_claim_text": "Primary method to execute pathway decomposition (PLAGE, ORA, GSEA) on perturbed datasets and compute ranked pathway activity scores",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:41.130565+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/peak-removal-robustness-testing/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Using mPLAGE, small correlated changes in a group of metabolites are rated as more interesting than large changes in an individual metabolite, where other metabolites in the set are not changing... The AL score in a sample j is given by vj, where v is the first row in V, which is a vector of coefficients representing the activity levels of the first metacompound in U (having the largest singular value) across samples.",
      "asbval:note": "mPLAGE (PLAGE for metabolomics) computes activity scores via SVD decomposition, which are then ranked and compared across methods.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
