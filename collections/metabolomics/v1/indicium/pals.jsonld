    {
      "@id": "asbval:assertion/skill/pathway-ranking-and-prioritization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PALS (Pathway Activity Level Scoring), a Python library, command line tool, and Web application that performs the ranking of significantly changing metabolite sets over different experimental conditions. The main algorithm in PALS is based on the pathway level analysis of gene expression (PLAGE) factorisation method and is denoted as mPLAGE (PLAGE for metabolomics).",
      "asbval:note": "Core functionality confirmed: activity level computation via mPLAGE and ranking by statistical significance (p-values).",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pathway-ranking-and-prioritization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Rank and prioritize metabolic or molecular pathways by computing activity level scores from intensity data and pathway definitions, then sorting by statistical significance.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:14.661972+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/pathway-ranking-and-prioritization/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The robustness of mPLAGE was evaluated on both synthetic and real data experiments and compared to both ORA and GSEA methods. The results demonstrated that the mPLAGE method is robust to noise and missing values, which is particularly important for metabolomics data.",
      "asbval:note": "Robustness to noise and missing data explicitly demonstrated in benchmarking.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pathway-ranking-and-prioritization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "particularly robust to noise and missing peaks in metabolomics",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:14.661972+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/pathway-ranking-and-prioritization/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "a peak intensity matrix X is constructed for each metabolite set, defined here as a collection of features that have been grouped in some manner, e.g., forming a particular metabolic pathway or molecular family. In X, each row represents a single feature and each column is a sample, grouped into user-defined factors/conditions.",
      "asbval:note": "Matrix structure confirmed. Annotation requirement confirmed: 'Features are annotated as compound formulae and these are linked to the metabolites in the metabolite set/pathway of interest.'",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pathway-ranking-and-prioritization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "peak intensity matrix (rows=peaks with KEGG/ChEBI/UniProt IDs, columns=samples)",
      "eco:evidence_type": {
