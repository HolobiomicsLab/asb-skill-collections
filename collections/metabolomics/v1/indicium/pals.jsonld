      }
    },
    {
      "@id": "asbval:assertion/skill/activity-score-robustness-assessment/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For the MF analysis, Global Natural Products Social Molecular Networking (GNPS) example data were taken from the American Gut Project... To analyse both MFs and Mass2Motifs, Python code is provided in PALS to retrieve information on the metabolite sets as well as the peak intensity table from GNPS",
      "asbval:note": "Paper explicitly uses GNPS data for Molecular Families analysis with PALS.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "activity-score-robustness-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "GNPS - Source of Molecular Families metabolite groupings for non-pathway robustness testing",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
