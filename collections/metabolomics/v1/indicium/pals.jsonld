    {
      "@id": "asbval:assertion/skill/comparative-enrichment-method-evaluation/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To assess the robustness of mPLAGE, benchmarking experiments were performed... To mimic the inclusion of formulae that arise due to incorrect identification/annotation, decoy features were generated... To simulate missing features, which often occurs in real metabolomics data, features were also randomly removed from pathways with a uniform probability of 0.2.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "comparative-enrichment-method-evaluation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Systematically benchmark pathway/metabolite set enrichment methods (PALS, ORA, GSEA) by introducing controlled levels of noise and missing peaks into metabolomics peak data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:36:40.502260+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/comparative-enrichment-method-evaluation/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "F1 score, which is a harmonic mean of precision and recall... precision (Prec=TP/(TP+FP)) measures pathway ranking relevancy... recall (Rec=TP/(TP+FN))... Assessing changes to the p-values of the true changing pathways",
      "asbval:note": "Robustness measured via F1 score, precision, recall, and p-value stability\u2014not rank correlation or effect size preservation.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "comparative-enrichment-method-evaluation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "measuring robustness using rank correlation and effect size preservation",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:36:40.502260+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/custom-metabolite-set-integration/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The modularity of PALS also means it is not limited to pathways, and any user-defined grouping of features (representing metabolite sets) can be readily analysed.",
      "asbval:note": "Paper explicitly states PALS supports user-defined metabolite set groupings beyond pathways.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "custom-metabolite-set-integration",
