      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/peak-removal-robustness-testing/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "[SUBSTRING-MATCH for PLAGE | role: Decomposition algorithm] The main algorithm in PALS is based on the pathway level analysis of gene expression (PLAGE) factorisation method and is denoted as mPLAGE (PLAGE for metabolomics).",
      "asbval:note": "PLAGE is the foundational decomposition method adapted for metabolomics as mPLAGE within PALS.",
