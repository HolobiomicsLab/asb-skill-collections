      }
    },
    {
      "@id": "asbval:assertion/skill/peak-removal-robustness-testing/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The nature of metabolomics data can make enrichment analysis for metabolite groups more challenging than for groups of genes. In particular, an untargeted metabolomics experiment contains a large diversity of chemical structures with the identity of many of the features unknown in mass spectral databases... Other more general omics issues, such as missing data, also influence metabolite pathway reconstruction from metabolomics data.",
      "asbval:note": "The paper identifies missing data and uncertain peak identification as key challenges in metabolomics that the robustness testing addresses.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "peak-removal-robustness-testing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill to datasets where peak identification is uncertain or peak dropout due to instrument noise, dynamic range limits, or post-processing filtering is expected to occur.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:41.130565+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/principal-component-extraction-from-pathway-subsets/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The AL score in a sample j is given by vj, where v is the first row in V, which is a vector of coefficients representing the activity levels of the first metacompound in U (having the largest singular value) across samples.",
      "asbval:note": "Verbatim description of SVD-based activity level scoring in mPLAGE method.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "principal-component-extraction-from-pathway-subsets",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Extract the first principal component (singular vector) from each metabolite pathway subset using singular value decomposition (SVD) to produce a single quantitative activity score per pathway.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
