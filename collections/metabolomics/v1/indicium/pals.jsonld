    {
      "@id": "asbval:assertion/card/10_1186_1471_2105_6_225__task_003/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To anaylse Mass2Motifs, a data set from the GNPS-MS2LDA workflow, consisting of 70 Rhamnacea species from two clades and various genera, was used.",
      "asbval:note": "MS2LDA is explicitly used to generate Mass2Motifs data analysed in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
