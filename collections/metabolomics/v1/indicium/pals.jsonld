    {
      "@id": "asbval:assertion/skill/singular-value-decomposition-metabolomics/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For the MF analysis, Global Natural Products Social Molecular Networking (GNPS) example data were taken from the American Gut Project... Python code is provided in PALS to retrieve information on the metabolite sets as well as the peak intensity table from GNPS",
      "asbval:note": "GNPS as source of molecular families confirmed.",
