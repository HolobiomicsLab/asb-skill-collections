      }
    },
    {
      "@id": "asbval:assertion/skill/principal-component-extraction-from-pathway-subsets/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The nature of metabolomics data can make enrichment analysis for metabolite groups more challenging than for groups of genes... As demonstrated in our previous work [5] where the PLAGE method was successfully applied to the enrichment analysis of Mass2Motifs, decomposing activity levels via SVD appeared to work well on metabolomics data where noise and missing data are prevalent.",
      "asbval:note": "Paper explicitly discusses why SVD-based approach is suited to metabolomics challenges.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "principal-component-extraction-from-pathway-subsets",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "making it well-suited for metabolomics data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:42:02.159055+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/principal-component-extraction-from-pathway-subsets/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "As an option for data normalisation, the intensity matrix is subsequently transformed to log space and standardised using the preprocessing module in Scipy [27] such that each factor has a zero mean and unit variance across the samples.",
