    {
      "@id": "asbval:assertion/card/10_1186_1471_2105_6_225__task_005/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Pathway ranking results are output as a CSV file listing pathways, or metabolite sets, and their p-values.",
      "asbval:note": "The paper confirms PALS outputs results as CSV with metabolite set names and statistics (p-values). Activity level scores are computed internally via mPLAGE decomposition (passage 9).",
