    {
      "@id": "asbval:assertion/skill/spectral-fragmentation-motif-analysis/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PALS is designed to look at how metabolic pathways or other groups of metabolites change between different experimental conditions... any user-defined grouping of features (representing metabolite sets) can be readily analysed.",
      "asbval:note": "Paper confirms PALS can use pathways as alternative when spectral groupings unavailable.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-fragmentation-motif-analysis",
