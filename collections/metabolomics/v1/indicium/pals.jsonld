    {
      "@id": "asbval:assertion/skill/molecular-family-grouping-analysis/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The nature of metabolomics data can make enrichment analysis for metabolite groups more challenging than for groups of genes. In particular, an untargeted metabolomics experiment contains a large diversity of chemical structures with the identity of many of the features unknown in mass spectral databases.",
      "asbval:note": "Passage 3 establishes the motivation: untargeted metabolomics with unknown identities; spectral groupings bypass annotation uncertainty.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-family-grouping-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have untargeted metabolomics peak intensity data and spectral groupings (Molecular Families or Mass2Motifs) but lack confident chemical annotations or want to avoid pathway database dependency.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:39:14.946510+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/molecular-family-grouping-analysis/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "An alternative way of producing metabolite sets is to to group features using spectral similarities, which can be incredibly useful for helping to identify unknown features. By exploiting the fragmentation spectra from tandem mass spectrometry, molecular networking [2] uses such spectral similarities to group metabolites into molecular families (MF).",
      "asbval:note": "Passage 3 confirms spectral grouping utility for unknown features and fragment-based clustering.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-family-grouping-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Spectral groupings are particularly useful when peaks cannot be reliably assigned to known metabolites, as they group by fragment pattern similarity rather than chemical identity.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:39:14.946510+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/non-pathway-metabolite-classification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The modularity of PALS also means it is not limited to pathways, and any user-defined grouping of features (representing metabolite sets) can be readily analysed. This is demonstrated by assessing the activity levels of metabolite sets grouped by similarity of fragmentation spectra.",
      "asbval:note": "Directly supported; paper explicitly demonstrates mPLAGE applied to Molecular Families and Mass2Motifs beyond pathways.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "non-pathway-metabolite-classification",
