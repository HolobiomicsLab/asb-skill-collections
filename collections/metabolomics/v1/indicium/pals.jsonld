    {
      "@id": "asbval:assertion/skill/missing-data-simulation-in-omics/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "PALS is freely available at https://pals.glasgowcompbio.org/ (accessed on 5 February 2021)... PALS is freely available from our project Web site.",
      "asbval:note": "Paper provides URL for PALS (https://pals.glasgowcompbio.org/), but does not provide GitHub repository URLs for ORA or GSEA as separate tools\u2014these are integrated into PALS. Card lists GitHub repos for all tools, but ORA and GSEA are not standalone tools with separate repos in this context; they are methods implemented within PALS.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
