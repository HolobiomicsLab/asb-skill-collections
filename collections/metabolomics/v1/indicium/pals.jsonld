    {
      "@id": "asbval:assertion/skill/peak-removal-robustness-testing/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The robustness of mPLAGE was evaluated on both synthetic and real data experiments and compared to both ORA and GSEA methods. The results demonstrated that the mPLAGE method is robust to noise and missing values, which is particularly important for metabolomics data.",
      "asbval:note": "The paper explicitly validates mPLAGE robustness against data degradation (noise and missing features) and compares it to ORA and GSEA.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "peak-removal-robustness-testing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When validating a metabolomics pathway analysis method (particularly decomposition-based approaches like PLAGE) against data quality degradation, or when comparing robustness across methods (PLAGE vs. ORA vs. GSEA).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
