      }
    },
    {
      "@id": "asbval:assertion/skill/comparative-enrichment-method-evaluation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The performance of mPLAGE was compared to widely used overrepresentation (ORA) analysis and gene set enrichment analysis (GSEA) methods... ORA approaches rely on testing for the presence or absence of significantly changing genes in a pathway, using statistical significance tests.",
