    {
      "@id": "asbval:assertion/card/10_1186_1471_2105_6_225__task_002/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Pathway ranking results are output as a CSV file listing pathways, or metabolite sets, and their p-values. From PALS, users obtain the ranking of changing pathways, or user-defined sets of metabolites, between experimental factors.",
      "asbval:note": "The paper explicitly describes output as ranked pathways with p-values (which reflect statistical significance of activity scores). The mPLAGE method produces activity level scores that are converted to t-statistics and p-values for ranking.",
      "asbval:perspicacite_kb": "asb-paper-10-3390-metabo11020103",
