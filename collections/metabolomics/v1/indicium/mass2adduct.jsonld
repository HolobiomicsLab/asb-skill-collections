      }
    },
    {
      "@id": "asbval:assertion/skill/spatial-correlation-filtering-in-msi/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A positive correlation value alone does not guarantee that two ions are chemically related. However, in combination with our prior knowledge on sample and matrix composition, it provides additional confidence to screen for potential adducts.",
      "asbval:note": "The rationale for spatial correlation as evidence of biochemical relationship is supported, though the paper notes that correlation alone is not definitive.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-0c04720",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-correlation-filtering-in-msi",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "The spatial correlation test is essential when working with MSI data where pixel intensity maps are available, because abundance co-localization is strong evidence that two ions are biochemically related rather than random peak pairs.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
