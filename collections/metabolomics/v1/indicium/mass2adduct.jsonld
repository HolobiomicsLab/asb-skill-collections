    {
      "@id": "asbval:assertion/skill/spatial-correlation-analysis-in-imaging-mass-spectrometry/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Adducts are expected to co-occur in the same spot as their parent metabolite for any given tissue sample. Consequently, calculating individual correlation values between the intensities of a peak and its putative adduct peak across all pixels of a MALDI-MSI dataset provides statistical support for MS1-based adduct identifications",
      "asbval:note": "Semantic equivalence: spatial correlation validates co-localization and co-variance.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-0c04720",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spatial-correlation-analysis-in-imaging-mass-spectrometry",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "spatial correlation in imaging data provides orthogonal validation that two peaks co-localize and co-vary in abundance",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:24:38.462677+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
