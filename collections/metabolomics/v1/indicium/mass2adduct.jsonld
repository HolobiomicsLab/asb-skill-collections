      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-annotation-and-overlay-visualization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MSI ion maps were produced with MSiReader v0.09 using an m/z tolerance window of \u00b12.5 ppm and displayed with a modified Jet heatmap without interpolation.",
      "asbval:note": "Paper uses MSiReader v0.09 for ion map visualization, not pointsAdducts() overlay scatter plots. The paper visualizes spatial distributions but does not describe overlaid scatter plots with contrasting colors/symbols for parent-adduct pairs as claimed. Visualization is heatmap-based, not scatter-plot-based.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-0c04720",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectral-annotation-and-overlay-visualization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Annotate mass spectra with identified parent ions and adduct ions, then visualize them as overlaid scatter plots using contrasting colors and symbols to reveal spatial and spectral relationships.",
