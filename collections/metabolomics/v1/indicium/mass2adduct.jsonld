    {
      "@id": "asbval:assertion/skill/mass-spectrum-histogram-interpretation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The mass difference was calculated for all pairs of peaks, and matched against a list of known adduct types within an uncertainty of... For each dataset, possible parent\u2013adduct ion pairs were identified in the following way: The mass difference was calculated for all pairs of peaks, and matched against a list of known adduct types.",
      "asbval:note": "Scope aligns with paper's methodology: all pairwise differences computed, then matched to known adducts.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-0c04720",
