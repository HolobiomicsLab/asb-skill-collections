    {
      "@id": "asbval:assertion/skill/multiple-testing-correction-bonferroni/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We applied three different methods to screen for false positives: (1) The Bonferroni correction was applied to the p-values from the correlation test, and pairs with corrected p \u2265 0.05 were rejected",
      "asbval:note": "Bonferroni correction is explicitly applied to p-values from Pearson correlation tests across ion pairs in MSI data, matching the research question.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-0c04720",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "multiple-testing-correction-bonferroni",
