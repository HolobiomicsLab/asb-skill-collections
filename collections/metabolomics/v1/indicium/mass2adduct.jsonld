      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After annotating ion pairs with known adducts (using adductMatch or diffGetPeaks), use this skill to filter suspected adduct pairs by testing if their pixel-level intensity profiles are significantly correlated.",
      "eco:evidence_type": {
