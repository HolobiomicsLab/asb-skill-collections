    {
      "@id": "asbval:assertion/skill/multiple-testing-correction-bonferroni/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The intensity matrix was loaded into R, where correlations of adduct pairs were calculated.",
      "asbval:note": "R is explicitly used for correlation calculations and statistical analysis in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-0c04720",
