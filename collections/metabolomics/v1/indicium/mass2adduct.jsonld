    {
      "@id": "asbval:assertion/claim/claim_004",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "In mass2adduct documentation, the term 'mass peak' is used to refer to both the ions themselves and to their nominal m/z values.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-0c04720",
      "asbval:source_excerpt": "o (m/z) that have been detected by the instrument. In this documentation, we use the term *mass peak* (in short: mass or peak) to refer to both the ions themselves and to their nominal m/z values.[^1]\n\nTwo ions may differ chemically from each other by a certain chemical moiety, e",
      "asbval:substring_in_paper": false,
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "claim_004",
      "asbval:target_artifact_kind": "ledger_claim",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:17:28.429654+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/claim/claim_005",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "A chemical transformation refers agnostically to the chemical difference between two ions.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-0c04720",
