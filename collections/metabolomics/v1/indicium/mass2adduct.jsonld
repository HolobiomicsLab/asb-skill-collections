    {
      "@id": "asbval:assertion/card/10_1021_acs_analchem_0c04720__task_002/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For each dataset, Pearson's two-sided correlation test was performed for all ion pairs using per-pixel intensity values. We applied three different methods to screen for false positives: (1) The Bonferroni correction was applied to the p-values from the correlation test, and pairs with corrected p \u2265 0.05 were rejected (2) Uncorrected p-values for positively correlated pairs were used for false-discovery-rate analysis with the R package qvalue v2.10.1, and we applied a q-value cutoff of 10\u20137 (3) A minimum correlation coefficient cutoff of r > 0.3 was applied directly",
      "asbval:note": "The paper describes Pearson correlation testing with Bonferroni and FDR corrections, but does not name a specific function 'corrPairsMSI()'. The paper states correlations were calculated in R but does not provide the exact function name. The card references a specific function name that is not explicitly mentioned in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-0c04720",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_002",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "How does the corrPairsMSI() function compute pairwise correlations between ion pairs in mass spectrometry imaging data with statistical correction?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:18:16.262072+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
