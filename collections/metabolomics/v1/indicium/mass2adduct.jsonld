    {
      "@id": "asbval:assertion/skill/adduct-ion-parent-ion-pairing-analysis/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Software to perform the adduct identification and correlation testing are implemented in an R package, mass2adduct.",
      "asbval:note": null,
