    {
      "@id": "asbval:assertion/skill/spatial-correlation-filtering-in-msi/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our approach is based on two major steps, calculating \u0394mass values between all peaks of a dataset and testing for spatial correlation only between parent and putative adduct ions",
      "asbval:note": "The workflow of mass-difference calculation followed by spatial correlation filtering is confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-0c04720",
      "asbval:supported_raw": "yes",
