      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-library-molecular-networking/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Currently, 1D EI GC-MS data are amenable... GNPS has now expanded to include GC-MS-specific molecular networking",
