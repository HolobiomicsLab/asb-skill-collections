    {
      "@id": "asbval:assertion/card/10_1038_s41587_020_0700_3__task_002/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Once the .mgf file is generated by GNPS-MSHub or imported from another deconvolution tool, the spectra can be searched against public, private or commercial libraries.",
      "asbval:note": "Paper confirms MGF format output from MSHub for downstream analysis including molecular networking. However, mzML format is not explicitly mentioned in the passages; only .mgf format is documented as the output format for MSHub.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-020-0700-3",
