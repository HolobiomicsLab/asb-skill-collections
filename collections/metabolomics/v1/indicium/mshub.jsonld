    },
    {
      "@id": "asbval:assertion/skill/spectral-library-molecular-networking/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the molecular networks are created through spectral similarity of the deconvoluted fragmentation spectrum without considering the molecular ion... EI-based cosine similarity networks are predominantly driven by structural similarity based on chemical class annotations",
      "asbval:note": "Paper explicitly uses cosine similarity for GC-MS molecular network construction.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-020-0700-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-library-molecular-networking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "clustering them via cosine similarity",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:03:03.988654+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-library-molecular-networking/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We engineered a machine learning approach, MSHub, to enable auto-deconvolution of gas chromatography-mass spectrometry (GC-MS) data... MSHub/GNPS performs auto-deconvolution of compound fragmentation patterns via unsupervised non-negative matrix factorization",
      "asbval:note": "MSHub is explicitly described as the auto-deconvolution tool for GC-MS data.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-020-0700-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-library-molecular-networking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "MSHub - Performs automated deconvolution of overlapping chromatographic peaks to extract individual compound spectra from GC-MS raw data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:03:03.988654+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-library-molecular-networking/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We then designed workflows to enable the community to store, process, share, annotate, compare and perform molecular networking of GC-MS data within the Global Natural Product Social (GNPS) Molecular Networking analysis platform.",
      "asbval:note": "GNPS is explicitly described as hosting GC-MS molecular networking workflows.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-020-0700-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-library-molecular-networking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "GNPS - Hosts the molecular networking workflow that clusters deconvolved spectra by cosine similarity and constructs the network graph",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:03:03.988654+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-library-molecular-networking/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Once the .mgf file is generated by GNPS-MSHub or imported from another deconvolution tool, the spectral features can be searched against public libraries",
      "asbval:note": "Paper confirms MGF format is used for deconvolved spectra in GNPS workflows.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-020-0700-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-library-molecular-networking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input spectra are deconvolved GC-MS spectra in MGF or mzTab format",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:03:03.988654+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-library-molecular-networking/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "However, to spot mis-assignments at the molecular family level, we propose to explore deconvoluted GC-MS data via molecular networking... These EI networks can be used to visualize chemical distributions and guide annotations.",
      "asbval:note": "Paper describes molecular networking for untargeted exploration and family-level annotation without prior identity.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-020-0700-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-library-molecular-networking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use this when exploring untargeted metabolomics data where compound identity is unknown but structural relationships matter.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:03:03.988654+00:00",
      "sepio:credibility_status": {
