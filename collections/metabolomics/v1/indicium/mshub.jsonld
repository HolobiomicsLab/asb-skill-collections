    {
      "@id": "asbval:assertion/skill/spectral-batch-submission-to-networking-server/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "GNPS-based GC-MS analysis enables data co- and re-analysis, as the processing is agnostic to the data origin. To showcase this ability, we built a global network of various public GC-MS datasets and applied a balance score of 65% to ensure that only good quality deconvoluted spectra are matched against the reference library. Molecular networking can further guide the annotation at the family level by utilizing information from connected nodes.",
      "asbval:note": "Paper describes batch processing of deconvolved spectra through GNPS for molecular networking. However, the tool is called 'GNPS' or 'GNPS/MassIVE', not 'GNPS_GC'. The paper does not explicitly mention GraphML/JSON output formats or command-line interface details for job submission/monitoring.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-020-0700-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectral-batch-submission-to-networking-server",
