    {
      "@id": "asbval:assertion/skill/molecular-network-graph-parsing/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Once the summary file is generated by GNPS-MSHub or imported from another deconvolution tool, the spectra can be searched against public, private or commercial libraries. The output from GNPS can be exported for use in statistical analysis environments and for data visualization (e.g., Supplementary Figs. 7\u201310), including molecular cartography.",
      "asbval:note": "Paper describes GNPS output export and visualization but does not explicitly document the task of parsing and validating network output files as a distinct workflow step. The paper focuses on GNPS job execution and result interpretation, not on programmatic parsing of network graph files.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-020-0700-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "molecular-network-graph-parsing",
