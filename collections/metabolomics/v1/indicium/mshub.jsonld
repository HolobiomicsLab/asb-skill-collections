    {
      "@id": "asbval:assertion/skill/raw-chromatography-data-parsing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We engineered a machine learning approach, MSHub, to enable auto-deconvolution of gas chromatography-mass spectrometry (GC-MS) data. We then designed workflows to enable the community to store, process, share, annotate, compare and perform molecular networking of GC-MS data within the Global Natural Product Social (GNPS) Molecular Networking analysis platform.",
      "asbval:note": "Paper describes MSHub/GNPS as performing auto-deconvolution and molecular networking of GC-MS data, but does not explicitly discuss raw data parsing from vendor formats or netCDF/mzML conversion as a distinct task. The paper states 'Currently, 1D EI GC-MS data are amenable' and mentions alternative tools (MZmine, OpenChrom, AMDIS, etc.) for deconvolution, but does not detail raw format parsing as a primary function of MSHub itself. The card frames this as a separate parsing skill; the paper treats it as part of the integrated workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41587-020-0700-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "raw-chromatography-data-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Load and parse raw gas chromatography\u2013mass spectrometry (GC-MS) data from vendor or open formats (netCDF, mzML) to prepare input for downstream peak deconvolution and molecular networking.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
