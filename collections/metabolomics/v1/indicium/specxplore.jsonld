    {
      "@id": "asbval:assertion/skill/spectral-similarity-distance-metric-selection/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The central overview of specXplore is based on a t-SNE embedding of the ms2deepscore pairwise similarity matrix serving as the primary similarity score... Spectral data can then be used to initialize a template specXplore object that automatically computes pairwise spectral similarities using three similarity scores: ms2deepscore, modified cosine scores, and spec2vec scores.",
      "asbval:note": "The paper explicitly describes selecting similarity metrics (ms2deepscore, modified cosine, spec2vec) as foundational to t-SNE embedding and interactive visualization.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04444",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-similarity-distance-metric-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Select and apply an appropriate distance metric for computing pairwise mass spectral similarities, which serves as the foundation for downstream dimensionality reduction and interactive visualization in LC-MS/MS data exploration.",
