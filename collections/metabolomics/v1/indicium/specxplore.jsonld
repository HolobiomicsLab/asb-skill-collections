      "asbval:evidence_quote": "SpecXplore makes use of state-of-the-art ms2deepscore pairwise spectral similarities as a quantitative backbone... Rather than being based on modified cosine scores, specXplore is based on ms2deepscore pairwise similarities, which can more accurately represent the structural similarities between compounds based on their spectra via a deep-learning-based embedding representation.",
      "asbval:note": "ms2deepscore confirmed as neural-network-based similarity metric. t-SNE embedding is computed from ms2deepscore similarity matrix.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04444",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "jupyter-notebook-workflow-automation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "ms2deepscore - Computes neural-network-based similarity scores between mass spectra and generates t-SNE embeddings",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
