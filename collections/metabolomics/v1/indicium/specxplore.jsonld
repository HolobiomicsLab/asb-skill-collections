    {
      "@id": "asbval:assertion/card/task_003/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "SpecXplore makes use of state-of-the-art ms2deepscore pairwise spectral similarities as a quantitative backbone",
      "asbval:note": "Confirmed multiple times. ms2deepscore is the primary similarity metric used for the t-SNE embedding.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-3c04444",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_003",
