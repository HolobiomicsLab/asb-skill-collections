      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "scikit-learn t-SNE: implements the t-SNE dimensionality reduction algorithm applied to ms2deepscore distance matrix",
