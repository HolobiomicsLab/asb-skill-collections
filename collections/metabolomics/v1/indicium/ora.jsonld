      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Verify that a background-set or experimental metabolite collection is correctly constructed by validating its composition against the metabolomics pathway database, ensuring absence of contamination, appropriate pathway coverage, and statistical soundness for Over-representation ",
