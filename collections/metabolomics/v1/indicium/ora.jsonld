    {
      "@id": "asbval:assertion/skill/metabolite-coverage-simulation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we investigated how the size of the background set affects ORA results. In Fig 2C, we simulated a reduction in the number of compounds identified in the experiment and identify differentially abundant (DA) metabolites based on the compounds in the reduced background set.",
      "asbval:note": "Paper simulates effects of background set size reduction (proxy for coverage), but focuses on background set size effects rather than explicitly modeling 'fractions of detected metabolites' or 'p-value distributions'. The paper does examine false-positive pathways (pathway gain rate) but not explicitly 'false-positive rates' as a statistical metric. The functional intent (coverage-dependent ORA behavior) is present but the specific framing (p-value distributions, false-positive rates as primary metrics) is not explicitly stated.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009105",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "metabolite-coverage-simulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Simulate Over-representation Analysis (ORA) outcomes across varying fractions of detected metabolites to quantify how metabolite detection coverage affects p-value distributions and false-positive rates in pathway analysis.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
