    {
      "@id": "asbval:assertion/skill/ora-statistical-background-definition/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To perform ORA, three essential inputs are required: a collection of pathways (or custom metabolite sets), a list of metabolites of interest, and a background or reference set of compounds... The background set contains all molecules which can be detected in the experiment... P-values for each pathway are calculated using a right-tailed Fisher's exact test based on the hypergeometric distribution... where N is the size of background set... One of the most salient findings was the difference in the number of SEPs detected when using an assay-specific versus a nonspecific background set. The use of a nonspecific background set... resulted in a drastic increase in the number of SEPs.",
      "asbval:note": "The research question is directly supported by the paper's focus on background set definition and its critical impact on ORA results.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009105",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ora-statistical-background-definition",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Define and construct the statistical background set for Over-representation Analysis (ORA) in metabolomics by identifying which metabolites from a pathway database serve as the denominator for significance testing. Correct background definition is critical because misspecificatio",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T09:45:37.969742+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/ora-statistical-background-definition/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The background set contains all molecules which can be detected in the experiment. For example, in transcriptomic studies, this consists of all genes or transcripts which can be quantified. In targeted metabolomics, the background set would contain all compounds assayed; in untargeted metabolomics, all annotatable metabolites (i.e., all the features in a dataset that can be annotated to a compound name or ID)... We investigated the effect of using a nonspecific background set, consisting of all unique compounds present in the KEGG organism-specific pathway set, compared to an assay-specific background set, consisting only of compounds identified and present in the abundance matrix of each dataset.",
      "asbval:note": "The scope directly aligns with the paper's investigation of background set construction choices and their impact on ORA results.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009105",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ora-statistical-background-definition",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You are implementing ORA for metabolomics pathway analysis and must decide which metabolites constitute the statistical background against which to test your experimental detection list. This skill applies when you have (1) a full metabolomics pathway database with known metaboli",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T09:45:37.969742+00:00",
