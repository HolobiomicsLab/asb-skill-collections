      "@id": "asbval:assertion/card/10_1371_journal_pcbi_1009105__task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "All simulations were performed using Python (v 3.8). Simulations with an element of randomisation were repeated 100 times, and results are reported as the mean of 100 random samplings of the simulation, alongside the standard error of the mean.",
      "asbval:note": "Paper confirms simulations were performed using Python v3.8, but no mention of a 'reproducible_simulations.ipynb' notebook or Jupyter notebook is found in any passage. The paper describes the simulation methodology in Methods section but does not reference a specific notebook file for reproduction.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009105",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
