    {
      "@id": "asbval:assertion/skill/pathway-database-filtering-by-detection/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A clear discrepancy was observed in many of the pathway p-values when using the nonspecific vs. specific background set (Fig 2A). A greater proportion of pathways had lower p-values when using the nonspecific background set than the specific counterpart.",
      "asbval:note": "The paper demonstrates that including undetected metabolites (nonspecific background) inflates p-value significance, confirming the distortion of p-value calibration.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009105",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pathway-database-filtering-by-detection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "undetected metabolites in the reference database inflate null distributions and distort p-value calibration",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T09:46:21.889480+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/pathway-database-filtering-by-detection/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "metabolomics datasets tend to cover a much lower proportion of the total metabolome than transcriptomic datasets do of the genome. Hence, metabolomics datasets tend to contain far fewer metabolites than transcripts found in transcriptomic datasets.",
      "asbval:note": "The paper confirms that metabolomics experiments typically have incomplete coverage of reference databases, supporting the applicability scope.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009105",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pathway-database-filtering-by-detection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have run a metabolomics experiment with incomplete coverage of a reference pathway database (e.g., 10\u2013100% of database metabolites detected)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T09:46:21.889480+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/pathway-database-filtering-by-detection/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The analytical platform and specific assay used for a metabolomics study can be expected to introduce bias into the pathways which might be detected by ORA. Assays typically differ in their ability to detect compounds with different physico-chemical properties (e.g., polarity)... It is evident that each of the four assay types covers a different area and proportion of the metabolic network.",
      "asbval:note": "The paper explicitly discusses how different analytical platforms and assay types introduce systematic bias in metabolite detection, supporting the claim about sensitivity limits.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009105",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pathway-database-filtering-by-detection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "The skill is essential if your detection method has known sensitivity limits (e.g., mass spectrometry ionization bias, LC retention time windows) that cause systematic metabolite dropout",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T09:46:21.889480+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
