      "asbval:target_artifact_id": "over-representation-analysis-pvalue-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Your metabolomics dataset has near-complete or genome-wide coverage (>95%) of the pathway database, in which case coverage bias is negligible and ORA p-values are more trustworthy.",
