        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/extracted-ion-chromatogram-processing/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "However, analyzing Orbitrap data in R has so far only been possible after raw data conversion to exchange formats like mz(X)ML. Unfortunately, conversion is accompanied by a loss of Orbitrap-specific information. This use case shows how easy it is to work directly with raw-formated Orbitrap data after installing our R package rawrr which applies vendor APIs for data access.",
      "asbval:note": "Paper explicitly contrasts direct raw file access with conversion to mzML/mzXML, supporting the 'when NOT to use' guidance.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "extracted-ion-chromatogram-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Input is already processed feature tables (mzML, mzXML, CSV peak lists) \u2014 use mass spectrometry format conversion tools instead.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:37:16.605167+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/extracted-ion-chromatogram-processing/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Individual scans or scan collections (sets) can be read by the function read Spectrum() which returns a rawrr Spectrum object or rawrr Spectrum Set... By using the read Index() function a data.frame that indexes all scans found in a raw file is returned.",
      "asbval:note": "readSpectrum() and readIndex() are confirmed as alternative functions for untargeted spectrum access.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "extracted-ion-chromatogram-processing",
