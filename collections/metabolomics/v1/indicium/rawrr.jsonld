      }
    },
    {
      "@id": "asbval:assertion/skill/retention-time-extraction-from-raw-spectra/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "rawrr utilizes a vendor-provided API named Raw File Reader to access spectral data logged in proprietary Thermo Fisher Scientific raw files... Specifically, R functions requesting access to data stored in binary raw files (reader family functions listed in Table 1) invoke compiled C# wrapper methods using a system call. Calling a wrapper method typically results in the execution of methods defined in the Raw File Reader dynamic link library provided by Thermo Fisher Scientific.",
      "asbval:note": "Paper confirms RawFileReader (case-insensitive match) is the underlying .NET/C# API invoked by rawrr via system calls.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "retention-time-extraction-from-raw-spectra",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "RawFileReader: .NET assembly (C#) wrapping proprietary Thermo Scientific APIs; underlying dependency invoked by rawrr via system calls to extract chromatographic and spectral data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:41:44.336298+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/retention-time-extraction-from-raw-spectra/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "MsBackendRawFileReader is not mentioned anywhere in the provided passages. The paper mentions plans to submit rawrr to Bioconductor and align with 'R for Mass Spectrometry initiative' but does not name or describe MsBackendRawFileReader specifically.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "no",
