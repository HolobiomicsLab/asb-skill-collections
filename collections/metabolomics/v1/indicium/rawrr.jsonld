      "@id": "asbval:assertion/skill/raw-file-data-extraction-via-api/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We strongly believe that a library providing raw data reading would finally close the gap and facilitate modular end-to-end analysis pipeline development in R... This could be of special interest to research environments/projects dealing with either big data analytics or scientists interested in code prototyping without formal computer science education.",
      "asbval:note": "Motivation and use case fully align with claim.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "raw-file-data-extraction-via-api",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill enables modular, reproducible access to raw mass spectrometry data for quality control, method optimization, and end-to-end proteomics pipelines in R without relying on GUI software.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
