    {
      "@id": "asbval:assertion/skill/irt-peptide-calibration-and-scoring/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For regression, we now extract the RTs at the maximum of the intensity traces stored in the rawrr Chromatogram object and fit a linear model of the form rt = a + b \u00b7 score... The fitted model can then be inspected using standard procedures... The corresponding R-squared indicates that the RTs behave highly linear.",
      "asbval:note": "Paper demonstrates linear regression fitting and R-squared computation but does not explicitly name 'stats::lm' or R base functions. The paper states 'fit a linear model' and discusses R-squared but uses generic language ('standard procedures'). The implementation uses base R functions but the specific function name is not verbatim in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "irt-peptide-calibration-and-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "R base (stats::lm): Fits linear regression model to RT observations and iRT scores; computes R-squared and residuals",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:38:05.437384+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/irt-peptide-calibration-and-scoring/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This example shows how easy it is to perform iRT regression in R by just using the raw measurement data, our package rawrr, and well-known base R functions supporting linear modeling... The initial step of iRT regression is to estimate the empirical RTs of a peptide set with known iRT scores. In the simplest case, this is achieved by computing an extracted ion chromatogram (XIC) for iRT peptide precursors, provided they were spiked into the sample matrix prior to data acquisition... The analyzed sample consisted of the iRT peptide mix (Biognosys) in a tryptic BSA digest (NEB)",
      "asbval:note": "Paper confirms iRT regression workflow and mentions Biognosys iRT peptides specifically, but does not mention Pierce iRT peptides. The scope claim includes 'e.g., Pierce or Biognosys' but only Biognosys is evidenced in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "irt-peptide-calibration-and-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When you need to assess whether retention times measured on a given LC-MS run follow the expected linear relationship defined by iRT peptide standards (e.g., Pierce or Biognosys iRT peptides).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:38:05.437384+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/irt-peptide-calibration-and-scoring/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not specify a minimum number of iRT peptides (11+) required for regression. The example uses iRT peptides but does not quantify the minimum count needed.",
