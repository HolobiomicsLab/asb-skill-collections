      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "RawFileReader: Thermo Fisher Scientific .NET assembly (C#) wrapped by rawrr; contains core mass spectrometry data reading logic",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
