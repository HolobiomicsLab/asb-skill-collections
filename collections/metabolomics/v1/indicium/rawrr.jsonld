    {
      "@id": "asbval:assertion/skill/mass-spectrometry-metadata-interpretation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Fundamentally important are libraries that provide raw data access... we decided to implement our R package named rawrr... These software tools usually offer GUIs that control running predefined analysis templates/workflows... Naturally, these offer greater analytical flexibility but require programming skills from the end-user... We strongly believe that a library providing raw data reading would finally close the gap and facilitate modular end-to-end analysis pipeline development in R.",
      "asbval:note": "Paper contrasts GUI-based tools (MaxQuant, Skyline) with programmatic library approach; emphasizes reproducibility and flexibility in R pipelines.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-metadata-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill enables direct programmatic access to proprietary binary raw file metadata without GUI-based software, supporting reproducible method optimization and quality control in bottom-up proteomics workflows.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:38:54.634539+00:00",
      "sepio:credibility_status": {
