      }
    },
    {
      "@id": "asbval:assertion/skill/two-layer-architecture-dispatch-testing/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "rawrr utilizes a vendor-provided API named Raw File Reader to access spectral data logged in proprietary Thermo Fisher Scienti fi c raw fi les... Calling a wrapper method typically results in the execution of methods de fi ned in the Raw File Reader dynamic link library provided by Thermo Fisher Scienti fi c.",
      "asbval:note": "Paper explicitly names 'Raw File Reader' as the vendor-provided API/assembly that rawrr wraps. Confirmed as Thermo Fisher Scientific .NET component.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "two-layer-architecture-dispatch-testing",
