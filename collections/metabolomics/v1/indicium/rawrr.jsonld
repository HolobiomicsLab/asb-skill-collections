    {
      "@id": "asbval:assertion/skill/r-package-installation-and-runtime-verification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our implementation consists of two language layers, the top R layer and the hidden C # layer. Specifically, R functions requesting access to data stored in binary raw files (reader family functions listed in Table 1) invoke compiled C # wrapper methods using a system call... Our precompiled wrapper methods are bundled in the rawrr executable file and shipped with the released R package. Running rawrr.exe requires the Mono environment on non-Microsoft operating systems.",
      "asbval:note": "The paper explicitly describes the need for external dependencies (.NET/Mono runtime) and compiled C# wrappers to be configured before R functions can execute.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "r-package-installation-and-runtime-verification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Install an R package and verify that all required external dependencies (compiled executables, .NET runtimes, system libraries) are correctly configured before attempting data access operations.",
