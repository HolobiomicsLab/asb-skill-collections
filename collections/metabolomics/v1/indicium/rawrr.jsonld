      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "rawrr \u2014 R package providing direct access to Orbitrap .raw file data; invokes readSpectrum() to extract scan data and instrument metadata via the RawFileReader C# wrapper",
