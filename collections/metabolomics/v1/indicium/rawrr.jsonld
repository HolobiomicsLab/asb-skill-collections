    {
      "@id": "asbval:assertion/skill/spectral-quality-assurance-proteomics/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our novel package rawrr now provides complete, OS-independent access to all spectral data logged in Thermo Fisher Scientific raw files... However, analyzing Orbitrap data in R has so far only been possible after raw data conversion to exchange formats like mz(X)ML.",
      "asbval:note": "Paper explicitly states rawrr is for Thermo Fisher Scientific raw files and contrasts with mz(X)ML exchange formats. Scope constraint is accurate.",
