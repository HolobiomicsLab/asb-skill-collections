    {
      "@id": "asbval:assertion/skill/extracted-ion-chromatogram-processing/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our R package rawDiag (J. Proteome Res. 2018, 17 (8), 2908\u20132914) has provided the proof-of-principle how access to mass spectrometry raw files can be realized by wrapping a vendor-provided advanced programming interface (API) for the purpose of metadata analysis and visualization.",
      "asbval:note": "rawDiag is mentioned as a predecessor package for 'metadata analysis and visualization' but the paper does not explicitly describe it as complementing rawrr for 'XIC quality assessment and instrument diagnostics' or state that it is used in the current work. The role description in the card is inferred rather than directly stated.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "extracted-ion-chromatogram-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "rawDiag \u2014 R package for visualization and diagnostic analysis of LC-MS method parameters; complements rawrr for XIC quality assessment and instrument diagnostics",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:37:16.605167+00:00",
      "sepio:credibility_status": {
