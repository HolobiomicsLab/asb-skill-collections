    {
      "@id": "asbval:assertion/skill/mass-spectrometry-metadata-interpretation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The plot shows typical Orbitrap peak attributes like resolution (R) and charge (z) above the most intense peaks... Diagnostic information related to AGC is shown in gray... the C-trap managed to collect the defined 100 000 charges within 2.8 ms, corresponding to only \u223c 5% of the maximum injection time of 55 ms.",
      "asbval:note": "Paper demonstrates extraction of resolving power (R), AGC target, and injection time from raw files.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-metadata-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have a Thermo Fisher .raw file and need to verify or document instrument configuration (resolving power, AGC target, injection time, scan filter strings) before downstream analysis",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
