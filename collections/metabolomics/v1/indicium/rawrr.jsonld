      }
    },
    {
      "@id": "asbval:assertion/skill/inter-scan-interval-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By using the read Index() function a data.frame that indexes all scans found in a raw fi le is returned. When subsetting it for our scan type of interest it becomes clear that the example data was recorded using parallel reaction monitoring (PRM) since the parent ion 487.2567 was isolated in regularly spaced intervals for fragment ion recording. The delta between consecutive scans is always 22 scans (one PRM cycle) and the depedency Type of the MS2 scans is NA (since it was triggered by an inclusion list).",
      "asbval:note": "The paper explicitly demonstrates extracting scan indices, filtering by precursor m/z and scan type, and validating inter-scan deltas for PRM data.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "inter-scan-interval-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validates that parallel reaction monitoring (PRM) acquisition maintains consistent scan spacing across all targeted cycles by extracting scan indices from a Thermo Fisher Scientific .raw file, filtering for a specific precursor m/z and scan type, and confirming that inter-scan de",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:37:52.813794+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/inter-scan-interval-validation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The delta between consecutive scans is always 22 scans (one PRM cycle)",
      "asbval:note": "The paper demonstrates that consistent delta values can be extracted and compared, which is the basis for detecting irregularities. The methodology supports this use case.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
