    {
      "@id": "asbval:assertion/skill/mass-spectrometry-precursor-identification/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Use Case II: iRT Regression for System Suitability Monitoring... This can be used for retention time calibration/prediction. In addition, fitted iRT regression models provide highly valuable information about LC-MS run performance.",
      "asbval:note": "Paper demonstrates iRT regression for system suitability monitoring and method validation.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-precursor-identification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "validation of LC-MS method linearity and peptide behavior",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
