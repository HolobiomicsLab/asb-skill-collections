    {
      "@id": "asbval:assertion/skill/spectral-quality-assurance-proteomics/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The plot shows typical Orbitrap peak attributes like resolution (R) and charge (z) above the most intense peaks when centroided data is available and selected... Centroided data also makes it possible to graph spectra using signal-to-noise as response value... By adding some diagnostic information related to the Orbitrap's advanced gain control (AGC) system, it becomes apparent that the C-trap managed to collect the defined 100 000 charges within 2.8 ms, corresponding to only \u223c 5% of the maximum injection time of 55 ms.",
      "asbval:note": "All three core claims (resolving power, AGC injection time, S/N ratios) are explicitly demonstrated in Use Case I with scan 9594.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-quality-assurance-proteomics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validates Orbitrap mass spectrometry spectral data by confirming instrument metadata (resolving power, AGC injection time) and quantifying signal-to-noise ratios for fragment ions relative to baseline noise.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:42:14.420160+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-quality-assurance-proteomics/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our novel package rawrr now provides complete, OS-independent access to all spectral data logged in Thermo Fisher Scientific raw files... Individual scans or scan collections (sets) can be read by the function read Spectrum() which returns a rawrr Spectrum object or rawrr Spectrum Set.",
      "asbval:note": "Function name in paper is 'readSpectrum()' (with camelCase); card uses 'readSpectrum()' correctly. Role and purpose match exactly.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
