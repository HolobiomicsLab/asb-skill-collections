    {
      "@id": "asbval:assertion/skill/two-layer-architecture-dispatch-testing/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our novel package rawrr now provides complete, OS-independent access to all spectral data logged in Thermo Fisher Scienti fi c raw fi les.",
      "asbval:note": "Paper confirms rawrr is an R package with system call dispatch to .NET. However, the paper does not name or document specific internal functions like '.rawrrAssembly' or '.getRawrrAssemblyVersion'. The card claims specific function names that are not mentioned in the provided passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "two-layer-architecture-dispatch-testing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "rawrr: R package providing internal dispatch functions (.rawrrAssembly, .getRawrrAssemblyVersion) and system call abstraction to .NET assembly",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:42:32.068693+00:00",
      "sepio:credibility_status": {
