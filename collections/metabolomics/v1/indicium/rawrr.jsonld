      }
    },
    {
      "@id": "asbval:assertion/skill/raw-file-data-extraction-via-api/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Table 1. List of rawrr Package Functions Connected to Reading Functionality: read File Header() Reads meta information from a raw file header list; read Index() Generates a scan index from a raw file data.frame; read Spectrum() Reads spectral data from a raw file rawrr Spectrum(Set); read Chromatogram() Reads chromatographic data from a raw file rawrr Chromatogram(Set)",
      "asbval:note": "Function names match (case-insensitive: readFileHeader vs read File Header, etc.). All four core functions confirmed.",
