      }
    },
    {
      "@id": "asbval:assertion/skill/extracted-ion-chromatogram-processing/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Use Case II: iRT Regression for System Suitability Monitoring... The initial step of iRT regression is to estimate the empirical RTs of a peptide set with known iRT scores. In the simplest case, this is achieved by computing an extracted ion chromatogram (XIC) for iRT peptide precursors... Each XIC was calculated using a tolerance of 10 ppm around the target mass and using only MS1-level scans.",
      "asbval:note": "Scope is directly aligned with Use Case II, which demonstrates XIC extraction at user-defined mass tolerance for retention time annotation.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "extracted-ion-chromatogram-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Extract and process chromatographic traces for specific m/z values from Thermo Fisher Scientific raw files, enabling targeted detection and retention time annotation of peptide precursors.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:37:16.605167+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/extracted-ion-chromatogram-processing/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The initial step of iRT regression is to estimate the empirical RTs of a peptide set with known iRT scores. In the simplest case, this is achieved by computing an extracted ion chromatogram (XIC) for iRT peptide precursors, provided they were spiked into the sample matrix prior to data acquisition.",
      "asbval:note": "iRT calibrants are explicitly used as the example use case in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "extracted-ion-chromatogram-processing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When to use: You have Thermo Fisher Orbitrap .raw files and need to locate and quantify specific peptide precursor ions (e.g., iRT calibrants, synthetic standards, or putative identifications).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:37:16.605167+00:00",
