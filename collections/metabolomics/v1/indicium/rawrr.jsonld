    {
      "@id": "asbval:assertion/skill/orbitrap-spectrum-extraction-from-raw-files/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This use case shows how easy it is to work directly with raw-formated Orbitrap data after installing our R package rawrr... Individual scans or scan collections (sets) can be read by the function readSpectrum() which returns a rawrr Spectrum object or rawrr Spectrum Set... The plot shows typical Orbitrap peak attributes like resolution (R) and charge (z) above the most intense peaks when centroided data is available",
      "asbval:note": "Paper demonstrates the exact use case described: extracting MS/MS spectra with metadata and centroided data for quality assessment in bottom-up proteomics.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "orbitrap-spectrum-extraction-from-raw-files",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Extract individual MS/MS spectra from Thermo Fisher Scientific Orbitrap .raw files with full instrument metadata and centroided m/z\u2013intensity arrays for reproducible access to raw spectral data and quality assessment of peptide fragmentation in bottom-up proteomics workflows.",
