    {
      "@id": "asbval:assertion/skill/irt-peptide-calibration-and-scoring/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By applying linear regression, one can convert observed peptide retention times (RTs) into dimensionless scores termed iRT values and vice versa. This can be used for retention time calibration/prediction. In addition, fitted iRT regression models provide highly valuable information about LC-MS run performance... For regression, we now extract the RTs at the maximum of the intensity traces stored in the rawrr Chromatogram object and fit a linear model of the form rt = a + b \u00b7 score... The corresponding R-squared indicates that the RTs behave highly linear.",
      "asbval:note": "Paper demonstrates iRT regression and R-squared reporting, but does not specify a target R-squared threshold of \u22650.99. The paper states 'The corresponding R-squared indicates that the RTs behave highly linear' but does not quantify the target value. The example shows R-squared was high but no specific threshold is mentioned.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "irt-peptide-calibration-and-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validates retention time (RT) linearity and instrument calibration by fitting a linear regression model to extracted ion chromatograms (XICs) of known iRT peptide standards, using their annotated iRT scores as the independent variable. The R-squared value (target \u22650.99) quantifie",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:38:05.437384+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
