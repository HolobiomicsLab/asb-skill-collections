    {
      "@id": "asbval:assertion/skill/orbitrap-spectrum-extraction-from-raw-files/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Libraries that support working with the spectral data in R also exist, for instance, the Bioconductor package MSnbase. However, they require conversion of raw data to exchange formats like mzML, which is primarily supported by the Proteowizard project and its software tool MSconvert.",
      "asbval:note": "Paper mentions ProteoWizard and MSconvert for conversion to mzML as an alternative workflow, but does not explicitly recommend it as a fallback for rawrr unavailability or platform support. The paper frames rawrr as eliminating the need for such conversion.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "orbitrap-spectrum-extraction-from-raw-files",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "ProteoWizard: Vendor-agnostic alternative for reading .raw files and converting to open formats (mzML); use if rawrr is unavailable or non-Windows platform support needed",
