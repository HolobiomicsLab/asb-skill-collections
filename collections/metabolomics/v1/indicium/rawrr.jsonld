    {
      "@id": "asbval:assertion/skill/prm-acquisition-event-identification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By using the read Index() function a data.frame that indexes all scans found in a raw fi le is returned. When subsetting it for our scan type of interest it becomes clear that the example data was recorded using parallel reaction monitoring (PRM) since the parent ion 487.2567 was isolated in regularly spaced intervals for fragment ion recording. The delta between consecutive scans is always 22 scans (one PRM cycle) and the depedency Type of the MS2 scans is NA (since it was triggered by an inclusion list).",
      "asbval:note": "The paper explicitly demonstrates extracting scan index, filtering for PRM scans, and validating inter-scan spacing (delta = 22 scans).",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prm-acquisition-event-identification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Identify and validate parallel reaction monitoring (PRM) acquisition cycles in Thermo Orbitrap raw files by extracting the scan index, filtering for targeted precursor ion acquisitions, and confirming consistent inter-scan spacing.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:40:25.249826+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/prm-acquisition-event-identification/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We use a complete LC-MS run recorded on a Q Exactive HF Orbitrap by parallel reaction monitoring (PRM) for demonstration purposes (File name: 20181113_010_autoQC01.raw)... By using the read Index() function a data.frame that indexes all scans found in a raw fi le is returned. When subsetting it for our scan type of interest it becomes clear that the example data was recorded using parallel reaction monitoring (PRM) since the parent ion 487.2567 was isolated in regularly spaced intervals for fragment ion recording.",
      "asbval:note": "Paper uses exact same precursor ion (487.2567) and demonstrates PRM cycle validation.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prm-acquisition-event-identification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have a Thermo Fisher Scientific .raw file containing PRM data and need to verify that acquisition of a specific precursor ion (e.g., LGGNEQVTR++ at m/z 487.2567) is happening at regular intervals",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:40:25.249826+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/prm-acquisition-event-identification/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our novel package rawrr now provides complete, OS-independent access to all spectral data logged in Thermo Fisher Scienti fi c raw fi les... rawrr utilizes a vendor-provided API named Raw File Reader to access spectral data logged in proprietary Thermo Fisher Scienti fi c raw fi les",
      "asbval:note": "rawrr confirmed as primary tool for accessing Thermo .raw files via RawFileReader API.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "prm-acquisition-event-identification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "rawrr - R package that wraps RawFileReader .NET assembly to read scan index and metadata from .raw files",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:40:25.249826+00:00",
      "sepio:credibility_status": {
