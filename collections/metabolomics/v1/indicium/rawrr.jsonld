    {
      "@id": "asbval:assertion/skill/instrumental-parameter-validation-mass-spectrometry/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Our novel package rawrr now provides complete, OS-independent access to all spectral data logged in Thermo Fisher Scientific raw files... rawrr utilizes a vendor-provided API named Raw File Reader to access spectral data logged in proprietary Thermo Fisher Scientific raw files... R functions requesting access to data stored in binary raw files (reader family functions listed in Table 1) invoke compiled C# wrapper methods using a system call.",
      "asbval:note": "rawrr confirmed as R package wrapping RawFileReader API for .raw file access.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
