    {
      "@id": "asbval:assertion/skill/instrumental-parameter-validation-mass-spectrometry/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The plot shows typical Orbitrap peak attributes like resolution (R) and charge (z) above the most intense peaks when centroided data is available and selected... By adding some diagnostic information related to the Orbitrap's advanced gain control (AGC) system, it becomes apparent that the C-trap managed to collect the defined 100 000 charges within 2.8 ms, corresponding to only \u223c 5% of the maximum injection time of 55 ms... Centroided data also makes it possible to graph spectra using signal-to-noise as response value.",
      "asbval:note": "Paper demonstrates extraction and validation of resolving power, AGC target, injection time, and signal-to-noise metrics from raw Orbitrap files using rawrr.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jproteome-0c00866",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "instrumental-parameter-validation-mass-spectrometry",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate that raw mass spectrometry data were acquired with reported instrument parameters (resolving power, AGC injection time, scan type) and confirm spectral quality metrics (signal-to-noise ratios for fragment ions).",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
