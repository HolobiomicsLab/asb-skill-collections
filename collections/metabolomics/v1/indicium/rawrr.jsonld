      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: You need to extract and process all ions in the run (full MS1 or MS2 spectra) rather than targeted m/z values \u2014 use readSpectrum() or readIndex() for untargeted access.",
      "eco:evidence_type": {
