    {
      "@id": "asbval:assertion/skill/error-metric-comparison-and-benchmarking/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The best results were obtained by a heavily regularized deep neural network trained with cosine annealing warm restarts and stochastic weight averaging, achieving a mean and median absolute errors of [Formula: see text] and [Formula: see text], respectively... To avoid data-leakage when reporting the performance metrics, nested cross-validation was employed.",
      "asbval:note": "Paper explicitly computes MAE and MEDAE (median absolute error) across multiple models (DNN, DKL, XGBoost, lightGBM, CatBoost, blending ensemble) and compares them systematically.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "error-metric-comparison-and-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Evaluate retention time prediction models by computing mean absolute error (MAE) and median absolute error (MdAE) against ground-truth experimental values, then systematically compare these metrics across different approaches and calibration scenarios to establish competitive bas",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:59.541305+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/error-metric-comparison-and-benchmarking/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "5, 666 molecular descriptors and 2, 214 fingerprints (MACCS166, Extended Connectivity, and Path Fingerprints fingerprints) were generated with the alvaDesc software.",
      "asbval:note": "alvaDesc is explicitly named and used to generate the exact fingerprint types mentioned in the card.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "error-metric-comparison-and-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "alvaDesc - generates molecular descriptors and fingerprints (MACCS166, Extended Connectivity, Path Fingerprints) that serve as inputs to retention time prediction models whose outputs are later benchmarked",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:59.541305+00:00",
      "sepio:credibility_status": {
