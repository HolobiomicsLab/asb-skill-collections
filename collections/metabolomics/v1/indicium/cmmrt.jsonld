    },
    {
      "@id": "asbval:assertion/skill/deep-neural-network-latent-space-mapping/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The METLIN Small Molecule Retention Time (SMRT) dataset consists of the experimental retention times of 80,038 small molecules... The dataset has a wide variety of small molecules analysed under the same conditions, including metabolites, natural products and drug-like small molecules.",
      "asbval:note": "Paper uses MACCS166, Extended Connectivity, and Path Fingerprints as standard features; scope note is consistent with paper's approach.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "deep-neural-network-latent-space-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "No pre-trained model exists or domain-specific fingerprints differ significantly from training data (MACCS166, Extended Connectivity, Path Fingerprints)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:14.437991+00:00",
