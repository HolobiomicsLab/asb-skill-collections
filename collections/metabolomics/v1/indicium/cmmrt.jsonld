    {
      "@id": "asbval:assertion/skill/feature-condition-comparative-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The models were trained using only the descriptors, only the fingerprints, and both types of features simultaneously... We have also created an ensemble with all the trained models... Several state of the art machine learning regressors were tested for predicting the RTs using three different sets of features: fingerprints only, descriptors only and fingerprints+descriptors.",
      "asbval:note": "Paper explicitly trains models under three feature conditions: descriptors-only, fingerprints-only, and combined, across multiple regressor architectures (XGBoost, lightGBM, CatBoost, DNN, DKL, SVM).",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-condition-comparative-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "A comparative experimental workflow that trains machine learning models under multiple feature input conditions (e.g., descriptors-only, fingerprints-only, combined) on the same dataset and architecture to quantify the independent contribution of each feature type to prediction a",
