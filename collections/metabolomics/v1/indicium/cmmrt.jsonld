      }
    },
    {
      "@id": "asbval:assertion/skill/regression-error-metric-evaluation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Several state of the art machine learning regressors were tested for predicting the RTs using three different sets of features: fingerprints only, descriptors only and fingerprints+descriptors... The different shapes indicate the features used for feeding the regressors (in the legend, fgp and desc indicate fingerprints and descriptors, respectively).",
      "asbval:note": "Paper systematically compares multiple model architectures (XGBoost, lightGBM, CatBoost, DNN, DKL, blending) and feature representations (descriptors, fingerprints, combined) using MAE/MEDAE metrics.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "regression-error-metric-evaluation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill is essential for comparing model architectures, feature representations, and hyperparameter choices in predictive tasks where absolute prediction accuracy matters.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
