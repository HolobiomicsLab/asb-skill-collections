      }
    },
    {
      "@id": "asbval:assertion/skill/deep-neural-network-training-regularization/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Accurate prediction of retention time for a given chromatographic method would be a valuable support for metabolite annotation... The best model was a Deep Neural Network (DNN) trained using molecular fingerprints, which improved the performance of the best previous models to predict Retention Time (RT)",
