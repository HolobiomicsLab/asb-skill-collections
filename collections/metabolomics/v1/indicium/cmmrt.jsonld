    {
      "@id": "asbval:assertion/card/10_1186_s13321_022_00613_8__task_005/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To project retention times between chromatographic methods, a novel Bayesian meta-learning approach that can learn from just a few molecules is proposed. By applying this projection between the deep neural network retention time predictions and a given chromatographic method, our approach can be integrated into a metabolite annotation workflow to obtain z-scores for the candidate annotations... The use of z-scores permits considering the uncertainty in the projection when ranking candidates, and not only the accuracy.",
      "asbval:note": "The paper explicitly describes combining DNN predictions with meta-learned projections to generate probabilistic scores (z-scores) for ranking metabolite candidates.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_005",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "How can DNN-predicted retention times be combined with meta-learned chromatographic projections to generate probabilistic likelihood scores for ranking candidate metabolite annotations?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:55:21.009729+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/card/10_1186_s13321_022_00613_8__task_005/001",
