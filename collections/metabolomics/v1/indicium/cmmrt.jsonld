      }
    },
    {
      "@id": "asbval:assertion/skill/retention-time-prediction/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we propose the use of meta-learning to solve the problem of learning from few samples... GPs are particularly suited as projection model... we shall use a GP parametrized with a constant mean, and a polynomial kernel of degree 4. That is f(x) \u223c GP(c, (xx' + \u03b3)^4).",
      "asbval:note": "Meta-learning framework, GP choice, and specific kernel configuration all confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "retention-time-prediction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Bayesian meta-learning approach using Gaussian Processes (GPs) with polynomial kernel (degree 4) and constant mean function to project RTs between chromatographic methods",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:00:20.166846+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/retention-time-prediction/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Descriptors were first standardized and imputed using median imputation... Features with 0 variance were removed. Highly correlated features were also eliminated (correlation > 0.9)... The only preprocessing applied to the fingerprint features was removing those with low variance.",
      "asbval:note": "All preprocessing steps and thresholds confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "retention-time-prediction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Feature preprocessing: standardization, median imputation, removal of zero-variance and highly correlated (>0.9) features for descriptors; variance thresholding for fingerprints",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:00:20.166846+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/retention-time-prediction/012",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Finally, quantile transformation was applied to RTs before fitting. The method transforms RTs to follow a standardized normal distribution.",
      "asbval:note": "Transformation method and rationale confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "retention-time-prediction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Quantile transformation applied to RTs to follow standardized normal distribution before fitting",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:00:20.166846+00:00",
