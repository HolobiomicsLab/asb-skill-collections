    {
      "@id": "asbval:assertion/skill/regression-error-metric-evaluation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To avoid data-leakage when reporting the performance of the different models, nested stratified cross-validation was used... The best results were obtained by a heavily regularized deep neural network trained with cosine annealing warm restarts and stochastic weight averaging, achieving a mean and median absolute errors of [Formula: see text] and [Formula: see text], respectively.",
      "asbval:note": "Paper explicitly uses MAE and MEDAE (median absolute error) as primary performance metrics for regression models on held-out test sets via nested cross-validation.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "regression-error-metric-evaluation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Quantitative assessment of machine learning regression model performance using mean absolute error (MAE) and median absolute error (MdAE) computed on held-out test sets.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:59:57.122827+00:00",
      "sepio:credibility_status": {
