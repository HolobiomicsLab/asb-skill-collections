      "asbval:target_artifact_id": "bayesian-meta-learning-projection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you need to transfer retention time predictions from one chromatographic method to another, but have access to only a small number (\u226510) of molecules with known retention times in both methods.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:57:33.302703+00:00",
