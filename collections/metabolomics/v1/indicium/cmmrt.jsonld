      }
    },
    {
      "@id": "asbval:assertion/skill/deep-neural-network-latent-space-mapping/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the number of training points was varied between 10 and 50; 50 was the number of molecules used in [21].",
      "asbval:note": "Paper tests with minimum 10 training points; fewer would be outside tested regime.",
