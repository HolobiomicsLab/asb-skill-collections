    {
      "@id": "asbval:assertion/skill/deep-neural-network-latent-space-mapping/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To make this workflow practical, it is desirable that the projection function can be learned from a very small dataset, so that the researcher only has to identify a small set of molecules... we propose a Bayesian meta-learning approach to project the predicted RTs to a specific Chromatographic Method (CM) based on just a few identified molecules.",
      "asbval:note": "Paper explicitly demonstrates learning projection functions from 10\u201350 calibration molecules.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "deep-neural-network-latent-space-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "minimal-calibration transfer between chromatographic methods",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:14.437991+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/deep-neural-network-latent-space-mapping/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "5, 666 molecular descriptors and 2, 214 fingerprints (MACCS166, Extended Connectivity, and Path Fingerprints fingerprints) were generated with the alvaDesc software.",
      "asbval:note": "alvaDesc is used to generate fingerprints and descriptors for the DNN training phase, not specifically for 'latent-space projection' as the card claims. The fingerprints are inputs to the DNN regressor, not to a latent-space projection step. The card's framing suggests a pipeline that does not exist in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "deep-neural-network-latent-space-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "alvaDesc: Generate molecular fingerprints (MACCS166, Extended Connectivity, Path Fingerprints) for input molecules prior to latent-space projection",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:14.437991+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/deep-neural-network-latent-space-mapping/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Python code is available on GitHub at https://github.com/constantino-garcia/cmmrt.",
      "asbval:note": "cmmrt repository contains code for DNN training and Bayesian meta-learning for RT projection, but there is no evidence in the paper that it implements 'latent-space extraction' as a distinct pipeline step. The paper does not describe extracting intermediate DNN representations as a latent space for projection.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "deep-neural-network-latent-space-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "cmmrt: Reference implementation of DNN training, latent-space extraction, and Bayesian meta-learning for RT projection",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
