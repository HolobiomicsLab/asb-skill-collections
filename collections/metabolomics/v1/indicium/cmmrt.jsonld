    {
      "@id": "asbval:assertion/skill/stochastic-weight-averaging-implementation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To improve the generalization ability of the DNN and to accelerate its training, we used a DNN with just 3 layers, regularized using large dropout rates... To improve the generalization ability of the DNN and to accelerate its training, we used cosine annealing warm restarts and stochastic weight averaging",
      "asbval:note": "Paper confirms SWA was used with cosine annealing warm restarts for DNN training on retention time prediction and achieved best results (MAE 39.2\u00b11.2s, MEDAE 17.2\u00b10.9s). However, the paper does not explicitly isolate or quantify the specific contribution of SWA alone to error reduction\u2014it presents SWA as part of a combined regularization strategy (dropout + cosine annealing + SWA). The claim about 'stabilizing learned representations across multiple training epochs' is a mechanistic interpretation not explicitly stated in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "stochastic-weight-averaging-implementation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Stochastic weight averaging (SWA) is a post-training technique that improves neural network generalization by averaging model weights collected at intervals during training, particularly effective when combined with cyclic learning rate schedules. In retention time prediction, SW",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:01:00.955006+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/stochastic-weight-averaging-implementation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We have trained state-of-the-art machine learning regressors using the 80, 038 experimental retention times from the METLIN Small Molecule Retention Tim (SMRT) dataset... 5, 666 molecular descriptors and 2, 214 fingerprints (MACCS166, Extended Connectivity, and Path Fingerprints fingerprints) were generated with the alvaDesc software... The best results were obtained by a heavily regularized deep neural network trained with cosine annealing warm restarts and stochastic weight averaging",
      "asbval:note": "Scope aligns with paper's actual experimental setup: 80,038 molecules, 5,666 descriptors + 2,214 fingerprints, DNN with dropout regularization, cosine annealing warm restarts + SWA, retention time regression task.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "stochastic-weight-averaging-implementation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when training a deeply regularized deep neural network on a large molecular feature dataset (e.g., >80,000 molecules with >5,000 descriptors and fingerprints) where you have already adopted a cyclic learning rate schedule (cosine annealing with warm restarts) and",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
