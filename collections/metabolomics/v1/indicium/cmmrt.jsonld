      }
    },
    {
      "@id": "asbval:assertion/skill/deep-neural-network-latent-space-mapping/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not propose extracting latent representations from the DNN. Instead, it uses the DNN to predict RTs on the SMRT dataset, then applies a separate Gaussian Process meta-learning model for projection. The DNN is not retrained; it is frozen and used as a feature extractor implicitly (via its predictions), but the paper does not explicitly frame or implement latent-space extraction as described in the card.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "deep-neural-network-latent-space-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "extracting latent representations allows you to learn a lightweight projection mapping rather than retraining the entire network",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:14.437991+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/deep-neural-network-latent-space-mapping/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To make this workflow practical, it is desirable that the projection function can be learned from a very small dataset... we propose a Bayesian meta-learning approach to project the predicted RTs to a specific Chromatographic Method (CM) based on just a few identified molecules... the number of training points was varied between 10 and 50.",
      "asbval:note": "Paper demonstrates projection learning with 10\u201350 calibration molecules.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "deep-neural-network-latent-space-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
