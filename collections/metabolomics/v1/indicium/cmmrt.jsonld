    {
      "@id": "asbval:assertion/skill/deep-neural-network-training-regularization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To improve the generalization ability of the DNN and to accelerate its training, we used cosine annealing warm restarts [39] and stochastic weight averaging (SWA) [40]... Regularization is key for achieving good generalization, since even a small shallow neural network can overfit the SMRT dataset in a few epochs. Driven by this observation, we used a DNN with just 3 layers, regularized using large dropout rates.",
      "asbval:note": "Claim is supported. Paper explicitly describes DNN training with cosine annealing warm restarts, SWA, and heavy regularization (dropout). L1/L2 regularization is not explicitly named in the passages but dropout is the primary regularization method used.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "deep-neural-network-training-regularization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Training a deep neural network with heavy L1/L2 regularization, cosine annealing warm restarts, and stochastic weight averaging to achieve robust regression on high-dimensional molecular feature spaces.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:32.298276+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/deep-neural-network-training-regularization/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We have trained state-of-the-art machine learning regressors using the 80, 038 experimental retention times from the METLIN Small Molecule Retention Tim (SMRT) dataset... 5, 666 molecular descriptors and 2, 214 fingerprints (MACCS166, Extended Connectivity, and Path Fingerprints fingerprints) were generated",
      "asbval:note": "Dataset size and feature dimensionality match the claim exactly.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "deep-neural-network-training-regularization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "prevent overfitting on modestly-sized datasets (e.g., 80K molecules) with thousands of features",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:32.298276+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/deep-neural-network-training-regularization/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To avoid data-leakage when reporting the performance metrics, nested cross-validation was employed... The best results were obtained by a heavily regularized deep neural network trained with cosine annealing warm restarts and stochastic weight averaging, achieving a mean and median absolute errors",
      "asbval:note": "Paper uses nested cross-validation to evaluate generalization on held-out test sets.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "deep-neural-network-training-regularization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "improve generalization on held-out test sets",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
