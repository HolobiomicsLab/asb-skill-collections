      }
    },
    {
      "@id": "asbval:assertion/skill/metabolite-candidate-ranking-likelihood-scoring/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The best results were obtained by a heavily regularized deep neural network trained with cosine annealing warm restarts and stochastic weight averaging, achieving a mean and median absolute errors of [Formula: see text] and [Formula: see text], respectively.",
