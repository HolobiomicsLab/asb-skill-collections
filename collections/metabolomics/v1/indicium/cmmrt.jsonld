    {
      "@id": "asbval:assertion/skill/retention-time-prediction/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The METLIN Small Molecule Retention Time (SMRT) dataset consists of the experimental retention times of 80,038 small molecules from the METLIN library [21]. All RTs were obtained using reverse-phase chromatography with high-performance liquid chromatography-mass spectrometry (HPLC-MS).",
      "asbval:note": "Dataset size and acquisition method confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "retention-time-prediction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
