    {
      "@id": "asbval:assertion/skill/bayesian-meta-learning-model-fitting/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To project retention times between chromatographic methods, a novel Bayesian meta-learning approach that can learn from just a few molecules is proposed... we propose the use of meta-learning to solve the problem of learning from few samples... Hence, we propose the use of meta-learning to solve the problem of learning from few samples.",
      "asbval:note": "Paper proposes Bayesian meta-learning with Gaussian Processes for RT projection from few samples (10+ molecules), but the claim about 'mapping to a pre-trained DNN's latent feature space' is not supported. The paper uses a pre-trained DNN to predict RTs on the SMRT dataset, then learns a separate GP projection function to map those predicted RTs to experimental RTs in different chromatographic methods. The GP does not extract or map through DNN latent features\u2014it operates on predicted RT values directly.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "bayesian-meta-learning-model-fitting",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Fit a Bayesian Gaussian Process meta-learning model to project retention times between different chromatographic methods using minimal calibration data (as few as 10 molecules). This approach learns a generalizable mapping from one chromatographic method's space to a pre-trained ",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:57:19.478283+00:00",
      "sepio:credibility_status": {
