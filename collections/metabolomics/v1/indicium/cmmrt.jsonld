    {
      "@id": "asbval:assertion/skill/deep-neural-network-latent-space-mapping/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To project retention times between chromatographic methods, a novel Bayesian meta-learning approach that can learn from just a few molecules is proposed... the prior distribution p(f) learned during meta-learning is updated with the new evidence {x\u0303, \u1ef9}, which should enable the prediction/ranking of {x\u0303*, \u1ef9*}.",
      "asbval:note": "Paper proposes Bayesian meta-learning for RT projection between chromatographic methods using few samples, but does NOT extract intermediate feature representations from the DNN as a latent space. Instead, the paper uses a DNN to predict RTs directly on the SMRT dataset, then applies a separate Gaussian Process (GP) meta-learning model for projection. The DNN and projection method are decoupled, not integrated via latent-space extraction. The card conflates two separate components.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "deep-neural-network-latent-space-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Extract intermediate feature representations from a pre-trained deep neural network and use them as a latent space onto which external data can be projected via Bayesian meta-learning, enabling rapid calibration-free or minimal-calibration transfer between chromatographic methods",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:14.437991+00:00",
