      }
    },
    {
      "@id": "asbval:assertion/skill/bayesian-meta-learning-projection/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To project retention times between chromatographic methods, a novel Bayesian meta-learning approach that can learn from just a few molecules is proposed. By applying this projection between the deep neural network retention time predictions and a given chromatographic method, our approach can be integrated into a metabolite annotation workflow to obtain z-scores for the candidate annotations.",
      "asbval:note": "Paper explicitly describes integration into metabolite annotation workflow with z-scores for ranking.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "bayesian-meta-learning-projection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it as the final step in a metabolite annotation workflow where DNN-predicted retention times and their uncertainties must be projected and converted into probabilistic likelihood scores for ranking candidates.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:57:33.302703+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/bayesian-meta-learning-projection/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To study the robustness of the projection method when only a few metabolites are known, the number of training points was varied between 10 and 50",
      "asbval:note": "Paper tests minimum of 10 training points, implying this is the practical lower bound.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "bayesian-meta-learning-projection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Fewer than 10 calibration molecules with paired retention times in both methods are available",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:57:33.302703+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/chromatographic-method-transfer/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To build such a projection function, a set of known molecules whos RTs is known in both CMs is needed... To make this workflow practical, it is desirable that the projection function can be learned from a very small dataset, so that the researcher only has to identify a small set of molecules. To that end, this work proposes a Bayesian meta-learning approach to project the predicted RTs to a specific Chromatographic Method (CM) based on just a few identified molecules.",
      "asbval:note": "Fully supported. Paper explicitly proposes Bayesian meta-learning for projection with few samples.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chromatographic-method-transfer",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Transfer retention time predictions between different chromatographic methods using Bayesian meta-learning trained on a small calibration set (as few as 10 molecules)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:57:49.373723+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/chromatographic-method-transfer/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "When decreasing the number of training points to just 10 samples, the percentage is 68%, while with 30 is 69%. This shows that meta-learning enables the creation of projection functions from just a few known metabolites.",
      "asbval:note": "Supported. Paper demonstrates 68% ranking accuracy with only 10 training points, showing competitive performance with minimal calibration data.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chromatographic-method-transfer",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "maintaining competitive error rates without requiring large amounts of method-specific training data",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:57:49.373723+00:00",
