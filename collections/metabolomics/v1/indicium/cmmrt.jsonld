      }
    },
    {
      "@id": "asbval:assertion/skill/error-metric-comparison-and-benchmarking/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Python code is available on GitHub at https://github.com/constantino-garcia/cmmrt.",
      "asbval:note": "Repository is confirmed present. Paper describes DNN and Bayesian meta-learned GP models for RT prediction and projection, with MAE/MEDAE metrics computed on outputs.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "error-metric-comparison-and-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "cmmrt (constantino-garcia/cmmrt) - implements DNN and Bayesian meta-learned GP models for retention time prediction and projection; error metrics are computed on model outputs",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:59.541305+00:00",
