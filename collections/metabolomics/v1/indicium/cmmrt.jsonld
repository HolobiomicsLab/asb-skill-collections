    {
      "@id": "asbval:assertion/skill/uncertainty-quantification-rt-prediction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The use of z-scores permits considering the uncertainty in the projection when ranking candidates, and not only the accuracy... the correct molecule was among the top three candidates filtered by mass and ranked according to z-scores.",
      "asbval:note": "Paper does quantify uncertainty and use it for ranking (via z-scores from GP projection intervals), but the primary uncertainty mechanism is Bayesian meta-learned Gaussian Processes for RT projection between chromatographic methods, not direct DNN uncertainty quantification. The DNN itself is trained with regularization and SWA but uncertainty is introduced via the GP projection layer, not from the DNN's internal predictions.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "uncertainty-quantification-rt-prediction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Quantify prediction uncertainty in deep neural network retention time (RT) models and convert those uncertainty bounds into probabilistic likelihood scores for ranking metabolite candidates.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:01:14.766844+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
