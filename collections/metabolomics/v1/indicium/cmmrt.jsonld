      }
    },
    {
      "@id": "asbval:assertion/skill/error-metric-comparison-and-benchmarking/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To study the robustness of the projection method when only a few metabolites are known, the number of training points was varied between 10 and 50; 50 was the number of molecules used in [21].",
      "asbval:note": "Paper explicitly tests projection with 10, 20, 30, 40, and 50 training points (molecules), comparing sparse vs. full calibration scenarios.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "error-metric-comparison-and-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "parameters",
      "asbval:target_claim_text": "10-molecule vs. full-calibration approaches for projection calibration",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:59.541305+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/error-metric-comparison-and-benchmarking/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MEDAE of 17.2 \u00b1 0.9 s and a MAE of 39.2 \u00b1 1.2 s when considering all molecules, and a MEDAE of 17.2 \u00b1 0.9 s and a MAE of 34.0 \u00b1 0.9 s when considering retained molecules only.",
      "asbval:note": "Paper reports MAE and MEDAE across multiple models (Tables 1\u20133) and projection scenarios (Table 4).",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "error-metric-comparison-and-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "MAE and MEDAE values across different models and calibration scenarios",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:59.541305+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/error-metric-comparison-and-benchmarking/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To avoid data-leakage when reporting the performance of the different models, nested stratified cross-validation was used. Nested cross-validation guarantees that different data is used to tune model parameters and to evaluate its performance by means of outer and inner cross-validation loops.",
      "asbval:note": "Paper explicitly employs nested cross-validation with 5-fold outer and 7-fold inner loops for robust error metric computation.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "error-metric-comparison-and-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Nested cross-validation to avoid data leakage when reporting performance metrics",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:58:59.541305+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/error-metric-comparison-and-benchmarking/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Bayesian hyperparameter search was used for parameter tuning... The parameters were tested following the predictions of a TPE algorithm [27].",
      "asbval:note": "Paper uses Tree-structured Parzen Estimator (TPE) for Bayesian hyperparameter optimization across regressors.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
