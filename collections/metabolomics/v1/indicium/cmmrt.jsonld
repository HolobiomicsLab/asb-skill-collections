    {
      "@id": "asbval:assertion/card/10_1186_s13321_022_00613_8__task_002/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In the literature there are both works reporting that fingerprints outperform molecular descriptors (e.g., [21]) and works claiming just the opposite (e.g., [24]). Our results slightly favor the usage of fingerprints, although it cannot be ruled out that the best type of feature depends on the machine learning regressor used.",
      "asbval:note": "The paper directly addresses this comparison across multiple regressors and datasets.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_002",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Do fingerprints outperform molecular descriptors alone when training machine learning models for retention time prediction on the METLIN SMRT dataset?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
