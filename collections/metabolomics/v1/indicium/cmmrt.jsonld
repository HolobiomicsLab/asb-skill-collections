    {
      "@id": "asbval:assertion/skill/metabolite-candidate-ranking-likelihood-scoring/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The best results were obtained by a heavily regularized deep neural network trained with cosine annealing warm restarts and stochastic weight averaging... Python code is available on GitHub at https://github.com/constantino-garcia/cmmrt.",
      "asbval:note": "The paper confirms the cmmrt repository contains code for DNN training with cosine annealing warm restarts and SWA, and implements the Bayesian meta-learning approach for RT projection.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolite-candidate-ranking-likelihood-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
