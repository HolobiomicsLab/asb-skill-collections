    {
      "@id": "asbval:assertion/skill/regression-model-evaluation-mae-metrics/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Retention time information is used for metabolite annotation in metabolomic experiments... We have trained state-of-the-art machine learning regressors using the 80, 038 experimental retention times from the METLIN Small Molecule Retention Tim (SMRT) dataset... To avoid data-leakage when reporting the performance metrics, nested cross-validation was employed.",
      "asbval:note": "Paper directly addresses retention time prediction on LC-MS datasets with held-out test evaluation using MAE/MEDAE as primary metrics.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "regression-model-evaluation-mae-metrics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When you have trained a regression model on experimental retention times or similar continuous molecular property predictions and need to quantify its generalization performance on held-out test data. Use this skill when MAE and MdAE are the primary evaluation metrics of interest",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:00:07.655940+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/regression-model-evaluation-mae-metrics/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "All the descriptors and fingerprints obtained with alvaDesc were used to feed the regressors... Descriptors were first standardized and imputed using median imputation when alvaDesc was not able to generate some descriptor.",
      "asbval:note": "Paper emphasizes consistent preprocessing and feature generation pipeline across all models evaluated.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "regression-model-evaluation-mae-metrics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: When the model has not been trained on the same dataset or feature engineering pipeline; evaluation must use consistent preprocessing.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:00:07.655940+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/regression-model-evaluation-mae-metrics/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Nested cross-validation guarantees that different data is used to tune model parameters and to evaluate its performance by means of outer and inner cross-validation loops... In the outer loop, train/test splits are generated, which are then used for averaging the test scores over several data splits.",
      "asbval:note": "Paper explicitly addresses the importance of proper cross-validation to avoid data leakage and ensure truly held-out test sets.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "regression-model-evaluation-mae-metrics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: When test set is not truly held-out (e.g., it overlaps with training data due to improper cross-validation setup).",
