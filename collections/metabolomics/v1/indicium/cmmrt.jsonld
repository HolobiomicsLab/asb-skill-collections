    {
      "@id": "asbval:assertion/skill/metabolite-candidate-ranking-likelihood-scoring/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By applying this projection between the deep neural network retention time predictions and a given chromatographic method, our approach can be integrated into a metabolite annotation workflow to obtain z-scores for the candidate annotations... The use of z-scores permits considering the uncertainty in the projection when ranking candidates, and not only the accuracy.",
      "asbval:note": "The paper explicitly describes using DNN RT predictions with Bayesian meta-learned projections to generate z-scores (probabilistic scores) for ranking candidates, incorporating uncertainty.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolite-candidate-ranking-likelihood-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Convert predicted retention times and their uncertainties into probabilistic likelihood scores to rank candidate metabolite annotations in descending order of plausibility. This skill integrates deep neural network RT predictions with Bayesian meta-learned chromatographic project",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:59:28.051672+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
