    {
      "@id": "asbval:assertion/skill/bayesian-meta-learning-projection/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To that end, this work proposes a Bayesian meta-learning approach to project the predicted RTs to a specific Chromatographic Method (CM) based on just a few identified molecules. This approach has the advantage of being able to generalize from a small training set while providing confidence intervals for the Retention Time (RT) projections between CMs, and not only a point estimate.",
      "asbval:note": "Core research question is directly supported. Paper explicitly proposes Bayesian meta-learning for RT projection with few molecules and confidence intervals.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "bayesian-meta-learning-projection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "A Bayesian meta-learning approach that projects retention times across different chromatographic methods using minimal calibration data (as few as 10 molecules), enabling probabilistic annotation scoring without extensive method-specific retraining.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:57:33.302703+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/bayesian-meta-learning-projection/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "GPs are particularly suited as projection model: they represent a distribution over functions, they can perform regression on smalls amount of data, and they can incorporate prior knowledge using the Bayesian framework.",
      "asbval:note": "Paper explicitly uses Gaussian Processes with Bayesian framework for projection with small data.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
