    {
      "@id": "asbval:assertion/skill/feature-condition-comparative-analysis/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Fig. 5 shows that models that did not employ Bayesian search (lightGBM and CatBoost) perform worse... These were also the models that benefited from using both descriptors and fingerprints; in the other models using both types of features together had a performance similar to using only the descriptors. In the literature there are both works reporting that fingerprints outperform molecular descriptors... Our results slightly favor the usage of fingerprints",
      "asbval:note": "Paper provides detailed MAE/MEDAE comparisons across feature conditions in Tables 1\u20133 and Figure 5, quantifying the independent contribution of each feature type.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-condition-comparative-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "Quantified independent contribution of each feature type to prediction accuracy (e.g., MAE/MEDAE for descriptors-only vs. fingerprints-only vs. combined)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:59:13.689067+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/feature-condition-comparative-analysis/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To avoid data-leakage when reporting the performance of the different models, nested stratified cross-validation was used. Nested cross-validation guarantees that different data is used to tune model parameters and to evaluate its performance by means of outer and inner cross-validation loops.",
      "asbval:note": "Paper explicitly employs nested cross-validation with 5-fold outer and 7-fold inner loops for all feature-condition comparisons.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s13321-022-00613-8",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "feature-condition-comparative-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Nested cross-validation to avoid data leakage when comparing feature conditions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:59:13.689067+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
