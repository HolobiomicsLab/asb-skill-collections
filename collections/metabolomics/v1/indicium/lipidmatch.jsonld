    {
      "@id": "asbval:assertion/skill/acquisition-mode-enumeration-and-validation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "LipidMatch has also been tested using data acquired on an Agilent 6540 Q-TOF (Agilent Technologies, Santa Clara, CA). LipidMatch can be used with a variety of other vendors and data formats. Ion selection techniques used to acquire fragmentation, including all-ion-fragmentation (AIF), inclusion list-based targeted approaches, and data-dependent topN (ddMS2-topN) approaches can be used with LipidMatch to annotate lipids acquired using liquid chromatography, direct injection, or imaging approaches.",
      "asbval:note": "Agilent Q-TOF is confirmed as tested, and direct infusion and imaging are mentioned as compatible modes generally, but the paper does not explicitly state that Agilent Q-TOF was tested with direct infusion and imaging specifically\u2014only that these modes are compatible with LipidMatch in general.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "acquisition-mode-enumeration-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[2]",
      "asbval:target_claim_text": "Agilent Q-TOF UHPLC-HRMS/MS - Validated instrument platform for direct infusion and imaging experiments",
      "eco:evidence_type": {
