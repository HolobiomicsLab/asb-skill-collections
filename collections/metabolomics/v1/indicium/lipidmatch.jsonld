    {
      "@id": "asbval:assertion/skill/mass-spectrometry-data-column-mapping/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Feature table(s) and MS/MS data are placed into a directory... Each folder should contain respective MS/MS data for that substrate in .ms2 format also ending in 'neg.csv' or 'pos.csv', depending on polarity.",
      "asbval:note": "Paper describes feature table format requirements but does not explicitly enumerate m/z, retention time, and intensity as the specific required columns. The paper mentions feature tables contain m/z and retention time (used for matching), but intensity is not explicitly stated as a required input column for LipidMatch feature tables.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mass-spectrometry-data-column-mapping",
