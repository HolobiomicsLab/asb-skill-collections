    {
      "@id": "asbval:assertion/skill/technical-specification-tabulation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "LipidMatch was developed and tested using data acquired from a Q-Exactive orbitrap mass spectrometer (Thermo Scientific, San Jose, CA). LipidMatch has also been tested using data acquired on an Agilent 6540 Q-TOF (Agilent Technologies, Santa Clara, CA). LipidMatch can be used with a variety of other vendors and data formats. Ion selection techniques used to acquire fragmentation, including all-ion-fragmentation (AIF), inclusion list-based targeted approaches, and data-dependent topN (ddMS2-topN) approaches can be used with LipidMatch to annotate lipids acquired using liquid chromatography, direct injection, or imaging approaches.",
      "asbval:note": "Paper documents validated platforms (Q-Exactive orbitrap, Agilent 6540 Q-TOF) and acquisition modes (AIF, ddMS2-topN, targeted, LC, direct injection, imaging), but does NOT provide a formal CSV-formatted compatibility matrix or comprehensive tabulation. The paper states compatibility in prose form only. Card claims extraction of 'definitive support matrix' in CSV format, but paper provides only narrative documentation of tested platforms and modes.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "technical-specification-tabulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Systematically extract and tabulate validated instrument platforms, vendor models, and acquisition mode combinations from software documentation and repositories to establish a definitive support matrix.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:16:13.734576+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
