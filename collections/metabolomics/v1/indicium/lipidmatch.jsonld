    {
      "@id": "asbval:assertion/skill/file-format-validation/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Users can modify which fragment ions for each lipid class must be observed for identification using a simple Excel sheet as outlined in the 6th video tutorial. In certain cases it may be important to optimize fragment criteria for applications not employing HCD fragmentation with an orbitrap analyzer.",
      "asbval:note": "Paper discusses validation of fragments and importance of correct annotation, but does not explicitly address 'silent registration failures' or malformed entry detection mechanisms. The concept of preventing errors is implied but not explicitly stated as a validation step.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "partial",
