      "@id": "asbval:assertion/skill/lipid-library-format-specification/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "[SUBSTRING-MATCH for LipidMatch | role: Primary software for lipid identification and library integration]",
      "asbval:note": "LipidMatch is the primary tool discussed throughout the paper for lipid identification and library management.",
