    {
      "@id": "asbval:assertion/skill/lipid-identification-scoring/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For each MS/MS scan of each feature, experimental fragments are matched against in silico lipid fragments m/z using a tolerance window (ppm)... Each fragment is assigned 1 if it is above the user defined minimum intensity and scans threshold and 0 if the fragment does not meet these criteria or was not found within the m/z tolerance... If multiple lipids are identified for a single feature, the lipids are ranked by the summed intensity of all their fragments with in silico fragment exact mass matches",
      "asbval:note": "Core workflow of LipidMatch confirmed: experimental m/z matching against in silico library with tolerance windows, intensity thresholds, and ranking by summed fragment intensity.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "lipid-identification-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Score and rank candidate lipid matches by comparing experimental fragment m/z values against in-silico fragmentation library values using mass tolerance thresholds and match quality metrics.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:13:26.109456+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/lipid-identification-scoring/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Lipids are identified if they contain the necessary observed fragments... After lipids are identified, they are assigned a number based on whether they are identified by class and fatty acyl constituents (1), by data-independent analysis (2), only by class (3), or only by precursor m/z without fragment matching (4)",
      "asbval:note": "LipidMatch assigns confidence levels (1-4) to lipid identifications based on fragment matching quality.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "lipid-identification-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill filters and prioritizes lipid identifications from high-resolution tandem mass spectrometry data to assign confidence to putative lipid assignments.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:13:26.109456+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/lipid-identification-scoring/002",
      "@type": "asbval:ClaimAssessment",
