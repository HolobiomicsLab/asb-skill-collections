    {
      "@id": "asbval:assertion/skill/peak-table-schema-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The feature table can have nearly any format, allowing flexibility in choosing feature processing workflows... Feature table(s) and MS/MS data are placed into a directory... Each folder should contain respective MS/MS data for that substrate in .ms2 format also ending in \"neg.csv\" or \"pos.csv\", depending on polarity.",
      "asbval:note": "Paper confirms that LipidMatch accepts feature tables from various peak-picking software (MZmine, XCMS, MS-DIAL) and describes file naming conventions (.csv format, polarity suffixes). However, the paper does NOT describe a formal schema validation step or explicit requirement checking for m/z, retention time, and intensity columns before ingestion. The paper states 'The feature table can have nearly any format, allowing flexibility' which suggests LipidMatch is permissive rather than strict about schema validation. The card's claim about preventing 'silent failures and data loss' through pre-ingestion validation is not explicitly addressed in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "peak-table-schema-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate that peak-picking output files conform to the LipidMatch input schema before ingestion, ensuring all required columns (m/z, retention time, intensity) are present, correctly named, and properly typed.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
