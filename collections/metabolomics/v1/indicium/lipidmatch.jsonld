      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Integration of user-authored .csv lipid libraries into LipidMatch to enable custom lipid entries as matching candidates in subsequent lipidomics analyses",
      "eco:evidence_type": {
