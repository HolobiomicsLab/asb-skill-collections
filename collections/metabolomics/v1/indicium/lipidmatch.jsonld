    {
      "@id": "asbval:assertion/card/task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "LipidMatch currently has over 250,000 lipid species spanning 56 lipid types contained in in silico fragmentation libraries.",
      "asbval:note": "Paper states LipidMatch contains 'over 250,000 lipid species spanning 56 lipid types', not 500,000+ species or 60+ types. The card's thresholds (500,000 species, 60 types) exceed what the paper documents.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Do the LipidMatch library files deposited in the GitHub repository contain at least 500,000 distinct lipid species across 60 or more lipid-type categories?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:08:07.807631+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/card/task_001/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We introduce LipidMatch, an R-based tool for lipid identification for liquid chromatography tandem mass spectrometry workflows.",
      "asbval:note": "LipidMatch is the primary tool discussed throughout the paper.",
