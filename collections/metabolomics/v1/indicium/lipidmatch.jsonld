    {
      "@id": "asbval:assertion/skill/lipid-library-format-specification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "LipidMatch libraries are static excel files, as with all four software previously mentioned, the user can select which lipid types to query using LipidMatch... LipidMatch libraries contain only exact m/z values of precursors and fragment ions, making it relatively trivial for users to generate in silico libraries and/or convert other databases to the LipidMatch library format.",
      "asbval:note": "Paper confirms .csv format and user-authored libraries with m/z fragmentation patterns, but describes libraries as 'Excel files' (not explicitly .csv) and emphasizes generation/conversion rather than formal 'specification and validation' process. The paper mentions video tutorial 6 for library development but does not detail a formal specification or validation framework.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "lipid-library-format-specification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Specification and validation of .csv lipid library file format for integration into LipidMatch, enabling custom lipid entries with annotated m/z fragmentation patterns to be incorporated as matching candidates.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:13:58.079387+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/lipid-library-format-specification/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Users can modify which fragment ions for each lipid class must be observed for identification using a simple Excel sheet as outlined in the 6th video tutorial... Libraries for LipidMatch can be developed using LipidBlast Templates or as explained in video tutorial 6 found in the Additional file 1. Each library should be developed with the correct annotation based on the structural resolution that can be inferred by fragments chosen for the identification criteria.",
      "asbval:note": "Paper confirms that user-authored libraries must conform to format requirements and provides guidance (video tutorial 6) for correct development.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "lipid-library-format-specification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill ensures that user-authored libraries conform to the format required for successful ingestion and deployment in lipidomics workflows.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:13:58.079387+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/lipid-library-format-specification/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "LipidMatch currently has over 250,000 lipid species spanning 56 lipid types contained in in silico fragmentation libraries.",
      "asbval:note": "Paper states 'over 250,000 lipid species', not 500,000+. The card's claim of 500,000+ is unsupported; the actual number is approximately half that.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "lipid-library-format-specification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "built-in 500,000+ species in-silico fragmentation library",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:13:58.079387+00:00",
