    {
      "@id": "asbval:assertion/skill/mass-spectrometry-fragment-matching/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "LipidMatch currently has over 250,000 lipid species spanning 56 lipid types contained in in silico fragmentation libraries... For each MS/MS scan of each feature, experimental fragments are matched against in silico lipid fragments m/z using a tolerance window (ppm).",
      "asbval:note": "Paper states LipidMatch contains 'over 250,000 lipid species spanning 56 lipid types', not '>500,000 species across 60+ lipid classes' as claimed. The core function (matching experimental fragments against in silico libraries using m/z tolerance) is correct, but the database size and lipid type counts are overstated in the card.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mass-spectrometry-fragment-matching",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Match experimental fragment m/z values against in-silico fragmentation libraries to identify lipids using tandem mass spectrometry data. This skill applies mass tolerance thresholds to compare high-resolution MS/MS spectra to comprehensive lipid databases containing >500,000 spec",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
