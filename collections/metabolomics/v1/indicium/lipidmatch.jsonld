    {
      "@id": "asbval:assertion/skill/mass-spectrometry-data-column-mapping/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The feature table can have nearly any format, allowing flexibility in choosing feature processing workflows... Once feature tables are created for each biological substrate and each polarity, features can be directly annotated using LipidMatch and the previously generated MS/MS data... Features can be determined from various peak picking software such as MZmine, XCMS, or MS-DIAL.",
      "asbval:note": "Paper explicitly states LipidMatch accepts feature tables from MZmine, XCMS, MS-DIAL with flexible format, and describes the workflow of converting/preparing these tables for LipidMatch input.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-data-column-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Convert peak-picking output from external mass spectrometry software (MZmine, XCMS, MS-DIAL, Compound Discoverer) into LipidMatch-compatible input format by mapping required columns (m/z, retention time, intensity) and validating schema compliance.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:15:02.244710+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-data-column-mapping/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "LipidMatch is designed to be integrated with other open-source software to streamline the lipidomics workflow... The feature table can have nearly any format, allowing flexibility in choosing feature processing workflows.",
      "asbval:note": "Paper describes LipidMatch as designed for integration with multiple peak-picking tools, supporting the bridging concept.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "mass-spectrometry-data-column-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill bridges the file-format handoff between heterogeneous peak-picker tools and a downstream lipidomics annotation pipeline.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T06:15:02.244710+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/mass-spectrometry-data-column-mapping/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We introduce LipidMatch, an R-based tool for lipid identification for liquid chromatography tandem mass spectrometry workflows... Once feature tables are created for each biological substrate and each polarity, features can be directly annotated using LipidMatch",
      "asbval:note": "LipidMatch is confirmed as the target annotation tool that consumes peak tables.",
