      }
    },
    {
      "@id": "asbval:assertion/skill/lipid-library-format-specification/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Furthermore, lipidome coverage can be increased by the user community by adding new in silico fragmentation libraries. Libraries for LipidMatch can be developed using LipidBlast Templates or as explained in video tutorial 6 found in the Additional file 1.",
      "asbval:note": "Paper explicitly supports user integration of custom libraries for expanded lipidome coverage.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "lipid-library-format-specification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When you have curated or synthesized a set of custom lipid species (e.g., rare or organism-specific lipids, modified lipids, or synthetic standards) and need to integrate them into LipidMatch for candidate matching against your experimental MS/MS datasets.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
