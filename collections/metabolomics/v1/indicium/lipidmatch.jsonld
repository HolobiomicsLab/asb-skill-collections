      }
    },
    {
      "@id": "asbval:assertion/skill/lipid-library-format-specification/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "LipidMatch currently has over 250,000 lipid species spanning 56 lipid types contained in in silico fragmentation libraries.",
      "asbval:note": "The 500,000+ figure is incorrect; paper states 'over 250,000 lipid species'. The logic of the 'when NOT to use' clause is sound but based on inflated library size.",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
