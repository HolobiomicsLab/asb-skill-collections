    {
      "@id": "asbval:assertion/skill/hrms-data-format-parsing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "LipidMatch was developed and tested using data acquired from a Q-Exactive orbitrap mass spectrometer (Thermo Scientific, San Jose, CA). LipidMatch has also been tested using data acquired on an Agilent 6540 Q-TOF (Agilent Technologies, Santa Clara, CA). LipidMatch can be used with a variety of other vendors and data formats.",
      "asbval:note": "Paper confirms LipidMatch accepts multiple vendor formats and instruments, but the actual parsing/loading mechanism is delegated to external tools (MSConvert, MZmine, XCMS, MS-DIAL). LipidMatch itself operates on .ms2 files and CSV feature tables, not raw vendor formats. The card conflates data format parsing (done by MSConvert/MZmine) with LipidMatch's role (matching against libraries).",
      "asbval:perspicacite_kb": "asb-paper-10-1186-s12859-017-1744-3",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "hrms-data-format-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Parse and load experimental high-resolution tandem mass spectrometry (HRMS/MS) data from instrument-specific file formats (mzML, CSV peaklists, vendor formats) into a standardized in-memory representation suitable for fragment m/z matching and lipid identification workflows.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
