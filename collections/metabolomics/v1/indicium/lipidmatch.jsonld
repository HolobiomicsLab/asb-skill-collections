      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use this skill to prevent malformed entries from failing silent registration or producing incorrect candidate matches in downstream MS/MS analyses.",
      "eco:evidence_type": {
