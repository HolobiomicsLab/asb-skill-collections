    {
      "@id": "asbval:assertion/card/task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "QC4Metabolomics, a real-time quality control monitoring software for untargeted metabolomics data... The Shiny app is available as open-source code at https://github.com/stanstrup/QC4Metabolomics. Docker images and a docker-compose setup file are also provided for easy deployment",
      "asbval:note": "Paper confirms QC4Metabolomics exists and is open-source on GitHub with Docker deployment, but does NOT mention Semantic Release, v1.0.0 versioning, or release artifact reproduction workflows. The paper describes the software and its deployment, not its release engineering process.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c07078",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "title",
      "asbval:target_claim_text": "Reproduce the initial QC4Metabolomics v1.0.0 release artifact produced by Semantic Release",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
