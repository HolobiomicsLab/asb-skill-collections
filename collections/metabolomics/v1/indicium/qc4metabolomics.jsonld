    {
      "@id": "asbval:assertion/skill/yaml-json-structural-parsing/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "QC4Metabolomics, a real-time quality control monitoring software for untargeted metabolomics data... The Shiny app is available as open-source code at https://github.com/stanstrup/QC4Metabolomics. Docker images and a docker-compose setup file are also provided for easy deployment, along with demo data.",
      "asbval:note": "QC4Metabolomics is confirmed as an open-source project with versioned components (Docker images, code repository). However, the paper does not describe YAML/JSON workflow definition files as primary artifacts or discuss schema validation of such files. The tool is real but the claimed role (workflow definition file validation) is not supported by the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c07078",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "yaml-json-structural-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "QC4metabolomics as source project implementing QC systems with versioned workflow components; workflow definition file is a primary artifact",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T13:08:25.277605+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
