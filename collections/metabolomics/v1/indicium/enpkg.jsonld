      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-data-processing-and-annotation/017",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Spectral matching was performed in Python using the matchms (v0.20.0) package against an in silico database (ISDB-LOTUS)... The m/z tolerance for parent mass and fragment matching was set to 0.01. The minimal cosine score for matching was set to 0.2 with 6 minimal matching fragments... ppm tolerance set to 10.",
