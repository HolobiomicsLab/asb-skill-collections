    {
      "@id": "asbval:assertion/skill/molecular-networking-construction/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Molecular networking was performed in Python using the matchms (v0.20.0) package for both PI and NI modes. The m/z tolerance for fragment matching was set to 0.01, and the modified cosine score cutoff for edge creation was set to 0.7.",
      "asbval:note": "Paper generates network edges (adjacency relationships) via matchms but does not explicitly export a standalone 'spectral adjacency matrix' as a distinct output format. The network structure itself encodes adjacency information.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "molecular-networking-construction",
