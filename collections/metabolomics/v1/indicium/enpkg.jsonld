      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-data-processing-and-annotation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "structural annotation using SIRIUS and CSI:FingerID and chemical class annotation using CANOPUS... Exported features' MS2 spectra were submitted to SIRIUS/CSI:FingerID and CANOPUS annotation. For PI mode, SIRIUS v4.9.12, SIRIUS lib v4.6.1, and CSI lib v1.6.0... For NI mode, SIRIUS v5.5.4, SIRIUS lib v4.12.3, and CSI lib v2.6.3 were used... For both ionization modes, CANOPUS was run.",
      "asbval:note": "Confirmed with specific versions. SIRIUS/CSI:FingerID used for structure prediction; CANOPUS for chemical class annotation.",
