      }
    },
    {
      "@id": "asbval:assertion/skill/natural-products-workflow-orchestration/023",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the minimal sufficient metadata should contain: the LC-HRMS2 data filename(s), a sample identifier (sample_id), the sample's type (QC, blank or sample), a sample's sources identifier (source_id), and the sample source's taxonomical denomination (source_taxon)",
      "asbval:note": "Taxonomic metadata (source_taxon) explicitly required for workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
