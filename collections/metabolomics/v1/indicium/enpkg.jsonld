      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[7] - enpkg_meta_analysis",
      "asbval:target_claim_text": "Step 5 modular component: retrieves NPClassifier taxonomy and Wikidata IDs for annotated compounds; also includes optional ChEMBL integration",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
