      }
    },
    {
      "@id": "asbval:assertion/skill/sample-centric-metabolite-annotation/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Each sample is considered individually for taxonomic metadata standardization, feature detection, structural annotation, and FBMN. The resulting standardized data and information from all considered samples are then integrated into a single knowledge graph (KG)... the sample-centric approach ensures that the data generated over time can be added to existing data set(s) quickly and efficiently",
      "asbval:note": "The paper explicitly describes the sample-centric approach and iterative integration into a knowledge graph.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-centric-metabolite-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Process each sample independently to enable iterative knowledge-graph assembly",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:49:47.924007+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/sample-centric-metabolite-annotation/012",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the data for each sample are processed to perform feature detection and export the resulting files (Figure 2B, step 1), here, using MZmine... a local implementation of FBMN using the matchms package",
      "asbval:note": "The workflow explicitly follows MZmine feature detection with molecular networking (FBMN) via matchms.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-centric-metabolite-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After MZmine feature detection and molecular networking on a single LC-MS/MS DDA sample",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:49:47.924007+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/sample-centric-metabolite-annotation/013",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the data for each sample are processed to perform feature detection and export the resulting files (Figure 2B, step 1), here, using MZmine... All previously described files are then organized in a sample-centered directory architecture",
      "asbval:note": "The workflow explicitly requires MZmine preprocessing as a prerequisite step.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-centric-metabolite-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Input spectral data has not been processed by MZmine",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
