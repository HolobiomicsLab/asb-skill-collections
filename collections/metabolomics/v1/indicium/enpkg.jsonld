      }
    },
    {
      "@id": "asbval:assertion/skill/knowledge-graph-generation-and-validation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The 2D InChiKeys were mapped against all WD compounds to retrieve the corresponding WD ID of the compounds sharing the same 2D IK... This reconciliation allows the user to run federated SPARQL queries over ENPKG and WD to retrieve, for example, among a given sample's structural annotations, the ones already reported in the same taxon.",
      "asbval:note": "Tool and role confirmed. Paper describes Wikidata integration for compound metadata and federated queries.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "knowledge-graph-generation-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Wikidata \u2014 External URI source for compound identifiers and chemical metadata integrated into graph entities",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
