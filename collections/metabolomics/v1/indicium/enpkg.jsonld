      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Sample metadata must include or be resolvable to a taxonomic origin for Open Tree of Life integration",
      "eco:evidence_type": {
