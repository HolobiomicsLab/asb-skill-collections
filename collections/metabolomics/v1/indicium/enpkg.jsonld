    {
      "@id": "asbval:assertion/skill/molecular-networking-construction/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To compare the total spectral content of the different samples (1,600 plant extracts data set only), we used our recently developed MEMO analysis (v0.1.4). Spectra were processed as follows in PI and NI modes.",
      "asbval:note": "MEMO explicitly used for spectral fingerprint comparison across samples.",
