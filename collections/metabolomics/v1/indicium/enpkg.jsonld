    {
      "@id": "asbval:assertion/skill/sample-centric-metabolite-annotation/015",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Spectral matching was performed in Python using the matchms (v0.20.0) package against an in silico database (ISDB-LOTUS) of fragmented natural products structures... Exported features' MS2 spectra were submitted to SIRIUS/CSI:FingerID and CANOPUS annotation",
      "asbval:note": "Both ISDB and SIRIUS explicitly require MS/MS fragmentation spectra; MS1-only data would not be suitable.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-centric-metabolite-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: You only have MS1 precursor masses without fragmentation spectra",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
