    {
      "@id": "asbval:assertion/skill/spectral-data-processing-and-annotation/014",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The centroid mass detector was used for mass detection with the noise level set to 1.0E4 for MS level set to 1... The ADAP chromatogram builder was used and set to a minimum group size of scans of 5, minimum group intensity threshold of 1.0E4, minimum highest intensity of 5.0E5, and m/z tolerance of 12 ppm.",
      "asbval:note": "Confirmed. Detailed MZmine parameters provided for NI mode; PI mode parameters referenced in prior publication.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-data-processing-and-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "parameters",
      "asbval:target_claim_text": "MZmine feature detection with noise level 1.0E4 (MS1), centroid mass detector, ADAP chromatogram builder with minimum group size 5 scans, minimum group intensity 1.0E4, minimum highest intensity 5.0E5, m/z tolerance 12 ppm",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:50:20.350884+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-data-processing-and-annotation/015",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For PI mode, SIRIUS v4.9.12, SIRIUS lib v4.6.1, and CSI lib v1.6.0... were used with following parameters: a ppm tolerance set to 10, maximum m/z of 800, 10 candidates considered with the following adducts: [M + H]+, [M + NH4]+, [M + K]+, [M + Na]+... For NI mode, SIRIUS v5.5.4, SIRIUS lib v4.12.3, and CSI lib v2.6.3 were used with the following parameters: a ppm tolerance set to 10, maximum m/z of 800, 10 candidates considered with the following adducts: [M \u2013 H]\u2212, [M + K-2H]\u2212, [M + Na-2H]\u2212.",
      "asbval:note": "Confirmed. Specific SIRIUS versions and parameters provided for both ionization modes.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-data-processing-and-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "parameters",
      "asbval:target_claim_text": "SIRIUS v4.9.12 (PI mode) and v5.5.4 (NI mode) with ppm tolerance 10, maximum m/z 800, 10 candidates, adducts [M+H]+, [M+NH4]+, [M+K]+, [M+Na]+ (PI) or [M-H]\u2212, [M+K-2H]\u2212, [M+Na-2H]\u2212 (NI)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:50:20.350884+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-data-processing-and-annotation/016",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Molecular networking was performed in Python using the matchms (v0.20.0) package... The m/z tolerance for fragment matching was set to 0.01, and the modified cosine score cutoff for edge creation was set to 0.7. The max_links parameter was set to 10 with a top_n parameter set to 15.",
      "asbval:note": "Confirmed. Detailed matchms parameters provided.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
