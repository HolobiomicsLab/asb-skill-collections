      }
    },
    {
      "@id": "asbval:assertion/skill/repository-cloning-and-structure-navigation/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Molecular networking was performed in Python using the matchms (v0.20.0) package for both PI and NI modes... The scripts used for Molecular Networking are available at https://github.com/enpkg/enpkg_full/tree/main/03_enpkg_mn_isdb_isdb_taxo. [And:] Spectral matching was performed in Python using the matchms (v0.20.0) package against an in silico database (ISDB-LOTUS)... The scripts used for spectral matching and taxonomical/chemical reweighting are available at https://github.com/enpkg/enpkg_full/tree/main/03_enpkg_mn_isdb_isdb_taxo.",
      "asbval:note": "Paper explicitly references enpkg_mn_isdb_isdb_taxo (note: paper uses 'isdb_isdb_taxo' not 'mn_isdb_taxo') for molecular networking and ISDB annotation with taxonomical reweighting.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "repository-cloning-and-structure-navigation",
