      "asbval:target_claim_field": "tools[5] - enpkg_mn_isdb_taxo",
      "asbval:target_claim_text": "Step 3 modular component: generates molecular networks and performs ISDB annotation with taxonomical reweighting",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:49:26.796417+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
