    {
      "@id": "asbval:assertion/skill/repository-cloning-and-structure-navigation/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The name of the producing organism (binomial nomenclature) of each sample was resolved using the Open Tree of Life (OTT) taxonomy (v3.5) to retrieve the OTT ID and the Wikidata ID. The scripts used for this taxonomic resolution are available in https://github.com/enpkg/enpkg_full/tree/main/02_enpkg_taxo_enhancer.",
      "asbval:note": "Paper explicitly references enpkg_taxo_enhancer for taxonomic resolution and Wikidata linking.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "repository-cloning-and-structure-navigation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[4] - enpkg_taxo_enhancer",
      "asbval:target_claim_text": "Step 2 modular component: resolves taxonomy and links to Wikidata",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:49:26.796417+00:00",
      "sepio:credibility_status": {
