    {
      "@id": "asbval:assertion/skill/spectral-data-processing-and-annotation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The spectral annotations (non stereochemically-defined chemical structures identified by their 2D InChIKeys) are then linked, if present, with their stereochemically defined counterparts in WD (identified by their complete InChIKeys)... The 2D InChiKeys were mapped against all WD compounds to retrieve the corresponding WD ID of the compounds sharing the same 2D IK.",
      "asbval:note": "Confirmed. Wikidata used for compound identifier reconciliation and federated queries.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acscentsci-3c00800",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-data-processing-and-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
