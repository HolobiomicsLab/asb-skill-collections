    {
      "@id": "asbval:assertion/skill/noise-filtering-threshold-application/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The peaks from the AIF spectra with correlation greater than a threshold \u03b8 defined by the user (usually 0.7\u20130.8, default 0.8) are gathered to form the pseudo-MS/MS spectrum.",
      "asbval:note": "Paper applies correlation-based thresholding (Pearson r > 0.7\u20130.8) to filter pseudo-MS/MS peaks, not intensity-based noise thresholds. The filtering is based on peak co-elution correlation, not raw intensity values. The card's claim of 'intensity-based noise thresholds' does not match the paper's actual method of correlation-based parent-fragment linking.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "noise-filtering-threshold-application",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply intensity-based noise thresholds to LC-MS/MS spectra to remove low-intensity signals and retain only biologically or analytically relevant fragment peaks. This preprocessing step is essential before library entry generation or metabolite annotation to improve signal-to-nois",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:46:22.243855+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/noise-filtering-threshold-application/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow is designed to annotate features obtained from LC\u2013MS experiments processed using software such as XCMS or MZmine, which may include all types of ions, namely, isotopologues, adducts, and in-source fragments.",
      "asbval:note": "Paper addresses AIF spectra annotation and fragment matching, but the filtering mechanism is correlation-based (parent-fragment peak shape matching), not intensity-based noise thresholding as claimed.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "partial",
