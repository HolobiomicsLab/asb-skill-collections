    {
      "@id": "asbval:assertion/skill/ms-ms-spectrum-peak-annotation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow was designed for feature-by-feature annotation on one or more LC\u2013MS AIF samples... The workflow can be divided into seven steps... (1)Data input. The workflow starts with a table of features (m/z and RT values) to be annotated (target features)... Positive and negative ionization modes for the same chromatography are analyzed separately... A random selection of 100 LC\u2013MS AIF chromatograms from both Lipid+ and Lipid\u2013 as well as HILIC+ datasets from the MESA cohort was processed in R using XCMS23 version 3.4.4 and RAMClustR package5 to obtain pseudo-MS/MS spectra",
      "asbval:note": "Paper confirms XCMS is used for processing raw LC-MS data prior to MetaboAnnotatoR annotation workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ms-ms-spectrum-peak-annotation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
