      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-result-visualization-verification/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow starts with a table of features (m/z and RT values) to be annotated (target features) and samples where the target features have been detected. This is used to load the raw AIF LC\u2013MS data which should be in the vendor-neutral formats mzML or netCDF. Alternatively, a RAMClustR R object containing deconvolved pseudo-MS/MS spectra for the features can also be used as data input.",
      "asbval:note": "The paper confirms that MetaboAnnotatoR accepts either raw LC-MS data or pre-processed RAMClustR objects with pseudo-MS/MS spectra, supporting the upstream preprocessing requirement.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-result-visualization-verification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Raw LC-MS data has not been processed to pseudo-MS/MS spectra via xcms and RamClustR; MetaboAnnotatoR requires centroid-mode AIF chromatograms and pseudo-MS/MS spectra as input.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:48:13.517896+00:00",
      "sepio:credibility_status": {
