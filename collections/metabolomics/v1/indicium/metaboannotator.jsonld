      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply intensity-based noise thresholds to LC-MS All-ion fragmentation (AIF) spectra and need to generate or match against ion fragment databases.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
