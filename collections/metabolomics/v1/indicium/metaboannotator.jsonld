    {
      "@id": "asbval:assertion/card/10_1021_acs_analchem_1c03032__task_001/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For each target feature, a list of the candidates ranked by score is produced, which includes the metabolite name, m/z matched, m/z error (ppm), the number of matched fragments, and score... The matches for each target feature are compiled and output to a table (.csv)",
      "asbval:note": "Paper describes output tables with ranked candidates and scores, but does not specifically mention 'three features annotated' or 'LPC(14:0) as rank-1 for feature 3'. These appear to be specific expected results from a particular test case not documented in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
