    {
      "@id": "asbval:assertion/skill/spectral-result-visualization-verification/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The matches for each target feature are compiled and output to a table (.csv) and graphical outputs are saved as .pdf files. For each target feature, a list of the candidates ranked by score is produced... Additionally, a list containing all rank 1 annotations is produced for quick result inspection. Graphical outputs contain, for each ranked result, the pseudo-MS/MS spectrum comprising the matched peaks and the corresponding EICs",
      "asbval:note": "The paper confirms .csv tables, .pdf graphical outputs, and ranked candidate lists. However, the paper does not explicitly mention MGF file output format in the provided passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectral-result-visualization-verification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "all expected output file types (global results table, ranked results, ranked spectra PDFs, pseudo-MS/MS MGF file) are present and non-empty in the output directory",
      "eco:evidence_type": {
