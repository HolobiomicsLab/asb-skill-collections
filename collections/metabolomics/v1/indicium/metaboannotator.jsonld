    {
      "@id": "asbval:assertion/skill/pseudo-ms-ms-spectra-ranking-and-curation/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow was designed for feature-by-feature annotation on one or more LC\u2013MS AIF samples... The workflow can be divided into seven steps... (1)Data input. The workflow starts with a table of features (m/z and RT values) to be annotated (target features)... This is used to load the raw AIF LC\u2013MS data which should be in the vendor-neutral formats mzML or netCDF. Alternatively, a RAMClustR5 R object containing deconvolved pseudo-MS/MS spectra for the features can also be used as data input.",
      "asbval:note": "XCMS confirmed as producing feature data used in the workflow. Paper states: 'The workflow was designed for feature-by-feature annotation on one or more LC\u2013MS AIF samples... processed using software such as XCMS23 or MZmine,24'",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pseudo-ms-ms-spectra-ranking-and-curation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "xcms - Produces peak-picked feature data and xcmsSet object required alongside RAMClustR spectra for annotation ranking",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:46:58.999176+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/pseudo-ms-ms-spectra-ranking-and-curation/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow has been implemented as an open-source R package MetaboAnnotatoR... A random selection of 100 LC\u2013MS AIF chromatograms from both Lipid+ and Lipid\u2013 as well as HILIC+ datasets from the MESA cohort was processed in R using XCMS23 version 3.4.4 and RAMClustR package5",
      "asbval:note": "R confirmed as runtime environment. However, the paper specifies XCMS version 3.4.4 and does not mention R version 4.5.0 or higher as a requirement. The specific version requirement '4.5.0 or higher' is not stated in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "pseudo-ms-ms-spectra-ranking-and-curation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
