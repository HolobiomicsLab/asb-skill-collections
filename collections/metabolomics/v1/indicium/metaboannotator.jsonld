    {
      "@id": "asbval:assertion/card/10_1021_acs_analchem_1c03032__task_003/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Each entry in a library file contains the (parent) metabolite name and adduct m/z and expected fragment m/z values... The libraries are organized as a collection of .csv files, one for each combination of a metabolite or class of metabolites (lipids) and an adducting species",
      "asbval:note": "The paper confirms that libraries are stored as CSV files with parent m/z and fragment m/z values. However, the paper does not describe 'intensity' as part of library entries\u2014in fact, it explicitly states: 'This has the advantage that users can input fragment information even when MS/MS spectra are not available in a spectral database... This also obviates variations in intensity from MS/MS spectra acquired in different instruments with different fragmentation energies.' Fragment match scores (occurrence scores) are mentioned as part of the annotation process, not library entry generation.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_003",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "CSV library entry containing annotated fragments with mass-to-charge, intensity, and fragment match scores",
      "eco:evidence_type": {
