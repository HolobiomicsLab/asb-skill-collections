    {
      "@id": "asbval:assertion/claim/claim_001",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "MetaboAnnotatoR is designed to perform metabolite annotation of features from LC-MS All-ion fragmentation (AIF) datasets using ion fragment databases.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:source_excerpt": "MetaboAnnotatoR is designed to perform metabolite annotation of features from\nLC-MS All-ion fragmentation (AIF) datasets, using ion fragment databases.",
