    {
      "@id": "asbval:assertion/skill/peak-detection-threshold-application/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The peaks from the AIF spectra with correlation greater than a threshold \u03b8 defined by the user (usually 0.7\u20130.8, default 0.8) are gathered to form the pseudo-MS/MS spectrum. If no pseudo-MS/MS spectrum is obtained (i.e., no peaks with r > \u03b8), the full AIF spectrum at the feature RT is used as the pseudo-MS/MS spectrum.",
      "asbval:note": "Paper implements correlation-based thresholding (Pearson r > \u03b8) for pseudo-MS/MS peak selection, not explicit noise/SNR or marker peak thresholds. The functional goal (filtering peaks) is present, but the mechanism differs from the card's description.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "peak-detection-threshold-application",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Application of noise and marker peak thresholds to filter MS/MS spectral peaks during library conversion or feature annotation",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:46:41.138412+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/pseudo-ms-ms-spectra-ranking-and-curation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For each candidate, the m/z of adduct and fragments will be compared with those of pseudo-MS/MS peaks using a 0.01 Da tolerance (default for Q-ToF type instruments, modifiable by the user)... (6)Candidate scoring and ranking. The score indicating the quality of the match between a library candidate and a target feature is composed of two parts: one measuring the similarity in m/z between the target and candidate and one gauging the similarity of the fragmentation patterns",
      "asbval:note": "Core workflow function confirmed: ranking candidates by matching fragments to pseudo-MS/MS spectra and scoring them.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pseudo-ms-ms-spectra-ranking-and-curation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill ranks and curates candidate metabolite annotations from pseudo-MS/MS spectra generated by RAMClustR, matching fragment ions against lipid or metabolite databases to identify and prioritize the most confident assignments.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:46:58.999176+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
