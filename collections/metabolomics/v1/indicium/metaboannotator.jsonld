    {
      "@id": "asbval:assertion/skill/annotation-candidate-comparative-scoring/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The score indicating the quality of the match between a library candidate and a target feature is composed of two parts: one measuring the similarity in m/z between the target and candidate and one gauging the similarity of the fragmentation patterns: S = Smz + Sma... The match score Sma is then the sum of occurrence scores for all fragments which match pseudo-MS/MS.",
      "asbval:note": "Core research question is directly supported by the paper's scoring and ranking methodology (step 6 of workflow).",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "annotation-candidate-comparative-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Rank and compare metabolite annotation candidates for LC-MS features by matching fragment ion patterns against libraries and scoring candidate matches to identify the most plausible metabolite identity.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:42:38.537713+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/annotation-candidate-comparative-scoring/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For each candidate, the m/z of adduct and fragments will be compared with those of pseudo-MS/MS peaks... For each target feature, a list of the candidates ranked by score is produced, which includes the metabolite name, m/z matched, m/z error (ppm), the number of matched fragments, and score.",
      "asbval:note": "Paper explicitly describes ranking multiple candidates per feature and using fragment matching to determine best match.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "annotation-candidate-comparative-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill is essential when a single LC-MS feature generates multiple candidate annotations and you need to determine which is most likely correct based on fragment ion agreement.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:42:38.537713+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/annotation-candidate-comparative-scoring/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "All-ion fragmentation (AIF) LC-MS/MS acquisition provides fragmentation data at no additional experimental time cost... we propose a novel approach for automated annotation of isotopologues, adducts, and in-source fragments from AIF LC-MS datasets by combining correlation-based parent-fragment linking with molecular fragment matching.",
      "asbval:note": "Paper focuses on AIF LC-MS data and fragment matching against libraries.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "annotation-candidate-comparative-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have pseudo-MS/MS spectra from LC-MS all-ion fragmentation (AIF) data that have been matched against one or more ion fragment databases",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
