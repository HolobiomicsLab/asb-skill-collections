    {
      "@id": "asbval:assertion/skill/pseudo-ms-ms-spectra-ranking-and-curation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow has been implemented as an open-source R package MetaboAnnotatoR, providing tools for automated annotation, reporting, and visualization.",
      "asbval:note": "MetaboAnnotatoR confirmed as R package for annotation and ranking. However, the paper does not explicitly name a function called 'annotateRC'. The paper describes the workflow steps (steps 1-7) but does not reference a specific function by that name. The workflow performs ranking via the 'Candidate scoring and ranking' step (step 6), but the exact function name 'annotateRC' is not verified in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
      "asbval:supported_raw": "partial",
