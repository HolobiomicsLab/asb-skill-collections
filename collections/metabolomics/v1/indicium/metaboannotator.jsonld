        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/metabolite-candidate-ranking-interpretation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The outputs when using RAMClustR deconvolved pseudo-MS/MS are equivalent except that EICs for the matched features are not shown... The outputs from Figure 2 allow the analyst to evaluate the quality of the annotation and decide on its confidence.",
      "asbval:note": "Paper supports evaluation of multiple candidates with different scores; lipid homolog scenario is consistent with paper's discussion of lipid annotation and ranking system.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
