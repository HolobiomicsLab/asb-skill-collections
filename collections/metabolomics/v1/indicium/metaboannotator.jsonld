      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Alternatively, a RAMClustR5 R object containing deconvolved pseudo-MS/MS spectra for the features can also be used as data input.",
      "asbval:note": "RAMClustR confirmed as source of pseudo-MS/MS spectra used in the workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-1c03032",
