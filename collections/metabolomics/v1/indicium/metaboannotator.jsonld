      }
    },
    {
      "@id": "asbval:assertion/skill/noise-filtering-threshold-application/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow is designed for feature-by-feature annotation on one or more LC\u2013MS AIF samples... A random selection of 100 LC\u2013MS AIF chromatograms from both Lipid+ and Lipid\u2013 as well as HILIC+ datasets from the MESA cohort was processed in R using XCMS version 3.4.4 and RAMClustR package to obtain pseudo-MS/MS spectra",
      "asbval:note": "XCMS is confirmed as upstream processing tool for peak-picking in the workflow.",
