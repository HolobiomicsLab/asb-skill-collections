      "context": "explicit",
      "subject": "explicit",
      "qualifier": "consistent_with",
      "relation": "describes",
      "object": "pyOpenMS-Viz is a Python library that provides a simple interface for extending the plotting capabilities of Pandas DataFrames for creating static or interactive visualizations of mass spectrometry data.",
