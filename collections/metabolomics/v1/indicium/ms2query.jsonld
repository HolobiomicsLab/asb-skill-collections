    {
      "@id": "asbval:assertion/skill/candidate-match-retrieval/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2Query is available as a well-tested and open-source Python library... The workflow for running MS2Query first uses MS2Deepscore to calculate spectral similarity scores between all library spectra and a query spectrum... Next, the top 2000 spectra with the highest MS2Deepscore are selected. MS2Query optimises re-ranking of the best analogue or exact match at the top by using a random forest... To reduce the toll on working memory, this information is stored in a SQLite library.",
      "asbval:note": "Fully supported: paper describes SQLite-backed library storage, pre-computed embeddings, and re-ranking workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "candidate-match-retrieval",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Retrieves a ranked set of library spectral candidates from a SQLite-backed spectral library for a given query MS/MS spectrum using pre-computed embeddings and spectral similarity scoring.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:39:28.104175+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/candidate-match-retrieval/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2Query searches for both exact matches and analogues in a reference library. First, potential candidates are selected based on MS2Deepscore, followed by re-ranking the spectra by using a random forest model.",
      "asbval:note": "Directly supported by paper's description of the two-stage workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "candidate-match-retrieval",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "bridges rapid full-library comparison with intelligent re-ranking to surface both exact matches and structurally similar analogues",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
