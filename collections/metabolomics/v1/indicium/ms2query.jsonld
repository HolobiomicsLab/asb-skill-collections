    {
      "@id": "asbval:assertion/card/https___zenodo_org_badge_latestdoi_306595295_svg__task_003/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2Query outputs a CSV file with all relevant information about the found matches for the query spectra. For each found analogue it also returns the chemical compound classes based on ClassyFire annotations to facilitate biochemical interpretation of the results.",
      "asbval:note": "Paper confirms MS2Query outputs scored candidate matches in CSV format, but does not name the output fields as 'average InChIKey score' or 'neighbourhood score'. The actual features used are: Spec2Vec similarity, precursor m/z, precursor m/z difference, average MS2Deepscore over 10 similar molecules, and average Tanimoto score for those 10 molecules.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
