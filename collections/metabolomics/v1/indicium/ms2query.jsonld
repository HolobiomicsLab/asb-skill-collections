    {
      "@id": "asbval:assertion/skill/spectral-library-candidate-ranking/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2Query searches for both exact matches and analogues in a reference library... MS2Query optimises re-ranking of the best analogue or exact match at the top by using a random forest that combines five features. The random forest predicts a score between 0 and 1 between each library and query mass spectrum. By using a minimum threshold for this score, unreliable matches can be filtered out.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
