    {
      "@id": "asbval:assertion/skill/ms2-data-preprocessing-pipeline/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The dataset was first cleaned using matchms. The metadata was cleaned to get a uniform format and to remove or correct misplaced metadata... The intensities of the mass fragmentation peaks are normalised. Peaks above 1000 Da were removed and peaks with an intensity of less than 0,1 % of the highest peak were removed. For spectra with more than 500 peaks, the peaks with the lowest intensities were removed. Spectra with less than 3 peaks were completely removed from the library.",
      "asbval:note": "Paper explicitly describes preprocessing steps including normalization, noise filtering (intensity thresholds, peak removal), and quality validation (minimum peak count requirement).",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ms2-data-preprocessing-pipeline",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "A systematic preprocessing workflow that prepares raw MS/MS spectral data for library matching by applying normalization, noise filtering, and quality validation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
