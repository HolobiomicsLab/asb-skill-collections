    {
      "@id": "asbval:assertion/card/https___zenodo_org_badge_latestdoi_306595295_svg__task_003/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2Query optimises re-ranking of the best analogue or exact match at the top by using a random forest that combines five features... As input for the random forest model, MS2Query uses 5 different features, calculated between the query spectrum and each of the 2000 preselected library spectra. These features are Spec2Vec similarity score, query precursor m/z, precursor m/z difference, a weighted average MS2Deepscore over 10 chemically similar library molecules, and the average Tanimoto score for these 10 chemically similar library molecules.",
      "asbval:note": "Paper describes computing 'average MS2Deepscore over 10 chemically similar library molecules' and 'average Tanimoto score for these 10 chemically similar library molecules', not 'average InChIKey score' or 'neighbourhood score' by those names. The 10 chemically similar molecules are selected based on Tanimoto score of chemical fingerprints derived from InChIKeys, but the scoring features are named differently than the card claims.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_003",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "How does the scoring module compute average InChIKey score and neighbourhood score for candidate matches in MS2Query?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:36:18.803094+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
