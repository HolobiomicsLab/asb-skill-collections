    {
      "@id": "asbval:assertion/skill/ms-ms-spectrum-parsing/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "First, an rdkit35 daylight fingerprint (2,048 bits) is generated from the SMILES for each unique 2D structure in the library. The SMILES were first sanitized by rdkit.",
      "asbval:note": "RDKit is confirmed to be used for generating molecular fingerprints from SMILES and for sanitizing SMILES strings. However, the paper does not describe it as 'optional' or explicitly as a dependency for extracting molecular classes; it is used for fingerprint generation during model training, not during spectrum parsing per se.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "ms-ms-spectrum-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "RDKit \u2013 Optional dependency for extracting molecular classes and computing chemical descriptors from SMILES/InChI metadata during library creation",
