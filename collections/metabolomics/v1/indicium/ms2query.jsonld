    {
      "@id": "asbval:assertion/skill/precursor-mass-filtering/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow for running MS2Query first uses MS2Deepscore to calculate spectral similarity scores between all library spectra and a query spectrum... Next, the top 2000 spectra with the highest MS2Deepscore are selected.",
