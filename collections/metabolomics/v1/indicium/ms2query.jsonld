    {
      "@id": "asbval:assertion/skill/candidate-match-retrieval/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The biggest speed improvement was achieved by pre-calculating mass spectral embeddings for Spec2Vec and MS2Deepscore... The library spectra are already known, therefore the embeddings for all library spectra are pre-calculated and stored.",
      "asbval:note": "Paper confirms pre-computed embeddings are central to the workflow.",
