    {
      "@id": "asbval:assertion/skill/library-analogue-search-branching/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2Query was designed to search for analogues and exact matches in one run... MS2Query searches for both exact matches and analogues in a reference library.",
