    {
      "@id": "asbval:assertion/skill/scoring-module-unit-testing/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2Query uses five different features, calculated between the query spectrum and each of the 2000 preselected library spectra. These features are Spec2Vec similarity score, query precursor m/z, precursor m/z difference, a weighted average MS2Deepscore over 10 chemically similar library molecules, and the average Tanimoto score for these 10 chemically most similar library molecules.",
      "asbval:note": "Paper describes the scoring module computing five features (Spec2Vec similarity, precursor m/z, precursor m/z difference, average MS2Deepscore, average Tanimoto score) via a random forest model, not specifically 'InChIKey score' and 'neighbourhood score' as named in the card. The card's terminology does not match the paper's actual scoring outputs. The paper does validate these scores through benchmarking and cross-validation, but not through unit tests as the card claims.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "scoring-module-unit-testing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
