    {
      "@id": "asbval:assertion/skill/inchikey-structural-similarity-scoring/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow for running MS2Query first uses MS2Deepscore to calculate spectral similarity scores between all library spectra and a query spectrum. Next, the top 2000 spectra with the highest MS2Deepscore are selected.",
      "asbval:note": "MS2Deepscore does pre-rank the top 2000 candidates correctly. However, 'InChIKey scoring' does not operate on this set in the way the card implies. Instead, Tanimoto scoring (fingerprint-based) and MS2Deepscore averaging operate on the top 2000 to select the 10 most chemically similar library molecules.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "inchikey-structural-similarity-scoring",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[MS2Deepscore].role",
      "asbval:target_claim_text": "Pre-ranks top 2000 spectral candidates by deep learning similarity; InChIKey scoring operates on this filtered candidate set",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
