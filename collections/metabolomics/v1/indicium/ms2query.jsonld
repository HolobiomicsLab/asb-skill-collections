    {
      "@id": "asbval:assertion/card/https___zenodo_org_badge_latestdoi_306595295_svg__task_003/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To test the performance of MS2Query, models were trained using publicly available mass spectra from GNPS... The performance on finding exact matches and finding analogues was tested separately using two different test sets... Benchmarking MS2Query on reference mass spectra and experimental case studies demonstrate improved reliability and scalability.",
      "asbval:note": "Paper includes extensive benchmarking and testing of the scoring module's correctness via 20-fold cross-validation and case studies.",
