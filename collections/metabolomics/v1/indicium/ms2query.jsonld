      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-intensity-normalisation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For doing the modified cosine score calculations the implementation of matchms was used, which is optimized for performance... The dataset was first cleaned using matchms. The metadata was cleaned to get a uniform format and to remove or correct misplaced metadata.",
      "asbval:note": "matchms is confirmed as a Python library used for spectrum handling and data cleaning operations in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-intensity-normalisation",
