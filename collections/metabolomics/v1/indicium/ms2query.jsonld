    {
      "@id": "asbval:assertion/skill/library-analogue-search-branching/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2Query was designed to search for analogues and exact matches in one run... The workflow for running MS2Query first uses MS2Deepscore to calculate spectral similarity scores between all library spectra and a query spectrum... Next, the top 2000 spectra with the highest MS2Deepscore are selected. MS2Query optimises re-ranking of the best analogue or exact match at the top by using a random forest that combines five features.",
      "asbval:note": "Fully supported. The paper describes the exact control-flow architecture for handling both match types in a single pass.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "library-analogue-search-branching",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When you need to reconstruct or validate the control-flow architecture of a spectral search system that must handle both exact-match library lookups and analogue discovery in a single pass",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:03.332098+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
