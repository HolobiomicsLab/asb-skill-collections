    {
      "@id": "asbval:assertion/skill/candidate-match-retrieval/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here we present MS2Query, a machine learning-based tool that integrates mass spectral embedding-based chemical similarity predictors (Spec2Vec and MS2Deepscore)... MS2Query optimises re-ranking of the best analogue or exact match at the top by using a random forest that combines five features.",
      "asbval:note": "MS2Query is the primary orchestrating tool; role is accurately described.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "candidate-match-retrieval",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "MS2Query: Main tool that orchestrates full-library spectral comparison and re-ranking candidate matches using pre-computed embeddings and random forest scoring",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:39:28.104175+00:00",
