      }
    },
    {
      "@id": "asbval:assertion/skill/candidate-match-retrieval/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The workflow for running MS2Query first uses MS2Deepscore to calculate spectral similarity scores between all library spectra and a query spectrum... Next, the top 2000 spectra with the highest MS2Deepscore are selected.",
      "asbval:note": "MS2Deepscore role is accurately described; it is used for initial candidate selection.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "candidate-match-retrieval",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "MS2Deepscore: Computes neural network-based spectral similarity embeddings used to retrieve top 2000 candidates before re-ranking",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
