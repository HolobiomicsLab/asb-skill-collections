      }
    },
    {
      "@id": "asbval:assertion/skill/ms-ms-spectrum-parsing/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The precursor m/z is the only metadata entry that is required for MS2Query and which serves to calculate the mass differences. Other spectra metadata such as retention time, SMILES, or compound names can be returned for results found by MS2Query.",
      "asbval:note": "Paper confirms that precursor m/z is required and that ionization mode is used (positive/negative mode spectra are handled separately). However, 'charge' is not explicitly mentioned as a required or extracted metadata field. Pickled matchms objects and USI are not mentioned in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "ms-ms-spectrum-parsing",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope \u2013 When to use",
      "asbval:target_claim_text": "You have raw or preprocessed MS/MS spectra in one of the supported formats (MGF, mzML, mzXML, JSON, MSP, mzXML, pickled matchms objects, or USI) and need to extract peak lists (m/z and intensity pairs) along with metadata (precursor m/z, charge, ionization mode) to feed into MS2Q",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:18.124500+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/ms-ms-spectrum-parsing/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By using pre-computed MS2Deepscore embeddings for library spectra, this full-library comparison can be computed much faster than existing alternatives",
      "asbval:note": "Paper confirms that pre-computed embeddings are used and that parsing would be unnecessary in such cases.",
