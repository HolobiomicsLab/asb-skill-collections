      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it when you need to separate exact-match candidate matches (precursor m/z difference near zero) from structural analogue matches, or when your research goal requires high specificity and you want to filter out matches with large precursor mass deviations that are unlikely to ",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
