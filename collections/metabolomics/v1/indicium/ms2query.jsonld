    {
      "@id": "asbval:assertion/skill/version-control-feature-branch-management/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2Query, a machine learning-based tool that integrates mass spectral embedding-based chemical similarity predictors (Spec2Vec and MS2Deepscore) as well as detected precursor masses to rank potential analogues and exact matches.",
      "asbval:note": "MS2Query is the primary subject of the paper and is extensively documented as a tool for searching analogues and exact matches in mass spectral libraries.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "version-control-feature-branch-management",
      "asbval:target_artifact_kind": "skill_bundle",
