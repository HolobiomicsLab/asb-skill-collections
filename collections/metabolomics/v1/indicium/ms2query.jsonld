    },
    {
      "@id": "asbval:assertion/skill/candidate-match-retrieval/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "As input for the random forest model, MS2Query uses 5 different features, calculated between the query spectrum and each of the 2000 preselected library spectra. These features are 1. Spec2Vec similarity, 2. query precursor m/z, 3. precursor m/z difference, 4. an average MS2Deepscore over 10 chemically similar library molecules, and 5. the average Tanimoto score for these 10 chemically most similar library molecules.",
      "asbval:note": "Spec2Vec is confirmed as one of five features used in re-ranking.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "candidate-match-retrieval",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Spec2Vec: Provides spectral feature vectorization contributing to the five combined features used in re-ranking",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:39:28.104175+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/candidate-match-retrieval/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "MZMine is not mentioned anywhere in the paper. The paper mentions MSCluster (for consensus spectra generation) and XCMS3 (for LC-MS feature picking), but not MZMine. The card appears to conflate general preprocessing tools with those actually used in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "no",
