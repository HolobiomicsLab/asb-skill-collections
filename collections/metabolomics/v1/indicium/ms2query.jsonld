    {
      "@id": "asbval:assertion/skill/library-analogue-search-branching/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2Query was designed to search for analogues and exact matches in one run... The workflow for running MS2Query first uses MS2Deepscore to calculate spectral similarity scores between all library spectra and a query spectrum... Next, the top 2000 spectra with the highest MS2Deepscore are selected. MS2Query optimises re-ranking of the best analogue or exact match at the top by using a random forest that combines five features.",
      "asbval:note": "Fully supported. Paper explicitly states MS2Query searches for both exact matches and analogues in one run, uses MS2Deepscore for initial selection, and random forest for re-ranking.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-37446-4",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "library-analogue-search-branching",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "MS2Query implements a unified workflow that internally branches between reliable true library matching and fast analogue search within a single run, using MS2Deepscore embeddings and random forest re-ranking to automatically select the most likely match type.",
