      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "RDKit: Used to compute molecular structure annotations (SMILES, InChI, InChIKey) and estimated molecular classes for library spectra",
      "eco:evidence_type": {
