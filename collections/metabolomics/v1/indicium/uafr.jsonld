    {
      "@id": "asbval:assertion/skill/summary-statistics-table-construction/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Table 1 Summary of NMDS and ANOSIM calculation for models processed with uafR... ANOSIM Model NMDS Stress R P # Compounds in Final Table Original Ponce et al. 2022 0.10 0.20 0.0013 3 uafR Ponce et al. 2022 0.11 0.185 0.0093 a>65% Match Factor 0.17 0.068 0.174 27 >75% Match Factor 0.11 0.016 0.331 16 >88.9 Match Factor 0.15 0.034 0.293 0 >97.2 Match Factor 0.04 -0.034 0.583",
