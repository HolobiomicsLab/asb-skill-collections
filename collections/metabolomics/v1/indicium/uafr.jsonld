      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validates that a raw GC-MS peak table (typically CSV output from Agilent Unknowns Analysis) conforms to the required schema before downstream processing.",
      "eco:evidence_type": {
