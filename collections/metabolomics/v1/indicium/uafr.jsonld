    {
      "@id": "asbval:assertion/skill/summary-statistics-table-construction/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We have developed an R package, uafR, that automates a grueling retrieval process for gas -chromatography coupled mass spectrometry (GC -MS) data... The package was tested in two experimental contexts: (1) A dataset of purified internal standards... (2) A large, previously published dataset, where the number and types of compounds identified were comparable (or identical) to those identified with the traditional manual peak annotation process.",
      "asbval:note": "uafR is the R package developed in the paper for GC-MS data processing, including functions like spreadOut() and mzExacto() for preprocessing and filtering.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
