      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "It performs these comparisons using the 'fmcsBatch()' function from the R package fmcsR",
      "asbval:note": "fmcsR is explicitly used for structural comparisons. Atomic features (rings, groups, atoms, charges) are extracted by ChemmineR, not fmcsR directly, but fmcsR performs the matching.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
