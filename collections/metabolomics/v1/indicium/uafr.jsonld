    {
      "@id": "asbval:assertion/skill/spectral-library-matching-and-m-z-peak-ranking/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The first function for GC -MS data is 'spreadOut().' Running this function on properly formatted GC -MS input will automatically prepare the data for the next steps in the processing pipeline. [...] Subsequent functions are designed to seamlessly interact with the list and will automatically use relevant information collected during 'spreadOut()'.",
      "asbval:note": "spreadOut() is confirmed as the first step in the pipeline.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-library-matching-and-m-z-peak-ranking",
