      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Agilent Unknowns Analysis \u2014 generates raw GC-MS peak list CSV with required column schema (Component.RT, Base.Peak.MZ, Component.Area, Compound.Name, Match.Factor, File.Name)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:32:17.350612+00:00",
