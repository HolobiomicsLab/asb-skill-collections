    {
      "@id": "asbval:assertion/skill/chemical-match-score-interpretation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The 'categorate()' function will then take the input library (saved as a '.CSV') and compare every chemical of interest to the chemicals in each user-defined 'chemical category,' returning two additional data frames\u2014(1) whether it has a strong (Tanimoto similarity greater than 0.95) or moderate (greater than 0.85) structural match with any of the chemicals in each group; and, (2) for strong matches, the name of a chemical that it was most similar to. It performs these comparisons using the 'fmcsBatch()' function from the R package fmcsR.",
      "asbval:note": "Both ChemmineR and fmcsR are explicitly named and their roles in structural matching with quantified thresholds (0.95, 0.85) are confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chemical-match-score-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Interpret structural similarity match scores from cheminformatics tools (ChemmineR, fmcsR) to identify and validate chemical compounds that meet structural equivalence thresholds.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:27:55.706963+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/chemical-match-score-interpretation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For the chemical structure processing, our package utilizes Tanimoto similarity... For this dataset, we compare the same statistical tests for the standardized areas for compounds identified with 4 methods by the uafR package... The substructure information generated using ChemmineR includes the number of rings, all subgroups (e.g., R-COH, R-COOH, etc.) and their counts, all atoms (e.g., C, N, S, As, etc.) and their counts, and the number of charges for every chemical with published structural data (or canonical SMILES from CACTUS) on PubChem.",
      "asbval:note": "ChemmineR explicitly used for structural analysis including rings, subgroups, atoms, and charges.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chemical-match-score-interpretation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "ChemmineR - Cheminformatics package that enables structural comparison and atomic feature analysis for computing match scores",
      "eco:evidence_type": {
