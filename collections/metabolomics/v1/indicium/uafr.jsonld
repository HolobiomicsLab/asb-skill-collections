    },
    {
      "@id": "asbval:assertion/skill/spectral-library-matching-and-m-z-peak-ranking/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The current build of uafR is optimized for raw output from Agilent's Unknowns Analysis Software",
      "asbval:note": "Paper confirms spreadOut() is designed for raw Unknowns Analysis output, not pre-processed data.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-library-matching-and-m-z-peak-ranking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input is already a pre-processed feature table or aggregated compound list \u2014 spreadOut() is designed for raw Unknowns Analysis CSV only.",
      "eco:evidence_type": {
