      }
    },
    {
      "@id": "asbval:assertion/skill/ms-peak-table-format-validation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We have developed an R package, uafR, that automates a grueling retrieval process for gas -chromatography coupled mass spectrometry (GC -MS) data",
      "asbval:note": "Paper confirms uafR is an R package, and the workflow involves reading CSV into R using read.csv() and loading the package.",
