    {
      "@id": "asbval:assertion/skill/chromatographic-retention-time-matching/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "If the chemicals of interest are already known, they can be extracted by name with a single function\u2014\"mzExacto()\".",
      "asbval:note": "Confirmed: mzExacto() is designed for known/predefined chemicals.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chromatographic-retention-time-matching",
