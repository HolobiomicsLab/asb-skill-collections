    {
      "@id": "asbval:assertion/skill/metabolite-quantification-accuracy-assessment/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The next step in the GC-MS workflow will depend on the type of analysis the user is performing. If the chemicals of interest are already known, they can be extracted by name with a single function\u2014'mzExacto().' However, for complex datasets or analyses that involve more unknowns, the user may want to cast a broader, but still accurate, net... Another approach could include subsetting with output from the function 'categorate().'",
      "asbval:note": "The workflow order (spreadOut \u2192 mzExacto \u2192 categorate/exactoThese) is confirmed in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolite-quantification-accuracy-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it as a quality-control checkpoint after spreadOut() preprocessing but before categorate() or exactoThese() subsetting",
