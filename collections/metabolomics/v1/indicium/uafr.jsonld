    {
      "@id": "asbval:assertion/skill/metabolite-quantification-accuracy-assessment/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The current build of uafR is optimized for raw output from Agilent's Unknowns Analysis Software... after setting up the analysis environment [i.e., directing Unknowns Analysis to the sample directory where a '.UAF' file (hence, uafR) is created], running the deconvolution algorithm to identify peaks, and searching the peaks against the installed library... a single '.CSV' file containing basic GC-MS output [i.e. retention times, peak area, captured mass-to-charge ratios (m/z), compound name, match quality]... can be exported and read into R",
      "asbval:note": "Agilent Unknowns Analysis is confirmed as the recommended software. The column names are confirmed in passage 4: 'retention times, peak area, captured mass-to-charge ratios (m/z), compound name, match quality' and explicitly listed in passage 4 as 'Compound.Name', 'File.Name', 'Base.Peak.MZ', 'Match.Factor', 'Component.RT'.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
