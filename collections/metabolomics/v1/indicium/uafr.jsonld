    {
      "@id": "asbval:assertion/skill/chromatographic-retention-time-matching/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "It can be downloaded for free along with sample datasets from Github at github.org/castratton/uafR or installed directly from R or RStudio using the developer tools: 'devtools::install_github(\"castratton/uafR\")'.",
      "asbval:note": "GitHub repository confirmed (note: passage shows github.org but standard is github.com; both refer to same repository).",
