    {
      "@id": "asbval:assertion/skill/compound-structural-fingerprint-comparison/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For the chemical structure processing, our package utilizes Tanimoto similarity, a commonly used and rigorously tested metric for physicochemical comparisons... The substructure information generated using ChemmineR includes the number of rings, all subgroups (e.g., R-COH, R-COOH, etc.) and their counts, all atoms (e.g., C, N, S, As, etc.) and their counts, and the number of charges for every chemical with published structural data... It performs these comparisons using the 'fmcsBatch()' function from the R package fmcsR... the function converts the chemical names into PubChem compound identifiers (CIDs) using the 'get_cid()' function from the R package webchem",
      "asbval:note": "All three packages (ChemmineR, fmcsR, webchem) are explicitly named and their roles in structural similarity computation are clearly described.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "compound-structural-fingerprint-comparison",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill uses cheminformatics packages (ChemmineR, fmcsR, webchem) to compute structural similarity scores between query chemicals and a reference library, identifying best-matched compounds based on atomic fingerprints and molecular features.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:29:45.962030+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/compound-structural-fingerprint-comparison/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For the chemical structure processing, our package utilizes Tanimoto similarity... The substructure information generated using ChemmineR includes the number of rings, all subgroups (e.g., R-COH, R-COOH, etc.) and their counts, all atoms (e.g., C, N, S, As, etc.) and their counts, and the number of charges for every chemical with published structural data",
      "asbval:note": "ChemmineR is used via read.SDFset() function for generating substructure data and molecular features.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "compound-structural-fingerprint-comparison",
      "asbval:target_artifact_kind": "skill_bundle",
