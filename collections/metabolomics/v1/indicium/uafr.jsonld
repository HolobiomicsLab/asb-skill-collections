    {
      "@id": "asbval:assertion/skill/summary-statistics-table-construction/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The first function for GC -MS data is \"spreadOut()\". Running this function on properly formatted GC -MS input will automatically prepare the data for the next steps in the processing pipeline... Next in the GC -MS workflow is to put the published information to use and aggregate every occurrence of the user-specified chemicals across every GC -MS sample. \"mzExacto()\" takes the output from \"spreadOut()\" along with the list of chemical names, and returns a single data frame containing their optimal retention time, exact mass, best identified match factor, and aggregated component area across samples in which it occurs.",
      "asbval:note": "Both spreadOut() and mzExacto() are core functions for preprocessing and filtering GC-MS data as described in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1371-journal-pone-0306202",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "summary-statistics-table-construction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[uafR].role",
