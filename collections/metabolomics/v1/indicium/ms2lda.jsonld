    {
      "@id": "asbval:assertion/skill/fragmentation-motif-learning/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2LDA, a method inspired by text modelling, to decompose fragmentation spectra into sets of conserved fragment and neutral loss features (called Mass2Motifs). As text documents can be decomposed into sets of co-occurring words (topics) MS2LDA decomposes each molecule into sets of Mass2Motifs, potentially indicative of structural families.",
      "asbval:note": "Core research question is directly supported. Paper describes MS2LDA as LDA-inspired method for discovering Mass2Motifs from fragmentation data without requiring prior identification.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx582",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "fragmentation-motif-learning",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply Latent Dirichlet Allocation (LDA) to a preprocessed bag-of-fragments corpus to infer Mass2Motifs\u2014recurring fragmentation patterns that explain observed tandem MS fragmentation data without prior compound identification.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:55:49.823988+00:00",
      "sepio:credibility_status": {
