      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Construct a network graph representation of Mass2Motifs discovered by MS2LDA, where nodes represent motifs annotated with their fragment/neutral-loss compositions and edges encode spectral similarity relationships.",
