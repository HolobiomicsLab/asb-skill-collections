    {
      "@id": "asbval:assertion/skill/mass2motif-network-construction/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The starting point for visualization is the network graph (A), nodes represent Mass2Motifs (circle) and molecules (squares). Mass2Motif nodes are sized according to the number of connected molecules. Edges represent connections between molecules and Mass2Motifs (above a certain threshold).",
      "asbval:note": "Paper describes network visualization with nodes representing Mass2Motifs and edges representing connections, but edges connect molecules to Mass2Motifs (not motif-to-motif similarity as claimed). The card claims edges encode 'spectral similarity relationships' between motifs, but the paper shows edges represent molecule-motif associations, not inter-motif similarity.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx582",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mass2motif-network-construction",
