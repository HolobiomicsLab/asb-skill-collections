      "@id": "asbval:assertion/skill/bag-of-words-document-representation-generation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "fragment and neutral loss features are extracted from the uploaded fragmentation file [mzML (alongside an optional peaklist file to filter the extracted precursors, see Supplementary Section S1), MSP, or MGF formats]",
      "asbval:note": "Paper explicitly supports all three file formats mentioned in the claim.",
