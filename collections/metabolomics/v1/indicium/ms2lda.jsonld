    {
      "@id": "asbval:assertion/skill/mass-fragment-pattern-querying/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "As a new feature, we offer matching functionality which allows users to compare the Mass2Motifs found in their data with those in our growing database of (often annotated) Mass2Motifs. Users can view candidate matches and link Mass2Motifs where they agree with the match. When linked, annotations are transferred between matched pairs.",
      "asbval:note": "The paper describes matching Mass2Motifs against a database and retrieving annotated matches, but the specific tools (MassQL, MotifDB) named in the card are not mentioned. The functional concept (matching motifs to a reference database for annotation) is present, but the implementation details differ.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx582",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mass-fragment-pattern-querying",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Query a MassQL-searchable MotifDB reference database using fragment and neutral-loss patterns extracted from MS2LDA-inferred Mass2Motifs to retrieve ranked database matches for motif annotation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
