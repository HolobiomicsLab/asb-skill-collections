    {
      "@id": "asbval:assertion/skill/mass2motif-annotation-mapping/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Ms2lda.org allows users to decompose and annotate MS/MS data with MS2LDA. In addition to the original MS2LDA functionality, we provide a new visualization screen, the ability to store annotations, decomposition, motif matching and MS1 analysis.",
      "asbval:note": "The paper describes motif matching and annotation functionality, but does not mention Spec2Vec similarity scoring or confidence metrics. The matching is described as comparison against a database of annotated Mass2Motifs, not via Spec2Vec.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx582",
      "asbval:supported_raw": "partial",
