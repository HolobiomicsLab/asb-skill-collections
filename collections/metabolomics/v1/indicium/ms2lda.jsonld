    {
      "@id": "asbval:assertion/card/10_5281_zenodo_15858124__task_004/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Ms2lda.org allows users to decompose and annotate MS/MS data with MS2LDA (van der Hooft et al., 2016). In addition to the original MS2LDA functionality, we provide a new visualization screen, the ability to store annotations, decomposition, motif matching and MS1 analysis.",
      "asbval:note": "MS2LDA is the core method used throughout the paper for decomposing MS/MS data and discovering Mass2Motifs.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx582",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_004",
