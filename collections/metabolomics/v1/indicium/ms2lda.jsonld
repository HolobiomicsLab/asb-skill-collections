    {
      "@id": "asbval:assertion/skill/spectral-similarity-computation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The system is implemented in Python with a minimal set of dependencies. Django is used as the Web application framework, whereas a job queue (Celery) is used to execute analyses asynchronously. As in the original publication, variational inference to discover Mass2Motifs is implemented in Numpy/SciPy, and interactive visualizations are performed in JavaScript (D3.js).",
      "asbval:note": "Python is confirmed as the implementation language for ms2lda.org system, including MS2LDA analysis and network visualization.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx582",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-similarity-computation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Python - Implementation language for spectral similarity computation and network construction workflows",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:01:12.453187+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-similarity-computation/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Ms2lda.org allows users to decompose and annotate MS/MS data with MS2LDA... we provide a new visualization screen... The starting point for visualization is the network graph (A), nodes represent Mass2Motifs (circle) and molecules (squares). Mass2Motif nodes are sized according to the number of connected molecules. Edges represent connections between molecules and Mass2Motifs (above a certain threshold).",
      "asbval:note": "Paper confirms network visualization of Mass2Motifs after LDA decomposition, but the mechanism for computing edge weights or determining connections is not explicitly described in provided passages. The phrase 'above a certain threshold' suggests filtering but not similarity computation methodology.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx582",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "spectral-similarity-computation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill after inferring Mass2Motif definitions from LDA modeling when you need to build a network representation of motif relationships.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:01:12.453187+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
