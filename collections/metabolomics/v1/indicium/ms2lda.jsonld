    {
      "@id": "asbval:assertion/skill/fragment-ion-peak-detection-and-normalization/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Features are extracted from mzML fragmentation files using the pymzML library and stored in a relational database (PostgreSQL) alongside inferred Mass2Motifs and associated metadata. Two analysis workflows are implemented in our system\u2014the original MS2LDA and a new feature, MS2LDA decomposition.",
      "asbval:note": "The paper describes loading and extracting features from MS/MS spectra as part of the MS2LDA workflow, but does not explicitly frame this as a separate 'fragment-ion-peak-detection-and-normalization' preprocessing step. The paper focuses on the overall MS2LDA decomposition method rather than detailed preprocessing documentation.",
      "asbval:perspicacite_kb": "asb-paper-10-1093-bioinformatics-btx582",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "fragment-ion-peak-detection-and-normalization",
