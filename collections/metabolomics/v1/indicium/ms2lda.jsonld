      }
    },
    {
      "@id": "asbval:assertion/card/10_5281_zenodo_15858124__task_001/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We recently published MS2LDA, a method for the decomposition of sets of molecular fragment data derived from large metabolomics experiments... Ms2lda.org allows users to decompose and annotate MS/MS data with MS2LDA",
      "asbval:note": "MS2LDA is the core method discussed throughout the paper.",
