      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Automated annotation of discovered Mass2Motifs by mapping them to known substructures via Spec2Vec similarity scoring against a spectral library. This skill bridges unsupervised motif discovery with interpretable structural labels and confidence metrics.",
