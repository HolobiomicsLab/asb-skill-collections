      }
    },
    {
      "@id": "asbval:assertion/skill/plant-metabolic-network-validation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We then apply COMMIT to high-quality consensus metabolic reconstructions based on genomes of the isolates from the Arabidopsis thaliana microbial culture collections, At-SPHERE, for two different soil community compositions [36,37].",
      "asbval:note": "Paper does work with plant-associated microbial communities (Arabidopsis thaliana-associated), but does not validate against known Arabidopsis thaliana plant metabolism. Validation is performed by comparing to reference microbial models (B. megaterium iMZ1055, M. extorquens iRP911) and by analyzing metabolic interactions within the microbial community, not against plant metabolic data.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009906",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "plant-metabolic-network-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use this skill when you have gap-filled metabolic models for plant-associated microbial community members and need to verify that filled reactions are consistent with known Arabidopsis thaliana metabolism",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
