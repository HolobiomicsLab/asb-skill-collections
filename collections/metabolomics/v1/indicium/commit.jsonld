    {
      "@id": "asbval:assertion/skill/plant-metabolic-network-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here, we describe COMMIT, a constraint-based approach that respects the composition of the microbial community and metabolite leakage in the process of gap filling metabolic reconstructions of the respective community members. We then apply COMMIT to high-quality consensus metabolic reconstructions based on genomes of the isolates from the Arabidopsis thaliana microbial culture collections, At-SPHERE, for two different soil community compositions",
      "asbval:note": "Paper applies COMMIT to Arabidopsis thaliana-associated microbial communities (not plant reconstructions themselves). The validation performed is of microbial metabolic reconstructions in the context of plant-associated communities, not validation of plant metabolic networks. The card conflates plant-associated microbial community modeling with plant metabolic network validation.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009906",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "plant-metabolic-network-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate gap-filled plant metabolic reconstructions by checking consistency with known plant metabolism and inter-member metabolic exchange requirements in microbial communities.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T09:53:47.147122+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/plant-metabolic-network-validation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not perform validation of plant metabolic reconstructions. COMMIT is applied to microbial isolates from Arabidopsis thaliana culture collections (At-SPHERE), not to plant metabolic models. The paper validates microbial community models, not plant models.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009906",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "plant-metabolic-network-validation",
      "asbval:target_artifact_kind": "skill_bundle",
