    {
      "@id": "asbval:assertion/skill/plant-metabolic-network-validation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "COMMIT relies on the FastGapFilling algorithm, which optimizes a weighted sum of the fluxes through the biomass and additional candidate reactions by using linear programming (LP) formulation... To this end, six parameters were used for permeability prediction based on Lipinski's rule [52,53], resulting in reduced costs for 2534 out of 4520 transport reactions in the gap-filling database. Moreover, reactions assigned to enzymes with sequence evidence in the respective genome were assigned a lower cost",
      "asbval:note": "COMMIT does generate gap-filled reconstructions and does track sequence evidence (genomic support) for reactions, but the paper does not describe explicit confidence annotations or source tracking in the output models. The paper tracks 'genomic support' but does not report confidence scores or detailed source annotations in the final models.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009906",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "plant-metabolic-network-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "COMMIT role: Generates community-dependent gap-filled metabolic reconstructions that serve as input to validation; outputs models with annotations indicating source and confidence of filled reactions",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T09:53:47.147122+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
