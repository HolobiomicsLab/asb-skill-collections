    },
    {
      "@id": "asbval:assertion/card/10_5281_zenodo_363932874__task_002/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Here, we describe COMMIT, a constraint-based approach that respects the composition of the microbial community and metabolite leakage in the process of gap filling metabolic reconstructions of the respective community members.",
      "asbval:note": "COMMIT is the primary tool developed and applied in this paper.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009906",
