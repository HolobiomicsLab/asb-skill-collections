    {
      "@id": "asbval:assertion/skill/microbial-genome-annotation-harmonization/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "COMMIT relies on the FastGapFilling algorithm, which optimizes a weighted sum of the fluxes through the biomass and additional candidate reactions by using linear programming (LP) formulation",
      "asbval:note": "COMMIT is primarily a gap-filling algorithm that considers community composition and metabolite leakage, not a consensus generation algorithm per se. Consensus generation is performed separately using the STATIS method and identifier matching (passage 4). The card conflates consensus generation with COMMIT's role\u2014COMMIT uses consensus reconstructions as input but does not generate them.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009906",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "microbial-genome-annotation-harmonization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[0].role",
      "asbval:target_claim_text": "Consensus generation algorithm that integrates draft metabolic reconstructions and identifies conserved metabolic reactions across all input models",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T09:53:31.508136+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
