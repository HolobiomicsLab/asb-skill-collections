      "asbval:target_claim_text": "Validate gap-filled plant metabolic reconstructions by checking consistency with known plant metabolism and inter-member metabolic exchange requirements in microbial communities.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
