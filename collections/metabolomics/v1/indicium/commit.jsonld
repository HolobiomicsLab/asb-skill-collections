      }
    },
    {
      "@id": "asbval:assertion/skill/metabolic-gap-filling-community-context/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Since members of microbial communities are often dependent on each other, gap-filling solutions of the community members must also be put into context of the community in which the organisms co-exist. In addition, the usage of gap-filled solutions and exudates from other community members may further reduce the overall number of added reactions to fill in the gaps in the metabolic reconstruction for the community.",
      "asbval:note": "Paper demonstrates that community context reduces gap-filling solution size compared to individual gap-filling.",
      "asbval:perspicacite_kb": "asb-paper-10_1371_journal_pcbi_1009906",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolic-gap-filling-community-context",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill is essential when working with multi-member community models where interdependencies and metabolic overlap can resolve gaps that cannot be addressed by single-organism reconstruction alone.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T09:52:56.785971+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/metabolic-gap-filling-community-context/002",
