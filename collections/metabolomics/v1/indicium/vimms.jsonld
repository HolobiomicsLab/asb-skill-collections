      }
    },
    {
      "@id": "asbval:assertion/skill/formula-sampler-configuration/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ViMMS 2.0 is a software framework that can be used to develop new fragmentation strategies in metabolomics completely in-silico as well as on mass spectrometry instruments. The framework allows users to generate chemical objects (produced synthetically or extracted from existing mzML files) and simulate a tandem mass spectrometry process... The framework allows users to plug in modular classes that specify parameters of chemicals, such as the distribution of their m/z values, RT, intensities, chromatographic shapes and associated MS2 spectra (Figure 1A).",
      "asbval:note": "ViMMS 2.0 is confirmed as the core framework for generating chemical objects and m/z distributions. However, the specific class names 'DatabaseFormulaSampler', 'UniformMZFormulaSampler', and 'ChemicalMixtureCreator' are not mentioned in the provided passages. The paper describes 'modular classes' for chemical generation but does not name these specific classes.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-03990",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "formula-sampler-configuration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "ViMMS with role: Core framework providing DatabaseFormulaSampler, UniformMZFormulaSampler, and ChemicalMixtureCreator classes for formula sampling and chemical population generation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:52:54.978216+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
