    {
      "id": "claim_001",
      "context": "explicit",
      "subject": "explicit",
      "qualifier": "consistent_with",
      "relation": "describes",
      "object": "ViMMS is a flexible and modular framework designed to simulate fragmentation strategies in tandem mass spectrometry-based metabolomics.",
      "asserted_by": "doi:10.1021/acs.analchem.0c03895",
      "@type": "asb:Claim",
      "source_task_kind_status": "ambiguous_multi_kind",
