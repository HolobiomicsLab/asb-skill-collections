    {
      "@id": "asbval:assertion/skill/metabolite-detection-and-acquisition-performance-benchmarking/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ViMMS 2.0 is distributed as a Python package that can be easily installed using pip. We require Python 3.0 or higher to run the framework. It depends on common packages such as numpy, scipy and pandas.",
      "asbval:note": "Paper confirms ViMMS 2.0 is a Python package and mentions evaluation metrics computation, but does not explicitly name 'EvaluationData pickles' or 'evaluate_simulated_env()' function. The functional claim (Python for metric computation) is supported, but specific API names are not verified in passages.",
