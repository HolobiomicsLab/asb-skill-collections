      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Generate synthetic chemical mixtures by sampling molecular formulas from the HMDB database within a specified m/z range, then create KnownChemical objects with realistic retention times, intensities, and chromatographic profiles for LC-MS simulation.",
      "eco:evidence_type": {
