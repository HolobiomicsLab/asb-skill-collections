    {
      "@id": "asbval:assertion/card/10_1021_acs_analchem_0c03895__task_002/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ViMMS 2.0 is a software framework that can be used to develop new fragmentation strategies in metabolomics completely in-silico as well as on mass spectrometry instruments. The framework allows users to generate chemical objects (produced synthetically or extracted from existing mzML files) and simulate a tandem mass spectrometry process, where different fragmentation strategies can be rapidly implemented, tested and evaluated.",
      "asbval:note": "Paper confirms ViMMS can extract chemicals from mzML files and simulate Top-N strategies with coverage metrics. However, no specific mention of 'beer samples' or validation against 'original experimental data' \u2014 the paper discusses the framework capability in general terms, not a specific beer dataset comparison task.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-03990",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_002",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Can ViMMS simulate Top-N MS/MS acquisition on real beer samples and reproduce the fragmentation coverage observed in the original experimental data?",
