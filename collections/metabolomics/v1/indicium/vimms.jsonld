      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When generating a virtual chemical mixture for LC-MS/MS simulation, you need to restrict the sample to a specific m/z window that matches your instrument's acquisition range",
