    {
      "@id": "asbval:assertion/skill/lc-ms-scan-acquisition-orchestration/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Chemicals can be generated in different ways: either in a purely synthetic manner (e.g. sampling their properties from databases or fixed statistical distributions) or by construction from existing data (mzML files)... Fragmentation strategies are implemented as controllers... Two enhanced DDA controllers (named SmartROI and WeightedDEW... SmartROI accomplishes this by tracking regions-of-interest in real-time and targeting those for fragmentation, while WeightedDEW implements a weighted dynamic exclusion scheme",
      "asbval:note": "Scope aligns with paper's description of chemical generation (real or synthetic) and fragmentation strategy implementation including exclusion schemes.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-03990",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "lc-ms-scan-acquisition-orchestration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When you have a curated list of chemical compounds (real or virtual), a defined fragmentation strategy (e.g., Top-N, exclusion lists), and need to simulate how that strategy will acquire MS1 and MS2 scans",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
