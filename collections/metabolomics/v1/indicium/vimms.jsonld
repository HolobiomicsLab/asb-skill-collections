    {
      "@id": "asbval:assertion/skill/metabolite-detection-and-acquisition-performance-benchmarking/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Two enhanced DDA controllers (named SmartROI and WeightedDEW, outlined by Davies et al. (2021)) are also provided that demonstrate how novel fragmentation strategies could be rapidly implemented and validated in ViMMS 2.0... Code is provided to compute various evaluation metrics, such as coverage and intensities of fragmented precursors. This allows users to benchmark different controller implementations comparatively.",
      "asbval:note": "Paper explicitly supports benchmarking of WeightedDEW and TopN-like controllers with coverage and intensity metrics.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-03990",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolite-detection-and-acquisition-performance-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Comparative evaluation of fragmentation strategies (WeightedDEW vs. TopN) measuring coverage metrics, intensity profiles, and MS/MS acquisition efficiency",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:54:24.289143+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/metabolite-detection-and-acquisition-performance-benchmarking/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Chemicals are input objects to the simulation process in ViMMS 2.0, and can be generated in different ways: either in a purely synthetic manner (e.g. sampling their properties from databases or fixed statistical distributions) or by construction from existing data (mzML files) via the extraction of RoI traces.",
      "asbval:note": "Paper confirms ViMMS 2.0 accepts both synthetic chemical generation and real mzML file input.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-03990",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "metabolite-detection-and-acquisition-performance-benchmarking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Using simulated or real mzML data against reference chemical libraries",
      "eco:evidence_type": {
