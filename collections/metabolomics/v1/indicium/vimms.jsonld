    {
      "@id": "asbval:assertion/skill/ms1-full-scan-acquisition-simulation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "ViMMS 2.0 is a software framework that can be used to develop new fragmentation strategies in metabolomics completely in-silico as well as on mass spectrometry instruments. The framework allows users to generate chemical objects (produced synthetically or extracted from existing mzML files) and simulate a tandem mass spectrometry process, where different fragmentation strategies can be rapidly implemented, tested and evaluated.",
      "asbval:note": "Paper describes ViMMS as enabling in-silico simulation of MS acquisition with chemical generation and strategy execution. MS1-only acquisition is a valid use case within the framework's capabilities.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-03990",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ms1-full-scan-acquisition-simulation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Simulate full-scan MS1 (parent ion) acquisition on known chemical compounds using ViMMS, generating realistic LC-MS chromatograms and MS1 spectra without fragmentation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:55:04.915797+00:00",
      "sepio:credibility_status": {
