      "asbval:target_claim_text": "This skill enables simulation-based development of LC-MS/MS fragmentation strategies without requiring real chemical standards or instrument time.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
