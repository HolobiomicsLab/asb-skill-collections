    {
      "@id": "asbval:assertion/skill/simulation-control-loop-architecture/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To illustrate how new strategies could be built on top of ViMMS 2.0, an example is given here of a Top-N controller that selects the N most intense precursor ions for fragmentation... This implementation overrides the _process_scan method, which determines how precursor ions in an incoming MS1 scan are prioritised for fragmentation... Scan parameters control, for example, whether a controller flexibly targets a single precursor ion for fragmentation",
      "asbval:note": "TopNController explicitly described with functionality matching the claim: selects top-N precursor ions, processes MS1 scans, and controls scan parameters.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-03990",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "simulation-control-loop-architecture",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TopNController - Fragmentation strategy implementation for selecting top-N precursor ions per survey scan with configurable isolation width, m/z tolerance, and intensity thresholds",
