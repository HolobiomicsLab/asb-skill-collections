    {
      "@id": "asbval:assertion/skill/formula-sampler-configuration/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The framework allows users to plug in modular classes that specify parameters of chemicals, such as the distribution of their m/z values, RT, intensities, chromatographic shapes and associated MS2 spectra (Figure 1A). Chemicals can be generated in single-sample or multi-sample settings.",
      "asbval:note": "Paper confirms ViMMS 2.0 has modular classes for generating chemical m/z distributions and supports m/z-based filtering, but does NOT name 'DatabaseFormulaSampler' or 'UniformMZFormulaSampler' specifically. Paper describes 'modular classes that specify parameters of chemicals' including 'm/z values' but does not provide the exact class names claimed in the card. The functional capability (generating chemicals with m/z bounds) is present; the specific class names are not verified in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-03990",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "formula-sampler-configuration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Configure and instantiate a formula sampler (e.g., DatabaseFormulaSampler or UniformMZFormulaSampler) to generate a population of chemical formulas within specified m/z bounds for virtual metabolomics simulation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
