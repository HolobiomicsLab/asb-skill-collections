    {
      "@id": "asbval:assertion/skill/lc-ms-scan-acquisition-orchestration/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To illustrate how new strategies could be built on top of ViMMS 2.0, an example is given here of a Top-N controller that selects the N most intense precursor ions for fragmentation. This strategy is common in real-world data-dependent acquisition (DDA) experiments... We have included a more complete Top-N strategy as the baseline controller in ViMMS 2.0 against which other strategies can be benchmarked.",
      "asbval:note": "TopNController explicitly mentioned and described as selecting N most intense precursors for DDA.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-03990",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "lc-ms-scan-acquisition-orchestration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "TopNController - Fragmentation strategy controller implementing data-dependent acquisition by selecting top N most abundant precursors",
      "eco:evidence_type": {
