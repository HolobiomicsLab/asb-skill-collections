    {
      "@id": "asbval:assertion/skill/ion-mobility-mass-spectrometry-data-processing/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "other IM technologies rely solely on external CCS calibration, posing challenges due to dissimilar chemical properties between lipids and calibrants... As CCS values of small molecule ions determined by IM-MS technologies like TIM-MS and TWIM-MS are dependent on the external calibration of the instrument the source(s) of CCS bias introduced by the calibration process cannot be easily identified.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
