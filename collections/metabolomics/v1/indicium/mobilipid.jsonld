    {
      "@id": "asbval:assertion/skill/internal-standardization-lipid-mapping/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By spiking U13C-labeled lipids into measured samples and determination of the CCSN2 bias between derived CCS values and the DTCCSN2 library, the extent of the bias can be assessed for each measured data file... The mathematics behind the internal standardization in MobiLipid are linear correction functions, based on the derived CCSN2 of U13C-labeled lipids and the deployed reference DTCCSN2 values... The functions require a minimum of three labeled lipids as input for each lipid class-adduct combination.",
      "asbval:note": "Paper uses DT CCS N2 library (not 'deuterated CCS library'). The card conflates 'deuterated' (D-labeled) with the actual U13C-labeled internal standards and DT CCS N2 reference library. The core function\u2014mapping measured CCS to a reference library using U13C-labeled standards to establish bias correction factors per lipid class\u2013adduct\u2014is correct, but the terminology 'deuterated CCS library' is inaccurate; the library is DT CCS N2 for U13C-labeled lipids, and deuterated standards are used separately for quantification.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "internal-standardization-lipid-mapping",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Map measured ion mobility-mass spectrometry lipid signals to a deuterated CCS library using U13C-labeled internal standards to establish bias correction factors for each lipid class\u2013adduct combination.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:42:40.518510+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/internal-standardization-lipid-mapping/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MobiLipid is a fully automated R Markdown tool utilizing a newly established DTCCSN2 library for U13C-labeled lipids to internally assess CCSN2 bias in IM-MS lipidomics workflows and allow CCS correction without the need for additional external calibration procedures.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "internal-standardization-lipid-mapping",
