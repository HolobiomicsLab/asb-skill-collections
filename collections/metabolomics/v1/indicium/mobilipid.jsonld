    {
      "@id": "asbval:assertion/skill/u13c-labeled-lipid-identification/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For the measurements, the extracts were dissolved in isopropanol and spiked with deuterated lipid standards... The applicability of MobiLipid is demonstrated for trapped IM (TIM)-MS measurements of an unlabeled yeast extract spiked with U 13 C-labeled lipids.",
      "asbval:note": "Paper explicitly describes spiking samples with U\u00b9\u00b3C-labeled lipids (yeast extract) as the workflow.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "u13c-labeled-lipid-identification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have measured CCS values from (LC-)IM-MS samples spiked with U\u00b9\u00b3C labeled internal standards (e.g., fully labeled yeast extract)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:44:28.394212+00:00",
      "sepio:credibility_status": {
