    {
      "@id": "asbval:assertion/skill/internal-standardization-lipid-mapping/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To evaluate the use of the new U13C lipidomics library, experiments were carried out on two different IM-MS platforms... LC-DTIM-MS and LC-TIM-MS measurements were performed using the U13C-labeled lipid yeast extract and its unlabeled version... Comparison of data for unlabeled (monoisotopic) and U13C-labeled lipids revealed a very small systematic shift...",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
