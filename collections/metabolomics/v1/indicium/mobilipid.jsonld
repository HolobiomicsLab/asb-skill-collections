      "@id": "asbval:assertion/skill/ion-mobility-mass-spectrometry-data-processing/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By applying the CCS correction integrated into the tool for the exemplary data set, the mean absolute CCS N2 biases of 10 lipid classes could be reduced to approximately 0%... This can deliver significant advantages for maintaining data quality across different IM-MS platforms and for dealing with annotation of diverse lipid classes across different lipidomics applications.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
