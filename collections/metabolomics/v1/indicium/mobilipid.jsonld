    {
      "@id": "asbval:assertion/skill/internal-standardization-with-isotope-labels/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MobiLipid, a novel tool facilitating the CCS quality control of IM-MS lipidomics workflows by internal standardization. MobiLipid utilizes a newly established DT CCS N2 library for uniformly (U) 13 C-labeled lipids... This automated open-source R Markdown tool enables internal monitoring and straightforward compensation for CCS N2 biases... By applying the CCS correction integrated into the tool for the exemplary data set, the mean absolute CCS N2 biases of 10 lipid classes could be reduced to approximately 0%.",
      "asbval:note": "Fully supported by abstract and introduction. The paper explicitly describes using U13C-labeled lipids as internal standards to monitor and correct CCS bias without additional external calibration.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "internal-standardization-with-isotope-labels",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Use fully labeled isotopic standards (e.g., U13C-labeled lipids) spiked into samples to calculate and correct systematic bias in ion mobility-derived collisional cross section (CCS) measurements without requiring additional external calibration.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:43:01.213089+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/internal-standardization-with-isotope-labels/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MobiLipid utilizes a newly established DT CCS N2 library for uniformly (U) 13 C-labeled lipids, derived from a U 13 C-labeled yeast extract, containing 377 DT CCS N2 values... By spiking U13C-labeled lipids into measured samples and determination of the CCSN2 bias between derived CCS values and the DTCCSN2 library, the extent of the bias can be assessed for each measured data file, providing a straightforward approach to achieving constant quality control",
      "asbval:note": "Directly supported. The paper establishes a reference library and uses it for quality control via internal standardization.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "internal-standardization-with-isotope-labels",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This approach enables accurate quality control of IM-MS lipidomics data by leveraging a reference library of isotope CCS values.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:43:01.213089+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/internal-standardization-with-isotope-labels/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For the measurements, the extracts were dissolved in isopropanol and spiked with deuterated lipid standards... The applicability of MobiLipid is demonstrated for trapped IM (TIM)-MS measurements of an unlabeled yeast extract spiked with U 13 C-labeled lipids.",
      "asbval:note": "Supported. The paper demonstrates the workflow using spiked samples and compares measured CCS to reference library values.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "internal-standardization-with-isotope-labels",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Your IM-MS lipidomics samples have been spiked with fully labeled isotopic internal standards (e.g., U13C yeast lipid extract), and you want to quantify and correct bias in measured CCS values by comparing them to literature or newly established reference CCS values for those sam",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:43:01.213089+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/internal-standardization-with-isotope-labels/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "All other IM-MS technologies, including TWIM-MS and TIM-MS, rely solely on external CCS calibration, with calibrants established by DTIM-MS. However, CCS calibrants usually have dissimilar chemical properties to analytes of interest, which poses some challenges for routine 'omics' workflows, including lipidomics... The functions require a minimum of three labeled lipids as input for each lipid class-adduct combination.",
      "asbval:note": "Supported. Paper identifies the limitation of external calibration and specifies the minimum of 3 lipids per class-adduct combination.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "internal-standardization-with-isotope-labels",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "This is particularly useful when vendor-supplied CCS calibration alone is insufficient or when you have limited numbers of detected lipids per class (\u22653 lipids per lipid class\u2013adduct combination) and want to avoid measuring additional external calibration standards.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:43:01.213089+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
