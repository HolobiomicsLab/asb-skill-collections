    {
      "@id": "asbval:assertion/skill/internal-standardization-lipid-mapping/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To address this constraint, a stable isotope-labeled biomass, like the yeast strain Komagataella phaffii (also referred to as Pichia pastoris), can be employed... The uniformly (U)13C-labeled yeast extract is a well-established internal standard that covers a broad palette of U13C-labeled lipids...",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
