      }
    },
    {
      "@id": "asbval:assertion/skill/u13c-labeled-lipid-identification/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The library was established using DTIM-MS measurements as a reference method... Specifically, LC-DTIM-MS measurements of a yeast extract dilution series in positive and negative ionization modes served for library generation... only DTCCSN2 values fulfilling the following criteria were included: (1) high mass accuracy (\u22645 ppm error), (2) confirmed detection in at least two samples, (3) confirmed coelution of adducts, and (4) a CCS relative standard deviation <1%.",
      "asbval:note": "Paper describes data requirements including lipid class, adduct type, and CCS values; mass accuracy and detection criteria align with input requirements.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "u13c-labeled-lipid-identification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Input data must contain lipid class, lipid species, adduct type, and measured CCS value for each detected lipid",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:44:28.394212+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/u13c-labeled-lipid-identification/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By spiking U13C-labeled lipids into measured samples and determination of the CCSN2 bias between derived CCS values and the DTCCSN2 library, the extent of the bias can be assessed",
      "asbval:note": "Paper makes clear that the workflow requires spiked U\u00b9\u00b3C-labeled lipids as internal standards.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
