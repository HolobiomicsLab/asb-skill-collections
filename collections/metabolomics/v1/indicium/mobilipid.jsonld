    {
      "@id": "asbval:assertion/card/task_001/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The library contains 377 DTCCSN2 values covering 15 lipid classes and 5 different adduct types ([M + H]+, [M + NH4]+, [M + Na]+, [M \u2013 H]\u2212, and [M + HCOO]\u2212)... DTCCSN2 values are in the range 189.4\u2013327.1 \u00c52",
      "asbval:note": "Paper explicitly describes the DTCCSN2 library structure, lipid class coverage (15 classes), and CCS value ranges.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "What is the structure, lipid class coverage, and range of CCS values contained in the DTCCSN2 library for U13C labeled lipids that is distributed with MobiLipid?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T12:39:33.745172+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/card/task_001/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MobiLipid is run in the R studio environment... further data filtering, evaluation, and visualization was done in the R studio programming environment (R version 4.3.2 and RStudio 2023.09.1)",
      "asbval:note": "Paper explicitly states R and RStudio are used for MobiLipid implementation and data processing.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-4c01253",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_001",
