    {
      "@id": "asbval:assertion/skill/url-format-constraint-checking/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The PoDP consists of a six-section form for easy and quick input of data (Fig. 1). The metadata is organized in projects that can consist of multiple related experiments, identified by their MassIVE accession or MetaboLights study identifier... To create a BGC\u2013MS/MS link, a MIBiG identifier for the same or similar BGC can be linked with a MS/MS URL and scan number",
      "asbval:note": "Paper describes PoDP storing project metadata with URLs (MassIVE accession, MetaboLights identifiers, MS/MS URLs, genome links), but does not explicitly discuss URL validation, whitespace detection, or JSON schema validation. The card's specific technical task (detecting embedded whitespace in URL fields via JSON schema validation) is not mentioned in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41589-020-00724-z",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "url-format-constraint-checking",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate URL fields in JSON project documents by detecting and flagging embedded whitespace characters that violate URL syntax. This skill ensures data quality in omics platforms that store structured project metadata with URL references.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
