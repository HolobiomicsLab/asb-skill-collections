      "@id": "asbval:assertion/skill/tsv-csv-file-parsing-and-aggregation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The R versions used for the project were 4.0.2 up to 4.1.2, and R-packages used were, in alphabetical order: ... data.table (1.14.2) ... tidyverse (1.3.1) (Wickham et al., 2019)",
      "asbval:note": "Paper explicitly lists R packages including data.table and tidyverse (which includes dplyr). Scripts in lotus-processor use these for data aggregation.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
