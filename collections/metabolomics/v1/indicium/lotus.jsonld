    {
      "@id": "asbval:assertion/skill/natural-product-database-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To illustrate the nature and dimensions of the LOTUS dataset, some selected examples of data interpretation are shown. First, the distribution of chemical structures among four important NP reservoirs: plants, fungi, animals, and bacteria (Table 3). Then, the distribution of biological organisms according to the number of related chemical structures and likewise the distribution of chemical structures across biological organisms are illustrated (Figure 4).",
      "asbval:note": "Paper performs distribution analysis and visualization of organism-structure pairs (Figure 4 shows 'structures per organism' and 'organisms per structure'), but does NOT perform explicit validation against external reference benchmarks or detect discrepancies via binned-count comparison. The paper analyzes observed distributions but does not compare them to reference benchmarks as the card claims.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "natural-product-database-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate curated natural products databases by comparing observed organism-structure distributions against reference benchmarks and detecting discrepancies in binned counts.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:38:32.715303+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/natural-product-database-validation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To assess the validity of the obtained results, a randomized set of 420 referenced structure-organism pairs was sampled in each reference subcategory and validated or rejected manually... To validate those filtering criteria, an additional set of 100 structure-organism pairs were manually analyzed... After manual validation, 97% of true positives were reached on the second set.",
      "asbval:note": "Paper explicitly validates data integrity through manual sampling and validation before dissemination.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "natural-product-database-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill ensures data integrity across large structure-organism pair collections before downstream computational chemistry applications.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
