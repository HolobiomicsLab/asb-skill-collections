    {
      "@id": "asbval:assertion/skill/count-verification-against-published-values/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "At its current stage of development, LOTUS disseminates 750,000+ referenced structure-organism pairs... In the end, the disseminated data contained 290,000+ unique chemical structures, 40,000+ distinct organisms and 75,000+ references.",
      "asbval:note": "LOTUS is a published peer-reviewed dataset (eLife 2022) with explicit headline statistics for all key entities.",
