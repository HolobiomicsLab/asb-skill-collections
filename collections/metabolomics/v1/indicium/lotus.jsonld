    {
      "@id": "asbval:assertion/skill/frequency-distribution-binning/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Building on the standards established by the related WikiProjects on Wikidata (Chemistry, Taxonomy and Source Metadata), a NP chemistry-oriented subproject was created... LOTUS implements multiple stages of harmonization, processing, and validation (Figure 1, stages 1\u20133).",
      "asbval:note": "lotus-processor implements the four-stage LOTUS workflow: harmonization, processing, validation, and dissemination.",
