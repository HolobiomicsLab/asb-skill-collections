    {
      "@id": "asbval:assertion/skill/structure-organism-pair-counting-and-deduplication/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After deduplication, 2M+ unique structure-organism pairs were obtained... In total, 163,800 structures with fully defined stereochemistry were uploaded as \"chemical compounds\" (Q11173), and 106,669 structures without fully defined stereochemistry were uploaded as \"group of stereoisomers\" (Q59199015)... the disseminated data contained 290,000+ unique chemical structures, 40,000+ distinct organisms and 75,000+ references.",
      "asbval:note": "The paper explicitly performs deduplication of structure-organism pairs and counts unique structures, organisms, and references. The distinction between 2D (planar structures) and 3D (stereochemistry-defined) is implicit in the handling of stereochemistry.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "structure-organism-pair-counting-and-deduplication",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Count and deduplicate structure-organism pairs and their constituent entities (unique structures, organisms, references) from curated natural products databases, separately for 2D and 3D molecular representations.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:40:43.181223+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/structure-organism-pair-counting-and-deduplication/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "All subsequent iterations including new data sources... will involve a comparison with the previously gathered data at the SSOT level... All details are available in the following script: src/2_curating/2_editing/structure/4_enriching/naming.R... The R versions used for the project were 4.0.2 up to 4.1.2, and R-packages used were, in alphabetical order: ChemmineR (3.42.1)... data.table (1.14.2)... tidyverse (1.3.1)",
      "asbval:note": "R is confirmed as used for data processing, curation, and analysis. The paper uses data.table and tidyverse packages which support grouping and deduplication operations.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
