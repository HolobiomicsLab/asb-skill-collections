    {
      "@id": "asbval:assertion/skill/frequency-distribution-binning/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Figure 4. Distribution of 'structures per organism' and 'organisms per structure'... on average, three organisms are reported per chemical structure and eleven structures per organism. Notably, half of all structures have been reported from a single organism and half of all studied organisms are reported to contain five or fewer structures.",
      "asbval:note": "The paper explicitly performs frequency binning of structures by organism count and organisms by structure count, reporting distribution across discrete bins (single organism, five or fewer structures, etc.).",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "frequency-distribution-binning",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Partitions a collection of unique entities (e.g., 2D chemical structures) into discrete frequency bins based on a count attribute (e.g., organism prevalence), then tallies membership in each bin and compares results against a gold-standard reference.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:37:53.112586+00:00",
      "sepio:credibility_status": {
