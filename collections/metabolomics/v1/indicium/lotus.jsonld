    {
      "@id": "asbval:assertion/skill/count-verification-against-published-values/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In total, 163,800 structures with fully defined stereochemistry were uploaded as \"chemical compounds\" (Q11173), and 106,669 structures without fully defined stereochemistry were uploaded as \"group of stereoisomers\" (Q59199015)... A snapshot of the obtained data at the time of re-submission (2021-12-20) is available at the following Zenodo community: https://zenodo.org/communities/the-lotus-initiative",
      "asbval:note": "Paper explicitly stratifies counts by stereochemistry (2D vs 3D/full stereochemistry) and provides downloadable TSV/CSV files with structure-organism pairs.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "count-verification-against-published-values",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use this skill specifically when the source provides TSV/CSV structure-organism pair tables with organism and structure identifier columns, and published counts for both 2D and 3D variants separately.",
