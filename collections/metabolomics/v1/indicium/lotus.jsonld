    {
      "@id": "asbval:assertion/skill/structure-organism-pair-counting-and-deduplication/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For bulk download, a frozen version of LOTUS data (timestamp of 2021-12-20) is also available at https://doi.org/10.5281/zenodo.5794106... LNPN bulk data can be retrieved as SDF or SMILES files, or as a complete MongoDB dump via https://lotus.naturalproducts.net/download... The download lotus part of lotus-wikidata-interact allows the download of all chemical compounds with a \"found in taxon\" property... It makes a copy of all the entities (compounds, taxa, references) into a local triplestore that can be queried with SPARQL as is or converted to a TSV file",
      "asbval:note": "LOTUS data is available in multiple formats including TSV, and the paper explicitly discusses separate handling of 2D and 3D structures (stereochemistry-defined vs. undefined).",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "structure-organism-pair-counting-and-deduplication",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When you have downloaded a curated structure-organism dataset (such as LOTUS) in TSV or CSV format with separate 2D and 3D structure-organism pair tables",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:40:43.181223+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/structure-organism-pair-counting-and-deduplication/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "At its current stage of development, LOTUS disseminates 750,000+ referenced structure-organism pairs... the disseminated data contained 290,000+ unique chemical structures, 40,000+ distinct organisms and 75,000+ references... The UpSet plot in Figure 5 indicates the poor overlap of preexisting electronic NP resources and the added value of an aggregated dataset.",
      "asbval:note": "The paper produces exactly these headline counts and demonstrates enumeration of source databases via UpSet plots.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "structure-organism-pair-counting-and-deduplication",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "produce authoritative headline counts of unique referenced pairs, unique curated structures, unique organisms, and source databases",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:40:43.181223+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
