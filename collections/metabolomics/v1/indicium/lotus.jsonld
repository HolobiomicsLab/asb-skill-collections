    {
      "@id": "asbval:assertion/skill/tsv-csv-file-parsing-and-aggregation/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The source data curation system is available at https://github.com/lotusnprod/lotus-processor (copy archived at swh:1:rev:78e6065d8eb9d0b0d11c2ea8de6ac66b445bca0e, Rutz, 2022a). This program takes the source data as input and outputs curated data, ready for dissemination.",
      "asbval:note": "lotus-processor is confirmed as the primary curation and processing system for LOTUS structure-organism pair data.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tsv-csv-file-parsing-and-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "lotus-processor as source repository providing curated LOTUS structure-organism pair datasets and standardized table schemas",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:18.411560+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/tsv-csv-file-parsing-and-aggregation/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "All subsequent iterations including new data sources, either updated information from the same data sources or new data, will involve a comparison with the previously gathered data at the SSOT level... All necessary scripts for data gathering and harmonization can be found in the lotus-processor repository in the src/1_gathering directory and processed is detailed in the corresponding methods section gathering section.",
      "asbval:note": "Paper confirms existence of scripts in lotus-processor but does not explicitly name all the specific R scripts listed in evidence_spans. The scripts are referenced generically as being in src/ directories. Some script names (e.g., standardizing.R, 1_integrating.R) are mentioned in methods but not all listed scripts are explicitly named in passages.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "tsv-csv-file-parsing-and-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[3].evidence_spans",
      "asbval:target_claim_text": "standardizing.R, 1_integrating.R, 1_cleaningOriginal.R, 4_cleaningTaxonomy.R, 5_addingOTL.R",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:18.411560+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/tsv-csv-file-parsing-and-aggregation/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A dictionary containing original and curated object translations was written for each object to avoid those translations being made again during the next curation step (src/2_curating/3_integrating.R).",
      "asbval:note": "Script 3_integrating.R is explicitly named; the card references 1_integrating.R which may be a different script in the same directory.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tsv-csv-file-parsing-and-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[3].evidence_spans",
      "asbval:target_claim_text": "1_integrating.R",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
