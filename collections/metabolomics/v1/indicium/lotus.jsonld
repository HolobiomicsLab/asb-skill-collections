    {
      "@id": "asbval:assertion/skill/molecular-duplicate-detection-and-deduplication/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The chemical sanitization step sought to standardize the representation of chemical structures coming from different sources. It consisted of three main stages (standardizing, fragment removal, and uncharging) achieved via the MolVS package... All details are available in the following script: src/2_curating/2_editing/structure/4_enriching/naming.R... From the 283,267 initial InChI, 242,068 (85%) sanitized structures were obtained... In total, 163,800 structures with fully defined stereochemistry were uploaded as \"chemical compounds\" (Q11173), and 106,669 structures without fully defined stereochemistry were uploaded as \"group of stereoisomers\" (Q59199015).",
      "asbval:note": "The paper describes sanitization and deduplication of chemical structures from multiple sources, consolidating them into a unique registry for Wikidata upload.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "molecular-duplicate-detection-and-deduplication",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Identifies and removes duplicate chemical structures from a translated SMILES table by validating structural integrity and consolidating redundant entries into a unique structure registry.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:38:12.126417+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
