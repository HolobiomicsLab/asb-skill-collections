      }
    },
    {
      "@id": "asbval:assertion/skill/taxonomic-metadata-integration/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "First, a scientific name recognition step, allowing us to retrieve canonical names was carried (src/2_curating/2_editing/organisms/subscripts/1_processingOriginal.R). Then, a subtraction step of the obtained canonical names from the original field was applied... After full resolution of canonical names, all obtained names were submitted to rotl (Michonneau et al., 2016) to obtain a unified taxonomy.",
      "asbval:note": "Paper describes organism name cleaning and OTL mapping, but the specific script names and file paths in the card (1_cleaningOriginal.R, 4_cleaningTaxonomy.R, interim/tables/2_cleaned/organism/cleaned.tsv.gz) do not appear verbatim in passages. The functional workflow is correct but exact file/script names differ from paper documentation.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "taxonomic-metadata-integration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After organism name cleaning and standardization (via 1_cleaningOriginal.R and 4_cleaningTaxonomy.R) has produced a cleaned organism table (interim/tables/2_cleaned/organism/cleaned.tsv.gz), apply this skill to map those cleaned names to Open Tree of Life (OTL) identifiers.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
