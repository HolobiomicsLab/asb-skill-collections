      }
    },
    {
      "@id": "asbval:assertion/skill/count-verification-and-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "From the 88,395 initial \"clean\" organism fields, 43,936 (50%) canonical names were obtained, of which 32,285 (37%) were uploaded to Wikidata. From the 300 initial \"dirty\" organism fields, 250 (83%) canonical names were obtained, of which 208 (69%) were uploaded to Wikidata... After deduplication, 2M+ unique structure-organism pairs were obtained.",
      "asbval:note": "Paper performs extensive validation and filtering of structure-organism pairs with manual validation (420 pairs sampled, then 100 pairs for F0.5 scoring), but does not explicitly describe 'binning by organism-prevalence categories' or comparing against 'gold-standard reference counts' in the way the card frames it. The paper validates data quality through manual sampling and automated filtering rules, not through frequency-bin matching against external benchmarks.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "count-verification-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Verify that binned frequency counts of unique chemical structures match gold-standard reference counts across organism-prevalence categories.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:36:14.393224+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/count-verification-and-validation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To assess the validity of the obtained results, a randomized set of 420 referenced structure-organism pairs was sampled in each reference subcategory and validated or rejected manually... To validate those filtering criteria, an additional set of 100 structure-organism pairs were manually analyzed. F0.5 score was used as a metric.",
      "asbval:note": "Paper explicitly validates data integrity through manual sampling and automated filtering to detect quality discrepancies.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "count-verification-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill ensures data integrity in large structure-organism pair datasets by detecting discrepancies between computed and expected distributions.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:36:14.393224+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/count-verification-and-validation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "As depicted in Figure 4, on average, three organisms are reported per chemical structure and eleven structures per organism. Notably, half of all structures have been reported from a single organism and half of all studied organisms are reported to contain five or fewer structures.",
      "asbval:note": "Paper reports distribution statistics (singleton structures, organism-per-structure counts) but does not explicitly frame validation as 'binning into named categories (singleton, low-diversity, medium-diversity, high-diversity)' or matching against external reference benchmarks. The analysis is descriptive rather than comparative.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "count-verification-and-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have grouped unique 2D chemical structures by organism prevalence and need to confirm that the counts in each frequency bin (singleton, low-diversity, medium-diversity, high-diversity) match published or curated reference values.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:36:14.393224+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
