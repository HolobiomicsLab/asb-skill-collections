    {
      "@id": "asbval:assertion/card/10_1007_s00044_016_1764_y__task_005/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To retrieve as much information as possible from the original organism field of each of the sources, the following procedure was followed: First, a scientific name recognition step, allowing us to retrieve canonical names was carried (src/2_curating/2_editing/organisms/subscripts/1_processingOriginal.R). Then, a subtraction step of the obtained canonical names from the original field was applied... They were subsequently submitted again to scientific name recognition (src/2_curating/2_editing/organisms/3_processingTranslated.R). After full resolution of canonical names, all obtained names were submitted to rotl (Michonneau et al., 2016) to obtain a unified taxonomy.",
      "asbval:note": "Paper uses rotl (R package wrapping Open Tree of Life API) to obtain unified taxonomy, not a script named '5_addingOTL.R'. The function exists but is not explicitly named in passages. The enrichment process is confirmed but the specific script name cannot be verified.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_005",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "How does the 5_addingOTL.R script enrich cleaned organism names with Open Tree of Life identifiers?",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:32:47.320261+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
