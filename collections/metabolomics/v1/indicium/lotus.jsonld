    {
      "@id": "asbval:assertion/skill/dataset-integrity-assessment/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Regarding the versioning aspects, some challenges are implied by the dynamic nature of the Wikidata environment. However, tracking of the data evolution can be achieved in multiple ways and at different levels: at the full Wikidata level, dumps are regularly created (https://dumps.wikimedia.org/wikidatawiki/entities) while at the individual entry level the full history of modification can be consulted...",
      "asbval:note": "The paper acknowledges the dynamic nature of Wikidata and describes version tracking mechanisms, supporting the guidance that cross-version comparisons require different approaches than direct reproduction.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "dataset-integrity-assessment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: When comparing counts across different dataset versions or snapshots (use change-tracking instead of direct reproduction)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:37:15.059635+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
