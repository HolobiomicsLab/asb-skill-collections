    {
      "@id": "asbval:assertion/skill/tsv-csv-file-parsing-and-aggregation/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The chemical sanitization step sought to standardize the representation of chemical structures coming from different sources. It consisted of three main stages (standardizing, fragment removal, and uncharging) achieved via the MolVS package.",
      "asbval:note": "Paper describes sanitization and stereochemistry processing but does not explicitly name the Python scripts listed in evidence_spans. The functionality is confirmed but script names are not verbatim in passages.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "tsv-csv-file-parsing-and-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[4].evidence_spans",
      "asbval:target_claim_text": "Python 3 packages including smiles.py, 3_cleaningAndEnriching/sanitizing.py, 3_cleaningAndEnriching/stereocounting.py",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:18.411560+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/tsv-csv-file-parsing-and-aggregation/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Bulk retrieval of a frozen (2021-12-20) version of LOTUS data is also available at https://doi.org/10.5281/zenodo.5794106 (Rutz et al., 2021a)... LNPN can also be queried via the application programming interface (API) as described in the documentation. LNPN bulk data can be retrieved as SDF or SMILES files, or as a complete MongoDB dump via https://lotus.naturalproducts.net/download.",
      "asbval:note": "Paper confirms availability of tabular TSV/CSV data for download and describes use cases for counting and aggregating structure-organism pairs.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tsv-csv-file-parsing-and-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When to use: You have TSV or CSV files containing structure-organism pairs and need to count unique pairs, unique structures, unique organisms, or enumerate source database identifiers",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:41:18.411560+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/tsv-csv-file-parsing-and-aggregation/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The initial entries (containing one or multiple producing organisms per structure, with one or multiple accepted names per organism) were processed into 2M+ referenced structure-organism pairs.",
      "asbval:note": "Paper distinguishes between raw record-level pairs and processed/aggregated data, supporting the scope boundary.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tsv-csv-file-parsing-and-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Input files are already in memory as aggregated summary tables rather than raw record-level pairs",
      "eco:evidence_type": {
