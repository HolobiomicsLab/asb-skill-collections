    {
      "@id": "asbval:assertion/skill/tsv-csv-file-parsing-and-aggregation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "After extensive data curation and harmonization of over 40 electronic ressources, pairs characterizing a NP occurrence were standardized at the chemical, biological and reference levels... LOTUS disseminates 750,000+ referenced structure-organism pairs... A frozen (as of 2021-12-20), tabular version of this dataset with its associated metadata is made available at https://doi.org/10.5281/zenodo.5794106",
      "asbval:note": "Paper explicitly describes curation of structure-organism pairs into standardized tabular format and provides frozen TSV/CSV datasets for download.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "tsv-csv-file-parsing-and-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Load delimited structure-organism pair tables (TSV/CSV) from a curated natural products dataset and aggregate them by unique identifiers (structure ID, organism ID) to produce count statistics.",
