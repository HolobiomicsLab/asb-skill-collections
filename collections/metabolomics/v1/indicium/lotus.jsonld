        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/tsv-csv-file-parsing-and-aggregation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "R - Python 3 - Java >= 17",
