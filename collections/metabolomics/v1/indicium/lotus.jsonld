    {
      "@id": "asbval:assertion/card/10_1007_s00044_016_1764_y__task_004/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The chemical sanitization step sought to standardize the representation of chemical structures coming from different sources. It consisted of three main stages (standardizing, fragment removal, and uncharging) achieved via the MolVS package... From the 248,185 initial SMILES, 207,658 (84%) sanitized structures were obtained",
      "asbval:note": "Paper describes sanitization via MolVS package (Python), not named scripts 'smiles.py' and 'sanitizing.py'. The functional process (SMILES standardization, sanitization, deduplication) is present, but the specific script names are not verified in passages.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_004",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "How do the smiles.py and sanitizing.py scripts transform raw SMILES strings from the gathering layer into standardized, deduplicated structural identifiers?",
      "eco:evidence_type": {
