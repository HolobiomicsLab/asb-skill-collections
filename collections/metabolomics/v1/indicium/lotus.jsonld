    {
      "@id": "asbval:assertion/skill/chemical-informatics-data-format-conversion/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "From the 248,185 initial SMILES, 207,658 (84%) sanitized structures were obtained, of which 98,685 (48%) had complete stereochemistry defined. 174,091 (70%) were uploaded to Wikidata.",
      "asbval:note": "The paper confirms processing of SMILES from initial sources into sanitized, validated structures. However, the specific file path 'interim/tables/0_original/structure/smiles.tsv.gz' is not mentioned in the passages; the paper references generic directory structures like 'src/2_curating/2_editing/structure/' but not the exact interim table paths claimed.",
      "asbval:perspicacite_kb": "asb-paper-10-7554-elife-70780",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "chemical-informatics-data-format-conversion",
