    {
      "@id": "asbval:assertion/skill/memo-ms-api-usage-and-parameter-configuration/018",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The MEMO strategy exploits the advantages of LC, namely its separative power (thus simplifying the chemical complexity of the analyzed sample and allowing isomerism resolving) while avoiding the caveats of a RT based alignment since the MEMO vectors only contain mass spectrometric information.",
      "asbval:note": "Core methodological principle of MEMO explicitly documented.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "memo-ms-api-usage-and-parameter-configuration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Retention time agnostic alignment avoiding RT-based feature matching",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:01:28.015884+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/memo-ms-api-usage-and-parameter-configuration/019",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The first step of the MEMO approach consists in extracting the fragment ions and neutral losses from each binned MS/MS spectra of the detected features (m/z @ RT) into so-called documents.",
      "asbval:note": "Core methodological step explicitly documented.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "memo-ms-api-usage-and-parameter-configuration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Fragment ion and neutral loss extraction from binned MS/MS spectra",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:01:28.015884+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/memomatrix-object-handling/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Multiple MEMO vectors and/or MEMO matrices can be merged, facilitating the subsequent addition of supplementary samples' MEMO vectors. This is a convenient characteristic of the MEMO analytical workflow, which allows iterative analysis of evolving datasets",
      "asbval:note": "Paper explicitly describes merging MEMO matrices and vectors for cross-cohort analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "memomatrix-object-handling",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Load, manipulate, and merge MemoMatrix objects\u2014the unified matrix representations of MS2 fingerprints generated from metabolomics samples\u2014to enable alignment and comparative analysis across separate sample cohorts.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:01:55.145240+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/memomatrix-object-handling/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MEMO thus allows the comparison of vast ensembles of samples, even when analyzed over long periods of time, and on different chromatographic or mass spectrometry platforms.",
      "asbval:note": "Paper demonstrates multi-matrix union across different platforms and batches.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "memomatrix-object-handling",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill supports both single-matrix serialization and multi-matrix union operations required for chemodiverse sample comparison.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:01:55.145240+00:00",
