    {
      "@id": "asbval:assertion/skill/spectral-fingerprint-vectorization/012",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Two approaches can be followed to generate a MEMO matrix and are described in Figure 1. On one side (Figure 1A1), it is possible to start directly from unaligned samples to construct a sample's MEMO vector... On the other side (Figure 1A2), it is also possible to start the process from an aligned feature intensity table (.csv file) and corresponding MS/MS spectra file (.mgf file).",
      "asbval:note": "Both workflows explicitly documented with detailed descriptions.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-fingerprint-vectorization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Two workflows: (1) MEMO from unaligned samples (direct from .mgf files without prior feature alignment), (2) MEMO from aligned samples (from pre-aligned feature intensity tables)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:06:40.347903+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-fingerprint-vectorization/013",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "peaks and losses to the precursor of the spectrum are converted into words (i.e. peak@mz and loss@mz) and grouped into so-called documents",
      "asbval:note": "Verbatim match: peaks and losses converted to word format.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-fingerprint-vectorization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Peaks and neutral losses are extracted from binned MS/MS spectra and converted into 'words' (peak@mz and loss@mz)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:06:40.347903+00:00",
