    {
      "@id": "asbval:assertion/skill/retention-time-agnostic-spectral-alignment/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "First, MS2 spectra are filtered and binned using matchms and spec2vec packages: peaks and losses to the precursor of the spectrum are converted into words (i.e. peak@mz and loss@mz) and grouped into so-called documents... Documents are then aggregated by summing peaks and losses occurrences across spectra of a given sample to obtain the MEMO vector... MEMO vectors can then be aligned to obtain a MEMO matrix... This way of building a MEMO matrix without prior RT based features alignment across samples is defined hereafter as 'MEMO from unaligned samples' approach",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "retention-time-agnostic-spectral-alignment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Generate MS2-based sample fingerprints by counting MS2 peaks and neutral losses, then align these fingerprints to enable cross-sample comparison without requiring retention time (RT) alignment.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:05:28.536203+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/retention-time-agnostic-spectral-alignment/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MEMO thus allows the comparison of vast ensembles of samples, even when analyzed over long periods of time, and on different chromatographic or mass spectrometry platforms... The MEMO strategy exploits the advantages of LC, namely its separative power (thus simplifying the chemical complexity of the analyzed sample and allowing isomerism resolving) while avoiding the caveats of a RT based alignment",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "retention-time-agnostic-spectral-alignment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This approach is particularly suited for comparing chemically diverse samples acquired across different LC methods or mass spectrometer technologies.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:05:28.536203+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/retention-time-agnostic-spectral-alignment/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Spectra were processed using memo_ms v0.1.3 (https://pypi.org/project/memo-ms/0.1.3/) and the following parameters for spectra import were used: min_relative_intensity: 0.01, max_relative_intensity: 1, min_peaks_required: 10, losses_from: 10, losses_to: 200, n_decimals: 2.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "retention-time-agnostic-spectral-alignment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "memo-ms with role: Executes memo_from_unaligned function to construct MemoMatrix objects by aligning MS2 fingerprints across samples",
