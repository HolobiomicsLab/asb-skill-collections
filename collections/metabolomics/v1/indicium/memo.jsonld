    {
      "@id": "asbval:assertion/skill/spectral-fingerprint-vectorization/015",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "For the comparison between QE and Q-ToF data, matrices were normalized sample-wise. The distance matrices were computed using pdist function ('braycurtis' metric)",
      "asbval:note": "Sample-wise normalization explicitly applied for cross-platform comparison.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-fingerprint-vectorization",
