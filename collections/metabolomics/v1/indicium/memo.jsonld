    {
      "@id": "asbval:assertion/skill/sample-vectorization-via-spectral-features/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This method is particularly suited for heterogeneous and chemodiverse sample sets... MEMO thus allows the comparison of vast ensembles of samples, even when analyzed over long periods of time, and on different chromatographic or mass spectrometry platforms.",
      "asbval:note": "All three use cases confirmed: chemodiverse samples, different LC/MS platforms, and RT shifts. Paper explicitly evaluates on Q-Exactive and Q-ToF (Maxis II).",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-vectorization-via-spectral-features",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it especially for chemodiverse samples (poor feature overlap), samples acquired on different LC methods or mass spectrometers (e.g. Maxiis Q-ToF vs Q-Exactive Orbitrap), or when strong retention-time shifts between runs make traditional feature alignment unreliable.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:06:04.581813+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/sample-vectorization-via-spectral-features/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This way of building a MEMO matrix without prior RT based features alignment across samples is defined hereafter as 'MEMO from unaligned samples' approach",
      "asbval:note": "Paper describes two workflows: MEMO from unaligned and MEMO from aligned samples. The card's 'when NOT to use' is not explicitly stated as a limitation in the paper; rather, the paper shows MEMO can work with both aligned and unaligned data. The claim is partially supported by the existence of the aligned workflow, but the paper does not discourage use with aligned data.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "sample-vectorization-via-spectral-features",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Input spectra are already aligned and feature-extracted (use a peak-picking and alignment tool instead)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
