      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-fingerprint-vectorization/014",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Documents are then aggregated by summing peaks and losses occurrences across spectra of a given sample to obtain the MEMO vector",
      "asbval:note": "Verbatim match: occurrences summed to create MEMO vector.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-fingerprint-vectorization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Words are aggregated by counting occurrences across all spectra within a sample to generate a MEMO vector",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
