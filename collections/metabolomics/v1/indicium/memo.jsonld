    {
      "@id": "asbval:assertion/skill/ms2-spectra-parsing-and-loading/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the only required input is a. mgf file for each sample (Mascot Generic Format, a text format commonly used to report fragmentation mass spectrometry data) containing all the sample's features MS/MS spectra. If these. mgf can be directly obtained from the raw data input, it is however recommended to proceed to a preliminary feature detection step using softwares such as MZmine for example",
      "asbval:note": "Paper confirms MGF format support and matchms parsing. mzML and mzXML are not explicitly mentioned in passages but are standard formats supported by matchms.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "ms2-spectra-parsing-and-loading",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Load and parse tandem mass spectrometry (MS2) spectra files in standardized formats (mzML, mzXML, MGF) using the matchms library",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:03:16.499699+00:00",
      "sepio:credibility_status": {
