    {
      "@id": "asbval:assertion/skill/sample-relationship-visualization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "These MEMO vectors can then be aligned and used for classical multivariate analysis (PCA, PCoA) and/or other dimensionality reduction approaches such as UMAP or TMAP (McInnes et al., 2018; Probst and Reymond 2020), allowing the efficient calculation and visualization of spectral relationships within large cohorts of samples.",
      "asbval:note": "PCoA is explicitly mentioned as applied to MEMO vectors (MS2 fingerprints) for visualization and sample clustering.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-relationship-visualization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply Multidimensional Scaling (MDS) or Principal Coordinate Analysis (PCoA) to MS2 fingerprint distance matrices to generate low-dimensional 2D scatter plots that enable visual comparison and clustering of metabolomics samples.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:05:43.595307+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/sample-relationship-visualization/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To reflect the chemical diversity of heterogeneous sample collections, while tackling batch-effects, several methods have been introduced that consider the relationships among analytes (notably via their MS/MS spectrum or chemical structure).",
      "asbval:note": "Paper emphasizes the importance of methods that identify relationships among samples in chemodiverse datasets.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-relationship-visualization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill is essential for identifying sample relationships and compositional similarities in chemodiverse datasets.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:05:43.595307+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/sample-relationship-visualization/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MEMO thus allows the comparison of vast ensembles of samples, even when analyzed over long periods of time, and on different chromatographic or mass spectrometry platforms.",
      "asbval:note": "Paper explicitly demonstrates MEMO's ability to handle batch effects, RT shifts, and different LC/MS platforms.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-relationship-visualization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill after generating aligned MS2 fingerprints (sample-by-fingerprint matrices) from metabolomics data when you need to visually inspect sample clustering, identify sample similarities, or detect batch effects and RT shifts across different LC methods or mass spectrom",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
