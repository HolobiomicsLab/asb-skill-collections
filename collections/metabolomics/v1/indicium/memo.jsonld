    {
      "@id": "asbval:assertion/skill/sample-vectorization-via-spectral-features/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MS2 spectra are filtered and binned using matchms and spec2vec packages: peaks and losses to the precursor of the spectrum are converted into words (i.e. peak@mz and loss@mz) and grouped into so-called documents (Huber et al., 2020; Huber et al., 2021). Documents are then aggregated by summing peaks and losses occurrences across spectra of a given sample to obtain the MEMO vector",
      "asbval:note": "Verbatim match: peaks and neutral losses are counted and aggregated into sample-level vectors (MEMO vectors). RT-agnostic design confirmed in abstract and introduction.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-vectorization-via-spectral-features",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Transform unaligned MS2 spectra into sample-level feature vectors (MemoMatrix) by counting MS2 peaks and neutral losses across all spectra in each sample, enabling retention-time agnostic comparison of metabolomics samples.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:06:04.581813+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/sample-vectorization-via-spectral-features/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MEMO thus allows the comparison of vast ensembles of samples, even when analyzed over long periods of time, and on different chromatographic or mass spectrometry platforms. This new addition to the computational metabolomics toolbox should drastically expand the scope of large-scale comparative analysis.",
      "asbval:note": "Scope alignment confirmed: paper explicitly states MEMO handles different LC/MS platforms and long time periods.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-vectorization-via-spectral-features",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill is essential when samples acquired on different LC\u2013MS platforms or with strong retention-time drift need to be compared despite poor feature overlap.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:06:04.581813+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/sample-vectorization-via-spectral-features/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Spectra were processed using memo_ms v0.1.3 (https://pypi.org/project/memo-ms/0.1.3/) and the following parameters for spectra import were used: min_relative_intensity: 0.01, max_relative_intensity: 1, min_peaks_required: 10, losses_from: 10, losses_to: 200, n_decimals: 2.",
      "asbval:note": "Tool name confirmed (case-insensitive: memo_ms). Role matches: core implementation of MEMO algorithm.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "sample-vectorization-via-spectral-features",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
