    {
      "@id": "asbval:assertion/skill/spectral-fingerprint-vectorization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "First, MS2 spectra are filtered and binned using matchms and spec2vec packages: peaks and losses to the precursor of the spectrum are converted into words (i.e. peak@mz and loss@mz) and grouped into so-called documents (Huber et al., 2020; Huber et al., 2021). Documents are then aggregated by summing peaks and losses occurrences across spectra of a given sample to obtain the MEMO vector",
      "asbval:note": "Verbatim match: peaks and losses are counted and aggregated into vectors; retention time-agnostic is explicitly stated in abstract and methods.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-fingerprint-vectorization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Generate numeric fingerprint vectors from MS2 spectra by counting occurrences of fragment peaks and neutral losses per sample, enabling retention time-agnostic comparison of metabolomics samples.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:06:40.347903+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
