    {
      "@id": "asbval:assertion/skill/neutral-loss-feature-extraction-from-spectra/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MEMO thus allows the comparison of vast ensembles of samples, even when analyzed over long periods of time, and on different chromatographic or mass spectrometry platforms... The MEMO strategy exploits the advantages of LC, namely its separative power (thus simplifying the chemical complexity of the analyzed sample and allowing isomerism resolving) while avoiding the caveats of a RT based alignment since the MEMO vectors only contain mass spectrometric information.",
      "asbval:note": "Scope statement is well-supported by paper's description of MEMO's applicability to cross-platform and cross-batch samples.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "neutral-loss-feature-extraction-from-spectra",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill when you have MS2 spectra data (MGF/mzML format) and aligned feature tables, and your analysis goal is to compare samples that may have poor MS1 feature overlap, strong retention-time shifts across runs, or were acquired on different LC-MS platforms.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:04:28.851796+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/neutral-loss-feature-extraction-from-spectra/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "MEMO vectors only contain mass spectrometric information [from MS/MS]... the only required input is a .mgf file for each sample (Mascot Generic Format, a text format commonly used to report fragmentation mass spectrometry data) containing all the sample's features MS/MS spectra.",
      "asbval:note": "Paper clearly requires MS/MS (MS2) spectra; MS1-only data would not be suitable.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "neutral-loss-feature-extraction-from-spectra",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Input spectra are MS1-only (no fragmentation data available)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:04:28.851796+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/neutral-loss-feature-extraction-from-spectra/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The main advantage of using unaligned files to construct a MEMO matrix is that the time-consuming feature alignment step, which is prone to batch effects, can be completely bypassed.",
      "asbval:note": "Paper explicitly states MEMO bypasses RT-based alignment; this is a core feature, not a limitation.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "neutral-loss-feature-extraction-from-spectra",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When NOT to use: Sample comparison goal requires chromatographic alignment (use traditional LC-MS feature alignment instead)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:04:28.851796+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/neutral-loss-feature-extraction-from-spectra/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not discuss this scenario or compatibility with pre-computed fingerprints. This is a reasonable inference but not explicitly addressed in the passages.",
