    {
      "@id": "asbval:assertion/skill/per-sample-spectral-aggregation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "First, MS2 spectra are filtered and binned using matchms and spec2vec packages: peaks and losses to the precursor of the spectrum are converted into words (i.e. peak@mz and loss@mz)",
      "asbval:note": "Role description aligns with paper's description of matchms filtering and binning spectra to extract peaks and losses.",
      "asbval:perspicacite_kb": "asb-paper-10-3389-fbinf-2022-842964",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "per-sample-spectral-aggregation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[role]",
      "asbval:target_claim_text": "matchms role: Parses raw MS2 spectra files and extracts precursor m/z and fragment peaks; provides spectrum objects and metadata cleaning",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T22:04:50.189270+00:00",
      "sepio:credibility_status": {
