    {
      "@id": "asbval:assertion/skill/quality-control-metric-distribution-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Asari includes a set of metrics to fully describe data quality... SNR (signal-to-noise ratio)... mSelectivity metric... cSelectivity is defined as how distinct chromatograhic elution peaks are... Together with peak shape, users can rely on them to routinely determine the peak quality. Global visualization of these three quality metrics in Yeast2021 data, in relation to peak size, is shown in Fig. 6c.",
      "asbval:note": "Paper explicitly discusses SNR, peak shape (Gaussian fitness), and selectivity metrics for quality assessment and filtering. Prominence is mentioned in peak detection algorithm context.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "quality-control-metric-distribution-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Analyze the distribution and selectivity of peak quality metrics (SNR, peak shape goodness-of-fit, peak height, prominence) across detected features to assess filtering efficacy and inform threshold tuning in LC-MS metabolomics workflows.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:54:05.757661+00:00",
      "sepio:credibility_status": {
