    {
      "@id": "asbval:assertion/skill/metabolomics-database-search-and-formula-matching/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Asari takes centroid mzML files as input and builds chromatograms for each as mass tracks... Annotation groups degenerate features into empirical compounds, and reference databases are used to match the m/z values in empirical compounds.",
      "asbval:note": "Paper confirms asari detects features and that annotation groups features into empirical compounds, and references are used for matching. However, the paper does not explicitly state that asari 'invokes' database search or that it orchestrates the full workflow including database search. The paper indicates these are separate steps: 'Annotation groups degenerate features into empirical compounds, and reference databases are used to match the m/z values' suggests these may be sequential but not necessarily integrated within asari itself.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "metabolomics-database-search-and-formula-matching",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "asari: Orchestrates the full workflow: detects features, constructs empirical compounds via khipu pre-annotation, then invokes database search and outputs annotated results",
