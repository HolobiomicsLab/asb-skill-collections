    {
      "@id": "asbval:assertion/skill/sample-study-size-stratified-algorithm-selection/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper describes mass alignment via mass tracks and composite mass tracks, but does not explicitly discuss a conditional algorithm selection strategy that switches between 'pairwise' and 'nearest-neighbor' approaches based on sample count. The paper emphasizes mass track alignment before elution peak detection and mentions LOWESS regression for RT alignment, but no mention of pairwise vs. nearest-neighbor algorithm selection logic.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "sample-study-size-stratified-algorithm-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "A performance-conscious strategy for selecting between pairwise and nearest-neighbor mass alignment algorithms based on study sample count.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:55:05.393167+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/sample-study-size-stratified-algorithm-selection/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The CPU time and memory use was largely a linear function of sample numbers (Fig. 8b, c). The results indicate that the performance gap between XCMS and asari widens for larger studies.",
      "asbval:note": "Paper demonstrates that asari scales well with sample count (linear scaling in CPU and memory), but does not describe a conditional algorithm selection strategy based on sample count thresholds (e.g., \u226410 vs. >10). The scalability claim is supported, but the mechanism of algorithm switching is not documented in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "sample-study-size-stratified-algorithm-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill enables asari to scale across small (\u226410 samples) and large studies by choosing algorithmically matched approaches that balance CPU and memory use.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:55:05.393167+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/sample-study-size-stratified-algorithm-selection/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Mass tracks are aligned cross samples before elution peak detection in asari (Fig. 2a, right). Aligned mass tracks of all samples form a 'MassGrid', which provides a foundation for trackable and high-quality feature correspondence.",
      "asbval:note": "Paper confirms that mass alignment occurs before MassGrid construction, but does not describe a decision point or algorithm selection strategy at this stage.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "sample-study-size-stratified-algorithm-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When beginning mass alignment in a multi-sample LC-MS metabolomics study, before constructing the MassGrid.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:55:05.393167+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/sample-study-size-stratified-algorithm-selection/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "No mention in the paper of 'pairwise anchor-track prioritization' for small studies or 'binning-based nearest-neighbor clustering' for large studies. The paper does not describe these specific algorithmic strategies or their sample-count-dependent selection.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "sample-study-size-stratified-algorithm-selection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "The decision depends on the total sample count in your project: small studies benefit from pairwise anchor-track prioritization, while large studies require binning-based nearest-neighbor clustering to avoid quadratic scaling.",
      "eco:evidence_type": {
