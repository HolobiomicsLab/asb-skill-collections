    {
      "@id": "asbval:assertion/card/10_1038_s41467_023_39889_1__task_005/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Small studies can be processed by asari under a minute. Some studies of 100 ~ 200 samples take less than 10 min by asari using a single CPU core. The full SLAW dataset of >2000 samples was processed in the previous study by XCMS on a cluster node of 15 CPU cores in 7~12 h. This same dataset was processed in ~1 h on a regular laptop computer using asari.",
      "asbval:note": "Paper provides throughput estimates (e.g., 100-200 samples in <10 min, >2000 samples in ~1 h) but does not provide a formal summary report with explicit mean throughput in samples/hour or extrapolated estimates for 1000-sample projects in structured format.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "task_005",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "expected_outputs",
      "asbval:target_claim_text": "Summary report (text or markdown) stating mean throughput (samples/hour) per cohort and extrapolated time estimate for 1000-sample project",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:44:15.652183+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/card/10_1038_s41467_023_39889_1__task_005/scope_drift",
      "@type": "asbval:ScopeDriftAssertion",
      "asbval:drift_notes": [
        "The card requests analysis of scalability 'up to >100 mzML files', which aligns with the paper's testing on datasets ranging from small studies to >2000 samples.",
        "The paper's scalability evaluation uses real datasets (HZV029, Yeast2021, BM21, SLAW) rather than synthetic or controlled-size mzML files, which is appropriate but slightly different from the card's framing of 'running it on increasing sample counts'.",
        "The card specifies 'pymzml' as a tool, but the paper does not use or mention pymzml; it uses centroided mzML files as input (processed by ThermoRawFileParser or msConvert upstream)."
      ],
      "asbval:n_drift_notes": 3,
