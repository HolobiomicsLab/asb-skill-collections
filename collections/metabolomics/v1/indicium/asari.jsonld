    {
      "@id": "asbval:assertion/skill/m-z-alignment-and-mass-grid-assembly/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A metabolite may have multiple degenerate features due to isotopes, adducts, neutral loss and fragments, which are grouped into an 'empirical compound' via another package khipu",
      "asbval:note": "Paper confirms khipu is used for isotope/adduct grouping, though this is downstream of m/z alignment (in the feature annotation step, not the m/z alignment step itself).",
