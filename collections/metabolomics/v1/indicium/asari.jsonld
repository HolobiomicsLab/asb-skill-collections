    {
      "@id": "asbval:assertion/skill/baseline-and-noise-level-estimation-from-quartile-statistics/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The default peak detection algorithm in asari first estimates the baseline and noise level on a composite mass track (details in the Supplementary Information). The statistics drive the decisions on baseline subtraction, detrending or smoothing.",
      "asbval:note": "Paper confirms baseline and noise estimation is performed in asari, but does not explicitly name 'quartile statistics' as the method. The paper states 'estimates the baseline and noise level' but relegates detailed methodology to Supplementary Information (not provided in passages). The quartile-based approach is inferred but not verbatim confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "baseline-and-noise-level-estimation-from-quartile-statistics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Estimate chromatographic baseline and noise level from the bottom intensity quartiles of a mass track to enable robust peak detection in LC-MS metabolomics.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
