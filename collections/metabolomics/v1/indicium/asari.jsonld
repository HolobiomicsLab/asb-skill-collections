    {
      "@id": "asbval:assertion/skill/retention-time-calibration-via-lowess-regression/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Retention time (RT) correction between samples, also called retention time alignment, is carried out by LOWESS regression, using a small subset of high-quality elution peaks. These reference peaks are easy to select from previously aligned mass tracks, preferably as the only peak on a mass track. The regression result is translated to an RT remapping function for each sample. This remapping is bidirectional: RT on the composite mass track is mapped back to each sample correctly regardless how much error is in the regression model.",
      "asbval:note": "LOWESS regression for RT correction is explicitly described. Landmark peak selection and boundary extension (bidirectional remapping) are confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "retention-time-calibration-via-lowess-regression",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "A statistically guided approach to correct sample-level retention time drift in LC-MS metabolomics by identifying high-confidence landmark peaks and applying LOWESS (locally weighted scatterplot smoothing) regression with boundary extension.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:54:48.184399+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/retention-time-calibration-via-lowess-regression/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Aligned mass tracks across samples are corrected for RT, using LOWESS regression on a subset of high-quality elution peaks, then aggregated into composite mass tracks. Elution peak detection is performed on the composite mass tracks, and feature table is generated by looking up the corresponding peak areas in each individual sample.",
      "asbval:note": "The workflow order is confirmed: mass track alignment \u2192 RT correction via LOWESS \u2192 composite mass track aggregation \u2192 elution peak detection.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "retention-time-calibration-via-lowess-regression",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After mass track extraction and alignment across samples, when preparing to detect elution peaks on composite mass tracks.",
      "eco:evidence_type": {
