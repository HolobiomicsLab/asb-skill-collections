    {
      "@id": "asbval:assertion/skill/time-and-memory-complexity-visualization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To test the scalability, we subset the SLAW data using varying sample numbers. The CPU time and memory use was largely a linear function of sample numbers (Fig. 8b, c). The results indicate that the performance gap between XCMS and asari widens for larger studies.",
      "asbval:note": "Paper directly addresses wall-clock runtime and memory scaling with sample numbers; Fig. 8b,c show empirical scaling curves.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "time-and-memory-complexity-visualization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Quantify and visualize how wall-clock runtime and peak memory usage scale with increasing sample numbers in LC-MS metabolomics data processing, enabling empirical verification of claimed computational efficiency on resource-constrained hardware.",
