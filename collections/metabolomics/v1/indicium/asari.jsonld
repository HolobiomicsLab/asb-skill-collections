      }
    },
    {
      "@id": "asbval:assertion/skill/peak-evaluation-metrics-cselectivity-snr-gaussian-fit/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A composite mass track is then separated into segments of valid signals, and peak detection is performed on each segment... The detected peaks are assessed by a set of quality metrics and retained only if the preset thresholds are met.",
      "asbval:note": "The paper describes peak evaluation on composite mass track segments and retention based on quality metrics, but asari uses its own local maximum search algorithm, not scipy.signal.find_peaks. The functional workflow is correct but the tool name is incorrect.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "peak-evaluation-metrics-cselectivity-snr-gaussian-fit",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After scipy.signal.find_peaks has identified candidate peaks on a composite mass track segment, evaluate each peak to decide whether to retain it in the final feature table.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:52:51.755904+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/peak-evaluation-metrics-cselectivity-snr-gaussian-fit/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The detected peaks are assessed by a set of quality metrics and retained only if the preset thresholds are met... These quality metrics are exported with the feature tables in asari.",
      "asbval:note": "The paper confirms that peaks are evaluated by quality metrics (cSelectivity, SNR, peak shape) and filtered before export to feature tables for downstream analysis.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "peak-evaluation-metrics-cselectivity-snr-gaussian-fit",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use this skill when you have detected peaks with coordinates (m/z, retention time) and need to filter by chromatographic selectivity, signal quality, and peak shape before reporting to downstream analysis or annotation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
