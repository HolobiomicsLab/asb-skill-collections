      "asbval:evidence_quote": null,
      "asbval:note": "Passages do not mention scipy.signal.find_peaks. Paper describes 'local maximum search algorithm' but does not name the specific implementation library or function used.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
