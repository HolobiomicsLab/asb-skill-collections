    {
      "@id": "asbval:assertion/skill/nearest-neighbor-clustering-by-mass-difference/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Aligned mass tracks across samples are corrected for RT, using LOWESS regression on a subset of high-quality elution peaks, then aggregated into composite mass tracks. All composite mass tracks are stored in the 'Composite Map'. Elution peak detection is performed on the composite mass tracks.",
      "asbval:note": "Paper confirms that mass alignment produces aligned mass tracks that feed into composite mass track construction and subsequent peak detection, matching the expected output of the nearest-neighbor clustering step.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "nearest-neighbor-clustering-by-mass-difference",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "expected_outputs (implicit)",
