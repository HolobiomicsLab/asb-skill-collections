    {
      "@id": "asbval:assertion/skill/quality-control-metric-distribution-analysis/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The detected peaks are assessed by a set of quality metrics and retained only if the preset thresholds are met... peak shape, here defined as the goodness of fitting to a Gaussian curve... SNR (signal-to-noise ratio) is often defined differently among tools. In asari, the noise for an elution peak is the average signal intensity of neighboring non-peak data points... Prominence is the vertical distance of a peak top to its adjacent local minima, therefore important to control for fluctuating data points.",
      "asbval:note": "All four metrics (SNR, peak shape/goodness-of-fit, peak height, prominence) are explicitly discussed in asari's peak detection and quality assessment.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "quality-control-metric-distribution-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After composite-map peak detection has produced an unfiltered peak list with SNR, peakshape (goodness_fitting), peak_height, and prominence values.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:54:05.757661+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/quality-control-metric-distribution-analysis/008",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The same plot can be used to weed out poor data quality, as illustrated in Supplementary Fig. 9a... users can rely on them to routinely determine the peak quality... Users can be confident of feature quality based on these metrics and own the decisions of filtering data.",
      "asbval:note": "Paper demonstrates filtering workflows and metric-based feature retention/rejection decisions.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "quality-control-metric-distribution-analysis",
