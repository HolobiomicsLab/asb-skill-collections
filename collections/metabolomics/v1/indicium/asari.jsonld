      }
    },
    {
      "@id": "asbval:assertion/skill/peak-evaluation-metrics-cselectivity-snr-gaussian-fit/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The default peak detection algorithm in asari first estimates the baseline and noise level on a composite mass track (details in the Supplementary Information). The statistics drive the decisions on baseline subtraction, detrending or smoothing. Detrending is to regress out shifting chromatographic background, used sparingly in necessary tracks... Noisy composite mass tracks are smoothed using simple moving average.",
      "asbval:note": "The paper describes mass track preprocessing (baseline, detrending, smoothing) but does not name the specific function 'peaks.audit_mass_track'. The function name appears to be an internal asari implementation detail not explicitly documented in the paper passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "peak-evaluation-metrics-cselectivity-snr-gaussian-fit",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "peaks.audit_mass_track",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:52:51.755904+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/peak-evaluation-metrics-cselectivity-snr-gaussian-fit/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Trackable and scalable Python program for high-resolution LC-MS metabolomics data preprocessing... Requires Python 3.8+.",
      "asbval:note": "Python requirement is confirmed in the paper metadata/abstract.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
