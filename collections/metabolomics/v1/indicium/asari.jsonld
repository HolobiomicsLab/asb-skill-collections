    {
      "@id": "asbval:assertion/card/10_1038_s41467_023_39889_1__task_004/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The default peak detection algorithm in asari first estimates the baseline and noise level on a composite mass track... Noisy composite mass tracks are smoothed using simple moving average... A composite mass track is then separated into segments of valid signals, and peak detection is performed on each segment. We use a local maximum search algorithm, with peak height and prominence requirements dynamically determined on the segment statistics.",
      "asbval:note": "Paper confirms asari has peak detection functionality with quality filtering, though it does not explicitly name a 'peaks module'.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "task_004",
      "asbval:target_artifact_kind": "card",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "asari peaks module",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:43:50.349643+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/card/10_1038_s41467_023_39889_1__task_004/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "These quality metrics are exported with the feature tables in asari... Users can be confident of feature quality based on these metrics and own the decisions of filtering data.",
      "asbval:note": "Paper confirms asari exports quality metrics with feature tables and supports filtering by SNR and peak shape. However, the specific filename 'preferred_Feature_table.tsv' is not mentioned, nor is the specific SNR threshold of >2 confirmed (only that SNR is used for filtering). Peak shape >0.5 threshold is confirmed. The concept of filtered vs. full feature tables is implied but not explicitly named as 'full_Feature_table.tsv' and 'preferred_Feature_table.tsv'.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
