      }
    },
    {
      "@id": "asbval:assertion/skill/quality-control-metric-distribution-analysis/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "High numbers of bad peaks are not acceptable in real-world applications due to their negative impacts on downstream analyses... features of questionable quality should not be used for decision making... The large numbers of 'extra' features reported by different tools are low-quality peaks, which are not reproducible and should not be used without additional evidence.",
      "asbval:note": "Paper demonstrates that filtering by quality metrics removes low-quality peaks while retaining reproducible, high-quality features.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "quality-control-metric-distribution-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill validates that peak filtering reduces false positives while retaining signal-rich features.",
      "eco:evidence_type": {
