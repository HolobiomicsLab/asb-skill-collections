    {
      "@id": "asbval:assertion/skill/nearest-neighbor-clustering-by-mass-difference/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "a nearest neighbor (NN) clustering is performed to establish the number of mass tracks",
      "asbval:note": "Paper confirms nearest-neighbor clustering for mass track alignment (passage [2] abstract mentions 'mass alignment' and 'mass tracks'; supplementary methods reference nn_cluster_by_mz_seeds). However, the paper does NOT explicitly state that this method avoids pairwise computation or is specifically designed for >10 samples. The paper emphasizes scalability and performance gains but does not detail the algorithmic trade-off (pairwise vs. binning) or sample-count thresholds in the main text passages provided. The histogram-based seeding is mentioned in the card but not explicitly confirmed in the provided passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "nearest-neighbor-clustering-by-mass-difference",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Groups mass tracks across LC-MS samples by clustering m/z values using nearest-neighbor methods seeded by histogram-based m/z detection, enabling scalable mass alignment for large studies (>10 samples) without pairwise computation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
