      }
    },
    {
      "@id": "asbval:assertion/skill/m-z-alignment-and-mass-grid-assembly/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not mention pymzml by name. Paper mentions 'ThermoRawFileParser' and 'msConvert' for data format conversion and centroiding, but does not specify which library asari uses internally for mzML parsing.",
