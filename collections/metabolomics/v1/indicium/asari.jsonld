      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "asari mass_functions module (nn_cluster_by_mz_seeds)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:50:21.188333+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/m-z-alignment-across-samples/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Aligned mass tracks of all samples form a 'MassGrid', which provides a foundation for trackable and high-quality feature correspondence... These data structures are JSON compatible and exposed, so that advanced users and developers can reuse them easily.",
      "asbval:note": "Paper confirms MassGrid class exists and is a core data structure. However, the specific method names (build_grid_sample_wise, add_sample, build_grid_by_centroiding, bin_track_mzs) are not mentioned in the passages. The paper states data structures are 'exposed' and 'reusable' but does not list these specific method names.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "m-z-alignment-across-samples",
