    {
      "@id": "asbval:assertion/skill/pairwise-alignment-with-anchor-prioritization/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The mass tracks that match 13C/12C and Na/H patterns are considered of high confidence and used as guides in the m/z alignment. Mass tracks are aligned cross samples before elution peak detection in asari.",
      "asbval:note": "Paper confirms anchor-based alignment using isotopes and adducts as guides, but does NOT specify a \u226410 sample threshold or pairwise-only strategy. The paper describes asari's general mass track alignment approach without sample-size stratification. The '\u226410 samples' constraint and 'pairwise alignment' framing appear to be extractor inferences not explicitly stated in the paper. The 1 ppm recalibration threshold is not mentioned.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "pairwise-alignment-with-anchor-prioritization",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "A mass track alignment strategy for small LC-MS metabolomics studies (\u226410 samples) that prioritizes alignment of anchor mass tracks (isotopes and adducts) before aligning remaining tracks, with optional m/z recalibration if systematic differences exceed 1 ppm.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:52:35.359057+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/pairwise-alignment-with-anchor-prioritization/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Mass tracks are aligned cross samples before elution peak detection in asari (Fig. 2a, right). This takes advantage of the superb mass resolution on today's instruments and avoids errors stemming from elution peak detection.",
      "asbval:note": "Paper describes mass track alignment across samples but does not specify a \u226410 sample threshold. The scope claim introduces a sample-size constraint not present in the paper. Asari is described as 'highly scalable' and tested on datasets with >2000 samples, suggesting it is NOT limited to small studies.",
