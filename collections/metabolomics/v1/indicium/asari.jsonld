    {
      "@id": "asbval:assertion/skill/chromatographic-peak-detection-with-prominence-control/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Elution peak detection is performed on the composite mass tracks, and feature table is generated by looking up the corresponding peak areas in each individual sample.",
      "asbval:note": "Paper focuses on composite mass tracks for peak detection, not per-sample mass tracks. The scope claim includes 'per-sample' but the paper's design emphasizes composite mass tracks as the primary approach. GC-MS is mentioned in scope but paper is LC-MS specific.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "chromatographic-peak-detection-with-prominence-control",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill after constructing baseline-corrected mass tracks (either composite across samples or per-sample) when you need to identify individual chromatographic peaks for feature extraction in LC-MS or GC-MS metabolomics workflows.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:47:33.552073+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/chromatographic-peak-detection-with-prominence-control/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The statistics drive the decisions on baseline subtraction, detrending or smoothing... peak detection is performed on each segment. We use a local maximum search algorithm, with peak height and prominence requirements dynamically determined on the segment statistics.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chromatographic-peak-detection-with-prominence-control",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it specifically when you have intensity arrays with known noise characteristics and want to avoid over-detection of shallow peaks or under-detection due to fixed, global prominence thresholds.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:47:33.552073+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/composite-mass-track-assembly-and-peak-detection/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Aligned mass tracks are summed into a 'composite mass track' after correction of retention time (Fig. 2b). With this approach, elution peak detection is no longer required on individual samples. It can be done on the composite mass track, then the peak area is looked up in each individual sample and reported as feature intensity values (Fig. 2b)... The default peak detection algorithm in asari first estimates the baseline and noise level on a composite mass track (details in the Supplementary Information). The statistics drive the decisions on baseline subtraction, detrending or smoothing... A composite mass track is then separated into segments of valid signals, and peak detection is performed on each segment. We use a local maximum search algorithm, with peak height and prominence requirements dynamically determined on the segment statistics.",
      "asbval:note": "Fully supported. The paper explicitly describes composite mass track assembly and statistics-guided local maxima detection with prominence control.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "composite-mass-track-assembly-and-peak-detection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Assemble aligned mass tracks from multiple LC-MS samples into a composite mass track, then detect elution peaks on this composite map using statistics-guided local maxima detection.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:47:49.616488+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/composite-mass-track-assembly-and-peak-detection/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "This greatly simplifies feature correspondence, and has a significant performance gain, by not repeating the computational cost of peak detection on all individual samples. Because the composite mass track has higher signals than any individual sample, the quality of peak detection is often improved.",
      "asbval:note": "Supported. Paper explicitly states the benefit of avoiding repeated peak detection and improving quality through composite approach.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "composite-mass-track-assembly-and-peak-detection",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This approach prioritizes mass resolution and selectivity, avoiding repeated peak detection on individual samples and improving reproducibility across the cohort.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:47:49.616488+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/composite-mass-track-assembly-and-peak-detection/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
