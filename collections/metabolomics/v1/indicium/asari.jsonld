      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/peak-quality-assessment-by-selectivity-and-snr-metrics/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Together with peak shape, users can rely on them to routinely determine the peak quality... The default peak detection algorithm in asari first estimates the baseline and noise level on a composite mass track... The detected peaks are assessed by a set of quality metrics and retained only if the preset thresholds are met.",
      "asbval:note": "Paper confirms use of mSelectivity, SNR, and Gaussian peak shape (>0.5) for quality filtering on composite mass tracks. However, the specific threshold mSelectivity >0.99 is not stated in passages; paper shows mSelectivity distribution but does not specify a >0.99 threshold. SNR >2 threshold also not explicitly stated; paper defines SNR calculation but does not name a specific threshold value. Peak shape >0.5 is confirmed in passage 8.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "peak-quality-assessment-by-selectivity-and-snr-metrics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Evaluate detected LC-MS peaks on composite mass tracks using selectivity (mSelectivity >0.99) and signal-to-noise ratio (SNR >2) metrics alongside Gaussian peakshape quality (>0.5) to filter spurious or low-confidence features before downstream annotation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:53:07.943576+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/peak-quality-assessment-by-selectivity-and-snr-metrics/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "High quality peaks should have peak shapes close to 1... peak shape, here defined as the goodness of fitting to a Gaussian curve",
      "asbval:note": "Paper describes Gaussian peak shape evaluation as part of asari's quality metrics, but does not name the specific function 'peaks.evaluate_gaussian_peak_on_intensity_list'. The function name appears to be an internal asari module name not explicitly mentioned in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
