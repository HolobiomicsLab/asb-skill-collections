      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/peak-evaluation-metrics-cselectivity-snr-gaussian-fit/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "An intuitive measure of peak quality is 'peak shape', here defined as the goodness of fitting to a Gaussian curve (other curves have been used but the impact on fitness scores is negligible).",
      "asbval:note": "The paper describes Gaussian peak fitting for quality assessment but does not name the specific function 'peaks.evaluate_gaussian_peak_on_intensity_list'. The function name appears to be an internal asari implementation detail not explicitly documented in the paper passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
