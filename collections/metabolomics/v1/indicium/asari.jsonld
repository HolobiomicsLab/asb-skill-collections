    {
      "@id": "asbval:assertion/skill/gaussian-peak-shape-evaluation/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not mention scipy.signal.find_peaks. It describes asari's own peak detection algorithm: 'The default peak detection algorithm in asari first estimates the baseline and noise level on a composite mass track... We use a local maximum search algorithm, with peak height and prominence requirements dynamically determined on the segment statistics.' No external scipy dependency is named.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "gaussian-peak-shape-evaluation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[1].name",
      "asbval:target_claim_text": "scipy.signal.find_peaks",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:49:51.367791+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
      "@id": "asbval:assertion/skill/gaussian-peak-shape-evaluation/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "We use a local maximum search algorithm, with peak height and prominence requirements dynamically determined on the segment statistics. Prominence is the vertical distance of a peak top to its adjacent local minima, therefore important to control for fluctuating data points. The detected peaks are assessed by a set of quality metrics and retained only if the preset thresholds are met.",
      "asbval:note": "asari itself implements local maximum detection and prominence calculation (not scipy.signal.find_peaks). The function is performed by asari's own algorithm, not an external scipy tool.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "gaussian-peak-shape-evaluation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[1].role",
      "asbval:target_claim_text": "Detects local maxima and prominence on mass tracks prior to Gaussian shape evaluation; provides candidate peaks and prominence values passed to shape filter",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:49:51.367791+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/gaussian-peak-shape-evaluation/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The software is open source on GitHub and available via standard Python package management tools... The software modules can be ported for other tools or scripting, as demonstrated by Jupyter notebooks in the code repositories.",
      "asbval:note": "asari is confirmed as a Python-based tool. The paper also states it is built as a Python package.",
