    {
      "@id": "asbval:assertion/skill/gaussian-peak-shape-evaluation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "An intuitive measure of peak quality is 'peak shape', here defined as the goodness of fitting to a Gaussian curve (other curves have been used but the impact on fitness scores is negligible). High quality peaks should have peak shapes close to 1... Together with peak shape, users can rely on them to routinely determine the peak quality.",
      "asbval:note": "Gaussian peak shape evaluation is explicitly described as a quality metric alongside SNR and cSelectivity (chromatographic selectivity, analogous to prominence). The paper confirms this is used for filtering peaks.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gaussian-peak-shape-evaluation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Quantifies the goodness-of-fit of detected LC-MS peaks to a Gaussian model to filter out poorly shaped peaks and retain high-quality features. This metric serves as one of three orthogonal quality thresholds (alongside SNR and prominence) in asari's peak quality filtering pipelin",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:49:51.367791+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/gaussian-peak-shape-evaluation/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The detected peaks are assessed by a set of quality metrics and retained only if the preset thresholds are met... Elution peak detection is performed on the composite mass tracks, and feature table is generated by looking up the corresponding peak areas in each individual sample.",
      "asbval:note": "The paper confirms that peak quality assessment (including peak shape) occurs after peak detection and before feature table generation.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "gaussian-peak-shape-evaluation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After peak detection on a composite mass track has identified candidate peaks in a mass chromatogram, and before compiling the final feature table.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
