    {
      "@id": "asbval:assertion/skill/peak-evaluation-metrics-cselectivity-snr-gaussian-fit/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "In asari, the noise for an elution peak is the average signal intensity of neighboring non-peak data points, 100 to each side; SNR is the ratio between peak height and noise (Fig. 6a).",
      "asbval:note": "The paper describes noise estimation from flanking regions but does not name the specific function 'peaks.compute_noise_by_flanks'. The function name appears to be an internal asari implementation detail not explicitly documented in the paper passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "peak-evaluation-metrics-cselectivity-snr-gaussian-fit",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "peaks.compute_noise_by_flanks",
