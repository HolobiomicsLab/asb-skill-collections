    {
      "@id": "asbval:assertion/skill/peak-evaluation-metrics-cselectivity-snr-gaussian-fit/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Similar for chromatography, cSelectivity is defined as how distinct chromatograhic elution peaks are (Fig. 6b).",
      "asbval:note": "The paper describes cSelectivity computation but does not name the specific function 'peaks.__peaks_cSelectivity_stats_'. The function name appears to be an internal asari implementation detail not explicitly documented in the paper passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "peak-evaluation-metrics-cselectivity-snr-gaussian-fit",
