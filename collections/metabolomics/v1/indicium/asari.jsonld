    {
      "@id": "asbval:assertion/skill/m-z-alignment-across-samples/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Mass tracks are aligned cross samples before elution peak detection in asari (Fig. 2a, right). This takes advantage of the superb mass resolution on today's instruments and avoids errors stemming from elution peak detection. Mass tracks lock in unique m/z values per sample, therefore greatly reducing the complexity of m/z alignment, compared to the alignment of individual elution peaks. The mass tracks that match 13 C/12 C and Na/H patterns are considered of high confidence and used as guides in the m/z alignment... Aligned mass tracks of all samples form a 'MassGrid', which provides a foundation for trackable and high-quality feature correspondence.",
      "asbval:note": "Paper confirms mass track alignment using anchor mass tracks (13C/12C and Na/H patterns) and MassGrid construction. However, the paper does NOT explicitly describe conditional selection between 'pairwise anchor-based' vs 'nearest-neighbor clustering' strategies based on study size. The card claims a specific algorithmic branching logic that is not verbatim in the passages. The paper describes mass track alignment and MassGrid but does not detail the conditional strategy selection mechanism or name 'nearest-neighbor clustering' as an alternative approach.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "m-z-alignment-across-samples",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Conditional alignment of mass tracks (extracted ion chromatograms) across LC-MS samples using either pairwise anchor-based or nearest-neighbor clustering strategies, selected by study size to balance statistical power with computational efficiency. Produces a MassGrid mapping tha",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:50:21.188333+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/m-z-alignment-across-samples/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "No passage mentions a function or module named 'nn_cluster_by_mz_seeds' or any 'mass_functions module' in asari. The paper describes mass track alignment and MassGrid construction but does not name this specific function or module.",
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "m-z-alignment-across-samples",
