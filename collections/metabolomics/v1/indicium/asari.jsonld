    {
      "@id": "asbval:assertion/skill/peak-quality-assessment-by-selectivity-and-snr-metrics/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Low quality peaks account for major discrepancy between different software tools... High numbers of bad peaks are not acceptable in real-world applications due to their negative impacts on downstream analyses... For biomedical studies, features of questionable quality should not be used for decision making.",
      "asbval:note": null,
      "asbval:perspicacite_kb": "asb-paper-10-1038-s41467-023-39889-1",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "peak-quality-assessment-by-selectivity-and-snr-metrics",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Apply this skill whenever you need to distinguish genuine metabolite peaks from instrumental noise, baseline fluctuations, or co-eluting contaminants that passed initial prominence filtering.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-16T05:53:07.943576+00:00",
      "sepio:credibility_status": {
