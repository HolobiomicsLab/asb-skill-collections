    {
      "@id": "asbval:assertion/skill/derivatizing-matrix-configuration/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "There are many examples of reactive matrices and derivatizing agents in the literature, e.g., FMP-10 (4-(anthracen-9-yl)2-fluoro-1-methylpyridin-1-ium iodide), TAHS (p-N,N,N-trimethylammonioanilyl N-hydroxysuccinimidyl carbamate iodide) and Girard-T.",
      "asbval:note": "TAHS is explicitly mentioned as an example derivatizing agent in the paper, supporting the use case scenario.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "derivatizing-matrix-configuration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have a derivatizing matrix (e.g., TAHS or other publicly documented reagent) with known composition and ionization behavior that you want to use in Met-ID for metabolite annotation, and the matrix is not yet configured in your Met-ID installation.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
