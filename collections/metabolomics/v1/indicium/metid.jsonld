    {
      "@id": "asbval:assertion/skill/reference-dataset-validation-for-metabolite-ions/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Met-ID is installed with a database derived from the Human Metabolome Database (HMDB) and LIPID MAPS and is searchable for common adducts, such as [M + H]+, [M + Na]+ and [M+K]+ in the positive ionization mode and [M-H]\u2212, [M+Cl]\u2212, [M+Na-2H]\u2212, [M+K-2H]\u2212 and [M-H2O\u2013H]\u2212 in the negative ionization mode, along with the derivatizing matrix FMP-10",
      "asbval:note": "Paper validates FMP-10 derivatized metabolites against HMDB and LIPID MAPS databases, not specifically 'Nature Methods FMP-10 data'. The paper does include MS2 database of FMP-10 derivatized standards (154 derivatized forms from 66 chemical standards) for validation, but the reference to 'Nature Methods FMP-10 data' appears to be a specific dataset name not mentioned in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "reference-dataset-validation-for-metabolite-ions",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Validate predicted metabolite adduct m/z values against published reference datasets (e.g., Nature Methods FMP-10 data) to ensure the derivatizing matrix ionization rules are correctly implemented and produce chemically plausible ions.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:06:57.503538+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/reference-dataset-validation-for-metabolite-ions/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Met-ID uses chemical information to optimize database queries, aiming to reduce the occurrence of false positives... By incorporating a priori knowledge about the specificity of derivatizing matrices and reagents, such as FMP-10 and AMPP, respectively, Met-ID uses the chemical structures in the form of simplified molecular-input line-entry system (SMILES) to parse the HMDB and LIPID MAPS and more effectively differentiate between potential candidates and noncandidates.",
      "asbval:note": "Paper demonstrates automated enumeration of FMP-10 derivatization sites (single, double, triple) and validation against experimental tissue data.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "reference-dataset-validation-for-metabolite-ions",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "automated adduct enumeration workflows generate ions matching experimentally observed patterns",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:06:57.503538+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/reference-dataset-validation-for-metabolite-ions/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The Met-ID MS2 database currently contains 154 derivatized forms originating from 66 chemical standards, including spectra at collision-induced dissociation (CID) ranges between 0 and 50 eV... Met-ID functions as a frontend for viewing and searching these MS2 spectra, enabling targeted exploration.",
      "asbval:note": "Paper describes validation of predicted ions against curated MS2 database of FMP-10 derivatized standards.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "reference-dataset-validation-for-metabolite-ions",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "After computing expected adduct ions for a metabolite using a derivatizing matrix ruleset, validate the predicted m/z values and adduct formulas against a curated reference dataset",
      "eco:evidence_type": {
