    {
      "@id": "asbval:assertion/skill/derivatizing-matrix-ionization-rule-application/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Met-ID is installed with a database derived from the Human Metabolome Database (HMDB) and LIPID MAPS and is searchable for common adducts, such as [M + H]+, [M + Na]+ and [M+K]+ in the positive ionization mode and [M-H]\u2212, [M+Cl]\u2212, [M+Na-2H]\u2212, [M+K-2H]\u2212 and [M-H2O\u2013H]\u2212 in the negative ionization mode, along with the derivatizing matrix FMP-10",
      "asbval:note": "Paper explicitly describes handling of non-standard adducts beyond [M+H]+ and [M-H]- for derivatizing matrices like FMP-10.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "derivatizing-matrix-ionization-rule-application",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Apply matrix-specific adduct ionization rulesets to predict non-standard ion forms (beyond [M+H]+ and [M-H]-) that arise from derivatizing matrices like FMP-10 in mass spectrometry metabolite identification.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:05:13.299329+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/derivatizing-matrix-ionization-rule-application/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "A prominent addition to the technique that enhances the detection of diverse metabolites is on-tissue chemical derivatization. This modifies metabolites directly on tissue sections, introducing permanent charges to the structure of target molecules and enhancing their ionization characteristics and detectability in MALDI-MSI.",
      "asbval:note": "Paper confirms that derivatization alters ionization behavior and is essential for metabolite detection in MSI.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "derivatizing-matrix-ionization-rule-application",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill is essential for correctly identifying metabolites when chemical derivatization alters the ionization behavior in MSI experiments.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:05:13.299329+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/derivatizing-matrix-ionization-rule-application/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Met-ID enables annotation of m / z features from any type of MALDI-MSI experiment, involving either derivatizing or conventional matrices. It utilizes structural information for derivatizing matrices to generate a subset of targets that contain only functional groups specific to the derivatization agent.",
      "asbval:note": "Paper describes Met-ID's capability to handle derivatizing matrices in MSI experiments.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "derivatizing-matrix-ionization-rule-application",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When working with mass spectrometry imaging data from metabolites treated with derivatizing matrices (e.g., FMP-10) that produce adduct ions beyond the common [M+H]+ in positive mode and [M-H]- in negative mode",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
