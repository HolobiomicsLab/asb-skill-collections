      }
    },
    {
      "@id": "asbval:assertion/skill/reference-dataset-validation-for-metabolite-ions/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To enable Met-ID to be used for any type of MSI experiment, it was developed to be dynamic, i.e., users can add their own metabolites, functional groups and matrices, as well as MS2 spectra to customize their own version of Met-ID... Met-ID also provides tools for calculating and supporting the different masses added by other derivatizing matrices.",
      "asbval:note": "Paper explicitly describes customization for new matrices and functional groups.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
