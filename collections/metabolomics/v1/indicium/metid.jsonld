      "@id": "asbval:assertion/skill/software-plugin-development/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Met-ID is released under an open Apache 2.0 license... Met-ID allows users to customize their own versions... Met-ID also provides tools for calculating and supporting the different masses added by other derivatizing matrices.",
      "asbval:note": "Met-ID is confirmed as the primary platform for metabolite identification in MSI and supports extensibility. However, the paper does not describe a formal 'plugin registry' mechanism; instead, it describes direct customization of databases and configuration files (SQLite databases, adding metabolites, functional groups, matrices, MS2 spectra). The term 'plugin registry' overstates the architectural formality.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "software-plugin-development",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools[0].role",
      "asbval:target_claim_text": "Primary software platform for metabolite identification in mass spectrometry imaging; provides the extensibility architecture and plugin registry into which new derivatizing matrices are registered and applied",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:07:27.647665+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
