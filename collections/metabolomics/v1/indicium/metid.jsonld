      }
    },
    {
      "@id": "asbval:assertion/skill/derivatizing-matrix-configuration/005",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The Met-ID MS2 database currently contains 154 derivatized forms originating from 66 chemical standards, including spectra at collision-induced dissociation (CID) ranges between 0 and 50 eV. Additionally, the MS2 database includes peaks from FMP-10 itself.",
      "asbval:note": "Paper confirms that Met-ID uses MS2 spectra from chemical standards and supports custom MS2 spectra input, aligning with the scope requirement for reference spectra.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "derivatizing-matrix-configuration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "You have access to the matrix's expected adduct forms (e.g., [M+matrix_adduct]+ ) and can obtain or have reference MS/MS spectra from chemical standards derivatized with that matrix.",
      "eco:evidence_type": {
