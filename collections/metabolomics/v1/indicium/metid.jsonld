      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "when the adduct enumeration module is newly configured, when testing support for a new derivatizing matrix, or when troubleshooting metabolite identification failures",
      "eco:evidence_type": {
