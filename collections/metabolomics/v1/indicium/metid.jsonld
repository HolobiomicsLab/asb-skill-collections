    {
      "@id": "asbval:assertion/skill/software-plugin-development/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Met-ID is also dependent on rdkit, a C++ framework for computational chemistry... The rdkit functionality was written in python files and turned into executable files using PyInstaller.",
      "asbval:note": "RDKit is confirmed as a dependency for computational chemistry. The paper states it is used but does not explicitly detail its role in computing 'ionization behavior' or 'adduct annotations for registered matrices.' The paper mentions Met-ID uses SMILES structures to parse databases and compute derivatization targets, but does not explicitly attribute this to RDKit's functionality.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "software-plugin-development",
