      }
    },
    {
      "@id": "asbval:assertion/skill/derivatizing-matrix-configuration/006",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "By incorporating a priori knowledge about the specificity of derivatizing matrices and reagents, such as FMP-10 and AMPP, respectively, Met-ID uses the chemical structures in the form of simplified molecular-input line-entry system (SMILES) to parse the HMDB and LIPID MAPS and more effectively differentiate between potential candidates and noncandidates.",
      "asbval:note": "Paper confirms that Met-ID requires a priori knowledge of matrix specificity and chemical properties, supporting the 'when NOT to use' criterion.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "derivatizing-matrix-configuration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "The derivatizing matrix has no documented or characterizable ionization behavior or expected adduct forms. [When NOT to use]",
      "eco:evidence_type": {
