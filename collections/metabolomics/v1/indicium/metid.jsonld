    {
      "@id": "asbval:assertion/skill/derivatizing-matrix-configuration/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To enhance its versatility, Met-ID allows users to customize their own versions. FMP-10 is a suitable matrix for experiments targeting neurotransmitters, and the base version of Met-ID is optimized for its use. However, Met-ID also provides tools for calculating and supporting the different masses added by other derivatizing matrices.",
      "asbval:note": "Paper confirms extensibility and customization for different matrices, but does not explicitly detail the architecture or mechanism for defining ionization behavior and adduct forms programmatically. The claim assumes a formal 'extensibility architecture' that is not explicitly named or described in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "derivatizing-matrix-configuration",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill extends Met-ID's extensibility architecture to support any derivatizing reagent with defined ionization behavior and expected adduct forms.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
