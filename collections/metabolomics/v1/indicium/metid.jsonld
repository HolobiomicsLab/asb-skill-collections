    {
      "@id": "asbval:assertion/skill/mass-spectrometry-ion-formula-assignment/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Met-ID, a graphical user interface software designed to efficiently identify metabolites from MALDI-MSI data sets... It utilizes structural information for derivatizing matrices to generate a subset of targets that contain only functional groups specific to the derivatization agent... The software is able to identify multiple derivatization sites on the same molecule, facilitating identification of the derivatized compound. This ability is exemplified by FMP-10, a reactive matrix that assists the covalent charge-tagging of molecules containing phenolic hydroxyl and/or primary or secondary amine groups.",
      "asbval:note": "Met-ID is confirmed as a metabolite identification platform for MALDI-MSI with support for FMP-10 and derivatizing matrices. However, the card's phrase 'implements adduct ion enumeration' is imprecise. Met-ID does not enumerate adducts de novo; it filters a precompiled database based on derivatization specificity. The paper describes this as 'generate a subset of targets' and 'parse the HMDB and LIPID MAPS' using SMILES, not as generative enumeration of adduct formulas.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "mass-spectrometry-ion-formula-assignment",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "Met-ID \u2014 Integrated software platform for automated metabolite identification in mass spectrometry imaging; implements adduct ion enumeration for derivatizing matrices including FMP-10",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:06:12.664657+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
    {
      "@id": "asbval:assertion/skill/metabolite-identification-validation/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "Met-ID enables annotation of m / z features from any type of MALDI-MSI experiment, involving either derivatizing or conventional matrices. It utilizes structural information for derivatizing matrices to generate a subset of targets that contain only functional groups specific to the derivatization agent.",
      "asbval:note": "Paper explicitly describes Met-ID's core function: recognizing derivatizing matrices and applying them to annotate metabolites. The validation aspect is demonstrated through the experimental examples (chemical standards, tissue samples).",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-analchem-5c00633",
