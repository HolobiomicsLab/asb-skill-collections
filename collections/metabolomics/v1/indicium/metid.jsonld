    },
    {
      "@id": "asbval:assertion/skill/derivatizing-matrix-configuration/007",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "FMP-10 is a suitable matrix for experiments targeting neurotransmitters, and the base version of Met-ID is optimized for its use.",
      "asbval:note": "Paper confirms that Met-ID comes pre-configured with FMP-10, supporting this 'when NOT to use' criterion.",
