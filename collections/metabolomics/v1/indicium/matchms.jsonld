    {
      "@id": "asbval:assertion/skill/python-workflow-scripting/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "matchms is an open-source Python package to import, process, clean, and compare mass spectrometry data (MS/MS)... Raw data can be imported from the commonly used formats msp, mzML, mzXML, MGF... as well as from JSON files (as provided by GNPS)... It allows to implement and run an easy-to-follow, easy-to-reproduce workflow from raw mass spectra to pre- and post-processed spectral data.",
      "asbval:note": "All file formats and core workflow concepts are explicitly mentioned in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-02411",
