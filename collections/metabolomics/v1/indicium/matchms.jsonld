    {
      "@id": "asbval:assertion/skill/similarity-matrix-export/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "matchms provides functions to derive different similarity scores between spectra. Those include the established spectra-based measures of the cosine score or modified cosine score (Watrous et al., 2012). The package also offers fast implementations of common similarity measures (Dice, Jaccard, Cosine) that can be used to compute similarity scores between molecular fingerprints",
      "asbval:note": "Paper confirms matchms computes pairwise similarity scores and provides a Scores object for comparison results. However, passages do not explicitly describe export to structured matrix file formats (sparse/dense serialization). The paper demonstrates in-memory score iteration but does not detail file export functionality.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-02411",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "similarity-matrix-export",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Export pairwise similarity scores computed across mass spectra into a structured matrix file format for downstream analysis and storage.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T21:24:10.334470+00:00",
      "sepio:credibility_status": {
