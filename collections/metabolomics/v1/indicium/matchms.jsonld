      "asbval:target_artifact_id": "python-workflow-scripting",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Implement reproducible, multi-step mass spectrometry data processing pipelines using Python scripts that import, clean, validate, and compare spectral data across standardized file formats (MGF, MSP, mzML, mzXML, JSON).",
