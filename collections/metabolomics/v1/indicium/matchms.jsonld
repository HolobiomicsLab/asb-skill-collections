    {
      "@id": "asbval:assertion/skill/spectral-similarity-matrix-computation/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "matchms is an open-source Python package to import, process, clean, and compare mass spectrometry data... matchms provides functions to derive different similarity scores between spectra. Those include the established spectra-based measures of the cosine score or modified cosine score... The package also offers fast implementations of common similarity measures (Dice, Jaccard, Cosine) that can be used to compute similarity scores between molecular fingerprints",
      "asbval:note": "Paper confirms matchms supports Cosine similarity, fingerprint-based measures (via rdkit), and scores matrix construction.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-02411",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-similarity-matrix-computation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "matchms - core library for loading preprocessed spectra, applying pairwise similarity measures (Cosine, fingerprint-based, metadata-based), and constructing scores matrices",
