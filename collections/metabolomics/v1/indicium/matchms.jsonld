    {
      "@id": "asbval:assertion/skill/pairwise-spectral-comparison/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "matchms provides functions to derive different similarity scores between spectra. Those include the established spectra-based measures of the cosine score or modified cosine score (Watrous et al., 2012). The package also offers fast implementations of common similarity measures (Dice, Jaccard, Cosine) that can be used to compute similarity scores between molecular fingerprints (rdkit, morgan1, morgan2, morgan3, all implemented using rdkit",
      "asbval:note": "Cosine and fingerprint-based measures confirmed. Metadata-related measures not explicitly named but metadata cleaning/harmonizing filters are described.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-02411",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "pairwise-spectral-comparison",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Compute similarity scores between all pairs of mass spectra using matchms' built-in similarity measures (Cosine, molecular fingerprint-based, or metadata-related assessments)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
