      }
    },
    {
      "@id": "asbval:assertion/card/task_004/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "matchms provides functions to derive different similarity scores between spectra. Those include the established spectra-based measures of the cosine score or modified cosine score... The package also offers fast implementations of common similarity measures (Dice, Jaccard, Cosine) that can be used to compute similarity scores between molecular fingerprints",
      "asbval:note": "Paper confirms matchms produces pairwise similarity scores (e.g., via calculate_scores with Cosine similarity in passage 4). However, the example workflow demonstrates spectrum-to-spectrum comparison, not fingerprint-based comparison. Fingerprint similarity is mentioned as a capability but no example output or workflow for fingerprint-based pairwise comparison is provided in the passages.",
      "asbval:perspicacite_kb": "asb-paper-10-21105-joss-02411",
