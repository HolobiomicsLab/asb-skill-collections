      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope: When to use",
      "asbval:target_claim_text": "Apply this skill when you have a pretrained model with documented performance on a bounded input domain (e.g., molecules \u226419 heavy atoms, sequences <1000 bp) and you need to establish whether and how much accuracy drops on held-out test cases outside that domain boundary.",
      "eco:evidence_type": {
