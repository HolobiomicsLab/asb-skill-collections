    {
      "@id": "asbval:assertion/skill/performance-degradation-quantification-and-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The accuracy of the framework drops from 69.6% to 33.0% when used to predict the structures from 106 experimental 1H and 13C NMR spectra of molecules employed in our previous work",
      "asbval:note": "Paper does measure accuracy degradation on out-of-scope data (experimental vs. simulated spectra), but the out-of-scope boundary is not about molecule size (>19 heavy atoms) but rather data type (experimental vs. simulated). The paper does NOT systematically test performance on molecules >19 heavy atoms; it only notes that accuracy 'drops below 80%' for 18-19 atom molecules in the test set, attributed to training data imbalance rather than a deliberate out-of-scope evaluation. The card's framing of 'beyond original training scope' conflates two different boundaries: the molecule size limit (19 heavy atoms, which is within scope) and the data modality (experimental vs. simulated, which is genuinely out-of-scope).",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "performance-degradation-quantification-and-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Quantifies and characterizes how a trained machine learning model's accuracy degrades when applied to data beyond its original training scope. This skill measures the gap between in-scope and out-of-scope performance, documents failure modes, and establishes known performance bou",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:04:58.618273+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
