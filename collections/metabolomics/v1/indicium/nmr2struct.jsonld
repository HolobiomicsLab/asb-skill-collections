    {
      "@id": "asbval:assertion/skill/performance-degradation-quantification-and-analysis/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we demonstrate the effectiveness of this framework on molecules with up to 19 heavy (non-hydrogen) atoms, a size for which there are trillions of possible structures",
      "asbval:note": "Paper does establish 19 heavy atoms as a tested boundary, but does not systematically evaluate performance on molecules >19 heavy atoms. The paper acknowledges accuracy drops for 18-19 atoms but attributes this to training data imbalance (GDB-17 only contains up to 17 atoms), not to a deliberate out-of-scope test. The card's guidance assumes systematic out-of-scope testing; the paper only incidentally touches this boundary.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "partial",
