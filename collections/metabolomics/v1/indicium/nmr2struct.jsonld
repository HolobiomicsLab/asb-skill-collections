    {
      "@id": "asbval:assertion/claim/claim_002",
      "@type": "asbval:ClaimAssessment",
      "asbval:claim_text": "Elucidating structure using only one-dimensional NMR spectra remains an extremely challenging problem because of the combinatorial explosion of the number of possible molecules as the number of constituent atoms is increased.",
