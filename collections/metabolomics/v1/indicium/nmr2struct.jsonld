      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-to-structure-mapping-prediction/009",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we processed the spectrum by mildly reducing the dimensionality of the data by linearly interpolating the spectrum of 32768 values down to a grid of 28000 values corresponding to a shift range of \u22122 to 12 ppm with a resolution of 0.0005 ppm... For the 13C NMR spectra... we processed the spectra by extracting the chemical shifts and binning them into 80 bins spanning the shift range of 3.42 to 231.3 ppm.",
      "asbval:note": "Preprocessing parameters match exactly.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-to-structure-mapping-prediction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Minimal preprocessing: 1H NMR interpolated to 28,000 values (0.0005 ppm resolution, -2 to 12 ppm range); 13C NMR binned into 80 bins (3.42 to 231.3 ppm)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:05:15.033734+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-to-structure-mapping-prediction/010",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we started with a set of \u223c143 thousand molecules from the SpectraBase30 database containing only C, N, and O as the non-hydrogen atoms and combined it with a set of \u223c3 million molecules randomly sampled from the GDB-17 data set14 to create a final data set of \u223c3.1 million molecules.",
      "asbval:note": "Training dataset composition confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-to-structure-mapping-prediction",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "methods",
      "asbval:target_claim_text": "Training data: ~143k molecules from SpectraBase + ~3M from GDB-17 (total ~3.1M for substructure-to-structure task)",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
