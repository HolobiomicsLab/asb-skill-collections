    {
      "@id": "asbval:assertion/skill/chemical-graph-connectivity-validation/003",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The left panel of Figure 2 shows in red the structure elucidation accuracy of the spectrum-to-structure multitask model as a function of the number of heavy atoms. In comparison to the substructure-to-structure model, there is a more systematic decrease in accuracy with the size of the molecule, decreasing from 77.5% at 10 heavy atoms to 52.0% at 19 heavy atoms.",
      "asbval:note": "Paper explicitly measures accuracy degradation as molecule size increases, including at the 19 heavy atom boundary. Failure modes are analyzed via Tanimoto similarity distributions.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "chemical-graph-connectivity-validation",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "Use it to quantify accuracy on a held-out test set, measure degradation when applying the model beyond its training scope (e.g., molecules >19 heavy atoms), and identify failure modes in structure recovery.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
