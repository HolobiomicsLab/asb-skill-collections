      }
    },
    {
      "@id": "asbval:assertion/skill/model-generalization-assessment-across-molecular-size-regimes/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we introduce a multitask machine learning framework that predicts the molecular structure (formula and connectivity) of an unknown compound solely based on its 1D 1 H and/or 13 C NMR spectra. First, we show how a transformer architecture can be constructed to efficiently solve the task... Integrating this capability with a convolutional neural network, we build an end-to-end model for predicting structure from spectra that is fast and accurate.",
      "asbval:note": "Paper does not name the model 'NMR2Struct'. The model is described as a 'multitask machine learning framework' combining a transformer and CNN. The card has assigned a tool name not present in the paper. The functional description (transformer + CNN for structure prediction from NMR) is correct.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "model-generalization-assessment-across-molecular-size-regimes",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "tools",
      "asbval:target_claim_text": "NMR2Struct: end-to-end transformer + CNN model for predicting molecular structure (formula and connectivity) from 1D NMR spectra",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:02:38.155472+00:00",
      "sepio:credibility_status": {
