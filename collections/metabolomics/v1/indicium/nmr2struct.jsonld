      }
    },
    {
      "@id": "asbval:assertion/skill/fragment-assembly-transformer-architecture/002",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the number of possible molecules suffers from a combinatorial explosion as the number of constituent atoms increases... To train the transformer on this task, we started with a set of \u223c143 thousand molecules from the SpectraBase30 database containing only C, N, and O as the non-hydrogen atoms and combined it with a set of \u223c3 million molecules randomly sampled from the GDB-17 data set",
      "asbval:note": "Scope claim supported: paper addresses combinatorial explosion problem; uses training data from SpectraBase and GDB-17 deposited datasets.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "fragment-assembly-transformer-architecture",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "scope",
      "asbval:target_claim_text": "When the combinatorial explosion of possible structures makes exhaustive enumeration infeasible and you have access to training data of fragment-structure ground truth pairs extracted from deposited molecular datasets.",
      "eco:evidence_type": {
