    {
      "@id": "asbval:assertion/skill/modality-contribution-quantification/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To investigate the relative importance of 1H and 13C NMR as inputs, we trained two versions of the model using either 1H or 13C NMR as the sole input. The accuracy of the model is significantly better with only 1H NMR (59.6%) than with only 13C NMR (22.0%)... However, the best accuracy is obtained only when combining both spectra, showing that they are complementary to each other in terms of the information they each provide.",
      "asbval:note": "Paper explicitly compares single-modality (1H only, 13C only) and joint-modality (1H + 13C) inference, quantifying independent and synergistic contributions.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "modality-contribution-quantification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Quantify the independent and joint contributions of individual input modalities (e.g., \u00b9H NMR, \u00b9\u00b3C NMR) to machine learning model performance by running inference under controlled modality conditions and comparing accuracy metrics.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T10:02:27.231484+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/modality-contribution-quantification/001",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "The accuracy of the model is significantly better with only 1H NMR (59.6%) than with only 13C NMR (22.0%)... However, the best accuracy is obtained only when combining both spectra, showing that they are complementary to each other in terms of the information they each provide.",
      "asbval:note": "Paper demonstrates that 1H NMR is the dominant driver (59.6% vs 22.0%) and that combined modalities show synergy (69.6% > 59.6%).",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "modality-contribution-quantification",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "This skill reveals which spectroscopic inputs drive predictions and whether synergy exists between combined modalities.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
