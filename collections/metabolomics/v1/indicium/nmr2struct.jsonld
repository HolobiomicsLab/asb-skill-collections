      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000338"
      }
    },
    {
      "@id": "asbval:assertion/skill/spectral-to-structure-mapping-prediction/011",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "the substructure vector for each molecule was computed using RDKit's substructure match functionality against the set of 957 substructures used in our previous work20 represented as SMART strings.",
      "asbval:note": "Substructure count and RDKit implementation confirmed.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "yes",
      "asbval:target_artifact_id": "spectral-to-structure-mapping-prediction",
