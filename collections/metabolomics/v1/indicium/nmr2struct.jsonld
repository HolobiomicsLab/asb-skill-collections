    {
      "@id": "asbval:assertion/skill/performance-degradation-quantification-and-analysis/004",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "we build an end-to-end model for predicting structure from spectra that is fast and accurate... Integrating this capability with a convolutional neural network... we have introduced a multitask machine learning approach for direct structure and substructure elucidation from 1H and 13C NMR spectra that leverages pretraining an encoder-decoder transformer",
      "asbval:note": "Paper uses a transformer + CNN architecture for structure prediction from NMR spectra, but the model is not named 'NMR2Struct' in the paper. The paper does not use this tool name; it refers to the model generically as 'multitask machine learning framework' or 'spectrum-to-structure model'. The card has assigned a tool name not present in the paper.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "performance-degradation-quantification-and-analysis",
