      "asbval:evidence_quote": null,
      "asbval:note": "Paper does not use PubChem or any external chemical database for out-of-scope testing. Training data comes from SpectraBase and GDB-17; test data is drawn from the same sources. No systematic retrieval of >19 heavy atom molecules from PubChem or similar is described. The paper only incidentally tests on 18-19 atom molecules (which are within scope) from the existing training/test split.",
      "asbval:perspicacite_kb": "asb-paper-10_1021_acscentsci_4c01132",
      "asbval:supported_raw": "no",
