      "asbval:target_claim_text": "transformer architecture \u2014 assembles spectral features and molecular fragments into connectivity predictions that are then matched against ground truth",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000033"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
