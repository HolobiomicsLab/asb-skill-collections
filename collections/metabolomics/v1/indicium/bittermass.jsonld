    {
      "@id": "asbval:assertion/card/task_002/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not describe BitterPredict's input format, descriptor extraction pipeline, or CSV/Excel preparation workflow. BitterPredict is mentioned only as a comparison tool that 'predicts the taste of a molecule based on its chemical structure' using 'physicochemical descriptors as inputs' (passage 9), but no details on descriptor preparation, file formats, or the .m file are provided. The paper focuses on BitterMasS (mass spectrum-based prediction), not BitterPredict's internal pipeline.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jafc-3c09767",
      "asbval:supported_raw": "no",
