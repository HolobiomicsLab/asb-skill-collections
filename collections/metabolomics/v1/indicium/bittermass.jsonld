    {
      "@id": "asbval:assertion/skill/descriptor-subgroup-partitioning/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "To obtain intuitive insights into the BitterMasS model, feature importance was extracted. In a Random Forest algorithm, on which the BitterMasS model is based, feature importance refers to the relative importance of each feature when making predictions... the values of each feature were expressed as a percentage and the 20 most important features are presented in Figure 3.",
      "asbval:note": "Paper performs feature importance analysis on BitterMasS (Random Forest), not descriptor ablation/subgroup partitioning. The paper extracts feature importance rankings but does not systematically ablate descriptor subgroups. The functional approach differs: paper uses built-in Random Forest feature importance rather than controlled removal of descriptor categories.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jafc-3c09767",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "descriptor-subgroup-partitioning",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Partition molecular descriptors into functionally coherent subgroups and systematically ablate each subgroup to quantify its impact on bitter/not-bitter prediction accuracy.",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:03:51.407090+00:00",
      "sepio:credibility_status": {
