    {
      "@id": "asbval:assertion/skill/prediction-sensitivity-analysis/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": null,
      "asbval:note": "The paper does not perform descriptor ablation studies. Instead, it uses Random Forest feature importance extraction (passage 8: 'To obtain intuitive insights into the BitterMasS model, feature importance was extracted'). The paper's approach is post-hoc feature importance ranking from a trained model, not systematic ablation of descriptor subgroups. The paper also does not discuss lipophilicity or topological features as descriptor categories\u2014it focuses on mass spectral peak bins and instrumental descriptors.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jafc-3c09767",
      "asbval:supported_raw": "no",
      "asbval:target_artifact_id": "prediction-sensitivity-analysis",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Systematically ablate input descriptor subgroups to quantify their individual impact on bitter/not-bitter prediction accuracy in a trained classifier. This skill reveals which molecular descriptor categories (e.g., lipophilicity, topological features) drive predictions and which ",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0007675"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:04:38.193781+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000340"
      }
    },
    {
