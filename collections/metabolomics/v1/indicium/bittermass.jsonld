    {
      "@id": "asbval:assertion/skill/chemical-structure-feature-encoding/000",
      "@type": "asbval:ClaimAssessment",
      "asbval:evidence_quote": "BitterPredict estimated that there are at least 11,000 compounds in the ChEBI database of molecules of biological interest that possess bitterness. Additional ML tools are developed to predict intense bitterness and the associated TAS2Rs. These methods use information about the structure of the compound.",
      "asbval:note": "The paper does discuss structure-based prediction (BitterPredict uses physicochemical descriptors from chemical structure), but the primary focus of BitterMasS is NOT structure-to-descriptor encoding. Instead, BitterMasS predicts bitterness directly from MASS SPECTRA, not from encoded chemical descriptors. The card's research question describes a structure-encoding task, but the paper's main contribution is spectrum-based prediction. BitterPredict (mentioned as a comparison tool) does use structure descriptors, but the paper does not detail the descriptor encoding process itself\u2014it only states that BitterPredict 'uses information about the structure of the compound' and 'Physicochemical descriptors are used as inputs to the model' (passage 9). The paper's core innovation is bypassing structure encoding entirely.",
      "asbval:perspicacite_kb": "asb-paper-10-1021-acs-jafc-3c09767",
      "asbval:supported_raw": "partial",
      "asbval:target_artifact_id": "chemical-structure-feature-encoding",
      "asbval:target_artifact_kind": "skill_bundle",
      "asbval:target_claim_field": "research_question",
      "asbval:target_claim_text": "Encoding molecular structures as quantitative chemical descriptor vectors suitable for machine learning classifiers. This skill transforms raw chemical structures into tabular feature representations (CSV/Excel) that capture structural properties required for predictive modeling ",
      "eco:evidence_type": {
        "@id": "http://purl.obolibrary.org/obo/ECO_0000361"
      },
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:03:13.986453+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
