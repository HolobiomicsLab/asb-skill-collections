    {
      "@id": "asbval:assertion/card/task_002/scope_drift",
      "@type": "asbval:ScopeDriftAssertion",
      "asbval:drift_notes": [
        "The candidate task card appears to conflate BitterMasS (the main tool developed in this paper) with BitterPredict (an external reference tool). The paper develops BitterMasS, which predicts bitterness from mass spectra, not from chemical structure descriptors.",
        "The research question and expected outputs focus on reconstructing BitterPredict's descriptor pipeline, but the paper does not document BitterPredict's internal methods\u2014it only cites BitterPredict (reference 14) as a comparison baseline.",
        "The paper extensively documents the BitterMasS descriptor extraction pipeline (binning strategy, intensity normalization, instrumental metadata encoding) but does not describe BitterPredict's descriptor preparation workflow.",
        "No CSV/Excel file formats or .m file specifications are mentioned in the paper for either tool."
      ],
      "asbval:n_drift_notes": 4,
      "asbval:target_artifact_id": "task_002",
      "asbval:target_artifact_kind": "card",
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
      "prov:wasGeneratedAtTime": "2026-06-15T14:01:33.576430+00:00",
      "sepio:credibility_status": {
        "@id": "http://purl.obolibrary.org/obo/SEPIO_0000339"
      }
    },
