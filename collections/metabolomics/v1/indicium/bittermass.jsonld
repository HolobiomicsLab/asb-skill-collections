      "@id": "asbval:assertion/card/task_003/scope_drift",
      "@type": "asbval:ScopeDriftAssertion",
      "asbval:drift_notes": [
        "The task card describes an analysis of BitterPredict's descriptor sensitivity via ablation, but the paper's focus is on developing BitterMasS (a mass spectrum-based predictor), not on analyzing BitterPredict's internal mechanisms.",
        "The paper does include feature importance analysis, but only for BitterMasS (the Random Forest model trained on mass spectral data), not for BitterPredict.",
        "BitterPredict is used as an external comparison tool to validate BitterMasS performance, not as the subject of sensitivity analysis.",
        "The task card appears to conflate BitterMasS feature importance (which is present in the paper) with BitterPredict descriptor ablation (which is not performed)."
      ],
      "asbval:n_drift_notes": 4,
      "asbval:target_artifact_id": "task_003",
      "asbval:target_artifact_kind": "card",
      "prov:wasAttributedTo": "anthropic/claude-haiku-4-5-20251001",
